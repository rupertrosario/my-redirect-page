    if ($u -gt 0) {
        return $u
    }

    return Get-RunEndUsecs $Run
}

function Test-IsHostObject {
    param([object]$RunObject)

    $type = Get-ObjectType $RunObject

    return ($type -match '(?i)host|server')
}

function Test-IsDbObject {
    param(
        [object]$RunObject,
        [string]$Environment
    )

    $type = Get-ObjectType $RunObject

    if ($type -match '(?i)host|server') {
        return $false
    }

    if ($Environment -eq "kSQL") {
        return ($type -match '(?i)database|db|sql')
    }

    if ($Environment -eq "kOracle") {
        if ($type -match '(?i)database|db|oracle') {
            return $true
        }

        # Oracle sometimes exposes weak object type but valid source mapping.
        $name = Get-ObjectName $RunObject
        $sid  = Get-ObjectSourceId $RunObject
        $src  = Get-ObjectDirectSourceName $RunObject

        if (-not [string]::IsNullOrWhiteSpace($name) -and
            (-not [string]::IsNullOrWhiteSpace($sid) -or -not [string]::IsNullOrWhiteSpace($src))) {
            return $true
        }
    }

    return $false
}

function Get-HostMapFromRun {
    param([object]$Run)

    $map = @{}

    foreach ($obj in @(AsArray $Run.objects)) {
        $objId = Get-ObjectId $obj
        $objName = Get-ObjectName $obj
        $objType = Get-ObjectType $obj

        if ([string]::IsNullOrWhiteSpace($objId) -or
            [string]::IsNullOrWhiteSpace($objName)) {
            continue
        }

        if ($objType -match '(?i)host|server' -or $objType -notmatch '(?i)database|db') {
            $map["$objId"] = "$objName"
        }
    }

    return $map
}

function Get-RunsForCandidatePg {
    param([object]$Candidate)

    if ([string]::IsNullOrWhiteSpace($Candidate.ClusterId) -or
        [string]::IsNullOrWhiteSpace($Candidate.PgId)) {
        return @()
    }

    $headers = New-ClusterHeaders -ClusterId "$($Candidate.ClusterId)"

    $uri = "$BaseUrl/v2/data-protect/protection-groups/$($Candidate.PgId)/runs" +
           "?numRuns=$NumRunsPerPg" +
           "&includeTenants=true" +
           "&excludeNonRestorableRuns=true" +
           "&includeObjectDetails=true" +
           "&runTypes=$([uri]::EscapeDataString($RunTypes))"

    $script:RunCalls++
    $script:CandidatePgsInspected++

    $json = Invoke-HeliosGetJson -Uri $uri -Headers $headers -Quiet

    if (-not $json -or -not $json.runs) {
        return @()
    }

    return @(
        @(AsArray $json.runs) |
        Where-Object { $_ } |
        Sort-Object @{ Expression = { Get-RunEndUsecs $_ }; Descending = $true }
    )
}

# =====================================================================
# Main row builders
# =====================================================================
function New-OutputRow {
    param(
        [string]$InputServer,
        [string]$BackupType,
        [string]$ObjectName,
        [string]$BackupLevel,
        [object]$StartUsecs,
        [object]$EndUsecs,
        [string]$ProtectionGroup,
        [string]$SourceName,
        [string]$ClusterName,
        [string]$Status,
        [string]$DebugSource
    )

    return [pscustomobject]@{
        InputServer     = if ($InputServer) { $InputServer } else { "-" }
        BackupType      = if ($BackupType) { $BackupType } else { "-" }
        ObjectName      = if ($ObjectName) { $ObjectName } else { "-" }
        BackupLevel     = if ($BackupLevel) { $BackupLevel } else { "-" }
        StartTimeET     = Convert-UsecsToET $StartUsecs
        EndTimeET       = Convert-UsecsToET $EndUsecs
        Duration        = Get-DurationText -StartUsecs $StartUsecs -EndUsecs $EndUsecs
        ProtectionGroup = if ($ProtectionGroup) { $ProtectionGroup } else { "-" }
        SourceName      = if ($SourceName) { $SourceName } else { "-" }
        ClusterName     = if ($ClusterName) { $ClusterName } else { "-" }
        System          = if ($ClusterName) { $ClusterName } else { "-" }
        Status          = if ($Status) { $Status } else { "Unknown" }
        BackupUsecs     = To-Int64Safe $EndUsecs
        DebugSource     = $DebugSource
    }
}

function Get-FsRowsForServer {
    param(
        [string]$ServerName,
        [hashtable]$ClusterMap
    )

    $rows = @()
    $candidates = @(Get-SearchCandidates -ServerName $ServerName -Environment $FsEnvironment)

    foreach ($candidate in $candidates) {
        $clusterName = Get-ClusterNameFromMap `
            -ClusterId "$($candidate.ClusterId)" `
            -ClusterMap $ClusterMap `
            -FallbackName "$($candidate.ClusterName)"

        $runs = @(Get-RunsForCandidatePg -Candidate $candidate)

        foreach ($run in $runs) {
            $runStatus = Get-RunStatus $run
            $runType   = Get-RunType $run

            if (-not (Test-SuccessStatus $runStatus)) {
                continue
            }

            if (-not (Test-RegularRunType $runType)) {
                continue
            }

            foreach ($obj in @(AsArray $run.objects)) {
                $objectName = Get-ObjectName $obj
                $sourceName = Get-ObjectDirectSourceName $obj

                if ([string]::IsNullOrWhiteSpace($sourceName)) {
                    $sourceName = $objectName
                }

                $match = Any-TextMatchesName `
                    -Texts @($objectName, $sourceName, "$($candidate.PgName)") `
                    -Name $ServerName

                if (-not $match) {
                    continue
                }

                $objStatus  = Get-ObjectStatus -Run $run -RunObject $obj
                $startUsecs = Get-ObjectStartUsecs -Run $run -RunObject $obj
                $endUsecs   = Get-ObjectEndUsecs -Run $run -RunObject $obj

                $rows += New-OutputRow `
                    -InputServer $ServerName `
                    -BackupType "FS" `
                    -ObjectName $(if ($objectName) { $objectName } else { $ServerName }) `
                    -BackupLevel (Get-BackupLevelFromRunType $runType) `
                    -StartUsecs $startUsecs `
                    -EndUsecs $endUsecs `
                    -ProtectionGroup "$($candidate.PgName)" `
                    -SourceName $(if ($sourceName) { $sourceName } else { $ServerName }) `
                    -ClusterName $clusterName `
                    -Status $(if ($objStatus) { $objStatus } else { $runStatus }) `
                    -DebugSource "FSRunObject"
            }
        }
    }

    return @($rows)
}

function Get-DbRowsForServerFromEnvironment {
    param(
        [string]$ServerName,
        [string]$Environment,
        [string]$BackupTypeLabel,
        [hashtable]$ClusterMap
    )

    $rows = @()
    $candidates = @(Get-SearchCandidates -ServerName $ServerName -Environment $Environment)

    foreach ($candidate in $candidates) {
        $clusterName = Get-ClusterNameFromMap `
            -ClusterId "$($candidate.ClusterId)" `
            -ClusterMap $ClusterMap `
            -FallbackName "$($candidate.ClusterName)"

        $runs = @(Get-RunsForCandidatePg -Candidate $candidate)

        foreach ($run in $runs) {
            $runStatus = Get-RunStatus $run
            $runType   = Get-RunType $run

            if (-not (Test-SuccessStatus $runStatus)) {
                continue
            }

            if (-not (Test-RegularRunType $runType)) {
                continue
            }

            $hostMap = Get-HostMapFromRun -Run $run

            foreach ($obj in @(AsArray $run.objects)) {
                if (-not (Test-IsDbObject -RunObject $obj -Environment $Environment)) {
                    continue
                }

                $objectName = Get-ObjectName $obj
                $sourceId   = Get-ObjectSourceId $obj
                $directSrc  = Get-ObjectDirectSourceName $obj
                $mappedSrc  = ""

                if (-not [string]::IsNullOrWhiteSpace($sourceId) -and $hostMap.ContainsKey("$sourceId")) {
                    $mappedSrc = "$($hostMap["$sourceId"])"
                }

                $sourceName = Get-FirstText @($mappedSrc, $directSrc)

                # Important: avoid returning every DB in a shared PG.
                # DB row must map back to the input server.
                if (-not (Any-TextMatchesName -Texts @($sourceName, $mappedSrc, $directSrc) -Name $ServerName)) {
                    continue
                }

                $objStatus  = Get-ObjectStatus -Run $run -RunObject $obj
                $startUsecs = Get-ObjectStartUsecs -Run $run -RunObject $obj
                $endUsecs   = Get-ObjectEndUsecs -Run $run -RunObject $obj

                $rows += New-OutputRow `
                    -InputServer $ServerName `
                    -BackupType $BackupTypeLabel `
                    -ObjectName $(if ($objectName) { $objectName } else { "-" }) `
                    -BackupLevel (Get-BackupLevelFromRunType $runType) `
                    -StartUsecs $startUsecs `
                    -EndUsecs $endUsecs `
                    -ProtectionGroup "$($candidate.PgName)" `
                    -SourceName $(if ($sourceName) { $sourceName } else { $ServerName }) `
                    -ClusterName $clusterName `
                    -Status $(if ($objStatus) { $objStatus } else { $runStatus }) `
                    -DebugSource "$BackupTypeLabel-RunObject"
            }
        }
    }

    return @($rows)
}

# =====================================================================
# Oracle fallback from PG config
# Used only if Oracle DB object rows do not expose host/source mapping.
# =====================================================================
function Resolve-CohesityObjectName {
    param(
        [string]$ObjectId,
        [string]$ClusterId
    )

    if ([string]::IsNullOrWhiteSpace($ObjectId) -or
        [string]::IsNullOrWhiteSpace($ClusterId)) {
        return ""
    }

    $headers = New-ClusterHeaders -ClusterId $ClusterId
    $uri = "$BaseUrl/v2/data-protect/objects/$ObjectId"

    $script:ObjectLookupCalls++

    $json = Invoke-HeliosGetJson -Uri $uri -Headers $headers -Quiet

    if (-not $json) {
        return ""
    }

    return Get-FirstText @($json.name, $json.displayName)
}

function Get-ProtectionGroupDetails {
    param(
        [string]$PgId,
        [string]$ClusterId,
        [string]$Environment
    )

    if ([string]::IsNullOrWhiteSpace($PgId) -or
        [string]::IsNullOrWhiteSpace($ClusterId)) {
        return $null
    }

    $headers = New-ClusterHeaders -ClusterId $ClusterId

    $uris = @(
        "$BaseUrl/v2/data-protect/protection-groups/$PgId",
        "$BaseUrl/v2/data-protect/protection-groups?ids=$([uri]::EscapeDataString($PgId))&environments=$([uri]::EscapeDataString($Environment))&includeLastRunInfo=true"
    )

    foreach ($uri in $uris) {
        $script:PgDetailCalls++

        $json = Invoke-HeliosGetJson -Uri $uri -Headers $headers -Quiet

        if (-not $json) {
            continue
        }

        if ($json.protectionGroups) {
            $pg = @(AsArray $json.protectionGroups | Where-Object { $_ }) | Select-Object -First 1

            if ($pg) {
                return $pg
            }
        }

        if ($json.id -or $json.name -or $json.oracleParams) {
            return $json
        }
    }

    return $null
}

function Get-LatestRunInfoForPg {
    param([object]$Candidate)

    $runs = @(Get-RunsForCandidatePg -Candidate $Candidate)

    foreach ($run in $runs) {
        $status = Get-RunStatus $run
        $runType = Get-RunType $run

        if (-not (Test-SuccessStatus $status)) {
            continue
        }

        if (-not (Test-RegularRunType $runType)) {
            continue
        }

        return [pscustomobject]@{
            StartUsecs  = Get-RunStartUsecs $run
            EndUsecs    = Get-RunEndUsecs $run
            RunType     = $runType
            Status      = $status
        }
    }

    return $null
}

function Add-UniqueText {
    param(
        [System.Collections.ArrayList]$List,
        [string]$Value
    )

    $v = Norm $Value

    if ([string]::IsNullOrWhiteSpace($v)) {
        return
    }

    if (-not $List.Contains($v)) {
        [void]$List.Add($v)
    }
}

function Get-OracleFallbackRowsForServer {
    param(
        [string]$ServerName,
        [hashtable]$ClusterMap
    )

    $rows = @()
    $candidates = @(Get-SearchCandidates -ServerName $ServerName -Environment $OracleEnvironment)

    foreach ($candidate in $candidates) {
        $pg = Get-ProtectionGroupDetails `
            -PgId "$($candidate.PgId)" `
            -ClusterId "$($candidate.ClusterId)" `
            -Environment $OracleEnvironment

        if (-not $pg -or -not $pg.oracleParams) {
            continue
        }

        $runInfo = Get-LatestRunInfoForPg -Candidate $candidate

        if (-not $runInfo) {
            continue
        }

        $clusterName = Get-ClusterNameFromMap `
            -ClusterId "$($candidate.ClusterId)" `
            -ClusterMap $ClusterMap `
            -FallbackName "$($candidate.ClusterName)"

        $pgName = Get-FirstText @($pg.name, $candidate.PgName)

        foreach ($obj in @(AsArray $pg.oracleParams.objects)) {
            $baseHostNames = New-Object System.Collections.ArrayList

            Add-UniqueText -List $baseHostNames -Value (Get-FirstText @(
                $obj.sourceName,
                $obj.hostName
            ))

            foreach ($dbParam in @(AsArray $obj.dbParams)) {
                $hostNames = New-Object System.Collections.ArrayList

                foreach ($h in @($baseHostNames)) {
                    Add-UniqueText -List $hostNames -Value $h
                }

                Add-UniqueText -List $hostNames -Value (Get-FirstText @(
                    $dbParam.sourceName,
                    $dbParam.hostName
                ))

                $channels = @()

                if ($dbParam.dbChannels.dbChannel) {
                    $channels += @(AsArray $dbParam.dbChannels.dbChannel)
                }
                elseif ($dbParam.dbChannels) {
                    $channels += @(AsArray $dbParam.dbChannels)
                }

                if ($channels.Count -eq 0) {
                    $dbName = Get-FirstText @(
                        $dbParam.databaseUniqueName,
                        $dbParam.databaseName,
                        $obj.databaseUniqueName,
                        $obj.dbUniqueName,
                        $obj.name
                    )

                    if ((Any-TextMatchesName -Texts @($hostNames) -Name $ServerName) -and
                        -not [string]::IsNullOrWhiteSpace($dbName)) {

                        $rows += New-OutputRow `
                            -InputServer $ServerName `
                            -BackupType "Oracle DB" `
                            -ObjectName $dbName `
                            -BackupLevel (Get-BackupLevelFromRunType "$($runInfo.RunType)") `
                            -StartUsecs $runInfo.StartUsecs `
                            -EndUsecs $runInfo.EndUsecs `
                            -ProtectionGroup $pgName `
                            -SourceName (@($hostNames) -join ";") `
                            -ClusterName $clusterName `
                            -Status "$($runInfo.Status)" `
                            -DebugSource "OraclePgConfigFallback"
                    }

                    continue
                }

                foreach ($channel in $channels) {
                    $channelHostNames = New-Object System.Collections.ArrayList

                    foreach ($h in @($hostNames)) {
                        Add-UniqueText -List $channelHostNames -Value $h
                    }

                    $hostIds = @()
                    $hostIds += @(AsArray $channel.databaseNodeList.hostId)
                    $hostIds += @(AsArray $channel.databaseNodeList.id)

                    foreach ($hostId in ($hostIds | Where-Object { $_ -and "$_".Trim() -ne "" } | Select-Object -Unique)) {
                        $resolvedHost = Resolve-CohesityObjectName `
                            -ObjectId "$hostId" `
                            -ClusterId "$($candidate.ClusterId)"

                        Add-UniqueText -List $channelHostNames -Value $resolvedHost
                    }

                    $dbName = Get-FirstText @(
                        $channel.databaseUniqueName,
                        $channel.databaseName,
                        $dbParam.databaseUniqueName,
                        $dbParam.databaseName,
                        $obj.databaseUniqueName,
                        $obj.dbUniqueName,
                        $obj.name
                    )

                    if ((Any-TextMatchesName -Texts @($channelHostNames) -Name $ServerName) -and
                        -not [string]::IsNullOrWhiteSpace($dbName)) {

                        $rows += New-OutputRow `
                            -InputServer $ServerName `
                            -BackupType "Oracle DB" `
                            -ObjectName $dbName `
                            -BackupLevel (Get-BackupLevelFromRunType "$($runInfo.RunType)") `
                            -StartUsecs $runInfo.StartUsecs `
                            -EndUsecs $runInfo.EndUsecs `
                            -ProtectionGroup $pgName `
                            -SourceName (@($channelHostNames) -join ";") `
                            -ClusterName $clusterName `
                            -Status "$($runInfo.Status)" `
                            -DebugSource "OraclePgConfigFallback"
                    }
                }
            }
        }
    }

    return @($rows)
}

# =====================================================================
# Final row selection
# =====================================================================
function Select-LatestFsRow {
    param([object[]]$Rows)

    return @(
        $Rows |
        Sort-Object @{ Expression = { [int64]$_.BackupUsecs }; Descending = $true } |
        Select-Object -First 1
    )
}

function Select-LatestDbRows {
    param([object[]]$Rows)

    $out = @()

    foreach ($grp in ($Rows | Group-Object InputServer, BackupType, ObjectName, SourceName)) {
        $out += (
            $grp.Group |
            Sort-Object @{ Expression = { [int64]$_.BackupUsecs }; Descending = $true } |
            Select-Object -First 1
        )
    }

    return @($out)
}

function Get-BackupTypeRank {
    param([string]$BackupType)

    switch ($BackupType) {
        "FS"        { return 1 }
        "SQL DB"    { return 2 }
        "Oracle DB" { return 3 }
        "DB"        { return 4 }
        default     { return 9 }
    }
}

# =====================================================================
# Load input
# =====================================================================
$InputRows = Import-Csv -Path $InputCsv

if ($null -eq $InputRows -or $InputRows.Count -eq 0) {
    throw "Input CSV is empty: $InputCsv"
}

if (-not ($InputRows[0].PSObject.Properties.Name -contains "ci_item")) {
    throw "Input CSV must contain column: ci_item"
}

$ServerList = $InputRows |
    ForEach-Object { Norm $_.ci_item } |
    Where-Object { -not [string]::IsNullOrWhiteSpace($_) } |
    Sort-Object -Unique

if (-not $ServerList -or $ServerList.Count -eq 0) {
    throw "No ci_item values found in $InputCsv"
}

$ServerList | Set-Content -Path $InputTxt -Encoding UTF8

# =====================================================================
# Build cluster map
# =====================================================================
Write-Host ""
Write-Host "Building cluster map..." -ForegroundColor Cyan

$clusterJson = Invoke-HeliosGetJson `
    -Uri "$BaseUrl/v2/mcm/cluster-mgmt/info" `
    -Headers $CommonHeaders

if (-not $clusterJson -or -not $clusterJson.cohesityClusters) {
    throw "No clusters returned from Helios."
}

$ClusterMap = @{}

foreach ($c in @(AsArray $clusterJson.cohesityClusters)) {
    $cname = Get-FirstText @(
        $c.clusterName,
        $c.name,
        $c.displayName
    )

    if ([string]::IsNullOrWhiteSpace($cname)) {
        $cname = "UnknownCluster"
    }

    Add-ClusterMapEntry -Map $ClusterMap -Id $c.clusterId -Name $cname
    Add-ClusterMapEntry -Map $ClusterMap -Id $c.id -Name $cname
    Add-ClusterMapEntry -Map $ClusterMap -Id $c.intId -Name $cname
    Add-ClusterMapEntry -Map $ClusterMap -Id $c.clusterIdentifier.clusterId -Name $cname
    Add-ClusterMapEntry -Map $ClusterMap -Id $c.clusterInfo.clusterId -Name $cname
}

Write-Host "Cluster map entries: $($ClusterMap.Count)" -ForegroundColor Green

# =====================================================================
# Main processing
# =====================================================================
$Results = @()
$DebugRows = @()

foreach ($server in $ServerList) {
    $script:ServersProcessed++

    Write-Host ""
    Write-Host "Processing server: $server" -ForegroundColor Cyan

    # -------------------------
    # FS
    # -------------------------
    $fsRaw = @(Get-FsRowsForServer -ServerName $server -ClusterMap $ClusterMap)
    $DebugRows += $fsRaw

    $fsLatest = @(Select-LatestFsRow -Rows $fsRaw)

    if ($fsLatest.Count -eq 0) {
        $Results += [pscustomobject]@{
            InputServer     = $server
            BackupType      = "FS"
            ObjectName      = $server
            BackupLevel     = $RunTypes
            StartTimeET     = "-"
            EndTimeET       = "NoFSBackupFound"
            Duration        = "-"
            ProtectionGroup = "-"
            SourceName      = $server
            ClusterName     = "-"
            System          = "-"
            Status          = "Unknown"
            BackupUsecs     = 0
            DebugSource     = "MissingFS"
        }
    }
    else {
        $Results += $fsLatest
    }

    # -------------------------
    # SQL DB
    # -------------------------
    $sqlRaw = @(Get-DbRowsForServerFromEnvironment `
        -ServerName $server `
        -Environment $SqlEnvironment `
        -BackupTypeLabel "SQL DB" `
        -ClusterMap $ClusterMap)

    $DebugRows += $sqlRaw

    # -------------------------
    # Oracle DB
    # -------------------------
    $oracleRaw = @(Get-DbRowsForServerFromEnvironment `
        -ServerName $server `
        -Environment $OracleEnvironment `
        -BackupTypeLabel "Oracle DB" `
        -ClusterMap $ClusterMap)

    $DebugRows += $oracleRaw

    # Oracle fallback only when normal Oracle DB rows are missing.
    if ($oracleRaw.Count -eq 0) {
        $oracleFallback = @(Get-OracleFallbackRowsForServer `
            -ServerName $server `
            -ClusterMap $ClusterMap)

        $oracleRaw += $oracleFallback
        $DebugRows += $oracleFallback
    }

    $dbRaw = @()
    $dbRaw += $sqlRaw
    $dbRaw += $oracleRaw

    $dbLatest = @(Select-LatestDbRows -Rows $dbRaw)

    if ($dbLatest.Count -eq 0) {
        $Results += [pscustomobject]@{
            InputServer     = $server
            BackupType      = "DB"
            ObjectName      = "-"
            BackupLevel     = $RunTypes
            StartTimeET     = "-"
            EndTimeET       = "NoDbBackupFound"
            Duration        = "-"
            ProtectionGroup = "-"
            SourceName      = $server
            ClusterName     = "-"
            System          = "-"
            Status          = "Unknown"
            BackupUsecs     = 0
            DebugSource     = "MissingDB"
        }
    }
    else {
        $Results += $dbLatest
    }
}

# =====================================================================
# Final output
# =====================================================================
$FinalRows = $Results |
    Sort-Object `
        InputServer,
        @{ Expression = { Get-BackupTypeRank $_.BackupType } },
        ObjectName,
        SourceName |
    Select-Object `
        InputServer,
        BackupType,
        ObjectName,
        BackupLevel,
        StartTimeET,
        EndTimeET,
        Duration,
        ProtectionGroup,
        SourceName,
        ClusterName,
        System,
        Status

$FinalRows |
    Export-Csv -Path $OutputCsv -NoTypeInformation -Encoding UTF8

if ($ExportDebugCsv) {
    $DebugRows |
        Sort-Object InputServer, BackupType, ObjectName, SourceName |
        Select-Object `
            InputServer,
            BackupType,
            ObjectName,
            BackupLevel,
            StartTimeET,
            EndTimeET,
            Duration,
            ProtectionGroup,
            SourceName,
            ClusterName,
            System,
            Status,
            BackupUsecs,
