function Add-ClusterMapEntry {
    param(
        [hashtable]$Map,
        [object]$Id,
        [string]$Name
    )

    $idText = Get-FirstText @($Id)

    if (-not [string]::IsNullOrWhiteSpace($idText) -and
        -not [string]::IsNullOrWhiteSpace($Name)) {
        $Map["$idText"] = $Name
    }
}

function Get-ClusterNameFromMap {
    param(
        [string]$ClusterId,
        [hashtable]$ClusterMap,
        [string]$FallbackName = ""
    )

    if (-not [string]::IsNullOrWhiteSpace($FallbackName) -and $FallbackName -ne "-") {
        return $FallbackName
    }

    if ([string]::IsNullOrWhiteSpace($ClusterId)) {
        return "-"
    }

    if ($ClusterMap.ContainsKey("$ClusterId")) {
        return "$($ClusterMap["$ClusterId"])"
    }

    return "$ClusterId"
}

