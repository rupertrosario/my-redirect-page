function Add-Candidate {
    param(
        [System.Collections.ArrayList]$List,
        [hashtable]$Seen,
        [string]$Environment,
        [string]$ClusterId,
        [string]$ClusterName,
        [string]$PgId,
        [string]$PgName
    )

    if ([string]::IsNullOrWhiteSpace($ClusterId)) {
        return
    }

    if ([string]::IsNullOrWhiteSpace($PgId)) {
        return
    }

    $key = "$Environment|$ClusterId|$PgId"

    if ($Seen.ContainsKey($key)) {
        return
    }

    $Seen[$key] = $true

    [void]$List.Add([pscustomobject]@{
        Environment = $Environment
        ClusterId   = "$ClusterId"
        ClusterName = if ($ClusterName) { "$ClusterName" } else { "-" }
        PgId        = "$PgId"
        PgName      = if ($PgName) { "$PgName" } else { "-" }
    })
}

function Get-CandidatesFromSearchJson {
    param(
        [object]$Json,
        [string]$Environment
    )

    $list = New-Object System.Collections.ArrayList
    $seen = @{}

    foreach ($obj in (Get-ResponseObjects $Json)) {

        # Common shape: objectProtectionInfos -> protectionGroups
        foreach ($opi in (AsArray $obj.objectProtectionInfos)) {

            foreach ($pg in (AsArray $opi.protectionGroups)) {
                Add-Candidate `
                    -List $list `
                    -Seen $seen `
                    -Environment $Environment `
                    -ClusterId (Get-ClusterIdFromNode -Obj $obj -ProtectionInfo $opi -Pg $pg) `
                    -ClusterName (Get-ClusterNameFromNode -Obj $obj -ProtectionInfo $opi -Pg $pg) `
                    -PgId (Get-PgIdFromNode -Obj $obj -ProtectionInfo $opi -Pg $pg) `
                    -PgName (Get-PgNameFromNode -Obj $obj -ProtectionInfo $opi -Pg $pg)
            }

            if (-not $opi.protectionGroups) {
                Add-Candidate `
                    -List $list `
                    -Seen $seen `
                    -Environment $Environment `
                    -ClusterId (Get-ClusterIdFromNode -Obj $obj -ProtectionInfo $opi -Pg $null) `
                    -ClusterName (Get-ClusterNameFromNode -Obj $obj -ProtectionInfo $opi -Pg $null) `
                    -PgId (Get-PgIdFromNode -Obj $obj -ProtectionInfo $opi -Pg $null) `
                    -PgName (Get-PgNameFromNode -Obj $obj -ProtectionInfo $opi -Pg $null)
            }
        }

        # Alternate shape: object -> protectionGroups
        foreach ($pg2 in (AsArray $obj.protectionGroups)) {
            Add-Candidate `
                -List $list `
                -Seen $seen `
                -Environment $Environment `
                -ClusterId (Get-ClusterIdFromNode -Obj $obj -ProtectionInfo $null -Pg $pg2) `
                -ClusterName (Get-ClusterNameFromNode -Obj $obj -ProtectionInfo $null -Pg $pg2) `
                -PgId (Get-PgIdFromNode -Obj $obj -ProtectionInfo $null -Pg $pg2) `
                -PgName (Get-PgNameFromNode -Obj $obj -ProtectionInfo $null -Pg $pg2)
        }

        # Alternate direct shape
        Add-Candidate `
            -List $list `
            -Seen $seen `
            -Environment $Environment `
            -ClusterId (Get-ClusterIdFromNode -Obj $obj -ProtectionInfo $null -Pg $null) `
            -ClusterName (Get-ClusterNameFromNode -Obj $obj -ProtectionInfo $null -Pg $null) `
            -PgId (Get-PgIdFromNode -Obj $obj -ProtectionInfo $null -Pg $null) `
            -PgName (Get-PgNameFromNode -Obj $obj -ProtectionInfo $null -Pg $null)
    }

    return @($list)
}

function Get-SearchCandidates {
    param(
        [string]$ServerName,
        [string]$Environment
    )

    $all = @()

    # Endpoint 1
    $script:SearchCalls++

    $uri1 = "$BaseUrl/v2/data-protect/search/objects" +
            "?searchString=$([uri]::EscapeDataString($ServerName))" +
            "&environments=$([uri]::EscapeDataString($Environment))" +
            "&includeTenants=true" +
            "&count=$SearchCount"

    $json1 = Invoke-HeliosGetJson -Uri $uri1 -Headers $CommonHeaders -Quiet

    if ($json1) {
        $all += @(Get-CandidatesFromSearchJson -Json $json1 -Environment $Environment)
    }

    # Endpoint 2 fallback/additional candidate source.
    # Some tenants expose better PG mapping here for protected objects.
    $script:SearchCalls++

    $uri2 = "$BaseUrl/v2/data-protect/search/protected-objects" +
            "?searchString=$([uri]::EscapeDataString($ServerName))" +
            "&environments=$([uri]::EscapeDataString($Environment))" +
            "&includeTenants=true" +
            "&count=$SearchCount"

    $json2 = Invoke-HeliosGetJson -Uri $uri2 -Headers $CommonHeaders -Quiet

    if ($json2) {
        $all += @(Get-CandidatesFromSearchJson -Json $json2 -Environment $Environment)
    }

    return @(
        $all |
        Where-Object {
            -not [string]::IsNullOrWhiteSpace($_.ClusterId) -and
            -not [string]::IsNullOrWhiteSpace($_.PgId)
        } |
        Sort-Object Environment, ClusterId, PgId -Unique
    )
}

# =====================================================================
# Run response parsing
