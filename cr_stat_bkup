# ==========================================================
# Cohesity Backup Validation â€“ OBJECT-FIRST (AUDIT READY)
# HyperV / Nutanix / Physical ONLY
# ==========================================================

$ChangeID   = Read-Host "Enter Change Number"
$ExecutedBy = (whoami).Trim()

# -------------------------
# Toggle
# -------------------------
$VerboseMode = $true   # set $false for clean output

# -------------------------
# Paths
# -------------------------
$CsvDirectory = "X:\PowerShell\Data\Cohesity\BackupValidation"
$InputCsv     = Join-Path $CsvDirectory "$ChangeID.csv"
$ReportDate   = Get-Date -Format "yyyy-MM-dd_HHmm"
$OutputCsv    = Join-Path $CsvDirectory "${ChangeID}_BackupStatus_$ReportDate.csv"

if (-not (Test-Path $InputCsv)) { throw "CSV not found" }

$CiList = Import-Csv $InputCsv

function Normalize($v){ if(!$v){return ""}; return $v.ToLower().Trim() }
function GetShort($v){ if(!$v){return ""}; return $v.Split('.')[0].ToLower() }

# -------------------------
# API
# -------------------------
$ApiKey = (Get-Content "X:\PowerShell\Cohesity_API_Scripts\DO_NOT_Delete\apikey.txt" -Raw).Trim()
$CommonHeaders = @{ accept="application/json"; apiKey=$ApiKey }

function ToDate($u){
    if(!$u){return ""}
    return [DateTimeOffset]::FromUnixTimeMilliseconds([int64]($u/1000)).LocalDateTime.ToString("dd-MMM-yyyy HH:mm:ss")
}

function IsSuccess($s){ return $s -in @("Succeeded","SucceededWithWarning","kSuccess") }

# -------------------------
# Get clusters
# -------------------------
$clusters = (Invoke-WebRequest `
    -Uri "https://helios.cohesity.com/v2/mcm/cluster-mgmt/info" `
    -Headers $CommonHeaders -Method Get).Content | ConvertFrom-Json

$clusters = $clusters.cohesityClusters

# -------------------------
# Storage
# -------------------------
$Results = @()
$found=0;$success=0;$fail=0

$totalCI = $CiList.Count
$ciIndex=0

$AllowedEnv = @("kHyperV","kAcropolis","kPhysical")

# -------------------------
# PROCESS
# -------------------------
foreach($r in $CiList){

    $ciIndex++
    $full  = Normalize $r.ci_item
    $short = GetShort $r.ci_item

    Write-Progress -Activity "Validating CIs" `
        -Status "$($r.ci_item) ($ciIndex/$totalCI)" `
        -PercentComplete (($ciIndex/$totalCI)*100)

    if($VerboseMode){ Write-Host "`n[CI] $($r.ci_item)" }

    $foundFlag = $false

    foreach($c in $clusters){

        if($foundFlag){ break }

        if($VerboseMode){ Write-Host "  â†’ Checking Cluster: $($c.name)" }

        try{
            $h = @{accept="application/json";apiKey=$ApiKey;accessClusterId=$c.clusterId}

            $pgs = (Invoke-WebRequest `
                -Uri "https://helios.cohesity.com/v2/data-protect/protection-groups?isActive=true&isDeleted=false" `
                -Headers $h -Method Get).Content | ConvertFrom-Json

            foreach($pg in $pgs.protectionGroups){

                if($foundFlag){ break }

                $runs = (Invoke-WebRequest `
                    -Uri "https://helios.cohesity.com/v2/data-protect/protection-groups/$($pg.id)/runs?numRuns=10&includeObjectDetails=true" `
                    -Headers $h -Method Get).Content | ConvertFrom-Json

                foreach($run in $runs.runs){

                    if($foundFlag){ break }

                    $info = $run.localBackupInfo[0]
                    if(!$info){continue}

                    foreach($o in $run.objects){

                        $env = $o.object.environment
                        if($AllowedEnv -notcontains $env){ continue }

                        $nameFull  = Normalize $o.object.name
                        $nameShort = GetShort $o.object.name

                        if($nameFull -eq $full -or $nameShort -eq $short){

                            $status = $info.status
                            $date   = ToDate $info.endTimeUsecs

                            $Results += [pscustomobject]@{
                                ci_item=$r.ci_item
                                BackupStatus=$status
                                LastCompleted=$date
                                Cluster=$c.name
                                Environment=$env
                                ProtectionGroup=$pg.name
                            }

                            $found++
                            if(IsSuccess $status){$success++}else{$fail++}

                            if($VerboseMode){
                                Write-Host "    âś” FOUND â†’ $($c.name) [$env] | $status"
                            }

                            $foundFlag = $true
                            break
                        }
                    }
                }
            }

        }catch{
            continue
        }
    }

    if(-not $foundFlag){
        $Results += [pscustomobject]@{
            ci_item=$r.ci_item
            BackupStatus="NoObject"
            LastCompleted=""
            Cluster=""
            Environment=""
            ProtectionGroup=""
        }

        if($VerboseMode){ Write-Host "    âś– NOT FOUND" }
    }
}

Write-Progress -Completed

# -------------------------
# FINAL TABLE
# -------------------------
Write-Host "`n------------------------------------------------------------"
Write-Host "Backup Validation Results"
Write-Host "------------------------------------------------------------"

$Results | Format-Table -AutoSize

# -------------------------
# AUDIT SUMMARY
# -------------------------
Write-Host "`n------------------------------------------------------------"
Write-Host "Backup Validation Summary (Audit View)"
Write-Host "------------------------------------------------------------"

$NoObject = ($Results | Where-Object {$_.BackupStatus -eq "NoObject"}).Count
$Success  = ($Results | Where-Object {$_.BackupStatus -in @("Succeeded","SucceededWithWarning","kSuccess")}).Count
$Fail     = ($Results | Where-Object {$_.BackupStatus -notin @("Succeeded","SucceededWithWarning","kSuccess","NoObject")}).Count

$Summary = @(
    [pscustomobject]@{
        ChangeNumber = $ChangeID
        ExecutedBy   = $ExecutedBy
        TotalObjects = $totalCI
        FoundObjects = $found
        Successful   = $Success
        Failed       = $Fail
        NotFound     = $NoObject
        RunDate      = (Get-Date)
    }
)

$Summary | Format-Table -AutoSize

# -------------------------
# CLUSTER DISTRIBUTION
# -------------------------
Write-Host "`nCluster Distribution"
$Results | Where-Object {$_.Cluster} |
Group-Object Cluster |
Select-Object Name,Count |
Sort-Object Count -Descending |
Format-Table -AutoSize

# -------------------------
# EXPORT
# -------------------------
$Results | Export-Csv $OutputCsv -NoTypeInformation
Write-Host "`nCSV: $OutputCsv"
