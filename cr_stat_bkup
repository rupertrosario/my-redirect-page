# ==========================================================
# Cohesity Backup Validation â€“ SEARCH + RUN (GET ONLY)
# Fastest, No PG Traversal
# ==========================================================

$ChangeID   = Read-Host "Enter Change Number"
$ExecutedBy = (whoami).Trim()

$VerboseMode = $true   # set to $false later

# -------------------------
# Paths
# -------------------------
$CsvDirectory = "X:\PowerShell\Data\Cohesity\BackupValidation"
$InputCsv     = Join-Path $CsvDirectory "$ChangeID.csv"
$ReportDate   = Get-Date -Format "yyyy-MM-dd_HHmm"
$OutputCsv    = Join-Path $CsvDirectory "${ChangeID}_BackupStatus_$ReportDate.csv"

if (-not (Test-Path $InputCsv)) { throw "CSV not found" }

$CiList = Import-Csv $InputCsv

function Normalize($v){ if(!$v){return ""}; return $v.ToLower().Trim() }
function GetShort($v){ if(!$v){return ""}; return $v.Split('.')[0].ToLower() }

# -------------------------
# API
# -------------------------
$ApiKey = (Get-Content "X:\PowerShell\Cohesity_API_Scripts\DO_NOT_Delete\apikey.txt" -Raw).Trim()
$Headers = @{ accept="application/json"; apiKey=$ApiKey }

function ToDate($u){
    if(!$u){return ""}
    return [DateTimeOffset]::FromUnixTimeMilliseconds([int64]($u/1000)).LocalDateTime.ToString("dd-MMM-yyyy HH:mm:ss")
}

function IsSuccess($s){ return $s -in @("Succeeded","SucceededWithWarning","kSuccess") }

$AllowedEnv = @("kHyperV","kAcropolis","kPhysical")

# -------------------------
# Storage
# -------------------------
$Results = @()
$found=0;$success=0;$fail=0

$totalCI = $CiList.Count
$ciIndex=0

# -------------------------
# PROCESS
# -------------------------
foreach($r in $CiList){

    $ciIndex++
    $ciName = $r.ci_item
    $full  = Normalize $ciName
    $short = GetShort $ciName

    Write-Progress -Activity "Validating CIs" `
        -Status "$ciName ($ciIndex/$totalCI)" `
        -PercentComplete (($ciIndex/$totalCI)*100)

    if($VerboseMode){ Write-Host "`n[CI] $ciName" }

    try{
        # -------------------------
        # SEARCH OBJECT
        # -------------------------
        $searchUrl = "https://helios.cohesity.com/v2/data-protect/search/protected-objects?searchString=$ciName"

        $searchResp = (Invoke-WebRequest `
            -Uri $searchUrl `
            -Headers $Headers -Method Get).Content | ConvertFrom-Json

        $match = $null

        foreach($obj in $searchResp.objects){

            $env = $obj.environment
            if($AllowedEnv -notcontains $env){ continue }

            $nameFull  = Normalize $obj.name
            $nameShort = GetShort $obj.name

            if($nameFull -eq $full -or $nameShort -eq $short){
                $match = $obj
                break
            }
        }

        if(-not $match){
            if($VerboseMode){ Write-Host "  âś– Not found in search" }

            $Results += [pscustomobject]@{
                ci_item=$ciName
                BackupStatus="NoObject"
                LastCompleted=""
                Cluster=""
                Environment=""
                ProtectionGroup=""
            }
            continue
        }

        if($VerboseMode){
            Write-Host "  âś” Found Object â†’ $($match.name) [$($match.environment)]"
        }

        # -------------------------
        # GET RUN
        # -------------------------
        $runUrl = "https://helios.cohesity.com/v2/data-protect/objects/$($match.id)/runs?numRuns=1"

        $runResp = (Invoke-WebRequest `
            -Uri $runUrl `
            -Headers $Headers -Method Get).Content | ConvertFrom-Json

        $run = $runResp.runs[0]

        if($run){
            $info = $run.localBackupInfo[0]

            $status = $info.status
            $date   = ToDate $info.endTimeUsecs

            $Results += [pscustomobject]@{
                ci_item=$ciName
                BackupStatus=$status
                LastCompleted=$date
                Cluster=$match.clusterName
                Environment=$match.environment
                ProtectionGroup=$run.protectionGroupName
            }

            $found++
            if(IsSuccess $status){$success++}else{$fail++}

            if($VerboseMode){
                Write-Host "    â†’ $status | $date"
            }
        }
        else{
            $Results += [pscustomobject]@{
                ci_item=$ciName
                BackupStatus="NoRun"
                LastCompleted=""
                Cluster=$match.clusterName
                Environment=$match.environment
                ProtectionGroup=""
            }
        }

    }catch{
        if($VerboseMode){ Write-Host "  ERROR: $($_.Exception.Message)" }

        $Results += [pscustomobject]@{
            ci_item=$ciName
            BackupStatus="Error"
            LastCompleted=""
            Cluster=""
            Environment=""
            ProtectionGroup=""
        }
    }
}

Write-Progress -Completed

# -------------------------
# FINAL OUTPUT
# -------------------------
Write-Host "`n------------------------------------------------------------"
Write-Host "Backup Validation Results"
Write-Host "------------------------------------------------------------"

$Results | Format-Table -AutoSize

# -------------------------
# AUDIT SUMMARY
# -------------------------
Write-Host "`n------------------------------------------------------------"
Write-Host "Backup Validation Summary"
Write-Host "------------------------------------------------------------"

$NoObject = ($Results | Where {$_.BackupStatus -eq "NoObject"}).Count
$Success  = ($Results | Where {$_.BackupStatus -in @("Succeeded","SucceededWithWarning","kSuccess")}).Count
$Fail     = ($Results | Where {$_.BackupStatus -notin @("Succeeded","SucceededWithWarning","kSuccess","NoObject")}).Count

[pscustomobject]@{
    ChangeNumber = $ChangeID
    ExecutedBy   = $ExecutedBy
    TotalObjects = $totalCI
    FoundObjects = $found
    Successful   = $Success
    Failed       = $Fail
    NotFound     = $NoObject
    RunDate      = (Get-Date)
} | Format-Table -AutoSize

# -------------------------
# EXPORT
# -------------------------
$Results | Export-Csv $OutputCsv -NoTypeInformation
Write-Host "`nCSV: $OutputCsv"
