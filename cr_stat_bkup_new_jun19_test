# ==========================================================
# Cohesity Backup Validation – DISPLAY + TXT REPORT OUTPUT
# GET ONLY | SEARCH ONLY | FAST CLUSTER DISCOVERY
#
# Endpoints used:
# 1) GET /v2/mcm/cluster-mgmt/info
# 2) GET /v2/data-protect/search/objects?searchString=<CI>&includeTenants=true&count=100
# 3) GET /v2/data-protect/search/protected-objects?searchString=<CI>
#
# Logic:
# - Reads CIs from CSV
# - Writes unique cleaned CIs to TXT in same location
# - Uses global search first to find candidate clusters
# - Searches protected-objects only on candidate clusters
# - If protected-object row has replicationSnapshotInfo.clusterId:
#       that row is replicated/target-side copy
#       clusterId inside replicationSnapshotInfo is source/original cluster
# - If target-side copy is found, script searches the source cluster also
# - For same CI + BackupType:
#       prefer row WITHOUT replicationSnapshotInfo
#       use replicated row only if original/source row is not found
# - Shows BackupType: SQL / Oracle / FS / NAS / Hyper-V / Nutanix / VMware / Unknown
# - If SQL or Oracle backup exists, also validates FS backup exists
# ==========================================================

$ErrorActionPreference = "Stop"

$ChangeID   = Read-Host "Enter Change Number"
$ExecutedBy = (whoami).Trim()

# -------------------------
# Paths
# -------------------------
$BaseDir   = "X:\PowerShell\Data\Cohesity\BackupValidation"
$InputCsv  = Join-Path $BaseDir "$ChangeID.csv"
$InputTxt  = Join-Path $BaseDir "$ChangeID.txt"
$TimeStamp = Get-Date -Format "yyyyMMdd_HHmm"
$OutputTxt = Join-Path $BaseDir "${ChangeID}_BackupReport_$TimeStamp.txt"

if (-not (Test-Path $InputCsv)) {
    throw "CSV not found: $InputCsv"
}

# -------------------------
# API Key
# -------------------------
$ApiKeyPath = "X:\PowerShell\Cohesity_API_Scripts\DO_NOT_Delete\apikey.txt"

if (-not (Test-Path $ApiKeyPath)) {
    throw "API key file not found: $ApiKeyPath"
}

$ApiKey = (Get-Content -Path $ApiKeyPath -Raw).Trim()

# -------------------------
# Settings
# -------------------------
$GlobalSearchCount = 100

# Fallback only when global search finds object but no mapped clusterId.
$EnableAllClusterFallback = $true

# Keep false for speed.
# If true, when global search finds no object, script scans all clusters.
$FallbackWhenNoGlobalObject = $false

# If a replicated/target row points back to a source cluster, search source cluster also.
$EnableReplicationSourceCheck = $true

# -------------------------
# Counters
# -------------------------
$GlobalSearchCalls             = 0
$ProtectedSearchCalls          = 0
$FallbackCiCount               = 0
$ReplicationSourceCheckCount   = 0

# -------------------------
# Helpers
# -------------------------
function Invoke-HeliosJson {
    param(
        [Parameter(Mandatory)] [string]$Uri,
        [Parameter(Mandatory)] [hashtable]$Headers,
        [int]$TimeoutSec = 30
    )

    try {
        $r = Invoke-WebRequest `
            -UseBasicParsing `
            -Method Get `
            -Uri $Uri `
            -Headers $Headers `
            -TimeoutSec $TimeoutSec `
            -ErrorAction Stop

        if ([string]::IsNullOrWhiteSpace($r.Content)) {
            return $null
        }

        return ($r.Content | ConvertFrom-Json)
    }
    catch {
        return $null
    }
}

function ToDate {
    param($Usecs)

    if (-not $Usecs) {
        return ""
    }

    try {
        return [DateTimeOffset]::FromUnixTimeMilliseconds([int64]($Usecs / 1000)).LocalDateTime.ToString("dd-MMM-yyyy HH:mm:ss")
    }
    catch {
        return ""
    }
}

function AsArray {
    param($Value)

    if ($null -eq $Value) {
        return @()
    }

    if ($Value -is [array]) {
        return @($Value)
    }

    return @($Value)
}

function Get-FirstText {
    param($Value)

    if ($null -eq $Value) {
        return ""
    }

    if ($Value -is [array]) {
        foreach ($Item in $Value) {
            $Text = Get-FirstText $Item
            if ($Text) {
                return $Text
            }
        }

        return ""
    }

    if ($Value -is [pscustomobject]) {
        foreach ($Prop in @("display_value", "displayName", "name", "value", "id", "clusterId", "clusterID", "intId")) {
            if ($Value.PSObject.Properties.Name -contains $Prop) {
                $Text = Get-FirstText $Value.$Prop

                if ($Text) {
                    return $Text
                }
            }
        }

        return ""
    }

    return "$Value".Trim()
}

function Get-UsecsValue {
    param($Value)

    if ($null -eq $Value) {
        return $null
    }

    $Values = @()

    foreach ($Item in (AsArray $Value)) {
        if ($null -ne $Item -and "$Item".Trim() -ne "") {
            try {
                $Values += [int64]$Item
            }
            catch {}
        }
    }

    if ($Values.Count -eq 0) {
        return $null
    }

    return ($Values | Sort-Object -Descending | Select-Object -First 1)
}

function Has-Property {
    param(
        $Object,
        [string]$PropertyName
    )

    if ($null -eq $Object) {
        return $false
    }

    try {
        return ($Object.PSObject.Properties.Name -contains $PropertyName)
    }
    catch {
        return $false
    }
}

function Is-ValidBackupRow {
    param($Row)

    if (-not $Row) {
        return $false
    }

    return $Row.LastBackupTime -notin @(
        "NoBackup",
        "NoBackupTime",
        "NoObject",
        "NoFSBackupFound",
        "",
        $null
    )
}

function Get-GlobalObjects {
    param($Json)

    if (-not $Json) {
        return @()
    }

    foreach ($Prop in @("objects", "results", "entities", "data", "items")) {
        if ($Json.PSObject.Properties.Name -contains $Prop) {
            return @(AsArray $Json.$Prop | Where-Object { $_ })
        }
    }

    if ($Json -is [array]) {
        return @($Json)
    }

    return @()
}

function Get-ProtectedObjects {
    param($Json)

    if (-not $Json) {
        return @()
    }

    foreach ($Prop in @("objects", "results", "entities", "data", "items")) {
        if ($Json.PSObject.Properties.Name -contains $Prop) {
            return @(AsArray $Json.$Prop | Where-Object { $_ })
        }
    }

    if ($Json -is [array]) {
        return @($Json)
    }

    return @()
}

function Add-ClusterId {
    param(
        [System.Collections.ArrayList]$List,
        $Value
    )

    foreach ($Item in (AsArray $Value)) {
        $Text = Get-FirstText $Item

        if (-not [string]::IsNullOrWhiteSpace($Text)) {
            [void]$List.Add($Text)
        }
    }
}

function Get-CandidateClusterIdsFromGlobalSearch {
    param($Json)

    $Ids = New-Object System.Collections.ArrayList
    $Objects = Get-GlobalObjects -Json $Json

    foreach ($Obj in $Objects) {

        Add-ClusterId -List $Ids -Value $Obj.clusterId
        Add-ClusterId -List $Ids -Value $Obj.clusterID
        Add-ClusterId -List $Ids -Value $Obj.sourceClusterId

        Add-ClusterId -List $Ids -Value $Obj.cluster.id
        Add-ClusterId -List $Ids -Value $Obj.cluster.clusterId
        Add-ClusterId -List $Ids -Value $Obj.cluster.clusterID

        Add-ClusterId -List $Ids -Value $Obj.clusterInfo.id
        Add-ClusterId -List $Ids -Value $Obj.clusterInfo.clusterId
        Add-ClusterId -List $Ids -Value $Obj.clusterInfo.clusterID

        foreach ($ProtectionInfo in (AsArray $Obj.objectProtectionInfos)) {

            Add-ClusterId -List $Ids -Value $ProtectionInfo.clusterId
            Add-ClusterId -List $Ids -Value $ProtectionInfo.clusterID

            Add-ClusterId -List $Ids -Value $ProtectionInfo.cluster.id
            Add-ClusterId -List $Ids -Value $ProtectionInfo.cluster.clusterId
            Add-ClusterId -List $Ids -Value $ProtectionInfo.cluster.clusterID

            Add-ClusterId -List $Ids -Value $ProtectionInfo.clusterInfo.id
            Add-ClusterId -List $Ids -Value $ProtectionInfo.clusterInfo.clusterId
            Add-ClusterId -List $Ids -Value $ProtectionInfo.clusterInfo.clusterID

            foreach ($Pg in (AsArray $ProtectionInfo.protectionGroups)) {
                Add-ClusterId -List $Ids -Value $Pg.clusterId
                Add-ClusterId -List $Ids -Value $Pg.clusterID

                Add-ClusterId -List $Ids -Value $Pg.cluster.id
                Add-ClusterId -List $Ids -Value $Pg.cluster.clusterId
                Add-ClusterId -List $Ids -Value $Pg.cluster.clusterID

                Add-ClusterId -List $Ids -Value $Pg.clusterInfo.id
                Add-ClusterId -List $Ids -Value $Pg.clusterInfo.clusterId
                Add-ClusterId -List $Ids -Value $Pg.clusterInfo.clusterID
            }
        }

        foreach ($Pg in (AsArray $Obj.protectionGroups)) {
            Add-ClusterId -List $Ids -Value $Pg.clusterId
            Add-ClusterId -List $Ids -Value $Pg.clusterID

            Add-ClusterId -List $Ids -Value $Pg.cluster.id
            Add-ClusterId -List $Ids -Value $Pg.cluster.clusterId
            Add-ClusterId -List $Ids -Value $Pg.cluster.clusterID

            Add-ClusterId -List $Ids -Value $Pg.clusterInfo.id
            Add-ClusterId -List $Ids -Value $Pg.clusterInfo.clusterId
            Add-ClusterId -List $Ids -Value $Pg.clusterInfo.clusterID
        }
    }

    return @(
        $Ids |
        Where-Object { -not [string]::IsNullOrWhiteSpace($_) } |
        Sort-Object -Unique
    )
}

function Get-SnapshotCandidates {
    param($Object)

    if (-not $Object) {
        return @()
    }

    $Snap = $null

    if ($Object.latestSnapshotInfo) {
        $Snap = $Object.latestSnapshotInfo
    }
    elseif ($Object.latestSnapshotsInfo) {
        $Snap = $Object.latestSnapshotsInfo
    }
    elseif ($Object.latestSnapshots) {
        $Snap = $Object.latestSnapshots
    }
    elseif ($Object.latestSnapshot) {
        $Snap = $Object.latestSnapshot
    }
    elseif ($Object.snapshotInfo) {
        $Snap = $Object.snapshotInfo
    }
    elseif ($Object.backupInfo) {
        $Snap = $Object.backupInfo
    }

    if (-not $Snap) {
        return @()
    }

    return @(AsArray $Snap | Where-Object { $_ })
}

function Get-SnapshotUsecs {
    param($Snapshot)

    if (-not $Snapshot) {
        return $null
    }

    foreach ($Field in @(
        "protectionRunStartTimeUsecs",
        "protectionRunEndTimeUsecs",
        "runStartTimeUsecs",
        "runEndTimeUsecs",
        "snapshotCreationTimeUsecs",
        "creationTimeUsecs",
        "startTimeUsecs",
        "endTimeUsecs"
    )) {
        if ($Snapshot.PSObject.Properties.Name -contains $Field) {
            $Usecs = Get-UsecsValue -Value $Snapshot.$Field

            if ($Usecs) {
                return $Usecs
            }
        }
    }

    if ($Snapshot.localBackupInfo) {
        foreach ($Lbi in (AsArray $Snapshot.localBackupInfo)) {
            $Usecs = Get-UsecsValue -Value $Lbi.startTimeUsecs

            if ($Usecs) {
                return $Usecs
            }

            $Usecs = Get-UsecsValue -Value $Lbi.endTimeUsecs

            if ($Usecs) {
                return $Usecs
            }
        }
    }

    return $null
}

function Get-BestSnapshot {
    param($Object)

    $Snapshots = Get-SnapshotCandidates -Object $Object

    if (-not $Snapshots -or $Snapshots.Count -eq 0) {
        return $null
    }

    return $Snapshots |
        Sort-Object @{ Expression = { [int64](Get-SnapshotUsecs -Snapshot $_) } } -Descending |
        Select-Object -First 1
}

function Get-ProtectionGroupName {
    param(
        $Object,
        $Snapshot
    )

    $Candidates = @(
        $Snapshot.protectionGroupName,
        $Snapshot.protectionGroup.name,
        $Snapshot.protectionGroup.displayName,
        $Snapshot.protectionGroupInfo.name,
        $Snapshot.protectionGroupInfo.displayName,

        $Object.protectionGroupName,
        $Object.protectionGroup.name,
        $Object.protectionGroup.displayName,
        $Object.protectionGroupInfo.name,
        $Object.protectionGroupInfo.displayName
    )

    foreach ($Candidate in $Candidates) {
        $Text = Get-FirstText $Candidate

        if (-not [string]::IsNullOrWhiteSpace($Text)) {
            return $Text
        }
    }

    return "-"
}

function Get-BackupType {
    param(
        $Object,
        $Snapshot
    )

    $Candidates = @()

    if ($Object) {
        $Candidates += $Object.environment
        $Candidates += $Object.object.environment
        $Candidates += $Object.objectType
        $Candidates += $Object.type
        $Candidates += $Object.protectionType

        $Candidates += $Object.sourceInfo.environment
        $Candidates += $Object.sourceInfo.type

        $Candidates += $Object.protectionSource.environment
        $Candidates += $Object.protectionSource.type

        $Candidates += $Object.entity.environment
        $Candidates += $Object.entity.type

        $Candidates += $Object.object.name
        $Candidates += $Object.name
        $Candidates += $Object.displayName

        $Candidates += $Object.latestSnapshotInfo.environment
        $Candidates += $Object.latestSnapshotInfo.objectType

        $Candidates += $Object.latestSnapshotsInfo.environment
        $Candidates += $Object.latestSnapshotsInfo.objectType
    }

    if ($Snapshot) {
        $Candidates += $Snapshot.environment
        $Candidates += $Snapshot.objectType
        $Candidates += $Snapshot.sourceInfo.environment
        $Candidates += $Snapshot.sourceInfo.type
    }

    $Texts = @()

    foreach ($Candidate in $Candidates) {
        $Text = Get-FirstText $Candidate

        if (-not [string]::IsNullOrWhiteSpace($Text)) {
            $Texts += $Text.ToLower()
        }
    }

    $AllText = ($Texts -join " ")

    if ($AllText -match "ksql|mssql|sqlserver|sql server|\bsql\b") {
        return "SQL"
    }

    if ($AllText -match "koracle|\boracle\b") {
        return "Oracle"
    }

    if ($AllText -match "kphysical|physical|filesystem|file_system|file system|volume|windows|linux") {
        return "FS"
    }

    if ($AllText -match "kgenericnas|kisilon|nas|isilon|smb|cifs|nfs") {
        return "NAS"
    }

    if ($AllText -match "khyperv|hyperv|hyper-v") {
        return "Hyper-V"
    }

    if ($AllText -match "kacropolis|nutanix|ahv|acropolis") {
        return "Nutanix"
    }

    if ($AllText -match "kvmware|vmware|virtual") {
        return "VMware"
    }

    return "Unknown"
}

function Get-ObjectNames {
    param($Object)

    $Names = @(
        $Object.name,
        $Object.objectName,
        $Object.hostName,
        $Object.displayName,
        $Object.sourceName,

        $Object.entity.displayName,
        $Object.entity.name,

        $Object.object.name,
        $Object.object.displayName,

        $Object.sourceInfo.name,
        $Object.sourceInfo.displayName,

        $Object.protectionSource.name,
        $Object.protectionSource.displayName
    )

    return @(
        $Names |
        ForEach-Object {
            $Text = Get-FirstText $_

            if ($Text) {
                $Text.ToLower()
            }
        } |
        Where-Object { $_ }
    )
}

function Object-MatchesCi {
    param(
        $Object,
        [string]$CiName
    )

    $CiLower = "$CiName".ToLower().Trim()

    if ([string]::IsNullOrWhiteSpace($CiLower)) {
        return $false
    }

    $Names = Get-ObjectNames -Object $Object

    if (-not $Names -or $Names.Count -eq 0) {
        return $false
    }

    foreach ($Name in $Names) {
        if ($Name -eq $CiLower) {
            return $true
        }

        if ($Name -like "*$CiLower*") {
            return $true
        }

        if ($CiLower -like "*$Name*") {
            return $true
        }
    }

    return $false
}

function Get-BackupTypeRank {
    param([string]$BackupType)

    switch ($BackupType) {
        "SQL"      { return 1 }
        "Oracle"   { return 2 }
        "FS"       { return 3 }
        "NAS"      { return 4 }
        "Hyper-V"  { return 5 }
        "Nutanix"  { return 6 }
        "VMware"   { return 7 }
        default    { return 9 }
    }
}

# -------------------------------------------------------------------
# replicationSnapshotInfo logic
#
# Based on observed protected-objects behavior:
# - Source/original row does not have replicationSnapshotInfo property
# - Target-side replicated row has replicationSnapshotInfo property
# - replicationSnapshotInfo.clusterId points to source/original clusterId
# -------------------------------------------------------------------
function Test-ReplicationSnapshotInfoPresent {
    param(
        $Object,
        $Snapshot
    )

    if (Has-Property -Object $Object -PropertyName "replicationSnapshotInfo") {
        return $true
    }

    if (Has-Property -Object $Snapshot -PropertyName "replicationSnapshotInfo") {
        return $true
    }

    if ($Object -and $Object.latestSnapshotInfo) {
        foreach ($Snap in (AsArray $Object.latestSnapshotInfo)) {
            if (Has-Property -Object $Snap -PropertyName "replicationSnapshotInfo") {
                return $true
            }
        }
    }

    if ($Object -and $Object.latestSnapshotsInfo) {
        foreach ($Snap in (AsArray $Object.latestSnapshotsInfo)) {
            if (Has-Property -Object $Snap -PropertyName "replicationSnapshotInfo") {
                return $true
            }
        }
    }

    return $false
}

function Get-ReplicationFromClusterId {
    param(
        $Object,
        $Snapshot
    )

    $Candidates = @()

    if (Has-Property -Object $Object -PropertyName "replicationSnapshotInfo") {
        $Candidates += $Object.replicationSnapshotInfo.clusterId
        $Candidates += $Object.replicationSnapshotInfo.clusterID
        $Candidates += $Object.replicationSnapshotInfo.sourceClusterId
        $Candidates += $Object.replicationSnapshotInfo.sourceClusterID
    }

    if (Has-Property -Object $Snapshot -PropertyName "replicationSnapshotInfo") {
        $Candidates += $Snapshot.replicationSnapshotInfo.clusterId
        $Candidates += $Snapshot.replicationSnapshotInfo.clusterID
        $Candidates += $Snapshot.replicationSnapshotInfo.sourceClusterId
        $Candidates += $Snapshot.replicationSnapshotInfo.sourceClusterID
    }

    if ($Object -and $Object.latestSnapshotInfo) {
        foreach ($Snap in (AsArray $Object.latestSnapshotInfo)) {
            if (Has-Property -Object $Snap -PropertyName "replicationSnapshotInfo") {
                $Candidates += $Snap.replicationSnapshotInfo.clusterId
                $Candidates += $Snap.replicationSnapshotInfo.clusterID
                $Candidates += $Snap.replicationSnapshotInfo.sourceClusterId
                $Candidates += $Snap.replicationSnapshotInfo.sourceClusterID
            }
        }
    }

    if ($Object -and $Object.latestSnapshotsInfo) {
        foreach ($Snap in (AsArray $Object.latestSnapshotsInfo)) {
            if (Has-Property -Object $Snap -PropertyName "replicationSnapshotInfo") {
                $Candidates += $Snap.replicationSnapshotInfo.clusterId
                $Candidates += $Snap.replicationSnapshotInfo.clusterID
                $Candidates += $Snap.replicationSnapshotInfo.sourceClusterId
                $Candidates += $Snap.replicationSnapshotInfo.sourceClusterID
            }
        }
    }

    foreach ($Candidate in $Candidates) {
        $Text = Get-FirstText $Candidate

        if (-not [string]::IsNullOrWhiteSpace($Text)) {
            return "$Text"
        }
    }

    return ""
}

function Get-ClusterNameFromId {
    param(
        [string]$ClusterId,
        [hashtable]$ClusterMap
    )

    if ([string]::IsNullOrWhiteSpace($ClusterId)) {
        return ""
    }

    if ($ClusterMap.ContainsKey("$ClusterId")) {
        return "$($ClusterMap["$ClusterId"].clusterName)"
    }

    return "$ClusterId"
}

function Get-CiRowsFromCluster {
    param(
        [Parameter(Mandatory)] [string]$Ci,
        [Parameter(Mandatory)] $Cluster,
        [Parameter(Mandatory)] [string]$ApiKey,
        [Parameter(Mandatory)] [hashtable]$ClusterMap
    )

    $Rows = @()

    $ProtectedSearchUrl = (
        "https://helios.cohesity.com/v2/data-protect/search/protected-objects" +
        "?searchString=$([uri]::EscapeDataString($Ci))"
    )

    $ProtectedJson = Invoke-HeliosJson -Uri $ProtectedSearchUrl -Headers @{
        accept          = "application/json"
        apiKey          = $ApiKey
        accessClusterId = "$($Cluster.clusterId)"
    }

    $ProtectedObjects = Get-ProtectedObjects -Json $ProtectedJson

    if (-not $ProtectedObjects -or $ProtectedObjects.Count -eq 0) {
        return @()
    }

    $MatchingObjects = @($ProtectedObjects | Where-Object {
        Object-MatchesCi -Object $_ -CiName $Ci
    })

    if ($MatchingObjects -and $MatchingObjects.Count -gt 0) {
        $ObjectsToCheck = $MatchingObjects
    }
    else {
        $ObjectsToCheck = $ProtectedObjects
    }

    foreach ($Obj in $ObjectsToCheck) {

        $Snap = Get-BestSnapshot -Object $Obj

        $BackupType = Get-BackupType -Object $Obj -Snapshot $Snap

        $ReplicationSnapshotInfoPresent = Test-ReplicationSnapshotInfoPresent `
            -Object $Obj `
            -Snapshot $Snap

        $ReplicationFromClusterId = Get-ReplicationFromClusterId `
            -Object $Obj `
            -Snapshot $Snap

        $ReplicationFromClusterName = Get-ClusterNameFromId `
            -ClusterId $ReplicationFromClusterId `
            -ClusterMap $ClusterMap

        if ($Snap) {
            $Usecs = Get-SnapshotUsecs -Snapshot $Snap

            if ($Usecs) {
                $LastBackupTime = ToDate $Usecs
            }
            else {
                $LastBackupTime = "NoBackupTime"
            }

            $ProtectionGroup = Get-ProtectionGroupName -Object $Obj -Snapshot $Snap

            $Rows += [pscustomobject]@{
                ServerName                     = $Ci
                BackupType                     = $BackupType
                ClusterName                    = "$($Cluster.clusterName)"
                ClusterId                      = "$($Cluster.clusterId)"
                ProtectionGroup                = $ProtectionGroup
                LastBackupTime                 = $LastBackupTime
                LastBackupUsecs                = if ($Usecs) { [int64]$Usecs } else { 0 }
                ReplicationSnapshotInfoPresent = [bool]$ReplicationSnapshotInfoPresent
                ReplicationFromClusterId       = $ReplicationFromClusterId
                ReplicationFromClusterName     = $ReplicationFromClusterName
            }
        }
        else {
            $ProtectionGroup = Get-ProtectionGroupName -Object $Obj -Snapshot $null

            $Rows += [pscustomobject]@{
                ServerName                     = $Ci
                BackupType                     = $BackupType
                ClusterName                    = "$($Cluster.clusterName)"
                ClusterId                      = "$($Cluster.clusterId)"
                ProtectionGroup                = $ProtectionGroup
                LastBackupTime                 = "NoBackup"
                LastBackupUsecs                = 0
                ReplicationSnapshotInfoPresent = [bool]$ReplicationSnapshotInfoPresent
                ReplicationFromClusterId       = $ReplicationFromClusterId
                ReplicationFromClusterName     = $ReplicationFromClusterName
            }
        }
    }

    return @($Rows)
}

function Select-BestRowsPerBackupType {
    param($Rows)

    if (-not $Rows -or $Rows.Count -eq 0) {
        return @()
    }

    $Selected = @()

    foreach ($Group in ($Rows | Group-Object BackupType)) {

        $GroupRows = @($Group.Group)

        $ValidRows = @($GroupRows | Where-Object {
            Is-ValidBackupRow $_
        })

        if ($ValidRows.Count -gt 0) {
            $Selected += (
                $ValidRows |
                Sort-Object `
                    @{ Expression = { if ($_.ReplicationSnapshotInfoPresent -eq $true) { 2 } else { 1 } } },
                    @{ Expression = { $_.LastBackupUsecs }; Descending = $true },
                    ClusterName,
                    ProtectionGroup |
                Select-Object -First 1
            )
        }
        else {
            $Selected += (
                $GroupRows |
                Sort-Object `
                    @{ Expression = { if ($_.ReplicationSnapshotInfoPresent -eq $true) { 2 } else { 1 } } },
                    ClusterName,
                    ProtectionGroup |
                Select-Object -First 1
            )
        }
    }

    return @($Selected)
}

# -------------------------
# CSV -> TXT
# -------------------------
$CiNames = Import-Csv -Path $InputCsv |
ForEach-Object {
    "$($_.ci_item)".Trim().Trim('"').Trim("'")
} |
Where-Object {
    -not [string]::IsNullOrWhiteSpace($_)
} |
Sort-Object -Unique

if (-not $CiNames -or $CiNames.Count -eq 0) {
    throw "No CI names found in CSV: $InputCsv"
}

$CiNames | Set-Content -Path $InputTxt

$CiList = Get-Content -Path $InputTxt |
ForEach-Object {
    $_.Trim().Trim('"').Trim("'")
} |
Where-Object {
    -not [string]::IsNullOrWhiteSpace($_)
}

if (-not $CiList -or $CiList.Count -eq 0) {
    throw "No CI names found in TXT: $InputTxt"
}

# -------------------------
# Get Clusters
# -------------------------
$ClusterUrl = "https://helios.cohesity.com/v2/mcm/cluster-mgmt/info"

$ClusterJson = Invoke-HeliosJson -Uri $ClusterUrl -Headers @{
    accept = "application/json"
    apiKey = $ApiKey
}

if (-not $ClusterJson -or -not $ClusterJson.cohesityClusters -or $ClusterJson.cohesityClusters.Count -eq 0) {
    throw "No clusters returned from Helios."
}

$Clusters = $ClusterJson.cohesityClusters |
ForEach-Object {
    $Name = Get-FirstText @($_.clusterName, $_.name, $_.displayName)
    $Id   = Get-FirstText @($_.clusterId, $_.id)

    [pscustomobject]@{
        clusterId   = "$Id"
        clusterName = "$Name"
        raw         = $_
    }
} |
Where-Object {
    -not [string]::IsNullOrWhiteSpace($_.clusterId)
} |
Sort-Object clusterName, clusterId

# ClusterMap stores only valid MCM clusters.
$ClusterMap = @{}

foreach ($Clu in $Clusters) {

    $Raw = $Clu.raw

    $PossibleIds = @(
        $Clu.clusterId,
        $Raw.clusterId,
        $Raw.id,
        $Raw.clusterIdentifier.clusterId,
        $Raw.clusterInfo.clusterId
    )

    foreach ($Id in $PossibleIds) {
        $IdText = Get-FirstText $Id

        if (-not [string]::IsNullOrWhiteSpace($IdText)) {
            $ClusterMap[$IdText] = $Clu
        }
    }
}

# -------------------------
# Process
# -------------------------
$Results = @()

foreach ($Ci in $CiList) {

    $Ci = $Ci.Trim().Trim('"').Trim("'")

    Write-Host "Processing: [$Ci]"

    if ([string]::IsNullOrWhiteSpace($Ci)) {
        continue
    }

    $CiAllRows = @()
    $SearchedClusterIds = New-Object 'System.Collections.Generic.HashSet[string]'

    # ------------------------------------------------------
    # Step 1: Global search
    # ------------------------------------------------------
    $GlobalSearchCalls++

    $GlobalSearchUrl = (
        "https://helios.cohesity.com/v2/data-protect/search/objects" +
        "?searchString=$([uri]::EscapeDataString($Ci))" +
        "&includeTenants=true" +
        "&count=$GlobalSearchCount"
    )

    $GlobalJson = Invoke-HeliosJson -Uri $GlobalSearchUrl -Headers @{
        accept = "application/json"
        apiKey = $ApiKey
    }

    $GlobalObjects = Get-GlobalObjects -Json $GlobalJson
    $CandidateClusterIds = Get-CandidateClusterIdsFromGlobalSearch -Json $GlobalJson

    $CandidateClusters = @()

    if ($CandidateClusterIds -and $CandidateClusterIds.Count -gt 0) {

        foreach ($ClusterId in $CandidateClusterIds) {

            if ($ClusterMap.ContainsKey("$ClusterId")) {
                $MatchedCluster = $ClusterMap["$ClusterId"]

                $CandidateClusters += [pscustomobject]@{
                    clusterId   = "$($MatchedCluster.clusterId)"
                    clusterName = "$($MatchedCluster.clusterName)"
                    searchMode  = "Fast"
                }
            }
        }
    }

    # Fallback if global search found object but cluster ID was not usable.
    if (-not $CandidateClusters -or $CandidateClusters.Count -eq 0) {

        $ShouldFallback =
            $EnableAllClusterFallback -and
            (
                ($GlobalObjects -and $GlobalObjects.Count -gt 0) -or
                $FallbackWhenNoGlobalObject
            )

        if ($ShouldFallback) {
            $FallbackCiCount++

            foreach ($Clu in $Clusters) {
                $CandidateClusters += [pscustomobject]@{
                    clusterId   = "$($Clu.clusterId)"
                    clusterName = "$($Clu.clusterName)"
                    searchMode  = "Fallback"
                }
            }
        }
    }

    $CandidateClusters = @(
        $CandidateClusters |
        Sort-Object clusterName, clusterId |
        Group-Object clusterId |
        ForEach-Object {
            $_.Group | Select-Object -First 1
        }
    )

    if (-not $CandidateClusters -or $CandidateClusters.Count -eq 0) {
        $Results += [pscustomobject]@{
            ServerName      = $Ci
            BackupType      = "Unknown"
            ClusterName     = "-"
            ProtectionGroup = "-"
            LastBackupTime  = "NoObject"
        }

        continue
    }

    # ------------------------------------------------------
    # Step 2: Search candidate clusters
    # ------------------------------------------------------
    foreach ($Clu in $CandidateClusters) {

        if ($SearchedClusterIds.Contains("$($Clu.clusterId)")) {
            continue
        }

        $ProtectedSearchCalls++
        [void]$SearchedClusterIds.Add("$($Clu.clusterId)")

        $Rows = Get-CiRowsFromCluster `
            -Ci $Ci `
            -Cluster $Clu `
            -ApiKey $ApiKey `
            -ClusterMap $ClusterMap

        if ($Rows -and $Rows.Count -gt 0) {
            $CiAllRows += $Rows
        }
    }

    # ------------------------------------------------------
    # Step 3: If replicated/target rows point to source cluster,
    # search source cluster too.
    # ------------------------------------------------------
    if ($EnableReplicationSourceCheck) {

        $SourceClusterIds = @(
            $CiAllRows |
            Where-Object {
                $_.ReplicationSnapshotInfoPresent -eq $true -and
                -not [string]::IsNullOrWhiteSpace($_.ReplicationFromClusterId)
            } |
            Select-Object -ExpandProperty ReplicationFromClusterId -Unique
        )

        foreach ($SourceClusterId in $SourceClusterIds) {

            if ([string]::IsNullOrWhiteSpace($SourceClusterId)) {
                continue
            }

            if ($SearchedClusterIds.Contains("$SourceClusterId")) {
                continue
            }

            if (-not $ClusterMap.ContainsKey("$SourceClusterId")) {
                continue
            }

            $SourceCluster = $ClusterMap["$SourceClusterId"]

            $ReplicationSourceCheckCount++
            $ProtectedSearchCalls++

            [void]$SearchedClusterIds.Add("$($SourceCluster.clusterId)")

            $SourceRows = Get-CiRowsFromCluster `
                -Ci $Ci `
                -Cluster $SourceCluster `
                -ApiKey $ApiKey `
                -ClusterMap $ClusterMap

            if ($SourceRows -and $SourceRows.Count -gt 0) {
                $CiAllRows += $SourceRows
            }
        }
    }

    if (-not $CiAllRows -or $CiAllRows.Count -eq 0) {
        $Results += [pscustomobject]@{
            ServerName      = $Ci
            BackupType      = "Unknown"
            ClusterName     = "-"
            ProtectionGroup = "-"
            LastBackupTime  = "NoObject"
        }

        continue
    }

    # ------------------------------------------------------
    # Step 4: Final selection per BackupType
    # Prefer row where replicationSnapshotInfo is not present.
    # If only replicated/target row exists, show it.
    # ------------------------------------------------------
    $SelectedRows = Select-BestRowsPerBackupType -Rows $CiAllRows

    $HasValidSQL = @($SelectedRows | Where-Object {
        $_.BackupType -eq "SQL" -and (Is-ValidBackupRow $_)
    }).Count -gt 0

    $HasValidOracle = @($SelectedRows | Where-Object {
        $_.BackupType -eq "Oracle" -and (Is-ValidBackupRow $_)
    }).Count -gt 0

    $HasValidFS = @($SelectedRows | Where-Object {
        $_.BackupType -eq "FS" -and (Is-ValidBackupRow $_)
    }).Count -gt 0

    $HasValidDB = $HasValidSQL -or $HasValidOracle

    # If DB exists but FS valid backup does not, remove any FS NoBackup row
    # and show clear NoFSBackupFound.
    if ($HasValidDB -and -not $HasValidFS) {
        $SelectedRows = @($SelectedRows | Where-Object { $_.BackupType -ne "FS" })
    }

    foreach ($Row in $SelectedRows) {
        $Results += [pscustomobject]@{
            ServerName      = $Row.ServerName
            BackupType      = $Row.BackupType
            ClusterName     = $Row.ClusterName
            ProtectionGroup = $Row.ProtectionGroup
            LastBackupTime  = $Row.LastBackupTime
        }
    }

    if ($HasValidDB -and -not $HasValidFS) {
        $Results += [pscustomobject]@{
            ServerName      = $Ci
            BackupType      = "FS"
            ClusterName     = "-"
            ProtectionGroup = "-"
            LastBackupTime  = "NoFSBackupFound"
        }
    }
}

# -------------------------
# Summary
# -------------------------
$TotalInputCIs = $CiList.Count
$TotalBackupRows = $Results.Count

$BackedUp = ($Results | Where-Object {
    $_.LastBackupTime -notin @("NoBackup", "NoBackupTime", "NoObject", "NoFSBackupFound", "")
}).Count

$NoBackup = ($Results | Where-Object {
    $_.LastBackupTime -in @("NoBackup", "NoBackupTime")
}).Count

$NoFSBackupFound = ($Results | Where-Object {
    $_.LastBackupTime -eq "NoFSBackupFound"
}).Count

$NoObject = ($Results | Where-Object {
    $_.LastBackupTime -eq "NoObject"
}).Count

$SortedResults = $Results |
    Sort-Object `
        ServerName,
        @{ Expression = { Get-BackupTypeRank -BackupType $_.BackupType } },
        ClusterName,
        ProtectionGroup

$DetailsText = (
    $SortedResults |
    Format-Table ServerName, BackupType, ClusterName, ProtectionGroup, LastBackupTime -AutoSize |
    Out-String -Width 300
).TrimEnd()

# -------------------------
# Build Report
# -------------------------
$Report = @()
$Report += "=========================================================="
$Report += "Cohesity Backup Validation Report"
$Report += "=========================================================="
$Report += "Change Number                    : $ChangeID"
$Report += "Executed By                      : $ExecutedBy"
$Report += "Run Date                         : $(Get-Date -Format 'dd-MMM-yyyy HH:mm:ss')"
$Report += ""
$Report += "Total Input CIs                  : $TotalInputCIs"
$Report += "Total Backup Rows                : $TotalBackupRows"
$Report += "Backed Up                        : $BackedUp"
$Report += "No Backup                        : $NoBackup"
$Report += "No FS Backup Found               : $NoFSBackupFound"
$Report += "No Object                        : $NoObject"
$Report += ""
$Report += "Global Search Calls              : $GlobalSearchCalls"
$Report += "Protected Search Calls           : $ProtectedSearchCalls"
$Report += "Fallback CI Count                : $FallbackCiCount"
$Report += "Replication Source Check Count   : $ReplicationSourceCheckCount"
$Report += ""
$Report += "----------------------------------------------------------"
$Report += "Details"
$Report += "----------------------------------------------------------"
$Report += ""
$Report += $DetailsText
$Report += ""
$Report += "----------------------------------------------------------"
$Report += "Summary Notes"
$Report += "----------------------------------------------------------"
$Report += "- Backed Up                     : CI found with valid snapshot and backup time"
$Report += "- No Backup                     : CI found in Cohesity but no usable snapshot time returned"
$Report += "- No Object                     : CI not found in Cohesity search"
$Report += "- NoFSBackupFound               : SQL/Oracle backup found, but no matching FS backup found for the CI"
$Report += "- BackupType                    : Derived from Cohesity protected object/search metadata"
$Report += "- Replication Rule              : If replicationSnapshotInfo exists, the row is replicated/target-side copy"
$Report += "- Replication Source Rule       : replicationSnapshotInfo.clusterId is treated as source/original clusterId"
$Report += "- Selection Rule                : For same CI + BackupType, source/original row is preferred over replicated/target row"
$Report += "- Endpoint Rule                 : Script uses only cluster list, global search, and protected-objects search"
$Report += ""
$Report += "----------------------------------------------------------"
$Report += "Report Location"
$Report += "----------------------------------------------------------"
$Report += $OutputTxt
$Report += "=========================================================="

# -------------------------
# Write Report
# -------------------------
$Report | Set-Content -Path $OutputTxt

# -------------------------
# Display
# -------------------------
Write-Host ""
Write-Host "=========================================================="
Write-Host "Cohesity Backup Validation Report"
Write-Host "=========================================================="
Write-Host "Change Number                    : $ChangeID"
Write-Host "Executed By                      : $ExecutedBy"
Write-Host "Run Date                         : $(Get-Date -Format 'dd-MMM-yyyy HH:mm:ss')"
Write-Host ""
Write-Host "Total Input CIs                  : $TotalInputCIs"
Write-Host "Total Backup Rows                : $TotalBackupRows"
Write-Host "Backed Up                        : $BackedUp"
Write-Host "No Backup                        : $NoBackup"
Write-Host "No FS Backup Found               : $NoFSBackupFound"
Write-Host "No Object                        : $NoObject"
Write-Host ""
Write-Host "Global Search Calls              : $GlobalSearchCalls"
Write-Host "Protected Search Calls           : $ProtectedSearchCalls"
Write-Host "Fallback CI Count                : $FallbackCiCount"
Write-Host "Replication Source Check Count   : $ReplicationSourceCheckCount"
Write-Host ""
Write-Host "----------------------------------------------------------"
Write-Host "Details"
Write-Host "----------------------------------------------------------"
Write-Host ""
Write-Host $DetailsText
Write-Host ""
Write-Host "----------------------------------------------------------"
Write-Host "Report Location"
Write-Host "----------------------------------------------------------"
Write-Host $OutputTxt
Write-Host "=========================================================="
