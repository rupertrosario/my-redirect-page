# ==========================================================
# Cohesity Backup Validation – DISPLAY + TXT REPORT OUTPUT
# GET ONLY | SEARCH ONLY | STABLE LOGIC
#
# Endpoints used:
# 1) GET /v2/mcm/cluster-mgmt/info
# 2) GET /v2/data-protect/search/objects?searchString=<CI>&includeTenants=true&count=100
# 3) GET /v2/data-protect/search/protected-objects?searchString=<CI>
#
# Replication logic:
# - If replicationSnapshotInfo property exists:
#     This is treated as replicated / target-side row.
#     replicationSnapshotInfo.clusterId is treated as source/original clusterId.
# - If replicationSnapshotInfo property does not exist:
#     This is treated as source/original or non-replicated row.
#
# Selection logic:
# - Collect all rows first.
# - If target row points to source cluster, search source cluster too.
# - For same CI + BackupType:
#     Prefer valid source/non-replicated row.
#     Use replicated/target row only if source row is not found.
#
# Output:
# - Console report
# - TXT report
# ==========================================================

$ErrorActionPreference = "Stop"
$FormatEnumerationLimit = -1

# -------------------------
# Input
# -------------------------
$ChangeID   = Read-Host "Enter Change Number"
$ExecutedBy = (whoami).Trim()

# -------------------------
# Paths
# -------------------------
$BaseDir   = "X:\PowerShell\Data\Cohesity\BackupValidation"
$InputCsv  = Join-Path $BaseDir "$ChangeID.csv"
$InputTxt  = Join-Path $BaseDir "$ChangeID.txt"
$TimeStamp = Get-Date -Format "yyyyMMdd_HHmm"
$OutputTxt = Join-Path $BaseDir "${ChangeID}_BackupReport_$TimeStamp.txt"

if (-not (Test-Path $InputCsv)) {
    throw "CSV not found: $InputCsv"
}

# -------------------------
# API
# -------------------------
$BaseUrl    = "https://helios.cohesity.com"
$ApiKeyPath = "X:\PowerShell\Cohesity_API_Scripts\DO_NOT_Delete\apikey.txt"

if (-not (Test-Path $ApiKeyPath)) {
    throw "API key file not found: $ApiKeyPath"
}

$ApiKey = (Get-Content -Path $ApiKeyPath -Raw).Trim()

# -------------------------
# Settings
# -------------------------
$GlobalSearchCount = 100

# Safer: if fast global search cannot provide usable cluster IDs, search all clusters.
$FallbackToAllClustersWhenNoCandidate = $true

# If replicated/target row points to source cluster, search that source cluster too.
$EnableReplicationSourceCheck = $true

# Display cluster search counts while running.
$ShowDebug = $true

# -------------------------
# Counters
# -------------------------
$GlobalSearchCalls           = 0
$ProtectedSearchCalls        = 0
$FallbackCiCount             = 0
$ReplicationSourceCheckCount = 0

# ==========================================================
# Helper functions
# ==========================================================
function Invoke-HeliosJson {
    param(
        [Parameter(Mandatory)] [string]$Uri,
        [Parameter(Mandatory)] [hashtable]$Headers,
        [int]$TimeoutSec = 45
    )

    try {
        $resp = Invoke-WebRequest `
            -UseBasicParsing `
            -Method Get `
            -Uri $Uri `
            -Headers $Headers `
            -TimeoutSec $TimeoutSec `
            -ErrorAction Stop

        if ([string]::IsNullOrWhiteSpace($resp.Content)) {
            return $null
        }

        return ($resp.Content | ConvertFrom-Json)
    }
    catch {
        if ($ShowDebug) {
            Write-Host "  GET failed: $Uri" -ForegroundColor DarkRed
            Write-Host "  $($_.Exception.Message)" -ForegroundColor DarkRed
        }

        return $null
    }
}

function AsArray {
    param($Value)

    if ($null -eq $Value) {
        return @()
    }

    if ($Value -is [array]) {
        return @($Value)
    }

    return @($Value)
}

function Has-Property {
    param(
        $Object,
        [string]$PropertyName
    )

    if ($null -eq $Object) {
        return $false
    }

    try {
        return ($Object.PSObject.Properties.Name -contains $PropertyName)
    }
    catch {
        return $false
    }
}

function Has-AnyProperty {
    param(
        $Object,
        [string[]]$PropertyNames
    )

    if ($null -eq $Object) {
        return $false
    }

    try {
        foreach ($p in $PropertyNames) {
            if ($Object.PSObject.Properties.Name -contains $p) {
                return $true
            }
        }
    }
    catch {}

    return $false
}

function Get-FirstText {
    param($Value)

    if ($null -eq $Value) {
        return ""
    }

    if ($Value -is [array]) {
        foreach ($item in $Value) {
            $txt = Get-FirstText -Value $item

            if (-not [string]::IsNullOrWhiteSpace($txt)) {
                return $txt
            }
        }

        return ""
    }

    if ($Value -is [pscustomobject]) {
        foreach ($prop in @(
            "display_value",
            "displayName",
            "name",
            "value",
            "id",
            "clusterId",
            "clusterID",
            "sourceClusterId",
            "sourceClusterID",
            "intId"
        )) {
            if ($Value.PSObject.Properties.Name -contains $prop) {
                $txt = Get-FirstText -Value $Value.$prop

                if (-not [string]::IsNullOrWhiteSpace($txt)) {
                    return $txt
                }
            }
        }

        return ""
    }

    return "$Value".Trim()
}

function Get-UsecsValue {
    param($Value)

    if ($null -eq $Value) {
        return $null
    }

    $nums = @()

    foreach ($item in (AsArray $Value)) {
        if ($null -ne $item -and "$item".Trim() -ne "") {
            try {
                $nums += [int64]$item
            }
            catch {}
        }
    }

    if ($nums.Count -eq 0) {
        return $null
    }

    return ($nums | Sort-Object -Descending | Select-Object -First 1)
}

function Convert-UsecsToLocalTime {
    param($Usecs)

    if (-not $Usecs) {
        return ""
    }

    try {
        return [DateTimeOffset]::FromUnixTimeMilliseconds([int64]($Usecs / 1000)).LocalDateTime.ToString("dd-MMM-yyyy HH:mm:ss")
    }
    catch {
        return ""
    }
}

function Is-ValidBackupRow {
    param($Row)

    if (-not $Row) {
        return $false
    }

    return $Row.LastBackupTime -notin @(
        "NoBackup",
        "NoBackupTime",
        "NoObject",
        "NoFSBackupFound",
        "",
        $null
    )
}

function Find-NestedPropertyValues {
    param(
        $Object,
        [string[]]$PropertyNames,
        [int]$MaxDepth = 6,
        [int]$Depth = 0
    )

    $found = @()

    if ($null -eq $Object) {
        return @()
    }

    if ($Depth -gt $MaxDepth) {
        return @()
    }

    foreach ($item in (AsArray $Object)) {

        if ($null -eq $item) {
            continue
        }

        if ($item -is [string] -or $item -is [int] -or $item -is [long] -or $item -is [double] -or $item -is [bool]) {
            continue
        }

        if ($item -is [pscustomobject]) {
            foreach ($prop in $item.PSObject.Properties) {

                if ($PropertyNames -contains $prop.Name) {
                    $found += $prop.Value
                }

                if ($prop.Value -is [pscustomobject] -or $prop.Value -is [array]) {
                    $found += Find-NestedPropertyValues `
                        -Object $prop.Value `
                        -PropertyNames $PropertyNames `
                        -MaxDepth $MaxDepth `
                        -Depth ($Depth + 1)
                }
            }
        }
    }

    return @($found)
}

# ==========================================================
# Response parsing
# ==========================================================
function Get-GlobalObjects {
    param($Json)

    if (-not $Json) {
        return @()
    }

    if ($Json -is [array]) {
        return @($Json)
    }

    foreach ($prop in @(
        "objects",
        "searchResults",
        "results",
        "entities",
        "data",
        "items"
    )) {
        if ($Json.PSObject.Properties.Name -contains $prop) {
            return @(AsArray $Json.$prop | Where-Object { $_ })
        }
    }

    return @($Json)
}

function Get-ProtectedObjects {
    param($Json)

    if (-not $Json) {
        return @()
    }

    if ($Json -is [array]) {
        return @($Json)
    }

    foreach ($prop in @(
        "objects",
        "protectedObjects",
        "protectedObjectResults",
        "searchResults",
        "results",
        "entities",
        "data",
        "items"
    )) {
        if ($Json.PSObject.Properties.Name -contains $prop) {
            return @(AsArray $Json.$prop | Where-Object { $_ })
        }
    }

    # Only return root object if it looks like an actual protected object.
    if (Has-AnyProperty -Object $Json -PropertyNames @(
        "latestSnapshotInfo",
        "latestSnapshotsInfo",
        "latestSnapshots",
        "latestSnapshot",
        "snapshotInfo",
        "backupInfo",
        "protectionGroupName",
        "protectionGroup",
        "protectionGroupInfo",
        "objectProtectionInfos",
        "environment",
        "objectType",
        "name",
        "displayName"
    )) {
        return @($Json)
    }

    return @()
}

# ==========================================================
# Cluster helpers
# ==========================================================
function Get-CandidateClusterIdsFromGlobalSearch {
    param($Json)

    $ids = @()

    $values = Find-NestedPropertyValues `
        -Object $Json `
        -PropertyNames @(
            "clusterId",
            "clusterID",
            "sourceClusterId",
            "sourceClusterID",
            "accessClusterId"
        ) `
        -MaxDepth 8

    foreach ($v in $values) {
        $txt = Get-FirstText -Value $v

        if (-not [string]::IsNullOrWhiteSpace($txt)) {
            $ids += $txt
        }
    }

    return @($ids | Sort-Object -Unique)
}

function Get-ClusterNameFromId {
    param(
        [string]$ClusterId,
        [hashtable]$ClusterMap
    )

    if ([string]::IsNullOrWhiteSpace($ClusterId)) {
        return ""
    }

    if ($ClusterMap.ContainsKey("$ClusterId")) {
        return "$($ClusterMap["$ClusterId"].ClusterName)"
    }

    return "$ClusterId"
}

# ==========================================================
# Object/snapshot helpers
# ==========================================================
function Get-SnapshotCandidates {
    param($Object)

    if (-not $Object) {
        return @()
    }

    $items = @()

    $items += @(AsArray $Object.latestSnapshotInfo)
    $items += @(AsArray $Object.latestSnapshotsInfo)
    $items += @(AsArray $Object.latestSnapshots)
    $items += @(AsArray $Object.latestSnapshot)
    $items += @(AsArray $Object.snapshotInfo)
    $items += @(AsArray $Object.backupInfo)

    return @($items | Where-Object { $_ })
}

function Get-SnapshotUsecs {
    param($Node)

    if (-not $Node) {
        return $null
    }

    foreach ($field in @(
        "protectionRunStartTimeUsecs",
        "protectionRunEndTimeUsecs",
        "runStartTimeUsecs",
        "runEndTimeUsecs",
        "snapshotCreationTimeUsecs",
        "creationTimeUsecs",
        "startTimeUsecs",
        "endTimeUsecs"
    )) {
        if (Has-Property -Object $Node -PropertyName $field) {
            $u = Get-UsecsValue -Value $Node.$field

            if ($u) {
                return $u
            }
        }
    }

    if (Has-Property -Object $Node -PropertyName "localBackupInfo") {
        foreach ($lbi in (AsArray $Node.localBackupInfo)) {
            $u = Get-UsecsValue -Value $lbi.startTimeUsecs
            if ($u) { return $u }

            $u = Get-UsecsValue -Value $lbi.endTimeUsecs
            if ($u) { return $u }
        }
    }

    return $null
}

function Get-BestSnapshot {
    param($Object)

    $snaps = @(Get-SnapshotCandidates -Object $Object)

    if (-not $snaps -or $snaps.Count -eq 0) {
        return $null
    }

    return $snaps |
        Sort-Object @{ Expression = { [int64](Get-SnapshotUsecs -Node $_) } } -Descending |
        Select-Object -First 1
}

function Get-BestBackupUsecs {
    param(
        $Object,
        $Snapshot
    )

    $u = Get-SnapshotUsecs -Node $Snapshot

    if ($u) {
        return $u
    }

    $u = Get-SnapshotUsecs -Node $Object

    if ($u) {
        return $u
    }

    return $null
}

function Get-ProtectionGroupName {
    param(
        $Object,
        $Snapshot
    )

    $values = @(
        $Snapshot.protectionGroupName,
        $Snapshot.protectionGroup.name,
        $Snapshot.protectionGroup.displayName,
        $Snapshot.protectionGroupInfo.name,
        $Snapshot.protectionGroupInfo.displayName,

        $Object.protectionGroupName,
        $Object.protectionGroup.name,
        $Object.protectionGroup.displayName,
        $Object.protectionGroupInfo.name,
        $Object.protectionGroupInfo.displayName,

        $Object.objectProtectionInfos.protectionGroups.name,
        $Object.objectProtectionInfos.protectionGroups.protectionGroupName
    )

    foreach ($v in $values) {
        $txt = Get-FirstText -Value $v

        if (-not [string]::IsNullOrWhiteSpace($txt)) {
            return $txt
        }
    }

    return "-"
}

function Get-BackupType {
    param(
        $Object,
        $Snapshot
    )

    $values = @()

    $values += $Object.environment
    $values += $Object.object.environment
    $values += $Object.objectType
    $values += $Object.type
    $values += $Object.protectionType

    $values += $Object.sourceInfo.environment
    $values += $Object.sourceInfo.type

    $values += $Object.protectionSource.environment
    $values += $Object.protectionSource.type

    $values += $Object.entity.environment
    $values += $Object.entity.type

    $values += $Object.object.name
    $values += $Object.name
    $values += $Object.displayName

    $values += $Object.latestSnapshotInfo.environment
    $values += $Object.latestSnapshotInfo.objectType
    $values += $Object.latestSnapshotsInfo.environment
    $values += $Object.latestSnapshotsInfo.objectType

    $values += $Snapshot.environment
    $values += $Snapshot.objectType
    $values += $Snapshot.sourceInfo.environment
    $values += $Snapshot.sourceInfo.type

    $txts = @()

    foreach ($v in $values) {
        $t = Get-FirstText -Value $v

        if (-not [string]::IsNullOrWhiteSpace($t)) {
            $txts += $t.ToLower()
        }
    }

    $all = ($txts -join " ")

    if ($all -match "ksql|mssql|sqlserver|sql server|\bsql\b") {
        return "SQL"
    }

    if ($all -match "koracle|\boracle\b") {
        return "Oracle"
    }

    if ($all -match "kgenericnas|kisilon|nas|isilon|smb|cifs|nfs") {
        return "NAS"
    }

    if ($all -match "khyperv|hyperv|hyper-v") {
        return "Hyper-V"
    }

    if ($all -match "kacropolis|nutanix|ahv|acropolis") {
        return "Nutanix"
    }

    if ($all -match "kvmware|vmware") {
        return "VMware"
    }

    if ($all -match "kphysical|physical|filesystem|file_system|file system|volume|windows|linux") {
        return "FS"
    }

    return "Unknown"
}

function Get-ObjectNames {
    param($Object)

    $values = @(
        $Object.name,
        $Object.objectName,
        $Object.hostName,
        $Object.displayName,
        $Object.sourceName,

        $Object.entity.displayName,
        $Object.entity.name,

        $Object.object.name,
        $Object.object.displayName,

        $Object.sourceInfo.name,
        $Object.sourceInfo.displayName,

        $Object.protectionSource.name,
        $Object.protectionSource.displayName
    )

    $names = @()

    foreach ($v in $values) {
        $txt = Get-FirstText -Value $v

        if (-not [string]::IsNullOrWhiteSpace($txt)) {
            $names += $txt.ToLower()
        }
    }

    return @($names | Sort-Object -Unique)
}

function Object-MatchesCi {
    param(
        $Object,
        [string]$CiName
    )

    $ciLower = "$CiName".ToLower().Trim()

    if ([string]::IsNullOrWhiteSpace($ciLower)) {
        return $false
    }

    $names = @(Get-ObjectNames -Object $Object)

    if (-not $names -or $names.Count -eq 0) {
        return $true
    }

    foreach ($n in $names) {
        if ($n -eq $ciLower) {
            return $true
        }

        if ($n -like "*$ciLower*") {
            return $true
        }

        if ($ciLower -like "*$n*") {
            return $true
        }
    }

    return $false
}

# ==========================================================
# Replication helpers
# ==========================================================
function Get-ReplicationSnapshotInfoNodes {
    param(
        $Object,
        $Snapshot
    )

    $nodes = @()

    $nodes += Find-NestedPropertyValues `
        -Object $Object `
        -PropertyNames @("replicationSnapshotInfo") `
        -MaxDepth 8

    $nodes += Find-NestedPropertyValues `
        -Object $Snapshot `
        -PropertyNames @("replicationSnapshotInfo") `
        -MaxDepth 8

    return @($nodes | Where-Object { $_ })
}

function Get-ReplicationFromClusterId {
    param(
        $Object,
        $Snapshot
    )

    $nodes = @(Get-ReplicationSnapshotInfoNodes -Object $Object -Snapshot $Snapshot)

    foreach ($node in $nodes) {
        $cid = Get-FirstText -Value @(
            $node.clusterId,
            $node.clusterID,
            $node.sourceClusterId,
            $node.sourceClusterID
        )

        if (-not [string]::IsNullOrWhiteSpace($cid)) {
            return "$cid"
        }
    }

    return ""
}

function Test-ReplicationSnapshotInfoPresent {
    param(
        $Object,
        $Snapshot
    )

    $nodes = @(Get-ReplicationSnapshotInfoNodes -Object $Object -Snapshot $Snapshot)

    return ($nodes.Count -gt 0)
}

# ==========================================================
# Row collection
# ==========================================================
function Get-CiRowsFromCluster {
    param(
        [Parameter(Mandatory)] [string]$Ci,
        [Parameter(Mandatory)] $Cluster,
        [Parameter(Mandatory)] [string]$ApiKey,
        [Parameter(Mandatory)] [hashtable]$ClusterMap
    )

    $rows = @()

    $uri = "$BaseUrl/v2/data-protect/search/protected-objects?searchString=$([uri]::EscapeDataString($Ci))"

    $json = Invoke-HeliosJson -Uri $uri -Headers @{
        accept          = "application/json"
        apiKey          = $ApiKey
        accessClusterId = "$($Cluster.ClusterId)"
    }

    $objects = @(Get-ProtectedObjects -Json $json)

    if ($ShowDebug) {
        Write-Host "  Cluster: $($Cluster.ClusterName) | Objects returned: $($objects.Count)" -ForegroundColor DarkGray
    }

    if (-not $objects -or $objects.Count -eq 0) {
        return @()
    }

    $matched = @($objects | Where-Object {
        Object-MatchesCi -Object $_ -CiName $Ci
    })

    if ($matched -and $matched.Count -gt 0) {
        $objectsToCheck = $matched
    }
    else {
        $objectsToCheck = $objects
    }

    foreach ($obj in $objectsToCheck) {

        $snap = Get-BestSnapshot -Object $obj
        $usecs = Get-BestBackupUsecs -Object $obj -Snapshot $snap

        if ($usecs) {
            $lastBackupTime = Convert-UsecsToLocalTime -Usecs $usecs
        }
        elseif ($snap) {
            $lastBackupTime = "NoBackupTime"
        }
        else {
            $lastBackupTime = "NoBackup"
        }

        $backupType = Get-BackupType -Object $obj -Snapshot $snap
        $pgName     = Get-ProtectionGroupName -Object $obj -Snapshot $snap

        $replicationPresent = Test-ReplicationSnapshotInfoPresent -Object $obj -Snapshot $snap
        $replicationFromId  = Get-ReplicationFromClusterId -Object $obj -Snapshot $snap
        $replicationFromName = Get-ClusterNameFromId -ClusterId $replicationFromId -ClusterMap $ClusterMap

        $rows += [pscustomobject]@{
            ServerName                     = $Ci
            BackupType                     = $backupType
            ClusterName                    = "$($Cluster.ClusterName)"
            ClusterId                      = "$($Cluster.ClusterId)"
            ProtectionGroup                = $pgName
            LastBackupTime                 = $lastBackupTime
            LastBackupUsecs                = if ($usecs) { [int64]$usecs } else { 0 }
            ReplicationSnapshotInfoPresent = [bool]$replicationPresent
            ReplicationFromClusterId       = $replicationFromId
            ReplicationFromClusterName     = $replicationFromName
        }
    }

    return @($rows)
}

function Select-BestRowsPerBackupType {
    param($Rows)

    if (-not $Rows -or $Rows.Count -eq 0) {
        return @()
    }

    $selected = @()

    foreach ($g in ($Rows | Group-Object BackupType)) {

        $groupRows = @($g.Group)

        $validRows = @($groupRows | Where-Object {
            Is-ValidBackupRow -Row $_
        })

        if ($validRows.Count -gt 0) {
            $selected += (
                $validRows |
                Sort-Object `
                    @{ Expression = { if ($_.ReplicationSnapshotInfoPresent -eq $true) { 2 } else { 1 } } },
                    @{ Expression = { $_.LastBackupUsecs }; Descending = $true },
                    ClusterName,
                    ProtectionGroup |
                Select-Object -First 1
            )
        }
        else {
            $selected += (
                $groupRows |
                Sort-Object `
                    @{ Expression = { if ($_.ReplicationSnapshotInfoPresent -eq $true) { 2 } else { 1 } } },
                    ClusterName,
                    ProtectionGroup |
                Select-Object -First 1
            )
        }
    }

    return @($selected)
}

function Get-BackupTypeRank {
    param([string]$BackupType)

    switch ($BackupType) {
        "SQL"      { return 1 }
        "Oracle"   { return 2 }
        "FS"       { return 3 }
        "NAS"      { return 4 }
        "Hyper-V"  { return 5 }
        "Nutanix"  { return 6 }
        "VMware"   { return 7 }
        default    { return 9 }
    }
}

# ==========================================================
# CSV -> TXT
# ==========================================================
$CiNames = Import-Csv -Path $InputCsv |
ForEach-Object {
    "$($_.ci_item)".Trim().Trim('"').Trim("'")
} |
Where-Object {
    -not [string]::IsNullOrWhiteSpace($_)
} |
Sort-Object -Unique

if (-not $CiNames -or $CiNames.Count -eq 0) {
    throw "No CI names found in CSV: $InputCsv"
}

$CiNames | Set-Content -Path $InputTxt

$CiList = Get-Content -Path $InputTxt |
ForEach-Object {
    $_.Trim().Trim('"').Trim("'")
} |
Where-Object {
    -not [string]::IsNullOrWhiteSpace($_)
}

if (-not $CiList -or $CiList.Count -eq 0) {
    throw "No CI names found in TXT: $InputTxt"
}

# ==========================================================
# Get clusters
# ==========================================================
$clusterJson = Invoke-HeliosJson -Uri "$BaseUrl/v2/mcm/cluster-mgmt/info" -Headers @{
    accept = "application/json"
    apiKey = $ApiKey
}

if (-not $clusterJson -or -not $clusterJson.cohesityClusters -or $clusterJson.cohesityClusters.Count -eq 0) {
    throw "No clusters returned from Helios."
}

$Clusters = @()

foreach ($c in @($clusterJson.cohesityClusters)) {

    $name = Get-FirstText -Value @(
        $c.clusterName,
        $c.name,
        $c.displayName
    )

    $id = Get-FirstText -Value @(
        $c.clusterId,
        $c.id
    )

    if ([string]::IsNullOrWhiteSpace($id)) {
        continue
    }

    if ([string]::IsNullOrWhiteSpace($name)) {
        $name = "Unknown-$id"
    }

    $Clusters += [pscustomobject]@{
        ClusterId   = "$id"
        ClusterName = "$name"
        Raw         = $c
    }
}

$Clusters = $Clusters | Sort-Object ClusterName, ClusterId

$ClusterMap = @{}

foreach ($clu in $Clusters) {

    $raw = $clu.Raw

    $possibleIds = @(
        $clu.ClusterId,
        $raw.clusterId,
        $raw.id,
        $raw.clusterIdentifier.clusterId,
        $raw.clusterInfo.clusterId,
        $raw.intId
    )

    foreach ($id in $possibleIds) {
        $txt = Get-FirstText -Value $id

        if (-not [string]::IsNullOrWhiteSpace($txt)) {
            $ClusterMap["$txt"] = $clu
        }
    }
}

# ==========================================================
# Process CIs
# ==========================================================
$Results = @()

foreach ($ci0 in $CiList) {

    $Ci = "$ci0".Trim().Trim('"').Trim("'")

    if ([string]::IsNullOrWhiteSpace($Ci)) {
        continue
    }

    Write-Host ""
    Write-Host "Processing: [$Ci]" -ForegroundColor Cyan

    $ciAllRows = @()
    $searchedClusterIds = New-Object 'System.Collections.Generic.HashSet[string]'

    # ------------------------------------------------------
    # Step 1: Global search for candidate clusters
    # ------------------------------------------------------
    $GlobalSearchCalls++

    $globalUri = "$BaseUrl/v2/data-protect/search/objects?searchString=$([uri]::EscapeDataString($Ci))&includeTenants=true&count=$GlobalSearchCount"

    $globalJson = Invoke-HeliosJson -Uri $globalUri -Headers @{
        accept = "application/json"
        apiKey = $ApiKey
    }

    $globalObjects = @(Get-GlobalObjects -Json $globalJson)
    $candidateClusterIds = @(Get-CandidateClusterIdsFromGlobalSearch -Json $globalJson)

    $candidateClusters = @()

    foreach ($cid in $candidateClusterIds) {
        if ($ClusterMap.ContainsKey("$cid")) {
            $candidateClusters += $ClusterMap["$cid"]
        }
    }

    $candidateClusters = @(
        $candidateClusters |
        Sort-Object ClusterName, ClusterId |
        Group-Object ClusterId |
        ForEach-Object {
            $_.Group | Select-Object -First 1
        }
    )

    if (-not $candidateClusters -or $candidateClusters.Count -eq 0) {

        if ($FallbackToAllClustersWhenNoCandidate) {
            $FallbackCiCount++

            if ($ShowDebug) {
                Write-Host "  No usable candidate cluster from global search. Falling back to all clusters." -ForegroundColor DarkYellow
            }

            $candidateClusters = @($Clusters)
        }
    }

    # ------------------------------------------------------
    # Step 2: Search candidate clusters
    # ------------------------------------------------------
    foreach ($clu in $candidateClusters) {

        if ($searchedClusterIds.Contains("$($clu.ClusterId)")) {
            continue
        }

        [void]$searchedClusterIds.Add("$($clu.ClusterId)")
        $ProtectedSearchCalls++

        $rows = Get-CiRowsFromCluster `
            -Ci $Ci `
            -Cluster $clu `
            -ApiKey $ApiKey `
            -ClusterMap $ClusterMap

        if ($rows -and $rows.Count -gt 0) {
            $ciAllRows += $rows
        }
    }

    # ------------------------------------------------------
    # Step 3: If target-side rows point to source cluster,
    # search the source cluster also.
    # ------------------------------------------------------
    if ($EnableReplicationSourceCheck) {

        $sourceClusterIds = @(
            $ciAllRows |
            Where-Object {
                $_.ReplicationSnapshotInfoPresent -eq $true -and
                -not [string]::IsNullOrWhiteSpace($_.ReplicationFromClusterId)
            } |
            Select-Object -ExpandProperty ReplicationFromClusterId -Unique
        )

        foreach ($sourceCid in $sourceClusterIds) {

            if ([string]::IsNullOrWhiteSpace($sourceCid)) {
                continue
            }

            if ($searchedClusterIds.Contains("$sourceCid")) {
                continue
            }

            if (-not $ClusterMap.ContainsKey("$sourceCid")) {
                continue
            }

            $sourceCluster = $ClusterMap["$sourceCid"]

            Write-Host "  Replication source check: $($sourceCluster.ClusterName)" -ForegroundColor DarkYellow

            [void]$searchedClusterIds.Add("$($sourceCluster.ClusterId)")
            $ReplicationSourceCheckCount++
            $ProtectedSearchCalls++

            $sourceRows = Get-CiRowsFromCluster `
                -Ci $Ci `
                -Cluster $sourceCluster `
                -ApiKey $ApiKey `
                -ClusterMap $ClusterMap

            if ($sourceRows -and $sourceRows.Count -gt 0) {
                $ciAllRows += $sourceRows
            }
        }
    }

    # ------------------------------------------------------
    # Step 4: Always output something
    # ------------------------------------------------------
    if (-not $ciAllRows -or $ciAllRows.Count -eq 0) {

        $Results += [pscustomobject]@{
            ServerName      = $Ci
            BackupType      = "Unknown"
            ClusterName     = "-"
            ProtectionGroup = "-"
            LastBackupTime  = "NoObject"
        }

        continue
    }

    # ------------------------------------------------------
    # Step 5: Select best row per backup type
    # ------------------------------------------------------
    $selectedRows = @(Select-BestRowsPerBackupType -Rows $ciAllRows)

    $hasValidSQL = @($selectedRows | Where-Object {
        $_.BackupType -eq "SQL" -and (Is-ValidBackupRow -Row $_)
    }).Count -gt 0

    $hasValidOracle = @($selectedRows | Where-Object {
        $_.BackupType -eq "Oracle" -and (Is-ValidBackupRow -Row $_)
    }).Count -gt 0

    $hasValidFS = @($selectedRows | Where-Object {
        $_.BackupType -eq "FS" -and (Is-ValidBackupRow -Row $_)
    }).Count -gt 0

    $hasValidDB = $hasValidSQL -or $hasValidOracle

    if ($hasValidDB -and -not $hasValidFS) {
        $selectedRows = @($selectedRows | Where-Object { $_.BackupType -ne "FS" })
    }

    foreach ($row in $selectedRows) {
        $Results += [pscustomobject]@{
            ServerName      = $row.ServerName
            BackupType      = $row.BackupType
            ClusterName     = $row.ClusterName
            ProtectionGroup = $row.ProtectionGroup
            LastBackupTime  = $row.LastBackupTime
        }
    }

    if ($hasValidDB -and -not $hasValidFS) {
        $Results += [pscustomobject]@{
            ServerName      = $Ci
            BackupType      = "FS"
            ClusterName     = "-"
            ProtectionGroup = "-"
            LastBackupTime  = "NoFSBackupFound"
        }
    }
}

# ==========================================================
# Summary
# ==========================================================
$TotalInputCIs   = $CiList.Count
$TotalBackupRows = $Results.Count

$BackedUp = @($Results | Where-Object {
    $_.LastBackupTime -notin @("NoBackup", "NoBackupTime", "NoObject", "NoFSBackupFound", "")
}).Count

$NoBackup = @($Results | Where-Object {
    $_.LastBackupTime -in @("NoBackup", "NoBackupTime")
}).Count

$NoFSBackupFound = @($Results | Where-Object {
    $_.LastBackupTime -eq "NoFSBackupFound"
}).Count

$NoObject = @($Results | Where-Object {
    $_.LastBackupTime -eq "NoObject"
}).Count

$SortedResults = $Results |
    Sort-Object `
        ServerName,
        @{ Expression = { Get-BackupTypeRank -BackupType $_.BackupType } },
        ClusterName,
        ProtectionGroup

$DetailsText = (
    $SortedResults |
    Format-Table ServerName, BackupType, ClusterName, ProtectionGroup, LastBackupTime -AutoSize |
    Out-String -Width 300
).TrimEnd()

# ==========================================================
# Build report
# ==========================================================
$Report = @()
$Report += "=========================================================="
$Report += "Cohesity Backup Validation Report"
$Report += "=========================================================="
$Report += "Change Number                    : $ChangeID"
$Report += "Executed By                      : $ExecutedBy"
$Report += "Run Date                         : $(Get-Date -Format 'dd-MMM-yyyy HH:mm:ss')"
$Report += ""
$Report += "Total Input CIs                  : $TotalInputCIs"
$Report += "Total Backup Rows                : $TotalBackupRows"
$Report += "Backed Up                        : $BackedUp"
$Report += "No Backup                        : $NoBackup"
$Report += "No FS Backup Found               : $NoFSBackupFound"
$Report += "No Object                        : $NoObject"
$Report += ""
$Report += "Global Search Calls              : $GlobalSearchCalls"
$Report += "Protected Search Calls           : $ProtectedSearchCalls"
$Report += "Fallback CI Count                : $FallbackCiCount"
$Report += "Replication Source Check Count   : $ReplicationSourceCheckCount"
$Report += ""
$Report += "----------------------------------------------------------"
$Report += "Details"
$Report += "----------------------------------------------------------"
$Report += ""
$Report += $DetailsText
$Report += ""
$Report += "----------------------------------------------------------"
$Report += "Summary Notes"
$Report += "----------------------------------------------------------"
$Report += "- Backed Up                     : CI found with valid snapshot and backup time"
$Report += "- No Backup                     : CI found in Cohesity but no usable snapshot time returned"
$Report += "- No Object                     : CI not found in Cohesity protected-object search"
$Report += "- NoFSBackupFound               : SQL/Oracle backup found, but no matching FS backup found for the CI"
$Report += "- BackupType                    : SQL / Oracle / FS / NAS / Hyper-V / Nutanix / VMware / Unknown"
$Report += "- Replication Rule              : replicationSnapshotInfo present = target-side replicated row"
$Report += "- Replication Source Rule       : replicationSnapshotInfo.clusterId = source/original clusterId"
$Report += "- Selection Rule                : Source/non-replicated row preferred over replicated target row"
$Report += "- Endpoint Rule                 : Only cluster list, global search, and protected-object search are used"
$Report += ""
$Report += "----------------------------------------------------------"
$Report += "Report Location"
$Report += "----------------------------------------------------------"
$Report += $OutputTxt
$Report += "=========================================================="

$Report | Set-Content -Path $OutputTxt

# ==========================================================
# Display
# ==========================================================
Write-Host ""
Write-Host "=========================================================="
Write-Host "Cohesity Backup Validation Report"
Write-Host "=========================================================="
Write-Host "Change Number                    : $ChangeID"
Write-Host "Executed By                      : $ExecutedBy"
Write-Host "Run Date                         : $(Get-Date -Format 'dd-MMM-yyyy HH:mm:ss')"
Write-Host ""
Write-Host "Total Input CIs                  : $TotalInputCIs"
Write-Host "Total Backup Rows                : $TotalBackupRows"
Write-Host "Backed Up                        : $BackedUp"
Write-Host "No Backup                        : $NoBackup"
Write-Host "No FS Backup Found               : $NoFSBackupFound"
Write-Host "No Object                        : $NoObject"
Write-Host ""
Write-Host "Global Search Calls              : $GlobalSearchCalls"
Write-Host "Protected Search Calls           : $ProtectedSearchCalls"
Write-Host "Fallback CI Count                : $FallbackCiCount"
Write-Host "Replication Source Check Count   : $ReplicationSourceCheckCount"
Write-Host ""
Write-Host "----------------------------------------------------------"
Write-Host "Details"
Write-Host "----------------------------------------------------------"
Write-Host ""
Write-Host $DetailsText
Write-Host ""
Write-Host "----------------------------------------------------------"
