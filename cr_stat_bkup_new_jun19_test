# ==========================================================
# Cohesity Backup Validation Report
# GET ONLY | DTSK-STYLE CLUSTER SELECTION
#
# Endpoints:
# 1) GET /v2/mcm/cluster-mgmt/info
# 2) GET /v2/data-protect/search/objects?searchString=<CI>&includeTenants=true&count=1
# 3) GET /v2/data-protect/search/protected-objects?searchString=<CI>
#
# Final Output:
# ServerName | BackupType | ClusterName | ProtectionGroup | LastBackupTime
#
# Important:
# - Selected cluster is internal only.
# - Final ClusterName comes from /v2/mcm/cluster-mgmt/info.
# - No replication/origin/failover logic.
# - No all-cluster scan.
# ==========================================================

$ErrorActionPreference = "Stop"
$FormatEnumerationLimit = -1
[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12

# -------------------------
# Input
# -------------------------
$ChangeID   = Read-Host "Enter Change Number"
$ExecutedBy = (whoami).Trim()

# -------------------------
# Paths
# -------------------------
$BaseDir   = "X:\PowerShell\Data\Cohesity\BackupValidation"
$InputCsv  = Join-Path $BaseDir "$ChangeID.csv"
$InputTxt  = Join-Path $BaseDir "$ChangeID.txt"
$TimeStamp = Get-Date -Format "yyyyMMdd_HHmm"
$OutputTxt = Join-Path $BaseDir "${ChangeID}_BackupReport_$TimeStamp.txt"

if (-not (Test-Path $InputCsv)) {
    throw "CSV not found: $InputCsv"
}

# -------------------------
# API
# -------------------------
$BaseUrl    = "https://helios.cohesity.com"
$ApiKeyPath = "X:\PowerShell\Cohesity_API_Scripts\DO_NOT_Delete\apikey.txt"

if (-not (Test-Path $ApiKeyPath)) {
    throw "API key file not found: $ApiKeyPath"
}

$ApiKey = (Get-Content -Path $ApiKeyPath -Raw).Trim()

# -------------------------
# Counters
# -------------------------
$GlobalSearchCalls    = 0
$ProtectedSearchCalls = 0

# ==========================================================
# Basic Helpers
# ==========================================================
function Invoke-HeliosGetJson {
    param(
        [Parameter(Mandatory = $true)][string]$Uri,
        [Parameter(Mandatory = $true)][hashtable]$Headers,
        [int]$TimeoutSec = 60
    )

    try {
        $resp = Invoke-WebRequest `
            -UseBasicParsing `
            -Method Get `
            -Uri $Uri `
            -Headers $Headers `
            -TimeoutSec $TimeoutSec `
            -ErrorAction Stop

        if ([string]::IsNullOrWhiteSpace($resp.Content)) {
            return $null
        }

        return ($resp.Content | ConvertFrom-Json)
    }
    catch {
        Write-Host "GET failed:" -ForegroundColor DarkRed
        Write-Host $Uri -ForegroundColor DarkRed
        Write-Host $_.Exception.Message -ForegroundColor DarkRed
        return $null
    }
}

function As-Array {
    param($Value)

    if ($null -eq $Value) {
        return @()
    }

    if ($Value -is [array]) {
        return @($Value)
    }

    return @($Value)
}

function First-Item {
    param($Value)

    $arr = @(As-Array -Value $Value)

    if ($arr.Count -eq 0) {
        return $null
    }

    return $arr[0]
}

function Has-Prop {
    param(
        $Object,
        [string]$Name
    )

    if ($null -eq $Object) {
        return $false
    }

    try {
        return ($Object.PSObject.Properties.Name -contains $Name)
    }
    catch {
        return $false
    }
}

function First-NonBlank {
    param($Values)

    foreach ($v in (As-Array -Value $Values)) {
        if ($null -eq $v) {
            continue
        }

        if ($v -is [array]) {
            foreach ($x in $v) {
                $t = First-NonBlank -Values $x
                if (-not [string]::IsNullOrWhiteSpace($t)) {
                    return $t
                }
            }

            continue
        }

        if ($v -is [pscustomobject]) {
            foreach ($p in @(
                "display_value",
                "displayName",
                "name",
                "value",
                "id",
                "clusterId",
                "clusterID",
                "sourceClusterId",
                "sourceClusterID",
                "accessClusterId",
                "intId"
            )) {
                if ($v.PSObject.Properties.Name -contains $p) {
                    $t = First-NonBlank -Values $v.$p
                    if (-not [string]::IsNullOrWhiteSpace($t)) {
                        return $t
                    }
                }
            }

            continue
        }

        $txt = "$v".Trim()

        if (-not [string]::IsNullOrWhiteSpace($txt)) {
            return $txt
        }
    }

    return ""
}

function Get-Usecs {
    param($Value)

    $values = @()

    foreach ($v in (As-Array -Value $Value)) {
        try {
            if ($null -ne $v -and "$v".Trim() -ne "") {
                $values += [int64]$v
            }
        }
        catch {}
    }

    if ($values.Count -eq 0) {
        return 0
    }

    return ($values | Sort-Object -Descending | Select-Object -First 1)
}

function Convert-UsecsToLocal {
    param($Usecs)

    if (-not $Usecs -or [int64]$Usecs -le 0) {
        return ""
    }

    try {
        return [DateTimeOffset]::FromUnixTimeMilliseconds([int64]($Usecs / 1000)).LocalDateTime.ToString("dd-MMM-yyyy HH:mm:ss")
    }
    catch {
        return ""
    }
}

function Is-ValidBackupRow {
    param($Row)

    if (-not $Row) {
        return $false
    }

    return $Row.LastBackupTime -notin @(
        "",
        $null,
        "NoBackup",
        "NoBackupTime",
        "NoObject",
        "NoFSBackupFound",
        "SearchFailed",
        "ClusterIdMissing"
    )
}

# ==========================================================
# Cluster Map
# ==========================================================
function Add-ClusterMapEntry {
    param(
        [Parameter(Mandatory = $true)][hashtable]$Map,
        $Id,
        $ClusterObject
    )

    $txt = First-NonBlank -Values @($Id)

    if (-not [string]::IsNullOrWhiteSpace($txt)) {
        $Map["$txt"] = $ClusterObject
    }
}

function Get-ClusterNameFromMap {
    param(
        [string]$ClusterId,
        [hashtable]$ClusterMap
    )

    if ([string]::IsNullOrWhiteSpace($ClusterId)) {
        return "-"
    }

    if ($ClusterMap.ContainsKey("$ClusterId")) {
        return "$($ClusterMap["$ClusterId"].ClusterName)"
    }

    return "$ClusterId"
}

# ==========================================================
# Global Search - DTSK Style
# ==========================================================
function Get-FirstGlobalSearchDetail {
    param($Json)

    if ($null -eq $Json) {
        return [pscustomobject]@{
            Object          = $null
            ProtectionInfo  = $null
            ProtectionGroup = $null
        }
    }

    $Object = $null

    if (Has-Prop -Object $Json -Name "objects") {
        $Object = First-Item -Value $Json.objects
    }

    if (-not $Object) {
        return [pscustomobject]@{
            Object          = $null
            ProtectionInfo  = $null
            ProtectionGroup = $null
        }
    }

    $ProtectionInfo = First-Item -Value $Object.objectProtectionInfos

    if (-not $ProtectionInfo) {
        return [pscustomobject]@{
            Object          = $Object
            ProtectionInfo  = $null
            ProtectionGroup = $null
        }
    }

    $ProtectionGroup = First-Item -Value $ProtectionInfo.protectionGroups

    return [pscustomobject]@{
        Object          = $Object
        ProtectionInfo  = $ProtectionInfo
        ProtectionGroup = $ProtectionGroup
    }
}

function Get-ClusterIdFromGlobalSearch {
    param(
        $Object,
        $ProtectionInfo,
        $ProtectionGroup
    )

    # This order matches the working DTSK logic.
    return First-NonBlank -Values @(
        # 1. objectProtectionInfos[0] first
        $ProtectionInfo.clusterId,
        $ProtectionInfo.clusterID,
        $ProtectionInfo.cluster.id,
        $ProtectionInfo.cluster.clusterId,
        $ProtectionInfo.cluster.clusterID,
        $ProtectionInfo.clusterInfo.id,
        $ProtectionInfo.clusterInfo.clusterId,
        $ProtectionInfo.clusterInfo.clusterID,

        # 2. objectProtectionInfos[0].protectionGroups[0] second
        $ProtectionGroup.clusterId,
        $ProtectionGroup.clusterID,
        $ProtectionGroup.cluster.id,
        $ProtectionGroup.cluster.clusterId,
        $ProtectionGroup.cluster.clusterID,
        $ProtectionGroup.clusterInfo.id,
        $ProtectionGroup.clusterInfo.clusterId,
        $ProtectionGroup.clusterInfo.clusterID,

        # 3. object-level fallback
        $Object.clusterId,
        $Object.clusterID,
        $Object.cluster.id,
        $Object.cluster.clusterId,
        $Object.cluster.clusterID,
        $Object.clusterInfo.id,
        $Object.clusterInfo.clusterId,
        $Object.clusterInfo.clusterID,
        $Object.sourceClusterId
    )
}

function Get-PGNameFromGlobalSearch {
    param($ProtectionGroup)

    $pg = First-NonBlank -Values @(
        $ProtectionGroup.name,
        $ProtectionGroup.protectionGroupName,
        $ProtectionGroup.policyName
    )

    if ([string]::IsNullOrWhiteSpace($pg)) {
        return "N/A"
    }

    return $pg
}

# ==========================================================
# Protected Object Parsing
# ==========================================================
function Get-ProtectedObjectArray {
    param($Json)

    if ($null -eq $Json) {
        return @()
    }

    if ($Json -is [array]) {
        return @($Json)
    }

    foreach ($p in @(
        "objects",
        "protectedObjects",
        "protectedObjectResults",
        "searchResults",
        "results",
        "entities",
        "items",
        "data"
    )) {
        if ($Json.PSObject.Properties.Name -contains $p) {
            return @(As-Array -Value $Json.$p | Where-Object { $_ })
        }
    }

    if (
        (Has-Prop -Object $Json -Name "latestSnapshotInfo") -or
        (Has-Prop -Object $Json -Name "latestSnapshotsInfo") -or
        (Has-Prop -Object $Json -Name "snapshotInfo") -or
        (Has-Prop -Object $Json -Name "backupInfo") -or
        (Has-Prop -Object $Json -Name "protectionGroupName") -or
        (Has-Prop -Object $Json -Name "environment") -or
        (Has-Prop -Object $Json -Name "objectType") -or
        (Has-Prop -Object $Json -Name "name") -or
        (Has-Prop -Object $Json -Name "displayName")
    ) {
        return @($Json)
    }

    return @()
}

function Get-Snapshots {
    param($Object)

    $snaps = @()

    $snaps += @(As-Array -Value $Object.latestSnapshotInfo)
    $snaps += @(As-Array -Value $Object.latestSnapshotsInfo)
    $snaps += @(As-Array -Value $Object.latestSnapshot)
    $snaps += @(As-Array -Value $Object.latestSnapshots)
    $snaps += @(As-Array -Value $Object.snapshotInfo)
    $snaps += @(As-Array -Value $Object.backupInfo)

    return @($snaps | Where-Object { $_ })
}

function Get-SnapshotTimeUsecs {
    param($Snapshot)

    if ($null -eq $Snapshot) {
        return 0
    }

    foreach ($f in @(
        "protectionRunStartTimeUsecs",
        "protectionRunEndTimeUsecs",
        "runStartTimeUsecs",
        "runEndTimeUsecs",
        "snapshotCreationTimeUsecs",
        "creationTimeUsecs",
        "startTimeUsecs",
        "endTimeUsecs"
    )) {
        if (Has-Prop -Object $Snapshot -Name $f) {
            $u = Get-Usecs -Value $Snapshot.$f
            if ($u -gt 0) {
                return $u
            }
        }
    }

    if (Has-Prop -Object $Snapshot -Name "localBackupInfo") {
        foreach ($lbi in (As-Array -Value $Snapshot.localBackupInfo)) {
            $u = Get-Usecs -Value $lbi.endTimeUsecs
            if ($u -gt 0) { return $u }

            $u = Get-Usecs -Value $lbi.startTimeUsecs
            if ($u -gt 0) { return $u }
        }
    }

    return 0
}

function Get-BestSnapshot {
    param($Object)

    $snaps = @(Get-Snapshots -Object $Object)

    if (-not $snaps -or $snaps.Count -eq 0) {
        return $null
    }

    return $snaps |
        Sort-Object @{ Expression = { [int64](Get-SnapshotTimeUsecs -Snapshot $_) } } -Descending |
        Select-Object -First 1
}

function Get-BackupType {
    param(
        $Object,
        $Snapshot,
        [string]$FallbackPGName
    )

    $textParts = @()

    $textParts += First-NonBlank -Values @($Object.environment)
    $textParts += First-NonBlank -Values @($Object.object.environment)
    $textParts += First-NonBlank -Values @($Object.objectType)
    $textParts += First-NonBlank -Values @($Object.type)
    $textParts += First-NonBlank -Values @($Object.protectionType)
    $textParts += First-NonBlank -Values @($Object.sourceInfo.environment)
    $textParts += First-NonBlank -Values @($Object.sourceInfo.type)
    $textParts += First-NonBlank -Values @($Object.protectionSource.environment)
    $textParts += First-NonBlank -Values @($Object.protectionSource.type)
    $textParts += First-NonBlank -Values @($Object.entity.environment)
    $textParts += First-NonBlank -Values @($Object.entity.type)
    $textParts += First-NonBlank -Values @($Object.name)
    $textParts += First-NonBlank -Values @($Object.displayName)
    $textParts += First-NonBlank -Values @($Object.object.name)
    $textParts += First-NonBlank -Values @($Object.object.displayName)
    $textParts += First-NonBlank -Values @($Snapshot.environment)
    $textParts += First-NonBlank -Values @($Snapshot.objectType)
    $textParts += First-NonBlank -Values @($Snapshot.sourceInfo.environment)
    $textParts += First-NonBlank -Values @($Snapshot.sourceInfo.type)
    $textParts += $FallbackPGName

    $text = (($textParts | Where-Object { -not [string]::IsNullOrWhiteSpace($_) }) -join " ").ToLower()

    if ($text -match "ksql|mssql|sqlserver|sql server|\bsql\b") {
        return "SQL"
    }

    if ($text -match "koracle|\boracle\b") {
        return "Oracle"
    }

    if ($text -match "kgenericnas|kisilon|nas|isilon|smb|cifs|nfs") {
        return "NAS"
    }

    if ($text -match "khyperv|hyperv|hyper-v") {
        return "Hyper-V"
    }

    if ($text -match "kacropolis|nutanix|ahv|acropolis") {
        return "Nutanix"
    }

    if ($text -match "kvmware|vmware|vc-") {
        return "VMware"
    }

    if ($text -match "kphysical|physical|filesystem|file_system|file system|volume|windows|linux|fs") {
        return "FS"
    }

    return "Unknown"
}

function Get-PGName {
    param(
        $Object,
        $Snapshot,
        [string]$FallbackPGName
    )

    $pg = First-NonBlank -Values @(
        $Snapshot.protectionGroupName,
        $Snapshot.protectionGroup.name,
        $Snapshot.protectionGroup.displayName,
        $Snapshot.protectionGroupInfo.name,
        $Snapshot.protectionGroupInfo.displayName,

        $Object.protectionGroupName,
        $Object.protectionGroup.name,
        $Object.protectionGroup.displayName,
        $Object.protectionGroupInfo.name,
        $Object.protectionGroupInfo.displayName,

        $Object.objectProtectionInfos.protectionGroups.name,
        $Object.objectProtectionInfos.protectionGroups.protectionGroupName
    )

    if (-not [string]::IsNullOrWhiteSpace($pg)) {
        return $pg
    }

    if (-not [string]::IsNullOrWhiteSpace($FallbackPGName)) {
        return $FallbackPGName
    }

    return "N/A"
}

function Get-ObjectNames {
    param($Object)

    $names = @()

    foreach ($v in @(
        $Object.name,
        $Object.objectName,
        $Object.hostName,
        $Object.displayName,
        $Object.sourceName,
        $Object.entity.name,
        $Object.entity.displayName,
        $Object.object.name,
        $Object.object.displayName,
        $Object.sourceInfo.name,
        $Object.sourceInfo.displayName,
        $Object.protectionSource.name,
        $Object.protectionSource.displayName
    )) {
        $t = First-NonBlank -Values @($v)

        if (-not [string]::IsNullOrWhiteSpace($t)) {
            $names += $t.ToLower()
        }
    }

    return @($names | Sort-Object -Unique)
}

function Object-MatchesCI {
    param(
        $Object,
        [string]$CI
    )

    $ciLower = $CI.ToLower().Trim()
    $names = @(Get-ObjectNames -Object $Object)

    if (-not $names -or $names.Count -eq 0) {
        return $true
    }

    foreach ($n in $names) {
        if ($n -eq $ciLower) { return $true }
        if ($n -like "*$ciLower*") { return $true }
        if ($ciLower -like "*$n*") { return $true }
    }

    return $false
}

function Get-BackupTypeRank {
    param([string]$BackupType)

    switch ($BackupType) {
        "SQL"      { return 1 }
        "Oracle"   { return 2 }
        "FS"       { return 3 }
        "NAS"      { return 4 }
        "Hyper-V"  { return 5 }
        "Nutanix"  { return 6 }
        "VMware"   { return 7 }
        default    { return 9 }
    }
}

function Select-BestRows {
    param($Rows)

    $selected = @()

    foreach ($g in ($Rows | Group-Object BackupType)) {

        $groupRows = @($g.Group)

        $valid = @($groupRows | Where-Object {
            Is-ValidBackupRow -Row $_
        })

        if ($valid.Count -gt 0) {
            $selected += (
                $valid |
                Sort-Object `
                    @{ Expression = { $_.LastBackupUsecs }; Descending = $true },
                    ClusterName,
                    ProtectionGroup |
                Select-Object -First 1
            )
        }
        else {
            $selected += (
                $groupRows |
                Sort-Object ClusterName, ProtectionGroup |
                Select-Object -First 1
            )
        }
    }

    return @($selected)
}

# ==========================================================
# Read CI List
# ==========================================================
$CiNames = Import-Csv -Path $InputCsv |
ForEach-Object {
    "$($_.ci_item)".Trim().Trim('"').Trim("'")
} |
Where-Object {
    -not [string]::IsNullOrWhiteSpace($_)
} |
Sort-Object -Unique

if (-not $CiNames -or $CiNames.Count -eq 0) {
    throw "No CI names found in CSV: $InputCsv"
}

$CiNames | Set-Content -Path $InputTxt

$CiList = Get-Content -Path $InputTxt |
ForEach-Object {
    $_.Trim().Trim('"').Trim("'")
} |
Where-Object {
    -not [string]::IsNullOrWhiteSpace($_)
}

if (-not $CiList -or $CiList.Count -eq 0) {
    throw "No CI names found in TXT: $InputTxt"
}

# ==========================================================
# Get Trusted Cluster Names
# ==========================================================
$ClusterJson = Invoke-HeliosGetJson `
    -Uri "$BaseUrl/v2/mcm/cluster-mgmt/info" `
    -Headers @{
        accept = "application/json"
        apiKey = $ApiKey
    }

if (-not $ClusterJson -or -not $ClusterJson.cohesityClusters) {
    throw "No clusters returned from Helios."
}

$ClusterMap = @{}

foreach ($c in @($ClusterJson.cohesityClusters)) {

    $cid = First-NonBlank -Values @($c.clusterId, $c.id)
    $cn  = First-NonBlank -Values @($c.clusterName, $c.name, $c.displayName)

    if ([string]::IsNullOrWhiteSpace($cid)) {
        continue
    }

    if ([string]::IsNullOrWhiteSpace($cn)) {
        $cn = "Unknown-$cid"
    }

    $clusterObj = [pscustomobject]@{
        ClusterId   = "$cid"
        ClusterName = "$cn"
    }

    Add-ClusterMapEntry -Map $ClusterMap -Id $c.clusterId -ClusterObject $clusterObj
    Add-ClusterMapEntry -Map $ClusterMap -Id $c.id -ClusterObject $clusterObj
    Add-ClusterMapEntry -Map $ClusterMap -Id $c.intId -ClusterObject $clusterObj
    Add-ClusterMapEntry -Map $ClusterMap -Id $c.clusterIdentifier.clusterId -ClusterObject $clusterObj
    Add-ClusterMapEntry -Map $ClusterMap -Id $c.clusterInfo.clusterId -ClusterObject $clusterObj
}

# ==========================================================
# Main Processing
# ==========================================================
$Results = @()

foreach ($CI in $CiList) {

    Write-Host ""
    Write-Host "Processing: [$CI]" -ForegroundColor Cyan

    $RowsForCi = @()

    # ------------------------------------------------------
    # Step 1: Global search with count=1
    # ------------------------------------------------------
    $GlobalSearchCalls++

    $GlobalUri =
        "$BaseUrl/v2/data-protect/search/objects" +
        "?searchString=$([uri]::EscapeDataString($CI))" +
        "&includeTenants=true" +
        "&count=1"

    $GlobalJson = Invoke-HeliosGetJson `
        -Uri $GlobalUri `
        -Headers @{
            accept = "application/json"
            apiKey = $ApiKey
        }

    $GlobalDetail = Get-FirstGlobalSearchDetail -Json $GlobalJson

    if (-not $GlobalDetail.Object) {
        $Results += [pscustomobject]@{
            ServerName      = $CI
            BackupType      = "Unknown"
            ClusterName     = "-"
            ProtectionGroup = "N/A"
            LastBackupTime  = "NoObject"
        }

        continue
    }

    $SelectedClusterId = Get-ClusterIdFromGlobalSearch `
        -Object $GlobalDetail.Object `
        -ProtectionInfo $GlobalDetail.ProtectionInfo `
        -ProtectionGroup $GlobalDetail.ProtectionGroup

    $FallbackPGName = Get-PGNameFromGlobalSearch -ProtectionGroup $GlobalDetail.ProtectionGroup

    if ([string]::IsNullOrWhiteSpace($SelectedClusterId)) {
        $Results += [pscustomobject]@{
            ServerName      = $CI
            BackupType      = "Unknown"
            ClusterName     = "-"
            ProtectionGroup = $FallbackPGName
            LastBackupTime  = "ClusterIdMissing"
        }

        continue
    }

    $SelectedClusterName = Get-ClusterNameFromMap `
        -ClusterId "$SelectedClusterId" `
        -ClusterMap $ClusterMap

    # ------------------------------------------------------
    # Step 2: Protected-object search on selected cluster only
    # ------------------------------------------------------
    $ProtectedSearchCalls++

    $ProtectedUri =
        "$BaseUrl/v2/data-protect/search/protected-objects" +
        "?searchString=$([uri]::EscapeDataString($CI))"

    $ProtectedJson = Invoke-HeliosGetJson `
        -Uri $ProtectedUri `
        -Headers @{
            accept          = "application/json"
            apiKey          = $ApiKey
            accessClusterId = "$SelectedClusterId"
        }

    $ProtectedObjects = @(Get-ProtectedObjectArray -Json $ProtectedJson)

    if (-not $ProtectedObjects -or $ProtectedObjects.Count -eq 0) {
        $Results += [pscustomobject]@{
            ServerName      = $CI
            BackupType      = "Unknown"
            ClusterName     = $SelectedClusterName
            ProtectionGroup = $FallbackPGName
            LastBackupTime  = "NoBackup"
        }

        continue
    }

    $MatchingObjects = @($ProtectedObjects | Where-Object {
        Object-MatchesCI -Object $_ -CI $CI
    })

    if ($MatchingObjects.Count -gt 0) {
        $ObjectsToCheck = $MatchingObjects
    }
    else {
        # Same as DTSK behavior: if protected-objects returned something, use it.
        $ObjectsToCheck = $ProtectedObjects
    }

    foreach ($Obj in $ObjectsToCheck) {

        $Snapshot = Get-BestSnapshot -Object $Obj

        if ($Snapshot) {
            $BackupUsecs = Get-SnapshotTimeUsecs -Snapshot $Snapshot
        }
        else {
            $BackupUsecs = 0
        }

        if ($BackupUsecs -gt 0) {
            $LastBackupTime = Convert-UsecsToLocal -Usecs $BackupUsecs
        }
        elseif ($Snapshot) {
            $LastBackupTime = "NoBackupTime"
        }
        else {
            $LastBackupTime = "NoBackup"
        }

        $BackupType = Get-BackupType `
            -Object $Obj `
            -Snapshot $Snapshot `
            -FallbackPGName $FallbackPGName

        $PGName = Get-PGName `
            -Object $Obj `
            -Snapshot $Snapshot `
            -FallbackPGName $FallbackPGName

        $RowsForCi += [pscustomobject]@{
            ServerName      = $CI
            BackupType      = $BackupType
            ClusterName     = $SelectedClusterName
            ProtectionGroup = $PGName
            LastBackupTime  = $LastBackupTime
            LastBackupUsecs = $BackupUsecs
        }
    }

    if (-not $RowsForCi -or $RowsForCi.Count -eq 0) {
        $Results += [pscustomobject]@{
            ServerName      = $CI
            BackupType      = "Unknown"
            ClusterName     = $SelectedClusterName
            ProtectionGroup = $FallbackPGName
            LastBackupTime  = "NoBackup"
        }

        continue
    }

    $SelectedRows = @(Select-BestRows -Rows $RowsForCi)

    # ------------------------------------------------------
    # Step 3: DB requires FS validation
    # ------------------------------------------------------
    $HasValidSQL = @($SelectedRows | Where-Object {
        $_.BackupType -eq "SQL" -and (Is-ValidBackupRow -Row $_)
    }).Count -gt 0

    $HasValidOracle = @($SelectedRows | Where-Object {
        $_.BackupType -eq "Oracle" -and (Is-ValidBackupRow -Row $_)
    }).Count -gt 0

    $HasValidFS = @($SelectedRows | Where-Object {
        $_.BackupType -eq "FS" -and (Is-ValidBackupRow -Row $_)
    }).Count -gt 0

    $HasValidDB = $HasValidSQL -or $HasValidOracle

    if ($HasValidDB -and -not $HasValidFS) {
        $SelectedRows = @($SelectedRows | Where-Object { $_.BackupType -ne "FS" })
    }

    foreach ($Row in $SelectedRows) {
        $Results += [pscustomobject]@{
            ServerName      = $Row.ServerName
            BackupType      = $Row.BackupType
            ClusterName     = $Row.ClusterName
            ProtectionGroup = $Row.ProtectionGroup
            LastBackupTime  = $Row.LastBackupTime
        }
    }

    if ($HasValidDB -and -not $HasValidFS) {
        $Results += [pscustomobject]@{
            ServerName      = $CI
            BackupType      = "FS"
            ClusterName     = $SelectedClusterName
            ProtectionGroup = "N/A"
            LastBackupTime  = "NoFSBackupFound"
        }
    }
}

# ==========================================================
# Summary
# ==========================================================
$SortedResults = $Results |
    Sort-Object `
        ServerName,
        @{ Expression = { Get-BackupTypeRank -BackupType $_.BackupType } },
        ClusterName,
        ProtectionGroup

$TotalInputCIs = $CiList.Count
$TotalRows     = $SortedResults.Count

$BackedUp = @($SortedResults | Where-Object {
    $_.LastBackupTime -notin @(
        "",
        "NoBackup",
        "NoBackupTime",
        "NoObject",
        "NoFSBackupFound",
        "ClusterIdMissing",
        "SearchFailed"
    )
}).Count

$NoBackup = @($SortedResults | Where-Object {
    $_.LastBackupTime -in @("NoBackup", "NoBackupTime")
}).Count

$NoFSBackupFound = @($SortedResults | Where-Object {
    $_.LastBackupTime -eq "NoFSBackupFound"
}).Count

$NoObject = @($SortedResults | Where-Object {
    $_.LastBackupTime -eq "NoObject"
}).Count

$ClusterIdMissing = @($SortedResults | Where-Object {
    $_.LastBackupTime -eq "ClusterIdMissing"
}).Count

$DetailsText = (
    $SortedResults |
    Format-Table ServerName, BackupType, ClusterName, ProtectionGroup, LastBackupTime -AutoSize |
    Out-String -Width 300
).TrimEnd()

# ==========================================================
# Report
# ==========================================================
$Report = @()
$Report += "=========================================================="
$Report += "Cohesity Backup Validation Report"
$Report += "=========================================================="
$Report += "Change Number              : $ChangeID"
$Report += "Executed By                : $ExecutedBy"
$Report += "Run Date                   : $(Get-Date -Format 'dd-MMM-yyyy HH:mm:ss')"
$Report += ""
$Report += "Total Input CIs            : $TotalInputCIs"
$Report += "Total Backup Rows          : $TotalRows"
$Report += "Backed Up                  : $BackedUp"
$Report += "No Backup                  : $NoBackup"
$Report += "No FS Backup Found         : $NoFSBackupFound"
$Report += "No Object                  : $NoObject"
$Report += "Cluster ID Missing         : $ClusterIdMissing"
$Report += ""
$Report += "Global Search Calls        : $GlobalSearchCalls"
$Report += "Protected Search Calls     : $ProtectedSearchCalls"
$Report += ""
$Report += "----------------------------------------------------------"
$Report += "Details"
$Report += "----------------------------------------------------------"
$Report += ""
$Report += $DetailsText
$Report += ""
$Report += "----------------------------------------------------------"
$Report += "Notes"
$Report += "----------------------------------------------------------"
$Report += "- Global search uses count=1, same as DTSK."
$Report += "- Cluster selection order follows DTSK: objectProtectionInfos first, protectionGroups second, object fallback last."
$Report += "- Final ClusterName is resolved from /v2/mcm/cluster-mgmt/info."
$Report += "- Protected-object endpoint is used for BackupType, ProtectionGroup, and LastBackupTime."
$Report += "- SQL/Oracle backup rows require an FS row. If FS is missing, NoFSBackupFound is added."
$Report += ""
$Report += "----------------------------------------------------------"
$Report += "Report Location"
$Report += "----------------------------------------------------------"
$Report += $OutputTxt
$Report += "=========================================================="

$Report | Set-Content -Path $OutputTxt

Write-Host ""
Write-Host ($Report -join "`n")
