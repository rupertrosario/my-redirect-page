# ==========================================================
# Cohesity Backup Validation Report
# GET ONLY | DTSK-STYLE SELECTED CLUSTER LOGIC
#
# Endpoints used:
# 1) GET /v2/mcm/cluster-mgmt/info
# 2) GET /v2/data-protect/search/objects?searchString=<CI>&includeTenants=true&count=1
# 3) GET /v2/data-protect/search/protected-objects?searchString=<CI>
#
# Output:
# ServerName | BackupType | ClusterName | ProtectionGroup | LastBackupTime
#
# Logic:
# - Global search is used only to select the correct cluster internally.
# - Final ClusterName always comes from /v2/mcm/cluster-mgmt/info.
# - Protected-object endpoint gives BackupType, PG name, and latest backup time.
# - If SQL/Oracle exists but FS does not, add FS = NoFSBackupFound.
# ==========================================================

$ErrorActionPreference = "Stop"
$FormatEnumerationLimit = -1

# -------------------------
# Input
# -------------------------
$ChangeID   = Read-Host "Enter Change Number"
$ExecutedBy = (whoami).Trim()

# -------------------------
# Paths
# -------------------------
$BaseDir   = "X:\PowerShell\Data\Cohesity\BackupValidation"
$InputCsv  = Join-Path $BaseDir "$ChangeID.csv"
$InputTxt  = Join-Path $BaseDir "$ChangeID.txt"
$TimeStamp = Get-Date -Format "yyyyMMdd_HHmm"
$OutputTxt = Join-Path $BaseDir "${ChangeID}_BackupReport_$TimeStamp.txt"

if (-not (Test-Path $InputCsv)) {
    throw "CSV not found: $InputCsv"
}

# -------------------------
# API
# -------------------------
$BaseUrl    = "https://helios.cohesity.com"
$ApiKeyPath = "X:\PowerShell\Cohesity_API_Scripts\DO_NOT_Delete\apikey.txt"

if (-not (Test-Path $ApiKeyPath)) {
    throw "API key file not found: $ApiKeyPath"
}

$ApiKey = (Get-Content -Path $ApiKeyPath -Raw).Trim()

# -------------------------
# Counters
# -------------------------
$GlobalSearchCalls    = 0
$ProtectedSearchCalls = 0

# ==========================================================
# Helpers
# ==========================================================
function Invoke-HeliosGetJson {
    param(
        [Parameter(Mandatory)][string]$Uri,
        [Parameter(Mandatory)][hashtable]$Headers,
        [int]$TimeoutSec = 60
    )

    try {
        $resp = Invoke-WebRequest `
            -UseBasicParsing `
            -Method Get `
            -Uri $Uri `
            -Headers $Headers `
            -TimeoutSec $TimeoutSec `
            -ErrorAction Stop

        if ([string]::IsNullOrWhiteSpace($resp.Content)) {
            return $null
        }

        return ($resp.Content | ConvertFrom-Json)
    }
    catch {
        Write-Host "GET failed: $Uri" -ForegroundColor DarkRed
        Write-Host $_.Exception.Message -ForegroundColor DarkRed
        return $null
    }
}

function As-Array {
    param($Value)

    if ($null -eq $Value) {
        return @()
    }

    if ($Value -is [array]) {
        return @($Value)
    }

    return @($Value)
}

function First-Item {
    param($Value)

    $arr = @(As-Array $Value)

    if ($arr.Count -eq 0) {
        return $null
    }

    return $arr[0]
}

function Has-Prop {
    param(
        $Object,
        [string]$Name
    )

    if ($null -eq $Object) {
        return $false
    }

    try {
        return ($Object.PSObject.Properties.Name -contains $Name)
    }
    catch {
        return $false
    }
}

function Get-Text {
    param($Value)

    if ($null -eq $Value) {
        return ""
    }

    if ($Value -is [array]) {
        foreach ($v in $Value) {
            $t = Get-Text $v

            if (-not [string]::IsNullOrWhiteSpace($t)) {
                return $t
            }
        }

        return ""
    }

    if ($Value -is [pscustomobject]) {
        foreach ($p in @(
            "display_value",
            "displayName",
            "name",
            "value",
            "id",
            "clusterId",
            "clusterID",
            "sourceClusterId",
            "sourceClusterID",
            "accessClusterId",
            "intId"
        )) {
            if ($Value.PSObject.Properties.Name -contains $p) {
                $t = Get-Text $Value.$p

                if (-not [string]::IsNullOrWhiteSpace($t)) {
                    return $t
                }
            }
        }

        return ""
    }

    return "$Value".Trim()
}

function Get-Usecs {
    param($Value)

    if ($null -eq $Value) {
        return 0
    }

    $values = @()

    foreach ($v in (As-Array $Value)) {
        try {
            if ($null -ne $v -and "$v".Trim() -ne "") {
                $values += [int64]$v
            }
        }
        catch {}
    }

    if ($values.Count -eq 0) {
        return 0
    }

    return ($values | Sort-Object -Descending | Select-Object -First 1)
}

function Convert-UsecsToLocal {
    param($Usecs)

    if (-not $Usecs -or [int64]$Usecs -le 0) {
        return ""
    }

    try {
        return [DateTimeOffset]::FromUnixTimeMilliseconds([int64]($Usecs / 1000)).LocalDateTime.ToString("dd-MMM-yyyy HH:mm:ss")
    }
    catch {
        return ""
    }
}

function Is-ValidBackupRow {
    param($Row)

    if (-not $Row) {
        return $false
    }

    return $Row.LastBackupTime -notin @(
        "",
        $null,
        "NoBackup",
        "NoBackupTime",
        "NoObject",
        "NoFSBackupFound"
    )
}

# ==========================================================
# Cluster map
# ==========================================================
function Add-ClusterMapEntry {
    param(
        [hashtable]$Map,
        $Id,
        $ClusterObject
    )

    $txt = Get-Text $Id

    if (-not [string]::IsNullOrWhiteSpace($txt)) {
        $Map["$txt"] = $ClusterObject
    }
}

function Get-ClusterNameFromMap {
    param(
        [string]$ClusterId,
        [hashtable]$ClusterMap
    )

    if ([string]::IsNullOrWhiteSpace($ClusterId)) {
        return "-"
    }

    if ($ClusterMap.ContainsKey("$ClusterId")) {
        return "$($ClusterMap["$ClusterId"].ClusterName)"
    }

    return "$ClusterId"
}

# ==========================================================
# Global search parsing
# ==========================================================
function Get-GlobalFirstObject {
    param($Json)

    if ($null -eq $Json) {
        return $null
    }

    if ($Json -is [array]) {
        return First-Item $Json
    }

    foreach ($p in @(
        "objects",
        "searchResults",
        "results",
        "entities",
        "items",
        "data"
    )) {
        if ($Json.PSObject.Properties.Name -contains $p) {
            return First-Item $Json.$p
        }
    }

    return $null
}

function Get-ClusterIdFromNode {
    param($Node)

    if ($null -eq $Node) {
        return ""
    }

    return Get-Text @(
        $Node.clusterId,
        $Node.clusterID,
        $Node.sourceClusterId,
        $Node.sourceClusterID,
        $Node.accessClusterId,
        $Node.cluster.id,
        $Node.cluster.clusterId,
        $Node.cluster.clusterID,
        $Node.clusterInfo.id,
        $Node.clusterInfo.clusterId,
        $Node.clusterInfo.clusterID
    )
}

function Get-SelectedClusterIdFromGlobalObject {
    param($Object)

    if ($null -eq $Object) {
        return ""
    }

    # Priority 1: first objectProtectionInfos -> first protectionGroups
    $opi = First-Item $Object.objectProtectionInfos

    if ($opi) {
        $pg = First-Item $opi.protectionGroups

        if ($pg) {
            $cid = Get-ClusterIdFromNode $pg

            if (-not [string]::IsNullOrWhiteSpace($cid)) {
                return $cid
            }
        }

        $cid = Get-ClusterIdFromNode $opi

        if (-not [string]::IsNullOrWhiteSpace($cid)) {
            return $cid
        }
    }

    # Priority 2: first object-level protectionGroups
    $pg2 = First-Item $Object.protectionGroups

    if ($pg2) {
        $cid = Get-ClusterIdFromNode $pg2

        if (-not [string]::IsNullOrWhiteSpace($cid)) {
            return $cid
        }
    }

    # Priority 3: object-level cluster fields
    $cid = Get-ClusterIdFromNode $Object

    if (-not [string]::IsNullOrWhiteSpace($cid)) {
        return $cid
    }

    return ""
}

# ==========================================================
# Protected-object parsing
# ==========================================================
function Get-ProtectedObjectArray {
    param($Json)

    if ($null -eq $Json) {
        return @()
    }

    if ($Json -is [array]) {
        return @($Json)
    }

    foreach ($p in @(
        "objects",
        "protectedObjects",
        "protectedObjectResults",
        "searchResults",
        "results",
        "entities",
        "items",
        "data"
    )) {
        if ($Json.PSObject.Properties.Name -contains $p) {
            return @(As-Array $Json.$p | Where-Object { $_ })
        }
    }

    # If root itself looks like a protected object, return it.
    if (
        (Has-Prop $Json "latestSnapshotInfo") -or
        (Has-Prop $Json "latestSnapshotsInfo") -or
        (Has-Prop $Json "snapshotInfo") -or
        (Has-Prop $Json "backupInfo") -or
        (Has-Prop $Json "protectionGroupName") -or
        (Has-Prop $Json "environment") -or
        (Has-Prop $Json "objectType") -or
        (Has-Prop $Json "name") -or
        (Has-Prop $Json "displayName")
    ) {
        return @($Json)
    }

    return @()
}

function Get-Snapshots {
    param($Object)

    $snaps = @()

    $snaps += @(As-Array $Object.latestSnapshotInfo)
    $snaps += @(As-Array $Object.latestSnapshotsInfo)
    $snaps += @(As-Array $Object.latestSnapshot)
    $snaps += @(As-Array $Object.latestSnapshots)
    $snaps += @(As-Array $Object.snapshotInfo)
    $snaps += @(As-Array $Object.backupInfo)

    return @($snaps | Where-Object { $_ })
}

function Get-SnapshotTimeUsecs {
    param($Snapshot)

    if ($null -eq $Snapshot) {
        return 0
    }

    foreach ($f in @(
        "protectionRunStartTimeUsecs",
        "protectionRunEndTimeUsecs",
        "runStartTimeUsecs",
        "runEndTimeUsecs",
        "snapshotCreationTimeUsecs",
        "creationTimeUsecs",
        "startTimeUsecs",
        "endTimeUsecs"
    )) {
        if (Has-Prop $Snapshot $f) {
            $u = Get-Usecs $Snapshot.$f

            if ($u -gt 0) {
                return $u
            }
        }
    }

    if (Has-Prop $Snapshot "localBackupInfo") {
        foreach ($lbi in (As-Array $Snapshot.localBackupInfo)) {
            $u = Get-Usecs $lbi.endTimeUsecs
            if ($u -gt 0) { return $u }

            $u = Get-Usecs $lbi.startTimeUsecs
            if ($u -gt 0) { return $u }
        }
    }

    return 0
}

function Get-BestSnapshot {
    param($Object)

    $snaps = @(Get-Snapshots $Object)

    if (-not $snaps -or $snaps.Count -eq 0) {
        return $null
    }

    return $snaps |
        Sort-Object @{ Expression = { [int64](Get-SnapshotTimeUsecs $_) } } -Descending |
        Select-Object -First 1
}

function Get-BackupType {
    param(
        $Object,
        $Snapshot
    )

    $vals = @()

    $vals += $Object.environment
    $vals += $Object.object.environment
    $vals += $Object.objectType
    $vals += $Object.type
    $vals += $Object.protectionType

    $vals += $Object.sourceInfo.environment
    $vals += $Object.sourceInfo.type

    $vals += $Object.protectionSource.environment
    $vals += $Object.protectionSource.type

    $vals += $Object.entity.environment
    $vals += $Object.entity.type

    $vals += $Object.name
    $vals += $Object.displayName
    $vals += $Object.object.name
    $vals += $Object.object.displayName

    $vals += $Snapshot.environment
    $vals += $Snapshot.objectType
    $vals += $Snapshot.sourceInfo.environment
    $vals += $Snapshot.sourceInfo.type

    $text = ""

    foreach ($v in $vals) {
        $t = Get-Text $v

        if (-not [string]::IsNullOrWhiteSpace($t)) {
            $text += " " + $t.ToLower()
        }
    }

    if ($text -match "ksql|mssql|sqlserver|sql server|\bsql\b") {
        return "SQL"
    }

    if ($text -match "koracle|\boracle\b") {
        return "Oracle"
    }

    if ($text -match "kgenericnas|kisilon|nas|isilon|smb|cifs|nfs") {
        return "NAS"
    }

    if ($text -match "khyperv|hyperv|hyper-v") {
        return "Hyper-V"
    }

    if ($text -match "kacropolis|nutanix|ahv|acropolis") {
        return "Nutanix"
    }

    if ($text -match "kvmware|vmware") {
        return "VMware"
    }

    if ($text -match "kphysical|physical|filesystem|file_system|file system|volume|windows|linux") {
        return "FS"
    }

    return "Unknown"
}

function Get-PGName {
    param(
        $Object,
        $Snapshot
    )

    $vals = @(
        $Snapshot.protectionGroupName,
        $Snapshot.protectionGroup.name,
        $Snapshot.protectionGroup.displayName,
        $Snapshot.protectionGroupInfo.name,
        $Snapshot.protectionGroupInfo.displayName,

        $Object.protectionGroupName,
        $Object.protectionGroup.name,
        $Object.protectionGroup.displayName,
        $Object.protectionGroupInfo.name,
        $Object.protectionGroupInfo.displayName,

        $Object.objectProtectionInfos.protectionGroups.name,
        $Object.objectProtectionInfos.protectionGroups.protectionGroupName
    )

    foreach ($v in $vals) {
        $t = Get-Text $v

        if (-not [string]::IsNullOrWhiteSpace($t)) {
            return $t
        }
    }

    return "-"
}

function Get-ObjectNames {
    param($Object)

    $vals = @(
        $Object.name,
        $Object.objectName,
        $Object.hostName,
        $Object.displayName,
        $Object.sourceName,
        $Object.entity.name,
        $Object.entity.displayName,
        $Object.object.name,
        $Object.object.displayName,
        $Object.sourceInfo.name,
        $Object.sourceInfo.displayName,
        $Object.protectionSource.name,
        $Object.protectionSource.displayName
    )

    $names = @()

    foreach ($v in $vals) {
        $t = Get-Text $v

        if (-not [string]::IsNullOrWhiteSpace($t)) {
            $names += $t.ToLower()
        }
    }

    return @($names | Sort-Object -Unique)
}

function Object-MatchesCI {
    param(
        $Object,
        [string]$CI
    )

    $ciLower = $CI.ToLower().Trim()
    $names = @(Get-ObjectNames $Object)

    if (-not $names -or $names.Count -eq 0) {
        return $true
    }

    foreach ($n in $names) {
        if ($n -eq $ciLower) { return $true }
        if ($n -like "*$ciLower*") { return $true }
        if ($ciLower -like "*$n*") { return $true }
    }

    return $false
}

function Get-BackupTypeRank {
    param([string]$BackupType)

    switch ($BackupType) {
        "SQL"      { return 1 }
        "Oracle"   { return 2 }
        "FS"       { return 3 }
        "NAS"      { return 4 }
        "Hyper-V"  { return 5 }
        "Nutanix"  { return 6 }
        "VMware"   { return 7 }
        default    { return 9 }
    }
}

function Select-BestRows {
    param($Rows)

    $selected = @()

    foreach ($g in ($Rows | Group-Object BackupType)) {

        $groupRows = @($g.Group)

        $valid = @($groupRows | Where-Object {
            Is-ValidBackupRow $_
        })

        if ($valid.Count -gt 0) {
            $selected += (
                $valid |
                Sort-Object `
                    @{ Expression = { $_.LastBackupUsecs }; Descending = $true },
                    ClusterName,
                    ProtectionGroup |
                Select-Object -First 1
            )
        }
        else {
            $selected += (
                $groupRows |
                Sort-Object ClusterName, ProtectionGroup |
                Select-Object -First 1
            )
        }
    }

    return @($selected)
}

# ==========================================================
# Read CI list
# ==========================================================
$CiNames = Import-Csv -Path $InputCsv |
ForEach-Object {
    "$($_.ci_item)".Trim().Trim('"').Trim("'")
} |
Where-Object {
    -not [string]::IsNullOrWhiteSpace($_)
} |
Sort-Object -Unique

if (-not $CiNames -or $CiNames.Count -eq 0) {
    throw "No CI names found in CSV: $InputCsv"
}

$CiNames | Set-Content -Path $InputTxt

$CiList = Get-Content -Path $InputTxt |
ForEach-Object {
    $_.Trim().Trim('"').Trim("'")
} |
Where-Object {
    -not [string]::IsNullOrWhiteSpace($_)
}

if (-not $CiList -or $CiList.Count -eq 0) {
    throw "No CI names found in TXT: $InputTxt"
}

# ==========================================================
# Get trusted cluster names
# ==========================================================
$ClusterJson = Invoke-HeliosGetJson `
    -Uri "$BaseUrl/v2/mcm/cluster-mgmt/info" `
    -Headers @{
        accept = "application/json"
        apiKey = $ApiKey
    }

if (-not $ClusterJson -or -not $ClusterJson.cohesityClusters) {
    throw "No clusters returned from Helios."
}

$Clusters = @()
$ClusterMap = @{}

foreach ($c in @($ClusterJson.cohesityClusters)) {

    $cid = Get-Text @($c.clusterId, $c.id)
    $cn  = Get-Text @($c.clusterName, $c.name, $c.displayName)

    if ([string]::IsNullOrWhiteSpace($cid)) {
        continue
    }

    if ([string]::IsNullOrWhiteSpace($cn)) {
        $cn = "Unknown-$cid"
    }

    $clusterObj = [pscustomobject]@{
        ClusterId   = "$cid"
        ClusterName = "$cn"
    }

    $Clusters += $clusterObj

    Add-ClusterMapEntry -Map $ClusterMap -Id $c.clusterId -ClusterObject $clusterObj
    Add-ClusterMapEntry -Map $ClusterMap -Id $c.id -ClusterObject $clusterObj
    Add-ClusterMapEntry -Map $ClusterMap -Id $c.intId -ClusterObject $clusterObj
    Add-ClusterMapEntry -Map $ClusterMap -Id $c.clusterIdentifier.clusterId -ClusterObject $clusterObj
    Add-ClusterMapEntry -Map $ClusterMap -Id $c.clusterInfo.clusterId -ClusterObject $clusterObj
}

$Clusters = $Clusters | Sort-Object ClusterName, ClusterId

# ==========================================================
# Process
# ==========================================================
$Results = @()

foreach ($CI in $CiList) {

    Write-Host ""
    Write-Host "Processing: [$CI]" -ForegroundColor Cyan

    $AllRows = @()

    # ------------------------------------------------------
    # 1. Global search to select cluster internally
    # ------------------------------------------------------
    $GlobalSearchCalls++

    $GlobalUri = "$BaseUrl/v2/data-protect/search/objects?searchString=$([uri]::EscapeDataString($CI))&includeTenants=true&count=1"

    $GlobalJson = Invoke-HeliosGetJson `
        -Uri $GlobalUri `
        -Headers @{
            accept = "application/json"
            apiKey = $ApiKey
        }

    $GlobalObject = Get-GlobalFirstObject -Json $GlobalJson
    $SelectedClusterId = Get-SelectedClusterIdFromGlobalObject -Object $GlobalObject

    if ([string]::IsNullOrWhiteSpace($SelectedClusterId)) {

        $Results += [pscustomobject]@{
            ServerName      = $CI
            BackupType      = "Unknown"
            ClusterName     = "-"
            ProtectionGroup = "-"
            LastBackupTime  = "NoObject"
        }

        continue
    }

    $SelectedClusterName = Get-ClusterNameFromMap -ClusterId $SelectedClusterId -ClusterMap $ClusterMap

    # ------------------------------------------------------
    # 2. Protected-object search on selected cluster only
    # ------------------------------------------------------
    $ProtectedSearchCalls++

    $ProtectedUri = "$BaseUrl/v2/data-protect/search/protected-objects?searchString=$([uri]::EscapeDataString($CI))"

    $ProtectedJson = Invoke-HeliosGetJson `
        -Uri $ProtectedUri `
        -Headers @{
            accept          = "application/json"
            apiKey          = $ApiKey
            accessClusterId = "$SelectedClusterId"
        }

    $Objects = @(Get-ProtectedObjectArray $ProtectedJson)

    if (-not $Objects -or $Objects.Count -eq 0) {

        $Results += [pscustomobject]@{
            ServerName      = $CI
            BackupType      = "Unknown"
            ClusterName     = $SelectedClusterName
            ProtectionGroup = "-"
            LastBackupTime  = "NoBackup"
        }

        continue
    }

    $MatchedObjects = @($Objects | Where-Object {
        Object-MatchesCI -Object $_ -CI $CI
    })

    # Important:
    # If Helios returned objects for searchString=<CI>, use them even if local name parser cannot match.
    if (-not $MatchedObjects -or $MatchedObjects.Count -eq 0) {
        $MatchedObjects = $Objects
    }

    foreach ($Obj in $MatchedObjects) {

        $Snap = Get-BestSnapshot $Obj

        if ($Snap) {
            $Usecs = Get-SnapshotTimeUsecs $Snap
        }
        else {
            $Usecs = 0
        }

        if ($Usecs -gt 0) {
            $LastBackupTime = Convert-UsecsToLocal $Usecs
        }
        elseif ($Snap) {
            $LastBackupTime = "NoBackupTime"
        }
        else {
            $LastBackupTime = "NoBackup"
        }

        $AllRows += [pscustomobject]@{
            ServerName      = $CI
            BackupType      = Get-BackupType -Object $Obj -Snapshot $Snap
            ClusterName     = $SelectedClusterName
            ProtectionGroup = Get-PGName -Object $Obj -Snapshot $Snap
            LastBackupTime  = $LastBackupTime
            LastBackupUsecs = $Usecs
        }
    }

    if (-not $AllRows -or $AllRows.Count -eq 0) {

        $Results += [pscustomobject]@{
            ServerName      = $CI
            BackupType      = "Unknown"
            ClusterName     = $SelectedClusterName
            ProtectionGroup = "-"
            LastBackupTime  = "NoObject"
        }

        continue
    }

    $SelectedRows = @(Select-BestRows $AllRows)

    # ------------------------------------------------------
    # 3. SQL/Oracle requires FS validation
    # ------------------------------------------------------
    $HasValidSQL = @($SelectedRows | Where-Object {
        $_.BackupType -eq "SQL" -and (Is-ValidBackupRow $_)
    }).Count -gt 0

    $HasValidOracle = @($SelectedRows | Where-Object {
        $_.BackupType -eq "Oracle" -and (Is-ValidBackupRow $_)
    }).Count -gt 0

    $HasValidFS = @($SelectedRows | Where-Object {
        $_.BackupType -eq "FS" -and (Is-ValidBackupRow $_)
    }).Count -gt 0

    $HasValidDB = $HasValidSQL -or $HasValidOracle

    if ($HasValidDB -and -not $HasValidFS) {
        $SelectedRows = @($SelectedRows | Where-Object { $_.BackupType -ne "FS" })
    }

    foreach ($Row in $SelectedRows) {
        $Results += [pscustomobject]@{
            ServerName      = $Row.ServerName
            BackupType      = $Row.BackupType
            ClusterName     = $Row.ClusterName
            ProtectionGroup = $Row.ProtectionGroup
            LastBackupTime  = $Row.LastBackupTime
        }
    }

    if ($HasValidDB -and -not $HasValidFS) {
        $Results += [pscustomobject]@{
            ServerName      = $CI
            BackupType      = "FS"
            ClusterName     = "-"
            ProtectionGroup = "-"
            LastBackupTime  = "NoFSBackupFound"
        }
    }
}

# ==========================================================
# Summary
# ==========================================================
$TotalInputCIs = $CiList.Count
$TotalRows     = $Results.Count

$BackedUp = @($Results | Where-Object {
    $_.LastBackupTime -notin @("NoBackup", "NoBackupTime", "NoObject", "NoFSBackupFound", "")
}).Count

$NoBackup = @($Results | Where-Object {
    $_.LastBackupTime -in @("NoBackup", "NoBackupTime")
}).Count

$NoFSBackupFound = @($Results | Where-Object {
    $_.LastBackupTime -eq "NoFSBackupFound"
}).Count

$NoObject = @($Results | Where-Object {
    $_.LastBackupTime -eq "NoObject"
}).Count

$SortedResults = $Results |
    Sort-Object `
        ServerName,
        @{ Expression = { Get-BackupTypeRank $_.BackupType } },
        ClusterName,
        ProtectionGroup

$DetailsText = (
    $SortedResults |
    Format-Table ServerName, BackupType, ClusterName, ProtectionGroup, LastBackupTime -AutoSize |
    Out-String -Width 300
).TrimEnd()

# ==========================================================
# Report
# ==========================================================
$Report = @()
$Report += "=========================================================="
$Report += "Cohesity Backup Validation Report"
$Report += "=========================================================="
$Report += "Change Number              : $ChangeID"
$Report += "Executed By                : $ExecutedBy"
$Report += "Run Date                   : $(Get-Date -Format 'dd-MMM-yyyy HH:mm:ss')"
$Report += ""
$Report += "Total Input CIs            : $TotalInputCIs"
$Report += "Total Backup Rows          : $TotalRows"
$Report += "Backed Up                  : $BackedUp"
$Report += "No Backup                  : $NoBackup"
$Report += "No FS Backup Found         : $NoFSBackupFound"
$Report += "No Object                  : $NoObject"
$Report += ""
$Report += "Global Search Calls        : $GlobalSearchCalls"
