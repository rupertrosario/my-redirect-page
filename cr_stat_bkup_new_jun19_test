    if ($null -eq $Node) {
        return ""
    }

    return First-NonBlank -Values @(
        $Node.protectionGroupId,
        $Node.protectionGroupID,
        $Node.groupId,
        $Node.jobId,
        $Node.id,
        $Node.uid,
        $Node.protectionGroup.id,
        $Node.protectionGroup.uid,
        $Node.protectionGroupInfo.id,
        $Node.protectionGroupInfo.uid
    )
}

function Get-PGNameFromNode {
    param($Node)

    if ($null -eq $Node) {
        return ""
    }

    return First-NonBlank -Values @(
        $Node.protectionGroupName,
        $Node.name,
        $Node.displayName,
        $Node.protectionGroup.name,
        $Node.protectionGroup.displayName,
        $Node.protectionGroupInfo.name,
        $Node.protectionGroupInfo.displayName,
        $Node.policyName
    )
}

function Get-NodeTextForType {
    param($Node)

    if ($null -eq $Node) {
        return ""
    }

    $parts = @()

    foreach ($v in @(
        $Node.environment,
        $Node.object.environment,
        $Node.objectType,
        $Node.type,
        $Node.protectionType,
        $Node.sourceInfo.environment,
        $Node.sourceInfo.type,
        $Node.protectionSource.environment,
        $Node.protectionSource.type,
        $Node.entity.environment,
        $Node.entity.type,
        $Node.name,
        $Node.displayName,
        $Node.object.name,
        $Node.object.displayName,
        $Node.protectionGroupName,
        $Node.policyName
    )) {
        $t = First-NonBlank -Values @($v)

        if (-not [string]::IsNullOrWhiteSpace($t)) {
            $parts += $t
        }
    }

    return (($parts | Where-Object { -not [string]::IsNullOrWhiteSpace($_) }) -join " ")
}

function Get-BackupTypeFromText {
    param([string]$Text)

    $t = "$Text".ToLower()

    if ($t -match "ksql|mssql|sqlserver|sql server|\bsql\b") {
        return "SQL"
    }

    if ($t -match "koracle|\boracle\b") {
        return "Oracle"
    }

    if ($t -match "kgenericnas|kisilon|nas|isilon|smb|cifs|nfs") {
        return "NAS"
    }

    if ($t -match "khyperv|hyperv|hyper-v") {
        return "Hyper-V"
    }

    if ($t -match "kacropolis|nutanix|ahv|acropolis") {
        return "Nutanix"
    }

    if ($t -match "kvmware|vmware|vc-") {
        return "VMware"
    }

    if ($t -match "kphysical|physical|filesystem|file_system|file system|volume|windows|linux|\bfs\b|_fs_|-fs-") {
        return "FS"
    }

    return "Unknown"
}

function Add-Candidate {
    param(
        [System.Collections.ArrayList]$List,
        [hashtable]$Seen,
        [string]$ServerName,
        [string]$ClusterId,
        [string]$PGId,
        [string]$PGName,
        [string]$BackupType,
        [string]$TypeHint
    )

    if ([string]::IsNullOrWhiteSpace($ClusterId)) {
        return
    }

    if ([string]::IsNullOrWhiteSpace($PGId)) {
        return
    }

    if ([string]::IsNullOrWhiteSpace($PGName)) {
        $PGName = "N/A"
    }

    if ([string]::IsNullOrWhiteSpace($BackupType)) {
        $BackupType = "Unknown"
    }

    $key = "$ClusterId|$PGId|$BackupType|$PGName"

    if ($Seen.ContainsKey($key)) {
        return
    }

    $Seen[$key] = $true

    [void]$List.Add([pscustomobject]@{
        ServerName = $ServerName
        ClusterId  = "$ClusterId"
        PGId       = "$PGId"
        PGName     = "$PGName"
        BackupType = "$BackupType"
        TypeHint   = "$TypeHint"
    })
}

function Get-CandidatesFromGlobalSearch {
    param(
        [string]$CI,
        $Json
    )

    $candidates = New-Object System.Collections.ArrayList
    $seen       = @{}

    $objects = @(Get-GlobalObjectArray -Json $Json)

    foreach ($obj in $objects) {

        $objectClusterId = Get-ClusterIdFromNode -Node $obj
        $objectPGId      = Get-PGIdFromNode -Node $obj
        $objectPGName    = Get-PGNameFromNode -Node $obj
        $objectText      = Get-NodeTextForType -Node $obj
        $objectType      = Get-BackupTypeFromText -Text $objectText

        # Object-level candidate, if PG exists at object level.
        Add-Candidate `
            -List $candidates `
            -Seen $seen `
            -ServerName $CI `
            -ClusterId $objectClusterId `
            -PGId $objectPGId `
            -PGName $objectPGName `
            -BackupType $objectType `
            -TypeHint $objectText

        # objectProtectionInfos first - DTSK idea
        foreach ($opi in (As-Array -Value $obj.objectProtectionInfos)) {

            $opiClusterId = Get-ClusterIdFromNode -Node $opi

            if ([string]::IsNullOrWhiteSpace($opiClusterId)) {
                $opiClusterId = $objectClusterId
            }

            $opiPGId   = Get-PGIdFromNode -Node $opi
            $opiPGName = Get-PGNameFromNode -Node $opi
            $opiText   = "$objectText " + (Get-NodeTextForType -Node $opi)
            $opiType   = Get-BackupTypeFromText -Text $opiText

            Add-Candidate `
                -List $candidates `
                -Seen $seen `
                -ServerName $CI `
                -ClusterId $opiClusterId `
                -PGId $opiPGId `
                -PGName $opiPGName `
                -BackupType $opiType `
                -TypeHint $opiText

            # protectionGroups second - DTSK idea
            foreach ($pg in (As-Array -Value $opi.protectionGroups)) {

                $pgClusterId = Get-ClusterIdFromNode -Node $pg

                if ([string]::IsNullOrWhiteSpace($pgClusterId)) {
                    $pgClusterId = $opiClusterId
                }

                if ([string]::IsNullOrWhiteSpace($pgClusterId)) {
                    $pgClusterId = $objectClusterId
                }

                $pgId   = Get-PGIdFromNode -Node $pg
                $pgName = Get-PGNameFromNode -Node $pg
                $pgText = "$opiText " + (Get-NodeTextForType -Node $pg)
                $pgType = Get-BackupTypeFromText -Text $pgText

                Add-Candidate `
                    -List $candidates `
                    -Seen $seen `
                    -ServerName $CI `
                    -ClusterId $pgClusterId `
                    -PGId $pgId `
                    -PGName $pgName `
                    -BackupType $pgType `
                    -TypeHint $pgText
            }
        }

        # Some responses may have protectionGroups directly under object.
        foreach ($pg2 in (As-Array -Value $obj.protectionGroups)) {

            $pg2ClusterId = Get-ClusterIdFromNode -Node $pg2

            if ([string]::IsNullOrWhiteSpace($pg2ClusterId)) {
                $pg2ClusterId = $objectClusterId
            }

            $pg2Id   = Get-PGIdFromNode -Node $pg2
            $pg2Name = Get-PGNameFromNode -Node $pg2
            $pg2Text = "$objectText " + (Get-NodeTextForType -Node $pg2)
            $pg2Type = Get-BackupTypeFromText -Text $pg2Text

            Add-Candidate `
                -List $candidates `
                -Seen $seen `
                -ServerName $CI `
                -ClusterId $pg2ClusterId `
                -PGId $pg2Id `
                -PGName $pg2Name `
                -BackupType $pg2Type `
                -TypeHint $pg2Text
        }
    }

    return @($candidates)
}

# ==========================================================
# Runs Parsing
# ==========================================================
function Get-RunArray {
    param($Json)

    if ($null -eq $Json) {
        return @()
    }

    if ($Json -is [array]) {
        return @($Json)
    }

    foreach ($p in @(
        "runs",
        "protectionRuns",
        "protectionGroupRuns",
        "runList",
        "results",
        "items",
        "data",
        "entities"
    )) {
        if ($Json.PSObject.Properties.Name -contains $p) {
            return @(As-Array -Value $Json.$p | Where-Object { $_ })
        }
    }

    if (
        (Has-Prop -Object $Json -Name "status") -or
        (Has-Prop -Object $Json -Name "localBackupInfo") -or
        (Has-Prop -Object $Json -Name "objects") -or
        (Has-Prop -Object $Json -Name "startTimeUsecs") -or
        (Has-Prop -Object $Json -Name "endTimeUsecs")
    ) {
        return @($Json)
    }

    return @()
}

function Get-RunObjects {
    param($Run)

    $objs = @()

    $objs += @(As-Array -Value $Run.objects)
    $objs += @(As-Array -Value $Run.objectRuns)
    $objs += @(As-Array -Value $Run.protectedObjects)
    $objs += @(As-Array -Value $Run.entities)
    $objs += @(As-Array -Value $Run.protectionRun.objects)
    $objs += @(As-Array -Value $Run.protectionRun.objectRuns)

    return @($objs | Where-Object { $_ })
}

function Get-StatusText {
    param($Node)

    if ($null -eq $Node) {
        return ""
    }

    return First-NonBlank -Values @(
        $Node.status,
        $Node.runStatus,
        $Node.backupStatus,
        $Node.protectionStatus,
        $Node.localBackupInfo.status,
        $Node.localSnapshotInfo.status,
        $Node.error,
        $Node.message
    )
}

function Is-SuccessStatus {
    param([string]$StatusText)

    if ([string]::IsNullOrWhiteSpace($StatusText)) {
        return $true
    }

    $s = "$StatusText".ToLower()

    if ($s -match "fail|failed|failure|error|cancel|canceled|cancelled|abort|aborted|skipped") {
        return $false
    }

    if ($s -match "success|succeeded|warning|succeededwithwarning|finished|complete|completed|kfinished|ksuccess") {
        return $true
    }

    # Unknown status but time exists can still be usable.
    return $true
}

function Get-MaxTimeUsecsFromNode {
    param(
        $Node,
        [int]$Depth = 0
    )

    if ($null -eq $Node) {
        return 0
    }

    if ($Depth -gt 6) {
        return 0
    }

    $max = 0

    foreach ($item in (As-Array -Value $Node)) {

        if ($null -eq $item) {
            continue
        }

        if ($item -is [pscustomobject]) {

            foreach ($prop in $item.PSObject.Properties) {

                $propName  = "$($prop.Name)"
                $propValue = $prop.Value

                if (
                    $propName -match "TimeUsecs$" -and
                    $propName -notmatch "expir|expiry|delete|deletion|remove|removed|retention|archiveExpiry"
                ) {
                    $u = Get-Usecs -Value $propValue

                    if ($u -gt $max) {
                        $max = $u
                    }
                }

                if ($propValue -is [array] -or $propValue -is [pscustomobject]) {
                    $nested = Get-MaxTimeUsecsFromNode -Node $propValue -Depth ($Depth + 1)

                    if ($nested -gt $max) {
                        $max = $nested
                    }
                }
            }
        }
    }

    return $max
}

function Get-ObjectNames {
    param($Object)

    $names = @()

    foreach ($v in @(
        $Object.name,
        $Object.objectName,
        $Object.hostName,
        $Object.displayName,
        $Object.sourceName,
        $Object.entity.name,
        $Object.entity.displayName,
        $Object.object.name,
        $Object.object.displayName,
        $Object.sourceInfo.name,
        $Object.sourceInfo.displayName,
        $Object.protectionSource.name,
        $Object.protectionSource.displayName
    )) {
        $t = First-NonBlank -Values @($v)

        if (-not [string]::IsNullOrWhiteSpace($t)) {
            $names += $t.ToLower()
        }
    }

    return @($names | Sort-Object -Unique)
}

function Object-MatchesCI {
    param(
        $Object,
        [string]$CI
    )

    $ciLower = $CI.ToLower().Trim()
    $names = @(Get-ObjectNames -Object $Object)

    if (-not $names -or $names.Count -eq 0) {
        return $false
    }

    foreach ($n in $names) {
        if ($n -eq $ciLower) { return $true }
        if ($n -like "*$ciLower*") { return $true }
        if ($ciLower -like "*$n*") { return $true }
    }

    return $false
}

function Get-LatestBackupFromRuns {
    param(
        [string]$CI,
        $Runs
    )

    $bestUsecs = 0

    foreach ($run in (As-Array -Value $Runs)) {

        if ($null -eq $run) {
            continue
        }

        $runStatus = Get-StatusText -Node $run

        if (-not (Is-SuccessStatus -StatusText $runStatus)) {
            continue
        }

        $runObjects = @(Get-RunObjects -Run $run)

        if ($runObjects.Count -gt 0) {

            $matchedObjects = @($runObjects | Where-Object {
                Object-MatchesCI -Object $_ -CI $CI
            })

            if ($matchedObjects.Count -eq 0) {
                continue
            }

            foreach ($obj in $matchedObjects) {

                $objStatus = Get-StatusText -Node $obj

                if (-not (Is-SuccessStatus -StatusText $objStatus)) {
                    continue
                }

                $objUsecs = Get-MaxTimeUsecsFromNode -Node $obj

                if ($objUsecs -le 0) {
                    $objUsecs = Get-MaxTimeUsecsFromNode -Node $run
                }

                if ($objUsecs -gt $bestUsecs) {
                    $bestUsecs = $objUsecs
                }
            }
        }
        else {
            # If run has no object list, use PG-level run time.
            # This is allowed because the candidate came from global search for that CI.
            $runUsecs = Get-MaxTimeUsecsFromNode -Node $run

            if ($runUsecs -gt $bestUsecs) {
                $bestUsecs = $runUsecs
            }
        }
    }

    return $bestUsecs
}

# ==========================================================
# Report Helpers
# ==========================================================
function Get-BackupTypeRank {
    param([string]$BackupType)

    switch ($BackupType) {
        "SQL"      { return 1 }
        "Oracle"   { return 2 }
        "FS"       { return 3 }
        "NAS"      { return 4 }
        "Hyper-V"  { return 5 }
        "Nutanix"  { return 6 }
        "VMware"   { return 7 }
        default    { return 9 }
    }
}

function Select-BestRows {
    param($Rows)

    $selected = @()

    foreach ($g in ($Rows | Group-Object BackupType)) {

        $groupRows = @($g.Group)

        $valid = @($groupRows | Where-Object {
            Is-ValidBackupRow -Row $_
        })

        if ($valid.Count -gt 0) {
            $selected += (
                $valid |
                Sort-Object -Property `
                    @{ Expression = { $_.LastBackupUsecs }; Descending = $true },
                    ClusterName,
                    ProtectionGroup |
                Select-Object -First 1
            )
        }
        else {
            $selected += (
                $groupRows |
                Sort-Object -Property ClusterName, ProtectionGroup |
                Select-Object -First 1
            )
        }
    }

    return @($selected)
}

# ==========================================================
# Read CI List
# ==========================================================
$CiNames = Import-Csv -Path $InputCsv |
ForEach-Object {
    "$($_.ci_item)".Trim().Trim('"').Trim("'")
} |
Where-Object {
    -not [string]::IsNullOrWhiteSpace($_)
} |
Sort-Object -Unique

if (-not $CiNames -or $CiNames.Count -eq 0) {
    throw "No CI names found in CSV: $InputCsv"
}

$CiNames | Set-Content -Path $InputTxt

$CiList = Get-Content -Path $InputTxt |
ForEach-Object {
    $_.Trim().Trim('"').Trim("'")
} |
Where-Object {
    -not [string]::IsNullOrWhiteSpace($_)
}

if (-not $CiList -or $CiList.Count -eq 0) {
    throw "No CI names found in TXT: $InputTxt"
}

# ==========================================================
# Get Trusted Cluster Names
# ==========================================================
$ClusterJson = Invoke-HeliosGetJson `
    -Uri "$BaseUrl/v2/mcm/cluster-mgmt/info" `
    -Headers @{
        accept = "application/json"
        apiKey = $ApiKey
    }

if (-not $ClusterJson -or -not $ClusterJson.cohesityClusters) {
    throw "No clusters returned from Helios."
}

$ClusterMap = @{}

foreach ($c in @($ClusterJson.cohesityClusters)) {

    $cid = First-NonBlank -Values @($c.clusterId, $c.id)
    $cn  = First-NonBlank -Values @($c.clusterName, $c.name, $c.displayName)

    if ([string]::IsNullOrWhiteSpace($cid)) {
        continue
    }

    if ([string]::IsNullOrWhiteSpace($cn)) {
        $cn = "Unknown-$cid"
    }

    $clusterObj = [pscustomobject]@{
        ClusterId   = "$cid"
        ClusterName = "$cn"
    }

    Add-ClusterMapEntry -Map $ClusterMap -Id $c.clusterId -ClusterObject $clusterObj
    Add-ClusterMapEntry -Map $ClusterMap -Id $c.id -ClusterObject $clusterObj
    Add-ClusterMapEntry -Map $ClusterMap -Id $c.intId -ClusterObject $clusterObj
    Add-ClusterMapEntry -Map $ClusterMap -Id $c.clusterIdentifier.clusterId -ClusterObject $clusterObj
    Add-ClusterMapEntry -Map $ClusterMap -Id $c.clusterInfo.clusterId -ClusterObject $clusterObj
}

# ==========================================================
# Main Processing
# ==========================================================
$Results = @()

foreach ($CI in $CiList) {

    if ($ShowProgress) {
        Write-Host ""
        Write-Host "Processing: [$CI]" -ForegroundColor Cyan
    }

    $RowsForCi = @()

    # ------------------------------------------------------
    # Step 1: Global search count=100
    # ------------------------------------------------------
    $GlobalSearchCalls++

    $GlobalUri =
        "$BaseUrl/v2/data-protect/search/objects" +
        "?searchString=$([uri]::EscapeDataString($CI))" +
        "&includeTenants=true" +
        "&count=$GlobalSearchCount"

    $GlobalJson = Invoke-HeliosGetJson `
        -Uri $GlobalUri `
        -Headers @{
            accept = "application/json"
            apiKey = $ApiKey
        }

    $Candidates = @(Get-CandidatesFromGlobalSearch -CI $CI -Json $GlobalJson)

    if ($ShowProgress) {
        Write-Host "  PG candidates found: $($Candidates.Count)" -ForegroundColor DarkGray
    }

    if (-not $Candidates -or $Candidates.Count -eq 0) {
        $Results += [pscustomobject]@{
            ServerName      = $CI
            BackupType      = "Unknown"
            ClusterName     = "-"
            ProtectionGroup = "N/A"
            LastBackupTime  = "NoPGFound"
        }

        continue
    }

    # ------------------------------------------------------
    # Step 2: For each candidate PG, read PG runs
    # ------------------------------------------------------
    foreach ($Candidate in $Candidates) {

        $ClusterName = Get-ClusterNameFromMap `
            -ClusterId $Candidate.ClusterId `
            -ClusterMap $ClusterMap

        $RunSearchCalls++

        $RunsUri =
            "$BaseUrl/v2/data-protect/protection-groups/" +
            "$([uri]::EscapeDataString($Candidate.PGId))" +
            "/runs"

        $RunsJson = Invoke-HeliosGetJson `
            -Uri $RunsUri `
            -Headers @{
                accept          = "application/json"
                apiKey          = $ApiKey
                accessClusterId = "$($Candidate.ClusterId)"
            }

        $Runs = @(Get-RunArray -Json $RunsJson)

        if (-not $Runs -or $Runs.Count -eq 0) {
            $RowsForCi += [pscustomobject]@{
                ServerName      = $CI
                BackupType      = $Candidate.BackupType
                ClusterName     = $ClusterName
                ProtectionGroup = $Candidate.PGName
                LastBackupTime  = "NoRunFound"
                LastBackupUsecs = 0
            }

            continue
        }

        $LatestUsecs = Get-LatestBackupFromRuns `
            -CI $CI `
            -Runs $Runs

        if ($LatestUsecs -gt 0) {
            $LastBackupTime = Convert-UsecsToReportTime -Usecs $LatestUsecs
        }
        else {
            $LastBackupTime = "NoBackup"
        }

        $RowsForCi += [pscustomobject]@{
            ServerName      = $CI
            BackupType      = $Candidate.BackupType
            ClusterName     = $ClusterName
            ProtectionGroup = $Candidate.PGName
            LastBackupTime  = $LastBackupTime
            LastBackupUsecs = $LatestUsecs
        }
    }

    # ------------------------------------------------------
    # Step 3: Clean/select rows
    # ------------------------------------------------------
    if (-not $RowsForCi -or $RowsForCi.Count -eq 0) {
        $Results += [pscustomobject]@{
            ServerName      = $CI
            BackupType      = "Unknown"
            ClusterName     = "-"
            ProtectionGroup = "N/A"
            LastBackupTime  = "NoBackup"
        }

        continue
    }

    # If known backup types exist, drop Unknown rows.
    $KnownRows = @($RowsForCi | Where-Object {
        $_.BackupType -ne "Unknown"
    })

    if ($KnownRows.Count -gt 0) {
        $RowsForCi = $KnownRows
    }

    $SelectedRows = @(Select-BestRows -Rows $RowsForCi)

    # ------------------------------------------------------
    # Step 4: DB requires FS validation
    # ------------------------------------------------------
    $HasValidSQL = @($SelectedRows | Where-Object {
        $_.BackupType -eq "SQL" -and (Is-ValidBackupRow -Row $_)
    }).Count -gt 0

    $HasValidOracle = @($SelectedRows | Where-Object {
        $_.BackupType -eq "Oracle" -and (Is-ValidBackupRow -Row $_)
    }).Count -gt 0

    $HasValidFS = @($SelectedRows | Where-Object {
        $_.BackupType -eq "FS" -and (Is-ValidBackupRow -Row $_)
    }).Count -gt 0

    $HasValidDB = $HasValidSQL -or $HasValidOracle

    if ($HasValidDB -and -not $HasValidFS) {
        $SelectedRows = @($SelectedRows | Where-Object { $_.BackupType -ne "FS" })
    }

    foreach ($Row in $SelectedRows) {
        $Results += [pscustomobject]@{
            ServerName      = $Row.ServerName
            BackupType      = $Row.BackupType
            ClusterName     = $Row.ClusterName
            ProtectionGroup = $Row.ProtectionGroup
            LastBackupTime  = $Row.LastBackupTime
        }
    }

    if ($HasValidDB -and -not $HasValidFS) {
        $Results += [pscustomobject]@{
            ServerName      = $CI
            BackupType      = "FS"
            ClusterName     = "-"
            ProtectionGroup = "N/A"
            LastBackupTime  = "NoFSBackupFound"
        }
    }
}

# ==========================================================
# Summary
# ==========================================================
$SortedResults = $Results |
    Sort-Object `
        ServerName,
        @{ Expression = { Get-BackupTypeRank -BackupType $_.BackupType } },
        ClusterName,
        ProtectionGroup

$TotalInputCIs = $CiList.Count
$TotalRows     = $SortedResults.Count

$BackedUp = @($SortedResults | Where-Object {
    $_.LastBackupTime -notin @(
        "",
        "NoBackup",
        "NoBackupTime",
        "NoObject",
        "NoPGFound",
        "NoRunFound",
        "NoFSBackupFound",
        "ClusterIdMissing",
        "PGIdMissing",
        "SearchFailed"
    )
}).Count

$NoBackup = @($SortedResults | Where-Object {
    $_.LastBackupTime -in @("NoBackup", "NoBackupTime", "NoRunFound")
}).Count

$NoPGFound = @($SortedResults | Where-Object {
    $_.LastBackupTime -eq "NoPGFound"
}).Count

$NoFSBackupFound = @($SortedResults | Where-Object {
    $_.LastBackupTime -eq "NoFSBackupFound"
}).Count

$DetailsText = (
    $SortedResults |
    Format-Table ServerName, BackupType, ClusterName, ProtectionGroup, LastBackupTime -AutoSize |
    Out-String -Width 300
).TrimEnd()

# ==========================================================
# Report
# ==========================================================
$Report = @()
$Report += "=========================================================="
$Report += "Cohesity Backup Validation Report"
$Report += "=========================================================="
$Report += "Change Number              : $ChangeID"
$Report += "Executed By                : $ExecutedBy"
$Report += "Run Date                   : $(Get-Date -Format 'yyyy-MM-dd HH:mm:ss')"
$Report += ""
$Report += "Total Input CIs            : $TotalInputCIs"
$Report += "Total Backup Rows          : $TotalRows"
$Report += "Backed Up                  : $BackedUp"
$Report += "No Backup                  : $NoBackup"
$Report += "No PG Found                : $NoPGFound"
$Report += "No FS Backup Found         : $NoFSBackupFound"
$Report += ""
$Report += "Global Search Calls        : $GlobalSearchCalls"
$Report += "PG Run Search Calls        : $RunSearchCalls"
$Report += ""
$Report += "----------------------------------------------------------"
$Report += "Details"
$Report += "----------------------------------------------------------"
$Report += ""
$Report += $DetailsText
$Report += ""
$Report += "----------------------------------------------------------"
$Report += "Notes"
$Report += "----------------------------------------------------------"
$Report += "- Global search uses count=100."
$Report += "- Global search is used to identify all candidate PGs and clusters for the CI."
$Report += "- PG runs endpoint is used to calculate latest backup time."
$Report += "- Final ClusterName is resolved from /v2/mcm/cluster-mgmt/info."
$Report += "- SQL/Oracle backup rows require an FS row. If FS is missing, NoFSBackupFound is added."
$Report += ""
$Report += "----------------------------------------------------------"
$Report += "Report Location"
$Report += "----------------------------------------------------------"
$Report += $OutputTxt
$Report += "=========================================================="

$Report | Set-Content -Path $OutputTxt

Write-Host ""
Write-Host ($Report -join "`n")
