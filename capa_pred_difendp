$y90  = [math]::Round((Get-Y -UsedPB ($TotalCapacityPB * 0.90)), 2)
$y100 = [math]::Round((Get-Y -UsedPB ($TotalCapacityPB * 1.00)), 2)

# ----------------------------------------------------------
# Y-axis dotted grid lines and labels
# ----------------------------------------------------------
$yAxisTicks = @(
    @{ Label = "0 Bytes"; ValuePB = 0 },
