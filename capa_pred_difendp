# ==========================================================
# Cohesity Helios Capacity Prediction Dashboard
# GET ONLY
#
# Current capacity source:
#   GET https://helios.cohesity.com/v2/stats/cluster-storage
#
# History source:
#   GET https://helios.cohesity.com/mcm/capacityPrediction
#
# Output:
#   HTML graph only
# ==========================================================

$ErrorActionPreference = "Stop"

# ----------------------------------------------------------
# User Configuration
# ----------------------------------------------------------

# API key helper - your current AES method
. "X:\PowerShell\Cohesity_API_Scripts\Common\ApiKeyAesHelper.ps1"

$ApiKey = Get-CohesityApiKeyFromAes `
    -EncryptedFile "X:\PowerShell\Cohesity_API_Scripts\Common\secure\cohesity_apikey.enc"

# Cluster identifier from Helios URL
$ClusterIdentifier = "605224895915468:1643172853790"

# accessClusterId is usually the value after :
$AccessClusterId = ($ClusterIdentifier -split ":")[-1]

# Must be actual total cluster capacity in PB
$TotalCapacityPB = 2.4

$OutputDir = "X:\PowerShell\Data\Cohesity\CapacityPrediction"

# Forecast trend window
$TrendDays = 84   # 12 weeks

# ----------------------------------------------------------
# Setup
# ----------------------------------------------------------
if (!(Test-Path $OutputDir)) {
    New-Item -ItemType Directory -Path $OutputDir -Force | Out-Null
}

$RunTime   = Get-Date
$TimeStamp = Get-Date -Format "yyyyMMdd_HHmmss"
$HtmlPath  = Join-Path $OutputDir "Cohesity_CapacityPrediction_$TimeStamp.html"

$PB = [math]::Pow(1024, 5)
$TB = [math]::Pow(1024, 4)

$TotalBytes = $TotalCapacityPB * $PB

# ----------------------------------------------------------
# Common Functions
# ----------------------------------------------------------
function Get-IsNumeric {
    param($Value)

    if ($null -eq $Value) {
        return $false
    }

    try {
        [double]$Value | Out-Null
        return $true
    }
    catch {
        return $false
    }
}

function Get-FirstNumericProperty {
    param(
        $Object,
        [string[]]$Names
    )

    foreach ($name in $Names) {
        $prop = $Object.PSObject.Properties[$name]
        if ($prop -and (Get-IsNumeric $prop.Value)) {
            return [double]$prop.Value
        }
    }

    return $null
}

function Get-CurrentPhysicalUsedBytes {
    param($StatsObject)

    # Prefer direct total/used fields if present
    $directValue = Get-FirstNumericProperty -Object $StatsObject -Names @(
        "totalPhysicalUsageBytes",
        "physicalUsedBytes",
        "physicalUsageBytes",
        "usedPhysicalBytes",
        "usedBytes"
    )

    if ($null -ne $directValue) {
        return $directValue
    }

    # Fallback: sum root-level physical usage buckets
    $physicalProps = $StatsObject.PSObject.Properties | Where-Object {
        $_.Name -match "PhysicalUsageBytes$" -and
        $_.Name -notmatch "^total" -and
        (Get-IsNumeric $_.Value)
    }

    if ($physicalProps.Count -gt 0) {
        $sum = 0
        foreach ($p in $physicalProps) {
            $sum += [double]$p.Value
        }
        return $sum
    }

    throw "Unable to determine current physical used bytes from /v2/stats/cluster-storage response. Run `$currentJson | Format-List * and confirm field names."
}

function Get-ForecastInfo {
    param(
        [double]$TargetBytes,
        [double]$CurrentBytes,
        [double]$GrowthBytesPerDay,
        [datetime]$RunDate,
        [string]$ReachedText
    )

    if ($CurrentBytes -ge $TargetBytes) {
        return [pscustomobject]@{
            Date    = $RunDate
            Text    = "Reached"
            Days    = "Reached"
            SubText = $ReachedText
        }
    }

    if ($GrowthBytesPerDay -le 0) {
        return [pscustomobject]@{
            Date    = $null
            Text    = "No Growth"
            Days    = "No Growth"
            SubText = "No positive growth trend"
        }
    }

    $forecastDate = $RunDate.AddDays(($TargetBytes - $CurrentBytes) / $GrowthBytesPerDay)
    $days = [math]::Ceiling(($forecastDate.Date - $RunDate.Date).TotalDays)

    return [pscustomobject]@{
        Date    = $forecastDate
        Text    = $forecastDate.ToString("MMM dd, yyyy")
        Days    = $days
        SubText = "$days days from run date"
    }
}

function Get-X {
    param([datetime]$Date)

    if ($script:totalSeconds -le 0) {
        return $script:plotLeft
    }

    return $script:plotLeft + ((($Date - $script:minDate).TotalSeconds / $script:totalSeconds) * $script:plotWidth)
}

function Get-Y {
    param([double]$UsedPB)

    return $script:plotBottom - (($UsedPB / $script:TotalCapacityPB) * $script:plotHeight)
}

# ----------------------------------------------------------
# API Call 1: Current Cluster Storage Stats
# ----------------------------------------------------------
$currentHeaders = @{
    accept          = "application/json"
    apiKey          = $ApiKey
    accessClusterId = $AccessClusterId
}

$currentUri = "https://helios.cohesity.com/v2/stats/cluster-storage"

$currentResponse = Invoke-WebRequest `
    -Uri $currentUri `
    -Method GET `
    -Headers $currentHeaders `
    -UseBasicParsing

$currentJson = $currentResponse.Content | ConvertFrom-Json

# Some APIs return root object, some return data object
$currentRoot = if ($currentJson.data) { $currentJson.data } else { $currentJson }

$CurrentUsedBytes = Get-CurrentPhysicalUsedBytes -StatsObject $currentRoot
$CurrentUsedPB    = $CurrentUsedBytes / $PB
$CurrentUsedTB    = $CurrentUsedBytes / $TB
$CurrentUsedPct   = ($CurrentUsedBytes / $TotalBytes) * 100

# ----------------------------------------------------------
# API Call 2: Historical Capacity Prediction Data
# ----------------------------------------------------------
$historyHeaders = @{
    accept = "application/json"
    apiKey = $ApiKey
}

$EncodedClusterIdentifier = [uri]::EscapeDataString($ClusterIdentifier)
$historyUri = "https://helios.cohesity.com/mcm/capacityPrediction?clusterIdentifiers=$EncodedClusterIdentifier"

$historyResponse = Invoke-WebRequest `
    -Uri $historyUri `
    -Method GET `
    -Headers $historyHeaders `
    -UseBasicParsing

$historyJson = $historyResponse.Content | ConvertFrom-Json

$rawPoints = @()

if ($historyJson.data.dataPointVec) {
    foreach ($p in $historyJson.data.dataPointVec) {

        if ($null -eq $p.timestampMsecs -or $null -eq $p.physicalUsedBytes) {
            continue
        }

        $dt = [DateTimeOffset]::FromUnixTimeMilliseconds([int64]$p.timestampMsecs).LocalDateTime

        # Keep only historical points up to script run date
        if ($dt -le $RunTime) {
            $rawPoints += [pscustomobject]@{
                Date      = $dt
                UsedBytes = [double]$p.physicalUsedBytes
                Source    = "History"
            }
        }
    }
}

# Add current data from latest API as the real current point
$rawPoints += [pscustomobject]@{
    Date      = $RunTime
    UsedBytes = [double]$CurrentUsedBytes
    Source    = "CurrentStats"
}

# Deduplicate by date; prefer CurrentStats if same day
$deduped = @()

$rawPoints |
    Sort-Object Date |
    Group-Object { $_.Date.ToString("yyyy-MM-dd") } |
    ForEach-Object {
        $current = $_.Group | Where-Object { $_.Source -eq "CurrentStats" } | Select-Object -Last 1

        if ($current) {
            $deduped += $current
        }
        else {
            $deduped += ($_.Group | Sort-Object Date | Select-Object -Last 1)
        }
    }

$data = $deduped |
    Sort-Object Date |
    ForEach-Object {
        $usedPB  = $_.UsedBytes / $PB
        $usedTB  = $_.UsedBytes / $TB
        $usedPct = ($_.UsedBytes / $TotalBytes) * 100

        [pscustomobject]@{
            Date        = $_.Date
            UsedBytes   = [double]$_.UsedBytes
            UsedPB      = [math]::Round($usedPB, 4)
            UsedTB      = [math]::Round($usedTB, 2)
            UsedPercent = [math]::Round($usedPct, 2)
            Source      = $_.Source
        }
    }

if ($data.Count -lt 2) {
    throw "Not enough data points for trend. Current API worked, but historical data is insufficient."
}

# ----------------------------------------------------------
# Trend and Forecast
# ----------------------------------------------------------
$latest = $data | Sort-Object Date | Select-Object -Last 1

$trendStart = $RunTime.AddDays(-1 * $TrendDays)

$trendData = $data | Where-Object {
    $_.Date -ge $trendStart -and $_.Date -le $RunTime
} | Sort-Object Date

if ($trendData.Count -lt 2) {
    $trendData = $data | Sort-Object Date
}

$trendFirst = $trendData | Select-Object -First 1
$trendLast  = $latest

$trendDateDays = ($trendLast.Date - $trendFirst.Date).TotalDays

if ($trendDateDays -le 0) {
    throw "Invalid trend date range."
}

$growthBytesPerDay = ([double]$trendLast.UsedBytes - [double]$trendFirst.UsedBytes) / $trendDateDays
$growthTBPerDay    = $growthBytesPerDay / $TB

$Info80 = Get-ForecastInfo `
    -TargetBytes ($TotalBytes * 0.80) `
    -CurrentBytes $latest.UsedBytes `
    -GrowthBytesPerDay $growthBytesPerDay `
    -RunDate $RunTime `
    -ReachedText "Already above 80%"

$Info90 = Get-ForecastInfo `
    -TargetBytes ($TotalBytes * 0.90) `
    -CurrentBytes $latest.UsedBytes `
    -GrowthBytesPerDay $growthBytesPerDay `
    -RunDate $RunTime `
    -ReachedText "Already above 90%"

$Info100 = Get-ForecastInfo `
    -TargetBytes ($TotalBytes * 1.00) `
    -CurrentBytes $latest.UsedBytes `
    -GrowthBytesPerDay $growthBytesPerDay `
    -RunDate $RunTime `
    -ReachedText "Already at full capacity"

$WarnHorizonDate = $RunTime.AddDays(90)

$Is90Risk = (
    $latest.UsedPercent -ge 90 -or
    ($Info90.Date -ne $null -and $Info90.Date -le $WarnHorizonDate)
)

$Is80Risk = (
    $latest.UsedPercent -ge 80 -or
    ($Info80.Date -ne $null -and $Info80.Date -le $WarnHorizonDate)
)

$Status = if ($Is90Risk) {
    "Critical"
}
elseif ($Is80Risk) {
    "Warning"
}
else {
    "Healthy"
}

$StatusColor = if ($Status -eq "Critical") {
    "#ff3b3b"
}
elseif ($Status -eq "Warning") {
    "#ffe12b"
}
else {
    "#44d17a"
}

$StatusSubText = if ($Status -eq "Critical") {
    "90% risk within 90 days"
}
elseif ($Status -eq "Warning") {
    "80% risk within 90 days"
}
else {
    "No 80/90 risk within 90 days"
}

$StatusText = if ($Info100.Days -is [int] -or $Info100.Days -is [double]) {
    if ($Info100.Days -gt 90) {
        "Running out of space: More than 90 days"
    }
    else {
        "Running out of space: $($Info100.Days) days"
    }
}
elseif ($Info100.Days -eq "Reached") {
    "Running out of space: Reached"
}
else {
    "Running out of space: No positive growth trend"
}

