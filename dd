# --- Prompt for credentials ---
$cred = Get-Credential   # popup for username/password

# --- Ignore SSL (self-signed certs) ---
add-type @"
using System.Net;
using System.Security.Cryptography.X509Certificates;
public class TrustAllCertsPolicy : ICertificatePolicy {
    public bool CheckValidationResult(ServicePoint srvPoint, X509Certificate certificate,
    WebRequest request, int certificateProblem) { return true; }
}
"@
[System.Net.ServicePointManager]::CertificatePolicy = New-Object TrustAllCertsPolicy

# --- GET system info ---
$ddIP = "https://<dd-ip>"
$response = Invoke-RestMethod -Uri "$ddIP/rest/v1/system" -Method GET -Credential $cred

$response


$dd = "https://<dd-ip>"
$cred = Get-Credential

# 1) See whether the web service is answering at all
Invoke-WebRequest -Uri $dd -Method GET -Credential $cred -SkipCertificateCheck

# 2) Test likely API base paths quickly
"/rest/v1","/api/v1","/rest","/api" | ForEach-Object {
    try {
        $r = Invoke-WebRequest -Uri ($dd + $_) -Method GET -Credential $cred -SkipCertificateCheck -ErrorAction Stop
        [pscustomobject]@{ Path = $_; Status = $r.StatusCode }
    } catch {
        [pscustomobject]@{ Path = $_; Status = $_.Exception.Response.StatusCode.value__ }
    }
}
