import { credentialVaultClient } from "@dynatrace-sdk/client-classic-environment-v2";

export default async function () {

const baseUrl = "https://helios.cohesity.com";

const vaultId = "credentials_vault-312312";
const d2 = await credentialVaultClient.getCredentialsDetails({ id: vaultId });
const apiKey = (d2?.token || d2?.password || "").trim();

if (!apiKey) throw new Error("No Helios API key available.");

const headers = { accept: "application/json", apiKey };

const MAX_ALERTS = 10000;
const ALERT_STATES = ["kOpen","kNote"];

const BUCKETS = [
{key:"kHardware",name:"Hardware"},
{key:"kSoftware",name:"Software"},
{key:"kDataService",name:"Data Service"},
{key:"kMaintenance",name:"Maintenance"}
];

const SYM_OK="✅";
const SYM_C="⛔";
const SYM_W="⚠️";
const SYM_I="ℹ️";

const norm=v=>v==null?"":String(v).trim();
const arr=v=>!v?[]:Array.isArray(v)?v:[v];

function md(headers,rows){
if(!rows.length)return "No data.";
const h=`| ${headers.join(" | ")} |`;
const s=`| ${headers.map(()=> "---").join(" | ")} |`;
const b=rows.map(r=>`| ${headers.map(c=>norm(r[c])).join(" | ")} |`);
return [h,s,...b].join("\n");
}

function pretty(text){
return String(text||"")
.replace(/^k/,"")
.replace(/([a-z])([A-Z])/g,"$1 $2")
.replace(/\b\w/g,c=>c.toUpperCase());
}

function sevBucket(s){
s=norm(s).toLowerCase();
if(s.includes("critical"))return "C";
if(s.includes("warning"))return "W";
if(s.includes("info"))return "I";
return "U";
}

function sevSym(b){
if(b==="C")return SYM_C;
if(b==="W")return SYM_W;
if(b==="I")return SYM_I;
return "";
}

function extractAlerts(p){
return arr(
p?.alerts ||
p?.alertsList?.alerts ||
p?.alertsList ||
p?.alertList ||
p
).filter(x=>x && typeof x==="object");
}

const params=new URLSearchParams();
params.set("maxAlerts",MAX_ALERTS);
params.set("alertStateList",ALERT_STATES.join(","));

const resp=await fetch(`${baseUrl}/v2/mcm/alerts?${params}`,{method:"GET",headers});
if(!resp.ok)throw new Error(`Alerts fetch failed ${resp.status}`);

const data=await resp.json();
const alerts=extractAlerts(data);

const buckets=new Map();
BUCKETS.forEach(b=>buckets.set(b.key,[]));

alerts.forEach(a=>{
const b=a?.alertTypeBucket;
if(buckets.has(b))buckets.get(b).push(a);
});

function dedupe(list){

const m=new Map();

list.forEach(a=>{
const key=`${a.clusterId}|${a.alertCode}`;
const ts=Number(a.latestTimestampUsecs||0);
const occ=Number(a.dedupCount||1);

if(!m.has(key)){
m.set(key,{alert:a,latest:ts,occ});
}else{
const p=m.get(key);
p.occ+=occ;
if(ts>=p.latest){
p.latest=ts;
p.alert=a;
}
}
});

return [...m.values()];
}

function render(bucketKey,bucketName){

let deduped=dedupe(buckets.get(bucketKey));

deduped.sort((a,b)=>{
const ca=a.alert.clusterName||"";
const cb=b.alert.clusterName||"";
return ca.localeCompare(cb);
});

const clusters=[...new Set(deduped.map(x=>x.alert.clusterName))].sort();
const categories=[...new Set(deduped.map(x=>pretty(x.alert.alertCategory)))].sort();

const header=`### Cohesity Helios — Active Alerts — ${bucketName}

Unique: Latest alert per cluster and alertCode
Scope: Active alerts (kOpen, kNote)
`;

const summary=[];

clusters.forEach(c=>{

const row={Cluster:c};
const counts={};

categories.forEach(cat=>{
counts[cat]={C:0,W:0,I:0};
});

deduped.forEach(x=>{
const a=x.alert;
if(a.clusterName!==c)return;

const cat=pretty(a.alertCategory);
const sev=sevBucket(a.severity);

if(counts[cat])counts[cat][sev]++;
});

categories.forEach(cat=>{
const v=counts[cat];

const parts=[];
if(v.C>0)parts.push(`${SYM_C}${v.C}`);
if(v.W>0)parts.push(`${SYM_W}${v.W}`);
if(v.I>0)parts.push(`${SYM_I}${v.I}`);

row[cat]=parts.length?parts.join(" "):SYM_OK;
});

summary.push(row);

});

const summaryMd=`**Summary**

${md(["Cluster",...categories],summary)}
`;

const crit=[],warn=[],info=[];

deduped.forEach(x=>{

const a=x.alert;
const sev=sevBucket(a.severity);

const row={
Cluster:a.clusterName,
Severity:`${sevSym(sev)} ${a.severity}`,
Category:pretty(a.alertCategory),
"Alert Code":a.alertCode,
State:a.alertState,
Occurrences:x.occ,
Description:a?.alertDocument?.alertDescription || ""
};

if(sev==="C")crit.push(row);
else if(sev==="W")warn.push(row);
else if(sev==="I")info.push(row);

});

const headers=[
"Cluster",
"Severity",
"Category",
"Alert Code",
"State",
"Occurrences",
"Description"
];

const parts=["**Details**",""];

if(crit.length){
parts.push(`**${SYM_C} Critical**`);
parts.push(md(headers,crit));
parts.push("\n\n");
}

if(warn.length){
parts.push(`**${SYM_W} Warning**`);
parts.push(md(headers,warn));
parts.push("\n\n");
}

if(info.length){
parts.push(`**${SYM_I} Info**`);
parts.push(md(headers,info));
parts.push("\n\n");
}

return [header,summaryMd,parts.join("\n")].join("\n\n");

}

return {

kHardwareSubject:"Cohesity Helios — Active Alerts — Hardware",
kHardwareMarkdown:render("kHardware","Hardware"),

kSoftwareSubject:"Cohesity Helios — Active Alerts — Software",
kSoftwareMarkdown:render("kSoftware","Software"),

kDataServiceSubject:"Cohesity Helios — Active Alerts — Data Service",
kDataServiceMarkdown:render("kDataService","Data Service"),

kMaintenanceSubject:"Cohesity Helios — Active Alerts — Maintenance",
kMaintenanceMarkdown:render("kMaintenance","Maintenance")

};

}
