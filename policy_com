        $parts += "Oracle: PersistMountpoints=$(ValueOrNA $o.persistMountpoints); VlanId=$(ValueOrNA $o.vlanParams.vlanId); Interface=$(ValueOrNA $o.vlanParams.interfaceName); DisableVlan=$(ValueOrNA $o.vlanParams.disableVlan)"
