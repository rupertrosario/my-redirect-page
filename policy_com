    if ($AlertingPolicy.alertTargets) {
        $targets = @()

        foreach ($t in @($AlertingPolicy.alertTargets)) {
            $targets += "Email=$(ValueOrNA $t.emailAddress); Type=$(ValueOrNA $t.recipientType); Language=$(ValueOrNA $t.language)"
