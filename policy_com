    if ($items.Count -eq 0) { return "N/A" }
    return ($items -join " | ")
}

function Format-BlackoutWindow {
    param($BlackoutWindow)

    if (-not $BlackoutWindow) {
        return "N/A"
    }

    $items = @()

    foreach ($b in @($BlackoutWindow)) {
        $day = ValueOrNA $b.day
        $start = "N/A"
        $end = "N/A"
        $tz = "N/A"

        if ($b.startTime) {
            $start = "$(ValueOrNA $b.startTime.hour):$(ValueOrNA $b.startTime.minute)"
            $tz = ValueOrNA $b.startTime.timeZone
        }

        if ($b.endTime) {
            $end = "$(ValueOrNA $b.endTime.hour):$(ValueOrNA $b.endTime.minute)"
            if ($tz -eq "N/A") { $tz = ValueOrNA $b.endTime.timeZone }
        }

        $items += "Day=$day; Start=$start; End=$end; TimeZone=$tz"
    }

    if ($items.Count -eq 0) { return "N/A" }
    return ($items -join " | ")
}

