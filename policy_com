        if ($copy -ne "N/A") { $parts += "CopyOnSuccess=$copy" }
        if ($runType -ne "N/A") { $parts += "RunType=$runType" }
        if ($timeout -ne "N/A") { $parts += "RunTimeouts=$timeout" }

        $items += ($parts -join "; ")
    }

    if ($items.Count -eq 0) { return "N/A" }
    return ($items -join " | ")
