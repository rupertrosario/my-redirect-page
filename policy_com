function Format-CascadedTargets {
    param(
        $CascadedTargetsConfig,
        [string]$TargetType
    )

    if (-not $CascadedTargetsConfig) {
        return "N/A"
    }

    $items = @()

    foreach ($cfg in @($CascadedTargetsConfig)) {
        $sourceClusterId = ValueOrNA $cfg.sourceClusterId

        if ($TargetType -eq "Replication") {
            $formatted = Format-ReplicationTargets $cfg.remoteTargets.replicationTargets
        }
        elseif ($TargetType -eq "Archival") {
            $formatted = Format-ArchivalTargets $cfg.remoteTargets.archivalTargets
        }
        else {
            $formatted = "N/A"
        }

        if ($formatted -ne "N/A") {
            if ($sourceClusterId -ne "N/A") {
                $items += "SourceClusterId=$sourceClusterId; $formatted"
            }
            else {
                $items += $formatted
            }
        }
    }

    if ($items.Count -eq 0) {
        return "N/A"
    }

    return ($items -join " | ")
}

