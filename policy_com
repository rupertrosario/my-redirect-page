    foreach ($t in @($Targets)) {
        $targetName = "N/A"

        if ($t.target -and $t.target.name) {
            $targetName = ValueOrNA $t.target.name
        }
        elseif ($t.targetName) {
            $targetName = ValueOrNA $t.targetName
        }
        elseif ($t.clusterName) {
            $targetName = ValueOrNA $t.clusterName
        }
        elseif ($t.regionName) {
            $targetName = ValueOrNA $t.regionName
        }
        elseif ($t.regionId) {
