    if ($EnvBackupParams.vmwareParams) {
        $v = $EnvBackupParams.vmwareParams
        $parts += "VMware: FallbackCrashConsistent=$(ValueOrNA $v.fallbackToCrashConsistent); SkipPhysicalRdmDisks=$(ValueOrNA $v.skipPhysicalRdmDisks)"
    }

    if ($EnvBackupParams.awsSnapshotParams) {
        $a = $EnvBackupParams.awsSnapshotParams
        $parts += "AWS: CreateAmi=$(ValueOrNA $a.createAmi); AmiFrequency=$(ValueOrNA $a.amiCreationFrequency)"
    }

    if ($EnvBackupParams.exchangeParams) {
        $e = $EnvBackupParams.exchangeParams
        $parts += "Exchange: BackupsCopyOnly=$(ValueOrNA $e.backupsCopyOnly)"
    }

    if ($EnvBackupParams.pureParams) {
        $p = $EnvBackupParams.pureParams
        $parts += "Pure: MaxSnapshotsOnPrimary=$(ValueOrNA $p.maxSnapshotsOnPrimary)"
    }

    if ($parts.Count -eq 0) {
        return "N/A"
    }

    return ($parts -join " | ")
}

