    if ($EnvBackupParams.sqlParams) {
        $s = $EnvBackupParams.sqlParams
        $parts += "SQL: UserDbPreference=$(ValueOrNA $s.userDbBackupPreferenceType); BackupSystemDbs=$(ValueOrNA $s.backupSystemDbs); AagPreference=$(ValueOrNA $s.aagBackupPreferenceType); CopyOnlyFull=$(ValueOrNA $s.fullBackupsCopyOnly); LogStreams=$(ValueOrNA $s.logBackupNumStreams)"
