function Format-AlertingPolicy {
    param($AlertingPolicy)

    if ($null -eq $AlertingPolicy) {
        return "N/A"
    }

    $parts = @()

    if ($AlertingPolicy.backupRunStatus) {
        $parts += "BackupRunStatus=$((@($AlertingPolicy.backupRunStatus) -join ','))"
    }

    if ($AlertingPolicy.alertTargets) {
        $targets = @()

        foreach ($t in @($AlertingPolicy.alertTargets)) {
            $email = ValueOrNA $t.emailAddress
            $type  = ValueOrNA $t.recipientType

            $targetParts = @()

            if ($email -ne "N/A") {
                $targetParts += "Email=$email"
            }

            if ($type -ne "N/A") {
                $targetParts += "Type=$type"
            }

            if ($targetParts.Count -gt 0) {
                $targets += ($targetParts -join "; ")
            }
        }

        if ($targets.Count -gt 0) {
            $parts += "AlertTargets=$($targets -join ' | ')"
        }
    }

    foreach ($field in @(
        "raiseObjectLevelFailureAlert",
        "raiseObjectLevelFailureAlertAfterLastAttempt",
        "raiseObjectLevelFailureAlertAfterEachAttempt"
    )) {
        if ($null -ne $AlertingPolicy.PSObject.Properties[$field]) {
            $parts += "$field=$(ValueOrNA $AlertingPolicy.$field)"
        }
    }

    if ($parts.Count -eq 0) {
        return "N/A"
    }

    return ($parts -join "; ")
}

