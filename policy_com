# -------------------------------
# Retention classification
# -------------------------------
function Convert-DaysToRetentionLabel {
    param([double]$Days)

    if ($Days -ge 34 -and $Days -le 36) { return "35D" }
    if ($Days -ge 13 -and $Days -le 15) { return "14D" }
    if ($Days -ge 6 -and $Days -le 8)   { return "7D" }
    if ($Days -ge 179 -and $Days -le 184) { return "6M" }
    if ($Days -ge 2554 -and $Days -le 2557) { return "7YR" }

    return "$([int][math]::Round($Days))D"
}

function Convert-RetentionToLabel {
    param(
        $Duration,
        $Unit
    )

    if ($null -eq $Duration) {
        return $null
    }

    [double]$d = 0

    if (-not [double]::TryParse([string]$Duration, [ref]$d)) {
        return $null
    }

    if ($d -le 0) {
        return $null
    }

    $u = (ValueOrNA $Unit).ToUpper()

    switch -Regex ($u) {
        "DAY" {
            return (Convert-DaysToRetentionLabel -Days $d)
        }

        "WEEK" {
            return (Convert-DaysToRetentionLabel -Days ($d * 7))
        }

        "MONTH" {
            if ($d -eq 6)  { return "6M" }
            if ($d -eq 84) { return "7YR" }
            return "$([int][math]::Round($d))M"
        }

        "YEAR" {
            if ($d -eq 7) { return "7YR" }
            return "$([int][math]::Round($d))YR"
        }

        "HOUR" {
            return (Convert-DaysToRetentionLabel -Days ($d / 24))
        }

        "MINUTE" {
            return (Convert-DaysToRetentionLabel -Days ($d / 1440))
        }

        default {
            if ($d -in @(7, 14, 35)) {
                return "$([int]$d)D"
            }
        }
    }

    return $null
}

function Get-RetentionLabelFromName {
    param([string]$PolicyName)

    $n = Normalize-Name $PolicyName

    if ($n -match '(^|[^0-9])7\s*(Y|YR|YRS|YEAR|YEARS)([^A-Z0-9]|$)') { return "7YR" }
    if ($n -match '(^|[^0-9])6\s*(M|MO|MOS|MONTH|MONTHS)([^A-Z0-9]|$)') { return "6M" }
    if ($n -match '(^|[^0-9])35\s*(D|DAY|DAYS)([^A-Z0-9]|$)') { return "35D" }
    if ($n -match '(^|[^0-9])14\s*(D|DAY|DAYS)([^A-Z0-9]|$)') { return "14D" }
    if ($n -match '(^|[^0-9])7\s*(D|DAY|DAYS)([^A-Z0-9]|$)') { return "7D" }

    if ($n -match '(^|[^0-9])35([^0-9]|$)') { return "35D" }
    if ($n -match '(^|[^0-9])14([^0-9]|$)') { return "14D" }
    if ($n -match '(^|[^0-9])7([^0-9]|$)')  { return "7D" }

    return $null
}

function Get-PolicyRetentionLabel {
    param($Policy)

    $fromName = Get-RetentionLabelFromName -PolicyName $Policy.name

    if ($fromName) {
        return $fromName
    }

    try {
        $r = $Policy.backupPolicy.regular.retention

        if ($r) {
            $label = Convert-RetentionToLabel -Duration $r.duration -Unit $r.unit

            if ($label) {
                return $label
            }
        }
    }
    catch {}

    try {
        foreach ($fb in @($Policy.backupPolicy.regular.fullBackups)) {
            if ($fb.retention) {
                $label = Convert-RetentionToLabel -Duration $fb.retention.duration -Unit $fb.retention.unit

                if ($label) {
                    return $label
                }
            }
        }
    }
    catch {}

    try {
        foreach ($er in @($Policy.extendedRetention)) {
            if ($er.retention) {
                $label = Convert-RetentionToLabel -Duration $er.retention.duration -Unit $er.retention.unit

                if ($label) {
                    return $label
                }
            }
        }
    }
    catch {}

    return "UNKNOWN"
}

function Get-ExpectedEnvironment {
    param([string]$PolicyRetention)

    switch ($PolicyRetention) {
        "35D" { return "PROD" }
        "6M"  { return "PROD" }
        "7YR" { return "PROD" }
        "14D" { return "MOD/NONPROD" }
        "7D"  { return "DEV" }
        default { return "UNKNOWN" }
    }
}

# -------------------------------
# Get clusters
# -------------------------------
Write-Host "=============================================" -ForegroundColor Cyan
Write-Host "   COHESITY POLICY INVENTORY CSV" -ForegroundColor White
Write-Host "=============================================" -ForegroundColor Cyan
Write-Host "Output: CSV only" -ForegroundColor Gray

try {
    $cluJson = Invoke-HeliosGetJson -Uri "$baseUrl/v2/mcm/cluster-mgmt/info" -Headers $commonHeaders
}
catch {
    throw "Failed to query Helios clusters: $($_.Exception.Message)"
}

$json_clu = @()

if ($cluJson.cohesityClusters) {
    $json_clu = @($cluJson.cohesityClusters)
}
elseif ($cluJson.clusters) {
    $json_clu = @($cluJson.clusters)
}
elseif ($cluJson.clusterInfos) {
    $json_clu = @($cluJson.clusterInfos)
}
elseif ($cluJson.mcmInfo.clusterInfos) {
    $json_clu = @($cluJson.mcmInfo.clusterInfos)
}

if (-not $json_clu -or $json_clu.Count -eq 0) {
    throw "No clusters returned from Helios."
}

$json_clu = @(
    $json_clu | Sort-Object {
        $n = ($_.name, $_.clusterName, $_.displayName, $_.ClusterName, $_.Name | Where-Object { $_ } | Select-Object -First 1)
        ValueOrNA $n
    }
)

# -------------------------------
# Main collection
# -------------------------------
$script:OptionalHeaders = New-Object System.Collections.ArrayList

$rows = @()
$clusterIssues = @()
$skippedDefaultPolicyCount = 0
$totalPoliciesExported = 0

$coreHeaders = @(
    "Cluster",
    "PolicyName",
    "PolicyRetention",
    "ExpectedEnvironment"
)

foreach ($cluster in $json_clu) {

    $clusterName = ($cluster.name, $cluster.clusterName, $cluster.displayName, $cluster.ClusterName, $cluster.Name | Where-Object { $_ } | Select-Object -First 1)
    $clusterId   = ($cluster.clusterId, $cluster.id, $cluster.ClusterId, $cluster.Id | Where-Object { $_ } | Select-Object -First 1)

    $clusterName = ValueOrNA $clusterName

    if ($clusterName -eq "N/A") {
        $clusterName = "Unknown"
    }

    if (-not $clusterId) {
        $clusterIssues += [pscustomobject]@{
            Cluster = $clusterName
            Issue   = "Cluster ID missing"
        }
        continue
    }

    Write-Host "Processing cluster: $clusterName" -ForegroundColor Cyan

    $headers = @{
        "apiKey" = $apiKey
        "accessClusterId" = [string]$clusterId
        "accept" = "application/json"
    }

    try {
        $policyListJson = Invoke-HeliosGetJson -Uri "$baseUrl/v2/data-protect/policies" -Headers $headers

        if ($policyListJson.policies) {
            $policies = @($policyListJson.policies)
        }
        elseif ($policyListJson -is [array]) {
            $policies = @($policyListJson)
        }
        else {
            $policies = @()
        }
    }
    catch {
        $clusterIssues += [pscustomobject]@{
            Cluster = $clusterName
            Issue   = "Policy fetch failed: $($_.Exception.Message)"
        }
        continue
    }

    foreach ($policy in ($policies | Sort-Object name)) {

        $policyName = ValueOrNA $policy.name

        if (Is-DefaultPolicy -PolicyName $policyName) {
            $skippedDefaultPolicyCount++
            continue
        }

        $policyRetention = Get-PolicyRetentionLabel -Policy $policy
        $expectedEnv = Get-ExpectedEnvironment -PolicyRetention $policyRetention

        $totalPoliciesExported++

        $row = [ordered]@{}

        Add-Core ([ref]$row) "Cluster" $clusterName
        Add-Core ([ref]$row) "PolicyName" $policyName
        Add-Core ([ref]$row) "PolicyRetention" $policyRetention
        Add-Core ([ref]$row) "ExpectedEnvironment" $expectedEnv

        Add-Optional ([ref]$row) "LastModifiedET" (Convert-UsecsToEtString $policy.lastModificationTimeUsecs)

        Add-Optional ([ref]$row) "RegularIncrementalSchedule" (Format-Schedule $policy.backupPolicy.regular.incremental.schedule)
        Add-Optional ([ref]$row) "RegularFullSchedule" (Format-Schedule $policy.backupPolicy.regular.full.schedule)
        Add-Optional ([ref]$row) "RegularRetention" (Format-Retention $policy.backupPolicy.regular.retention)
        Add-Optional ([ref]$row) "RegularFullBackups" (Format-FullBackups $policy.backupPolicy.regular.fullBackups)
        Add-Optional ([ref]$row) "PrimaryBackupTarget" (Format-PrimaryBackupTarget $policy.backupPolicy.regular.primaryBackupTarget)

        Add-Optional ([ref]$row) "LogSchedule" (Format-Schedule $policy.backupPolicy.log.schedule)
        Add-Optional ([ref]$row) "LogRetention" (Format-Retention $policy.backupPolicy.log.retention)

        Add-Optional ([ref]$row) "BmrSchedule" (Format-Schedule $policy.backupPolicy.bmr.schedule)
        Add-Optional ([ref]$row) "BmrRetention" (Format-Retention $policy.backupPolicy.bmr.retention)

        Add-Optional ([ref]$row) "CdpRetention" (Format-Retention $policy.backupPolicy.cdp.retention)

        Add-Optional ([ref]$row) "StorageArraySnapshotSchedule" (Format-Schedule $policy.backupPolicy.storageArraySnapshot.schedule)
        Add-Optional ([ref]$row) "StorageArraySnapshotRetention" (Format-Retention $policy.backupPolicy.storageArraySnapshot.retention)

        Add-Optional ([ref]$row) "RunTimeouts" (Format-RunTimeouts $policy.backupPolicy.runTimeouts)
        Add-Optional ([ref]$row) "RetryOptions" (Format-RetryOptions $policy.retryOptions)

        Add-Optional ([ref]$row) "BlackoutWindow" (Format-BlackoutWindow $policy.blackoutWindow)
        Add-Optional ([ref]$row) "ExtendedRetention" (Format-ExtendedRetention $policy.extendedRetention)

        Add-Optional ([ref]$row) "ReplicationTargets" (Format-ReplicationTargets $policy.remoteTargetPolicy.replicationTargets)
        Add-Optional ([ref]$row) "ArchivalTargets" (Format-ArchivalTargets $policy.remoteTargetPolicy.archivalTargets)
        Add-Optional ([ref]$row) "CloudSpinTargets" (Format-NamedTargets $policy.remoteTargetPolicy.cloudSpinTargets "CloudSpin")
        Add-Optional ([ref]$row) "OnPremDeployTargets" (Format-NamedTargets $policy.remoteTargetPolicy.onpremDeployTargets "OnPremDeploy")
        Add-Optional ([ref]$row) "RpaasTargets" (Format-NamedTargets $policy.remoteTargetPolicy.rpaasTargets "RPaaS")
        Add-Optional ([ref]$row) "OnPremVaultTargets" (Format-NamedTargets $policy.remoteTargetPolicy.onpremVaultTargets "OnPremVault")
        Add-Optional ([ref]$row) "CrossRegionTargets" (Format-NamedTargets $policy.remoteTargetPolicy.crossRegionTargets "CrossRegion")
        Add-Optional ([ref]$row) "SourceTargets" (Format-SourceTargets $policy.remoteTargetPolicy.sourceTargets)

        Add-Optional ([ref]$row) "CascadedReplicationTargets" (Format-CascadedTargets $policy.cascadedTargetsConfig "Replication")
        Add-Optional ([ref]$row) "CascadedArchivalTargets" (Format-CascadedTargets $policy.cascadedTargetsConfig "Archival")

        Add-Optional ([ref]$row) "EnvBackupParams" (Format-EnvBackupParams $policy.rpoPolicySettings.envBackupParams)
        Add-Optional ([ref]$row) "IndexingPolicy" (Format-IndexingPolicy $policy.rpoPolicySettings.indexingPolicy)
        Add-Optional ([ref]$row) "AlertingPolicy" (Format-AlertingPolicy $policy.rpoPolicySettings.alertingPolicy)
        Add-Optional ([ref]$row) "BackupQosPrincipal" $policy.rpoPolicySettings.backupQosPrincipal

        Add-Optional ([ref]$row) "SkipIntervalMins" $policy.skipIntervalMins

        $rows += [pscustomobject]$row
    }
}

# -------------------------------
# Build CSV with dynamic optional headers
# -------------------------------
$allHeaders = @()
$allHeaders += $coreHeaders
$allHeaders += @($script:OptionalHeaders)

$finalRows = @()

foreach ($r in $rows) {
    $out = [ordered]@{}

    foreach ($h in $allHeaders) {
        if ($null -ne $r.PSObject.Properties[$h]) {
            $out[$h] = ValueOrNA $r.$h
        }
        else {
            $out[$h] = "N/A"
        }
    }

    $finalRows += [pscustomobject]$out
}

$timestamp = Get-Date -Format "yyyyMMdd_HHmm"
$csvPath = Join-Path $logDirectory "Cohesity_Policy_Inventory_$timestamp.csv"

$finalRows | Export-Csv -Path $csvPath -NoTypeInformation -Encoding UTF8

# -------------------------------
# Console summary only
# -------------------------------
Write-Host "`n==============================" -ForegroundColor Cyan
Write-Host "POLICY INVENTORY SUMMARY" -ForegroundColor White
Write-Host "==============================" -ForegroundColor Cyan
Write-Host "Clusters discovered        : $($json_clu.Count)"
Write-Host "Policies exported          : $totalPoliciesExported"
Write-Host "Default policies excluded  : $skippedDefaultPolicyCount"
Write-Host "Dynamic columns included   : $($script:OptionalHeaders.Count)"

if ($clusterIssues.Count -gt 0) {
    Write-Host "Cluster fetch issues       : $($clusterIssues.Count)" -ForegroundColor Yellow
    foreach ($ci in $clusterIssues) {
        Write-Host (" - {0}: {1}" -f $ci.Cluster, $ci.Issue) -ForegroundColor Yellow
    }
}

Write-Host "CSV output                 : $csvPath"
Write-Host "=============================="
Write-Host "Processing complete."
