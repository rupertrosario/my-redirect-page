        }

        $schedule = Format-Schedule $t.schedule
        $retention = Format-Retention $t.retention
        $logRetention = Format-Retention $t.logRetention
        $copy = ValueOrNA $t.copyOnRunSuccess
        $runType = ValueOrNA $t.backupRunType
        $timeout = Format-RunTimeouts $t.runTimeouts

        $parts = @("Type=$TargetKind")

        if ($targetName -ne "N/A") { $parts += "Target=$targetName" }
        if ($schedule -ne "N/A") { $parts += "Schedule=$schedule" }
        if ($retention -ne "N/A") { $parts += "Retention=$retention" }
