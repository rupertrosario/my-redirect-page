function Format-BlackoutWindow {
    param($BlackoutWindow)

    if (-not $BlackoutWindow) {
        return "N/A"
    }

    $items = @()

    foreach ($b in @($BlackoutWindow)) {
        $day   = ValueOrNA $b.day
        $start = "N/A"
        $end   = "N/A"

        if ($b.startTime) {
            $hour = ValueOrNA $b.startTime.hour
            $min  = ValueOrNA $b.startTime.minute

            if ($hour -ne "N/A" -and $min -ne "N/A") {
                $start = "$hour`:$min"
            }
        }

        if ($b.endTime) {
            $hour = ValueOrNA $b.endTime.hour
            $min  = ValueOrNA $b.endTime.minute

            if ($hour -ne "N/A" -and $min -ne "N/A") {
                $end = "$hour`:$min"
            }
        }

        $parts = @()

        if ($day -ne "N/A") {
            $parts += "Day=$day"
        }

        if ($start -ne "N/A") {
            $parts += "Start=$start"
        }

        if ($end -ne "N/A") {
            $parts += "End=$end"
        }

        if ($parts.Count -gt 0) {
            $items += ($parts -join "; ")
        }
    }

    if ($items.Count -eq 0) {
        return "N/A"
    }

    return ($items -join " | ")
}

