# =====================================================================
# Cohesity Policy Inventory CSV
# Multi-Cluster | Helios | GET-only | PowerShell 5.1 compatible
#
# Uses:
# - GET /v2/mcm/cluster-mgmt/info
# - GET /v2/data-protect/policies
#
# Output:
# - CSV only
# - One row per non-default policy
# - Dynamic optional headers only when values exist
# - No JSON columns
# - No policy-by-id calls
# - Default policies excluded: Protect Once, Silver, Gold, Bronze
# =====================================================================

$ErrorActionPreference = "Stop"

# -------------------------------
# Config
# -------------------------------
$baseUrl      = "https://helios.cohesity.com"
$apikeypath   = "X:\PowerShell\Cohesity_API_Scripts\DO_NOT_Delete\apikey.txt"
$logDirectory = "X:\PowerShell\Data\Cohesity\PolicyInventory"

if (-not (Test-Path -Path $logDirectory -PathType Container)) {
    New-Item -Path $logDirectory -ItemType Directory -Force | Out-Null
}

if (-not (Test-Path $apikeypath)) {
    throw "API key file not found at $apikeypath"
}

$apiKey = (Get-Content -Path $apikeypath -Raw).Trim()

$commonHeaders = @{
    "apiKey" = $apiKey
    "accept" = "application/json"
}

# -------------------------------
# GET wrapper
# -------------------------------
function Invoke-HeliosGetJson {
    param(
        [Parameter(Mandatory)][string]$Uri,
        [Parameter(Mandatory)][hashtable]$Headers
    )

    if ($PSVersionTable.PSVersion.Major -lt 6) {
        $resp = Invoke-WebRequest -Uri $Uri -Headers $Headers -Method Get -UseBasicParsing -ErrorAction Stop
    }
    else {
        $resp = Invoke-WebRequest -Uri $Uri -Headers $Headers -Method Get -ErrorAction Stop
    }

    if (-not $resp -or [string]::IsNullOrWhiteSpace($resp.Content)) {
        return $null
    }

    return ($resp.Content | ConvertFrom-Json)
}

# -------------------------------
# Generic helpers
# -------------------------------
function ValueOrNA {
    param($Value)

    if ($null -eq $Value) {
        return "N/A"
    }

    if ($Value -is [array]) {
        $items = @(
            $Value | Where-Object {
                $null -ne $_ -and -not [string]::IsNullOrWhiteSpace([string]$_)
            }
        )

        if ($items.Count -eq 0) {
            return "N/A"
        }

        return ($items -join ",")
    }

    $text = [string]$Value

    if ([string]::IsNullOrWhiteSpace($text)) {
        return "N/A"
    }

    return $text.Trim()
}

function Is-UsefulValue {
    param($Value)

    $v = ValueOrNA $Value

    if ($v -eq "N/A") { return $false }
    if ($v -eq "{}")  { return $false }
    if ($v -eq "[]")  { return $false }

    return $true
}

function Normalize-Name {
    param([string]$Name)

    if ([string]::IsNullOrWhiteSpace($Name)) {
        return ""
    }

    $n = $Name.Trim().ToUpper()
    $n = $n -replace "LOG[\s_\-]*SHIPPING", "LOGSHIPPING"
    $n = $n -replace "NON[\s_\-]*PROD", "NONPROD"

    return $n
}

function Is-DefaultPolicy {
    param([string]$PolicyName)

    $compact = (Normalize-Name $PolicyName) -replace '[^A-Z0-9]', ''

    return ($compact -in @(
        "PROTECTONCE",
        "SILVER",
        "GOLD",
        "BRONZE"
    ))
}

function Convert-UsecsToEtString {
    param($Usecs)

    if ($null -eq $Usecs -or "$Usecs" -eq "0" -or "$Usecs" -eq "") {
        return "N/A"
    }

    try {
        [double]$n = [double]$Usecs
        if ($n -le 0) { return "N/A" }

        $ms = [math]::Round($n / 1000)
        $dtUtc = ([DateTime]'1970-01-01T00:00:00Z').AddMilliseconds($ms)

        try {
            $tz = [System.TimeZoneInfo]::FindSystemTimeZoneById("Eastern Standard Time")
            return ([System.TimeZoneInfo]::ConvertTimeFromUtc($dtUtc, $tz)).ToString("yyyy-MM-dd HH:mm:ss")
        }
        catch {
            return $dtUtc.ToString("yyyy-MM-dd HH:mm:ss")
        }
    }
    catch {
        return "N/A"
    }
}

function Format-Retention {
    param($Retention)

    if ($null -eq $Retention) {
        return "N/A"
    }

    $duration = ValueOrNA $Retention.duration
    $unit     = ValueOrNA $Retention.unit

    if ($duration -eq "N/A" -or $unit -eq "N/A") {
        return "N/A"
    }

    if ($duration -eq "0") {
        return "N/A"
    }

    return "$duration $unit"
}

function Format-Schedule {
    param($Schedule)

    if ($null -eq $Schedule) {
        return "N/A"
    }

    $parts = @()

    $unit = ValueOrNA $Schedule.unit
    if ($unit -ne "N/A") {
        $parts += "Unit=$unit"
    }

    if ($Schedule.minuteSchedule -and $Schedule.minuteSchedule.frequency -ne $null -and "$($Schedule.minuteSchedule.frequency)" -ne "0") {
        $parts += "Every=$($Schedule.minuteSchedule.frequency) Minutes"
    }

    if ($Schedule.hourSchedule -and $Schedule.hourSchedule.frequency -ne $null -and "$($Schedule.hourSchedule.frequency)" -ne "0") {
        $parts += "Every=$($Schedule.hourSchedule.frequency) Hours"
    }

    if ($Schedule.daySchedule -and $Schedule.daySchedule.frequency -ne $null -and "$($Schedule.daySchedule.frequency)" -ne "0") {
        $parts += "Every=$($Schedule.daySchedule.frequency) Days"
    }

    if ($Schedule.weekSchedule -and $Schedule.weekSchedule.dayOfWeek) {
        $parts += "Days=$((@($Schedule.weekSchedule.dayOfWeek) -join ','))"
    }

    if ($Schedule.monthSchedule) {
        $m = $Schedule.monthSchedule
        $mp = @()

        if ($m.dayOfWeek) {
            $mp += "Days=$((@($m.dayOfWeek) -join ','))"
        }

        if ((ValueOrNA $m.weekOfMonth) -ne "N/A") {
            $mp += "WeekOfMonth=$(ValueOrNA $m.weekOfMonth)"
        }

        if ($m.dayOfMonth -ne $null -and "$($m.dayOfMonth)" -ne "0") {
            $mp += "DayOfMonth=$(ValueOrNA $m.dayOfMonth)"
        }

        if ($mp.Count -gt 0) {
            $parts += "Month=[$($mp -join '; ')]"
        }
    }

    if ($Schedule.yearSchedule) {
        $y = $Schedule.yearSchedule
        $yp = @()

        if ((ValueOrNA $y.dayOfYear) -ne "N/A") {
            $yp += "DayOfYear=$(ValueOrNA $y.dayOfYear)"
        }

        if ($y.monthDay) {
            if ($y.monthDay.month -ne $null -and "$($y.monthDay.month)" -ne "0") {
                $yp += "Month=$(ValueOrNA $y.monthDay.month)"
            }

            if ($y.monthDay.dayOfTheMonth -ne $null -and "$($y.monthDay.dayOfTheMonth)" -ne "0") {
                $yp += "Day=$(ValueOrNA $y.monthDay.dayOfTheMonth)"
            }
        }

        if ($yp.Count -gt 0) {
            $parts += "Year=[$($yp -join '; ')]"
        }
    }

    if ($Schedule.frequency -ne $null -and "$($Schedule.frequency)" -ne "0") {
        $parts += "Frequency=$(ValueOrNA $Schedule.frequency)"
    }

    if ($parts.Count -eq 0) {
        return "N/A"
    }

    return ($parts -join "; ")
}

