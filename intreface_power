# Headers (keep your existing $ApiKey / $Cluster_id variables)
$headers = @{
  accept          = 'application/json'
  apiKey          = $ApiKey
  accessClusterId = $Cluster_id
}

# Body must be JSON (booleans, not strings)
$body = @{ includeBondSlaveDetails = $true; includeStats = $true } | ConvertTo-Json -Depth 5

$url = 'https://helios.cohesity.com/irisservices/api/v1/public/interface'

# Use POST (GET+Body is wrong/ignored in PowerShell)
$json = Invoke-RestMethod -Method Post -Uri $url -Headers $headers -ContentType 'application/json' -Body $body

$results = foreach ($i in $json.interfaces) {
  [pscustomobject]@{
    Name       = $i.name
    MacAddress = $i.macAddress
    RxBytes    = $i.stats.rxBytes
    TxBytes    = $i.stats.txBytes
  }
}

$results | Format-Table -AutoSize
