# =========================================
# Cohesity - Users Only - Easy Multi Cluster
# Paste normal cluster URLs below
# Put only one special URL for different domain
# Uses separate credential prompt for special domain
# =========================================

# --------- Paste your cluster URLs here ----------
$clusterUrls = @(
    "https://cluster1.domain.com",
    "https://cluster2.domain.com",
    "https://cluster3.domain.com"
)

# --------- Only if one cluster uses a different domain ----------
$specialClusterUrl = "https://alb.domain.com"   # leave blank if none

# --------- Domains ----------
$defaultDomain = "YOUR_DEFAULT_AD_DOMAIN"
$specialDomain = "YOUR_SPECIAL_AD_DOMAIN"       # domain for special cluster

# --------- Prompt for credentials ----------
Write-Host "Enter credentials for default domain: $defaultDomain" -ForegroundColor Yellow
$defaultCred = Get-Credential

$specialCred = $null
if ($specialClusterUrl -and $specialClusterUrl.Trim() -ne "") {
    Write-Host "Enter credentials for special domain: $specialDomain" -ForegroundColor Yellow
    $specialCred = Get-Credential
}

# --------- Combine all URLs ----------
$allClusterUrls = @($clusterUrls)
if ($specialClusterUrl -and $specialClusterUrl.Trim() -ne "") {
    $allClusterUrls += $specialClusterUrl
}

$final = @()

foreach ($clusterUrl in $allClusterUrls) {

    # Pick domain + credential automatically
    if ($clusterUrl -eq $specialClusterUrl) {
        $domain = $specialDomain
        $cred   = $specialCred
    } else {
        $domain = $defaultDomain
        $cred   = $defaultCred
    }

    Write-Host "`nProcessing $clusterUrl" -ForegroundColor Cyan

    # Get token
    $authHeaders = @{
        "accept"       = "application/json"
        "content-type" = "application/json"
    }

    $authBody = @{
        username = $cred.UserName
        password = $cred.GetNetworkCredential().Password
        domain   = $domain
    } | ConvertTo-Json

    try {
        $authResponse = Invoke-RestMethod `
            -Uri "$clusterUrl/v2/access-tokens" `
            -Method POST `
            -Headers $authHeaders `
            -Body $authBody `
            -ErrorAction Stop

        if (-not $authResponse.accessToken) {
            throw "No access token returned."
        }

        $token = $authResponse.accessToken
    }
    catch {
        $final += [PSCustomObject]@{
            ClusterUrl = $clusterUrl
            Username   = ""
            Domain     = $domain
            Roles      = ""
            Status     = "TOKEN_FAILED"
        }
        continue
    }

    # Get users
    $apiHeaders = @{
        "accept"        = "application/json"
        "authorization" = "Bearer $token"
    }

    try {
        $usersResponse = Invoke-RestMethod `
            -Uri "$clusterUrl/v2/users" `
            -Method GET `
            -Headers $apiHeaders `
            -ErrorAction Stop

        $usersList = if ($usersResponse.users) { $usersResponse.users } else { $usersResponse }

        foreach ($u in $usersList) {
            $final += [PSCustomObject]@{
                ClusterUrl = $clusterUrl
                Username   = $u.username
                Domain     = $u.domain
                Roles      = (($u.roles | ForEach-Object { $_.name }) -join ", ")
                Status     = "OK"
            }
        }
    }
    catch {
        $final += [PSCustomObject]@{
            ClusterUrl = $clusterUrl
            Username   = ""
            Domain     = $domain
            Roles      = ""
            Status     = "USERS_FAILED"
        }
    }
}

$final | Format-Table -AutoSize
