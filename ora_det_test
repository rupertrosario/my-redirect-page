# =====================================================================
# Cohesity Oracle One Cluster / One PGID Run Debug
# STRICTLY READ-ONLY GET-only
#
# Purpose:
# - Work only on ONE cluster and ONE PGID
# - Directly call:
#   /v2/data-protect/protection-groups/{PGID}/runs
#
# Checks:
# - runs[].localBackupInfo.runType
# - runs[].localBackupInfo.endTimeUsecs
# - runs[].objects[].object.name
# - runs[].objects[].localSnapshotInfo.snapshotInfo.status
# - runs[].objects[].localSnapshotInfo.snapshotInfo.endTimeUsecs
# - runs[].objects[].localSnapshotInfo.snapshotInfo.snapshotCreationTimeUsecs
#
# Output:
# - Console table
# - Raw JSON file
# - Flattened CSV
# =====================================================================

$ErrorActionPreference = "Stop"
$FormatEnumerationLimit = -1
[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12

# -------------------------------
# Fill these two
# -------------------------------
$ClusterId = "PASTE_CLUSTER_ID_HERE"
$PgId      = "PASTE_PGID_HERE"

# -------------------------------
# Settings
# -------------------------------
$baseUrl    = "https://helios.cohesity.com"
$apikeypath = "X:\PowerShell\Cohesity_API_Scripts\DO_NOT_Delete\apikey.txt"
$outDir     = "H:\Cohesity_API\Logs"

$MaxPages = 5

if (-not (Test-Path $outDir)) {
    New-Item -Path $outDir -ItemType Directory | Out-Null
}

if (-not (Test-Path $apikeypath)) {
    throw "API key file not found: $apikeypath"
}

$apiKey = (Get-Content -Path $apikeypath -Raw).Trim()

$headers = @{
    apiKey          = $apiKey
    accessClusterId = $ClusterId
    accept          = "application/json"
}

# =====================================================================
# Helpers
# =====================================================================
function Invoke-HeliosGetJson {
    param(
        [Parameter(Mandatory)][string]$Uri,
        [Parameter(Mandatory)][hashtable]$Headers
    )

    $resp = Invoke-WebRequest -Uri $Uri -Headers $Headers -Method Get -UseBasicParsing

    if (-not $resp -or [string]::IsNullOrWhiteSpace($resp.Content)) {
        return $null
    }

    return ($resp.Content | ConvertFrom-Json)
}

function Get-FirstNonEmpty {
    param([object[]]$Values)

    foreach ($v in @($Values)) {
        foreach ($vv in @($v)) {
            if ($null -ne $vv -and "$vv".Trim() -ne "") {
                return $vv
            }
        }
    }

    return ""
}

function To-Number {
    param($Value)

    if ($null -eq $Value -or "$Value".Trim() -eq "") {
        return 0
    }

    try {
        return [double]$Value
    }
    catch {
        return 0
    }
}

function Convert-UsecsToET {
    param($Usecs)

    if ($null -eq $Usecs -or "$Usecs".Trim() -eq "" -or "$Usecs" -eq "0") {
        return ""
    }

    try {
        $epochUtc = [DateTime]::SpecifyKind([datetime]"1970-01-01 00:00:00", [DateTimeKind]::Utc)
        $dtUtc = $epochUtc.AddSeconds(([double]$Usecs / 1000000))

        try {
            $tz = [TimeZoneInfo]::FindSystemTimeZoneById("Eastern Standard Time")
            $dtEt = [TimeZoneInfo]::ConvertTimeFromUtc($dtUtc, $tz)
            return $dtEt.ToString("yyyy-MM-dd HH:mm:ss")
        }
        catch {
            return ($dtUtc.ToString("yyyy-MM-dd HH:mm:ss") + " UTC")
        }
    }
    catch {
        return ""
    }
}

function Test-LogRunType {
    param([string]$RunType)

    if ([string]::IsNullOrWhiteSpace($RunType)) {
        return $false
    }

    return ($RunType -match '(?i)log|archive')
}

# =====================================================================
# Call /runs for this PGID
# =====================================================================
Write-Host ""
Write-Host "ClusterId : $ClusterId" -ForegroundColor Cyan
Write-Host "PGID      : $PgId" -ForegroundColor Cyan

$allRuns = @()
$page = 0
$cookie = ""

do {
    $page++

    $runsUri = "$baseUrl/v2/data-protect/protection-groups/$PgId/runs"

    if (-not [string]::IsNullOrWhiteSpace($cookie)) {
        $runsUri = "$runsUri`?paginationCookie=$([uri]::EscapeDataString($cookie))"
    }

    Write-Host ""
    Write-Host "Calling page $page :" -ForegroundColor Yellow
    Write-Host $runsUri

    $runsJson = Invoke-HeliosGetJson -Uri $runsUri -Headers $headers

    $runsThisPage = @($runsJson.runs | Where-Object { $_ })
    $allRuns += $runsThisPage

    Write-Host "Runs returned on page $page : $($runsThisPage.Count)" -ForegroundColor Yellow

    $cookie = Get-FirstNonEmpty -Values @($runsJson.paginationCookie)

    if ($runsJson.isResponseTruncated -ne $true) {
        break
    }

} while (-not [string]::IsNullOrWhiteSpace($cookie) -and $page -lt $MaxPages)

# =====================================================================
# Save raw JSON
# =====================================================================
$stamp = Get-Date -Format "yyyy-MM-dd_HHmmss"

$rawJsonPath = Join-Path $outDir "one_pg_runs_raw_$stamp.json"

[PSCustomObject]@{
    ClusterId = $ClusterId
    PGID      = $PgId
    Runs      = $allRuns
} |
ConvertTo-Json -Depth 100 |
Out-File -FilePath $rawJsonPath -Encoding utf8

# =====================================================================
# Flatten run/object rows
# =====================================================================
$rows = @()
$runIndex = 0

foreach ($run in $allRuns) {

    $runIndex++

    $runType = Get-FirstNonEmpty -Values @(
        $run.localBackupInfo.runType,
        $run.originalBackupInfo.runType,
        $run.runType
    )

    $runStatus = Get-FirstNonEmpty -Values @(
        $run.localBackupInfo.status,
        $run.originalBackupInfo.status,
        $run.status
    )

    $runEndUsecs = Get-FirstNonEmpty -Values @(
        $run.localBackupInfo.endTimeUsecs,
        $run.originalBackupInfo.endTimeUsecs,
        $run.endTimeUsecs
    )

    $runStartUsecs = Get-FirstNonEmpty -Values @(
        $run.localBackupInfo.startTimeUsecs,
        $run.originalBackupInfo.startTimeUsecs,
        $run.startTimeUsecs
    )

    $objects = @($run.objects | Where-Object { $_ })

    if ($objects.Count -eq 0) {
        $rows += [PSCustomObject]@{
            RunIndex              = $runIndex
            ObjectIndex           = ""
            RunType               = $runType
            IsLogRun              = Test-LogRunType -RunType $runType
            RunStatus             = $runStatus
            RunStartUsecs         = $runStartUsecs
            RunStartET            = Convert-UsecsToET -Usecs $runStartUsecs
            RunEndUsecs           = $runEndUsecs
            RunEndET              = Convert-UsecsToET -Usecs $runEndUsecs

            DBName                = ""
            ObjectId              = ""
            ObjectSourceName      = ""

            SnapshotStatus        = ""
            ObjEndUsecs           = ""
            ObjEndET              = ""
            SnapshotCreateUsecs   = ""
            SnapshotCreateET      = ""

            EffectiveBackupUsecs  = $runEndUsecs
            EffectiveBackupET     = Convert-UsecsToET -Usecs $runEndUsecs

            HasObject             = "No"
            HasObjectEndTime      = "No"
        }

        continue
    }

    $objectIndex = 0

    foreach ($obj in $objects) {

        $objectIndex++

        $dbName = Get-FirstNonEmpty -Values @(
            $obj.object.name,
            $obj.name
        )

        $objectId = Get-FirstNonEmpty -Values @(
            $obj.object.id
        )

        $objectSourceName = Get-FirstNonEmpty -Values @(
            $obj.object.sourceName
        )

        $snapshotStatus = Get-FirstNonEmpty -Values @(
            $obj.localSnapshotInfo.snapshotInfo.status,
            $obj.originalBackupInfo.snapshotInfo.status
        )

        $objEndUsecs = Get-FirstNonEmpty -Values @(
            $obj.localSnapshotInfo.snapshotInfo.endTimeUsecs,
            $obj.originalBackupInfo.snapshotInfo.endTimeUsecs
        )

        $snapshotCreateUsecs = Get-FirstNonEmpty -Values @(
            $obj.localSnapshotInfo.snapshotInfo.snapshotCreationTimeUsecs,
            $obj.originalBackupInfo.snapshotInfo.snapshotCreationTimeUsecs
        )

        # Effective backup time: object end first, snapshot creation second, run end third.
        $effectiveUsecs = Get-FirstNonEmpty -Values @(
            $objEndUsecs,
            $snapshotCreateUsecs,
            $runEndUsecs
        )

        $rows += [PSCustomObject]@{
            RunIndex              = $runIndex
            ObjectIndex           = $objectIndex
            RunType               = $runType
            IsLogRun              = Test-LogRunType -RunType $runType
            RunStatus             = $runStatus
            RunStartUsecs         = $runStartUsecs
            RunStartET            = Convert-UsecsToET -Usecs $runStartUsecs
            RunEndUsecs           = $runEndUsecs
            RunEndET              = Convert-UsecsToET -Usecs $runEndUsecs

            DBName                = $dbName
            ObjectId              = $objectId
            ObjectSourceName      = $objectSourceName

            SnapshotStatus        = $snapshotStatus
            ObjEndUsecs           = $objEndUsecs
            ObjEndET              = Convert-UsecsToET -Usecs $objEndUsecs
            SnapshotCreateUsecs   = $snapshotCreateUsecs
            SnapshotCreateET      = Convert-UsecsToET -Usecs $snapshotCreateUsecs

            EffectiveBackupUsecs  = $effectiveUsecs
            EffectiveBackupET     = Convert-UsecsToET -Usecs $effectiveUsecs

            HasObject             = "Yes"
            HasObjectEndTime      = if ($objEndUsecs) { "Yes" } else { "No" }
        }
    }
}

# =====================================================================
# Latest summary from this one PG
# =====================================================================
$latestIndex = @{}

foreach ($r in $rows) {

    if ([string]::IsNullOrWhiteSpace($r.DBName)) {
        continue
    }

    $key = $r.DBName.Trim().ToUpper()

    if (-not $latestIndex.ContainsKey($key)) {
        $latestIndex[$key] = [PSCustomObject]@{
            DBName                    = $r.DBName
            LatestRegularBackupUsecs  = 0
            LatestRegularBackupET     = ""
            LatestLogBackupUsecs      = 0
            LatestLogBackupET         = ""
        }
    }

    $entry = $latestIndex[$key]
    $backupNum = To-Number -Value $r.EffectiveBackupUsecs

    if ($backupNum -le 0) {
        continue
    }

    if ($r.IsLogRun -eq $true) {
        if ($backupNum -gt [double]$entry.LatestLogBackupUsecs) {
            $entry.LatestLogBackupUsecs = $backupNum
            $entry.LatestLogBackupET    = $r.EffectiveBackupET
        }
    }
    else {
        if ($backupNum -gt [double]$entry.LatestRegularBackupUsecs) {
            $entry.LatestRegularBackupUsecs = $backupNum
            $entry.LatestRegularBackupET    = $r.EffectiveBackupET
        }
    }
}

$latestRows = $latestIndex.Values |
    Select-Object DBName, LatestRegularBackupET, LatestLogBackupET |
    Sort-Object DBName

# =====================================================================
# Output
# =====================================================================
$rawCsvPath    = Join-Path $outDir "one_pg_runs_flattened_$stamp.csv"
$latestCsvPath = Join-Path $outDir "one_pg_latest_backup_$stamp.csv"

$rows |
    Export-Csv -Path $rawCsvPath -NoTypeInformation -Encoding utf8

$latestRows |
    Export-Csv -Path $latestCsvPath -NoTypeInformation -Encoding utf8

Write-Host ""
Write-Host "Summary" -ForegroundColor Cyan
Write-Host "Total runs              : $($allRuns.Count)"
Write-Host "Flattened rows          : $($rows.Count)"
Write-Host "Rows with objects       : $(@($rows | Where-Object { $_.HasObject -eq 'Yes' }).Count)"
Write-Host "Rows with DBName        : $(@($rows | Where-Object { $_.DBName }).Count)"
Write-Host "Rows with ObjEndET      : $(@($rows | Where-Object { $_.ObjEndET }).Count)"
Write-Host "Rows with Effective ET  : $(@($rows | Where-Object { $_.EffectiveBackupET }).Count)"
Write-Host "Latest DB rows          : $($latestRows.Count)"

Write-Host ""
Write-Host "Raw JSON       : $rawJsonPath" -ForegroundColor Green
Write-Host "Flattened CSV  : $rawCsvPath" -ForegroundColor Green
Write-Host "Latest CSV     : $latestCsvPath" -ForegroundColor Green

Write-Host ""
Write-Host "First 30 flattened rows:" -ForegroundColor Cyan

$rows |
    Select-Object -First 30 `
        RunIndex,
        ObjectIndex,
        RunType,
        IsLogRun,
        RunStatus,
        DBName,
        SnapshotStatus,
        ObjEndET,
        SnapshotCreateET,
        RunEndET,
        EffectiveBackupET |
    Format-Table -AutoSize

Write-Host ""
Write-Host "Latest backup summary:" -ForegroundColor Cyan

$latestRows |
    Format-Table -AutoSize
