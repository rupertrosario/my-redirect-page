$ErrorActionPreference = "Stop"
[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12

$baseUrl = "https://helios.cohesity.com"
$apikeypath = "X:\PowerShell\Cohesity_API_Scripts\DO_NOT_Delete\apikey.txt"
$apiKey = (Get-Content -Path $apikeypath -Raw).Trim()

# Put one cluster ID here
$clusterId = "PASTE_CLUSTER_ID_HERE"

$headers = @{
    apiKey          = $apiKey
    accessClusterId = $clusterId
    accept          = "application/json"
}

function Invoke-HeliosGetJson {
    param(
        [string]$Uri,
        [hashtable]$Headers
    )

    $resp = Invoke-WebRequest -Uri $Uri -Headers $Headers -Method Get -UseBasicParsing
    return ($resp.Content | ConvertFrom-Json)
}

function Convert-UsecsToET {
    param($Usecs)

    if (-not $Usecs) { return "" }

    $epochUtc = [DateTime]::SpecifyKind([datetime]"1970-01-01 00:00:00", [DateTimeKind]::Utc)
    $dtUtc = $epochUtc.AddSeconds(([double]$Usecs / 1000000))
    $tz = [TimeZoneInfo]::FindSystemTimeZoneById("Eastern Standard Time")

    return ([TimeZoneInfo]::ConvertTimeFromUtc($dtUtc, $tz)).ToString("yyyy-MM-dd HH:mm:ss")
}

# Get Oracle PGs
$pgUri = "$baseUrl/v2/data-protect/protection-groups?environments=kOracle&isDeleted=false&isActive=true&includeLastRunInfo=true"
$pgJson = Invoke-HeliosGetJson -Uri $pgUri -Headers $headers

$pgs = @($pgJson.protectionGroups | Where-Object { $_ })

Write-Host ""
Write-Host "Oracle PGs found: $($pgs.Count)" -ForegroundColor Cyan

$pgs |
Select-Object `
    @{n="PGName";e={$_.name}},
    @{n="Id";e={$_.id}},
    @{n="ProtectionGroupId";e={$_.protectionGroupId}} |
Format-Table -AutoSize

# Pick first PG for test
$pg = $pgs | Select-Object -First 1

Write-Host ""
Write-Host "Testing PG: $($pg.name)" -ForegroundColor Yellow
Write-Host "PG id: $($pg.id)"
Write-Host "PG protectionGroupId: $($pg.protectionGroupId)"

$pgId = if ($pg.id) { $pg.id } else { $pg.protectionGroupId }

$runsUri = "$baseUrl/v2/data-protect/protection-groups/$pgId/runs"
$runsJson = Invoke-HeliosGetJson -Uri $runsUri -Headers $headers

$runs = @($runsJson.runs | Where-Object { $_ })

Write-Host ""
Write-Host "Runs returned: $($runs.Count)" -ForegroundColor Cyan

$debugRows = @()

foreach ($run in $runs) {

    $runType = $run.localBackupInfo.runType

    foreach ($obj in @($run.objects | Where-Object { $_ })) {

        $dbName = $obj.object.name

        $endUsecs = $obj.localSnapshotInfo.snapshotInfo.endTimeUsecs

        if (-not $endUsecs) {
            $endUsecs = $obj.localSnapshotInfo.snapshotInfo.snapshotCreationTimeUsecs
        }

        $debugRows += [PSCustomObject]@{
            RunType        = $runType
            DBName         = $dbName
            ObjectId       = $obj.object.id
            SnapshotStatus = $obj.localSnapshotInfo.snapshotInfo.status
            EndUsecs       = $endUsecs
            EndTimeET      = if ($endUsecs) { Convert-UsecsToET -Usecs $endUsecs } else { "" }
        }
    }
}

Write-Host ""
Write-Host "Run object rows found: $($debugRows.Count)" -ForegroundColor Cyan

$debugRows |
Sort-Object DBName, RunType |
Format-Table -AutoSize

$debugCsv = "H:\Cohesity_API\Logs\oracle_run_debug.csv"
$debugRows | Export-Csv -Path $debugCsv -NoTypeInformation -Encoding utf8

Write-Host ""
Write-Host "Debug CSV exported: $debugCsv" -ForegroundColor Green
