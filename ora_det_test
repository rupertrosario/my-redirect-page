# =====================================================================
# Cohesity Oracle - One Cluster / One PGID Latest Backup Test
# STRICTLY READ-ONLY GET-only
#
# Source:
# - /v2/data-protect/protection-groups/{PGID}/runs
#
# Uses:
# - runs[].localBackupInfo.runType
# - runs[].localBackupInfo.status
# - runs[].localBackupInfo.endTimeUsecs
#
# Output:
# - LatestRegularBackupET
# - LatestLogBackupET
# - ReplicationTargetCluster
# - LatestReplicationEndTimeET
# =====================================================================

$ErrorActionPreference = "Stop"
[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12

# -------------------------------
# Fill these
# -------------------------------
$ClusterId = "PASTE_CLUSTER_ID_HERE"
$PgId      = "PASTE_PGID_HERE"

# -------------------------------
# Settings
# -------------------------------
$baseUrl    = "https://helios.cohesity.com"
$apikeypath = "X:\PowerShell\Cohesity_API_Scripts\DO_NOT_Delete\apikey.txt"
$outDir     = "H:\Cohesity_API\Logs"

$MaxRunPages = 10

if (-not (Test-Path $outDir)) {
    New-Item -Path $outDir -ItemType Directory | Out-Null
}

if (-not (Test-Path $apikeypath)) {
    throw "API key file not found: $apikeypath"
}

$apiKey = (Get-Content -Path $apikeypath -Raw).Trim()

$headers = @{
    apiKey          = $apiKey
    accessClusterId = $ClusterId
    accept          = "application/json"
}

# =====================================================================
# Helpers
# =====================================================================
function Invoke-HeliosGetJson {
    param(
        [Parameter(Mandatory)][string]$Uri,
        [Parameter(Mandatory)][hashtable]$Headers
    )

    $resp = Invoke-WebRequest -Uri $Uri -Headers $Headers -Method Get -UseBasicParsing

    if (-not $resp -or [string]::IsNullOrWhiteSpace($resp.Content)) {
        return $null
    }

    return ($resp.Content | ConvertFrom-Json)
}

function Get-FirstNonEmpty {
    param([object[]]$Values)

    foreach ($v in @($Values)) {
        foreach ($vv in @($v)) {
            if ($null -ne $vv -and "$vv".Trim() -ne "") {
                return $vv
            }
        }
    }

    return ""
}

function To-Number {
    param($Value)

    if ($null -eq $Value -or "$Value".Trim() -eq "") {
        return 0
    }

    try {
        return [double]$Value
    }
    catch {
        return 0
    }
}

function Convert-UsecsToET {
    param($Usecs)

    if ($null -eq $Usecs -or "$Usecs".Trim() -eq "" -or "$Usecs" -eq "0") {
        return ""
    }

    try {
        $epochUtc = [DateTime]::SpecifyKind([datetime]"1970-01-01 00:00:00", [DateTimeKind]::Utc)
        $dtUtc = $epochUtc.AddSeconds(([double]$Usecs / 1000000))

        try {
            $tz = [TimeZoneInfo]::FindSystemTimeZoneById("Eastern Standard Time")
            $dtEt = [TimeZoneInfo]::ConvertTimeFromUtc($dtUtc, $tz)
            return $dtEt.ToString("yyyy-MM-dd HH:mm:ss")
        }
        catch {
            return ($dtUtc.ToString("yyyy-MM-dd HH:mm:ss") + " UTC")
        }
    }
    catch {
        return ""
    }
}

function Test-SuccessStatus {
    param([string]$Status)

    if ([string]::IsNullOrWhiteSpace($Status)) {
        return $false
    }

    return ($Status -match '(?i)success|succeed|succeededwithwarning|warning')
}

function Test-LogRunType {
    param([string]$RunType)

    if ([string]::IsNullOrWhiteSpace($RunType)) {
        return $false
    }

    return ($RunType -match '(?i)log|archive')
}

function Get-ReplicationTarget {
    param([object]$Run)

    return Get-FirstNonEmpty -Values @(
        $Run.replicationInfo.replicationTargetResults.clusterName,
        $Run.replicationInfo.replicationTargetResults.ClusterName,
        $Run.replicationInfo.replicationTargetResults.targetClusterName,
        $Run.replicationInfo.replicationTargetResults.targetName,
        $Run.localBackupInfo.replicationInfo.replicationTargetResults.clusterName,
        $Run.localBackupInfo.replicationInfo.replicationTargetResults.ClusterName,
        $Run.localBackupInfo.replicationInfo.replicationTargetResults.targetClusterName,
        $Run.localBackupInfo.replicationInfo.replicationTargetResults.targetName
    )
}

function Get-ReplicationEndUsecs {
    param([object]$Run)

    return Get-FirstNonEmpty -Values @(
        $Run.replicationInfo.replicationTargetResults.endTimeUsecs,
        $Run.replicationInfo.replicationTargetResults.endTimeInUsecs,
        $Run.replicationInfo.replicationTargetResults.replicationEndTimeUsecs,
        $Run.replicationInfo.replicationTargetResults.finishTimeUsecs,
        $Run.replicationInfo.replicationTargetResults.completedTimeUsecs,
        $Run.replicationInfo.replicationTargetResults.completionTimeUsecs,

        $Run.localBackupInfo.replicationInfo.replicationTargetResults.endTimeUsecs,
        $Run.localBackupInfo.replicationInfo.replicationTargetResults.endTimeInUsecs,
        $Run.localBackupInfo.replicationInfo.replicationTargetResults.replicationEndTimeUsecs,
        $Run.localBackupInfo.replicationInfo.replicationTargetResults.finishTimeUsecs,
        $Run.localBackupInfo.replicationInfo.replicationTargetResults.completedTimeUsecs,
        $Run.localBackupInfo.replicationInfo.replicationTargetResults.completionTimeUsecs
    )
}

# =====================================================================
# Get runs
# =====================================================================
$allRuns = @()
$page = 0
$cookie = ""

do {
    $page++

    $runsUri = "$baseUrl/v2/data-protect/protection-groups/$PgId/runs"

    if (-not [string]::IsNullOrWhiteSpace($cookie)) {
        $runsUri = "$runsUri`?paginationCookie=$([uri]::EscapeDataString($cookie))"
    }

    Write-Host ""
    Write-Host "Calling page $page" -ForegroundColor Yellow
    Write-Host $runsUri

    $runsJson = Invoke-HeliosGetJson -Uri $runsUri -Headers $headers

    $runsThisPage = @($runsJson.runs | Where-Object { $_ })
    $allRuns += $runsThisPage

    Write-Host "Runs returned: $($runsThisPage.Count)" -ForegroundColor Cyan

    $cookie = Get-FirstNonEmpty -Values @($runsJson.paginationCookie)

    if ($runsJson.isResponseTruncated -ne $true) {
        break
    }

} while (-not [string]::IsNullOrWhiteSpace($cookie) -and $page -lt $MaxRunPages)

# =====================================================================
# Flatten run-level data only
# =====================================================================
$runRows = @()

foreach ($run in $allRuns) {

    $runType = Get-FirstNonEmpty -Values @(
        $run.localBackupInfo.runType,
        $run.originalBackupInfo.runType,
        $run.runType
    )

    $runStatus = Get-FirstNonEmpty -Values @(
        $run.localBackupInfo.status,
        $run.originalBackupInfo.status,
        $run.status
    )

    $runEndUsecs = Get-FirstNonEmpty -Values @(
        $run.localBackupInfo.endTimeUsecs,
        $run.originalBackupInfo.endTimeUsecs,
        $run.endTimeUsecs
    )

    $repTarget = Get-ReplicationTarget -Run $run
    $repEndUsecs = Get-ReplicationEndUsecs -Run $run

    $runRows += [PSCustomObject]@{
        RunType                  = $runType
        IsLogRun                 = Test-LogRunType -RunType $runType
        Status                   = $runStatus
        IsSuccess                = Test-SuccessStatus -Status $runStatus
        RunEndUsecs              = $runEndUsecs
        RunEndET                 = Convert-UsecsToET -Usecs $runEndUsecs
        ReplicationTargetCluster = $repTarget
        ReplicationEndUsecs      = $repEndUsecs
        ReplicationEndTimeET     = Convert-UsecsToET -Usecs $repEndUsecs
    }
}

# =====================================================================
# Latest calculation
# =====================================================================
$latestRegularUsecs = 0
$latestRegularET = ""

$latestLogUsecs = 0
$latestLogET = ""

$latestReplicationUsecs = 0
$latestReplicationET = ""
$latestReplicationTarget = ""

foreach ($r in $runRows) {

    if ($r.IsSuccess -ne $true) {
        continue
    }

    $runEndNum = To-Number -Value $r.RunEndUsecs

    if ($runEndNum -gt 0) {
        if ($r.IsLogRun -eq $true) {
            if ($runEndNum -gt $latestLogUsecs) {
                $latestLogUsecs = $runEndNum
                $latestLogET = $r.RunEndET
            }
        }
        else {
            if ($runEndNum -gt $latestRegularUsecs) {
                $latestRegularUsecs = $runEndNum
                $latestRegularET = $r.RunEndET
            }
        }
    }

    $repEndNum = To-Number -Value $r.ReplicationEndUsecs

    if ($repEndNum -gt 0) {
        if ($repEndNum -gt $latestReplicationUsecs) {
            $latestReplicationUsecs = $repEndNum
            $latestReplicationET = $r.ReplicationEndTimeET
            $latestReplicationTarget = $r.ReplicationTargetCluster
        }
    }
    elseif ([string]::IsNullOrWhiteSpace($latestReplicationTarget) -and
            -not [string]::IsNullOrWhiteSpace($r.ReplicationTargetCluster)) {
        $latestReplicationTarget = $r.ReplicationTargetCluster
    }
}

$summary = [PSCustomObject]@{
    ClusterId                  = $ClusterId
    PGID                       = $PgId
    LatestRegularBackupET      = $latestRegularET
    LatestLogBackupET          = $latestLogET
    ReplicationTargetCluster   = $latestReplicationTarget
    LatestReplicationEndTimeET = $latestReplicationET
}

# =====================================================================
# Output
# =====================================================================
$stamp = Get-Date -Format "yyyy-MM-dd_HHmmss"

$runCsv = Join-Path $outDir "one_pg_run_level_test_$stamp.csv"
$summaryCsv = Join-Path $outDir "one_pg_latest_summary_$stamp.csv"

$runRows |
    Sort-Object RunEndUsecs -Descending |
    Export-Csv -Path $runCsv -NoTypeInformation -Encoding utf8

$summary |
    Export-Csv -Path $summaryCsv -NoTypeInformation -Encoding utf8

Write-Host ""
Write-Host "Run-level rows:" -ForegroundColor Cyan

$runRows |
    Sort-Object RunEndUsecs -Descending |
    Select-Object RunType, IsLogRun, Status, IsSuccess, RunEndET, ReplicationTargetCluster, ReplicationEndTimeET |
    Format-Table -AutoSize

Write-Host ""
Write-Host "Latest summary:" -ForegroundColor Cyan

$summary | Format-List

Write-Host ""
Write-Host "Run CSV     : $runCsv" -ForegroundColor Green
Write-Host "Summary CSV : $summaryCsv" -ForegroundColor Green
