function Format-RetryOptions {
    param($RetryOptions)

    if ($null -eq $RetryOptions) {
        return "N/A"
    }

    $retriesRaw  = ValueOrNA $RetryOptions.retries
    $intervalRaw = ValueOrNA $RetryOptions.retryIntervalMins

    [int]$retries = 0
    [int]$interval = 0

    [void][int]::TryParse([string]$retriesRaw, [ref]$retries)
    [void][int]::TryParse([string]$intervalRaw, [ref]$interval)

    if ($retries -le 0) {
        return "No retries on error"
    }

    $parts = @()
    $parts += "Retry $retries times"

    if ($interval -gt 0) {
        $parts += "$interval minutes apart"
    }

    return ($parts -join "; ")
}