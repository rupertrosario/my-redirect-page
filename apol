function formatRetryOptions(retryOptions) {
  if (!retryOptions) return "N/A";

  const retriesRaw = valueOrNA(retryOptions?.retries);
  const intervalRaw = valueOrNA(retryOptions?.retryIntervalMins);

  const retries = Number(retriesRaw);
  const interval = Number(intervalRaw);

  if (!Number.isFinite(retries) || retries <= 0) {
    return "No retries on error";
  }

  const parts = [];
  parts.push(`Retry ${retries} times`);

  if (Number.isFinite(interval) && interval > 0) {
    parts.push(`${interval} Min apart`);
  }

  return parts.join("; ");
}
