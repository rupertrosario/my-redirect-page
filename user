$command   = whoami
$user_name = ($command -split "\\")[-1]

if ($user_name -notmatch '^x_') {
    $user_name = "x_$user_name"
}

Write-Output "Running the script as user: $user_name`n"

$clustersAvailable = @(
    "cluster1",
    "cluster2",
    "cluster3"
)

$mfaClusters = @(
    "cluster1"
)

$allResults = @()

foreach ($cluster in $clustersAvailable) {
    Write-Host "`nProcessing cluster: $cluster" -ForegroundColor Cyan

    # Failsafe: check if cluster is reachable on HTTPS
    $reachable = $false
    try {
        $reachable = Test-NetConnection -ComputerName $cluster -Port 443 -InformationLevel Quiet -WarningAction SilentlyContinue
    }
    catch {
        $reachable = $false
    }

    if (-not $reachable) {
        Write-Warning "Cluster not reachable: $cluster"
        $allResults += [PSCustomObject]@{
            Cluster   = $cluster
            Type      = "N/A"
            Principal = "UNREACHABLE"
            Domain    = "N/A"
            Roles     = "N/A"
        }
        continue
    }

    try {
        if ($cluster -in $mfaClusters) {
            $mfa_code = Read-Host "Enter MFA code for $cluster"

            $result = & "X:\PowerShell\Scripts\Archive\rupert_scripts\usersandGroups.ps1" `
                -vip $cluster `
                -username $user_name `
                -domain `
                -mfaCode $mfa_code
        }
        else {
            $result = & "X:\PowerShell\Scripts\Archive\rupert_scripts\usersandGroups.ps1" `
                -vip $cluster `
                -username $user_name `
                -domain
        }

        if ($result) {
            $allResults += $result | ForEach-Object {
                [PSCustomObject]@{
                    Cluster   = $cluster
                    Type      = $_.Type
                    Principal = $_.Principal
                    Domain    = $_.Domain
                    Roles     = ($_.Roles -join ", ")
                }
            }
        }
        else {
            $allResults += [PSCustomObject]@{
                Cluster   = $cluster
                Type      = "N/A"
                Principal = "NO DATA RETURNED"
                Domain    = "N/A"
                Roles     = "N/A"
            }
        }
    }
    catch {
        Write-Warning "Failed on cluster $cluster : $($_.Exception.Message)"
        $allResults += [PSCustomObject]@{
            Cluster   = $cluster
            Type      = "N/A"
            Principal = "SCRIPT ERROR"
            Domain    = "N/A"
            Roles     = $_.Exception.Message
        }
    }
}

$allResults |
    Sort-Object Cluster, Type, Principal |
    Format-Table -AutoSize

$allResults |
    Export-Csv "X:\PowerShell\Scripts\Archive\rupert_scripts\Consolidated_Users_Groups.csv" -NoTypeInformation
