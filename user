$command   = whoami
$user_name = ($command -split "\\")[-1]

if ($user_name -notmatch '^x_') {
    $user_name = "x_$user_name"
}

Write-Output "Running the script as user: $user_name`n"

$clustersAvailable = @(
    "cluster1",
    "cluster2",
    "cluster3"
)

$mfaClusters = @(
    "cluster1"
)

$allResults = @()

foreach ($cluster in $clustersAvailable) {
    Write-Host "`nProcessing cluster: $cluster" -ForegroundColor Cyan

    try {
        if ($cluster -in $mfaClusters) {
            $mfa_code = Read-Host "Enter the code"

            $result = & "X:\PowerShell\Scripts\Archive\rupert_scripts\usersandGroups.ps1" `
                -vip $cluster `
                -username $user_name `
                -domain `
                -mfaCode $mfa_code
        }
        else {
            $result = & "X:\PowerShell\Scripts\Archive\rupert_scripts\usersandGroups.ps1" `
                -vip $cluster `
                -username $user_name `
                -domain
        }

        if ($result) {
            $allResults += $result | Select-Object `
                @{Name='Cluster';Expression={$cluster}},
                Type,
                Principal,
                Domain,
                @{Name='Roles';Expression={
                    if ($_.Roles -is [System.Array]) { $_.Roles -join ', ' } else { $_.Roles }
                }}
        }
    }
    catch {
        Write-Warning "Failed on $cluster : $($_.Exception.Message)"
    }
}

$allResults | Format-Table -AutoSize

$allResults | Export-Csv "X:\PowerShell\Scripts\Archive\rupert_scripts\UsersAndGroups_Consolidated.csv" -NoTypeInformation
