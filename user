$command   = whoami
$user_name = ($command -split "\\")[-1]

if ($user_name -notmatch '^x_') {
    $user_name = "x_$user_name"
}

Write-Host "Running the script as user: $user_name`n" -ForegroundColor Yellow

# ==========================================
# UPDATE THESE CLUSTERS
# ==========================================
$clustersAvailable = @(
    "cluster1",
    "cluster2",
    "cluster3"
)

# Only put MFA-required clusters here
$mfaClusters = @(
    "cluster1"
)

$allResults = @()

foreach ($cluster in $clustersAvailable) {
    Write-Host "`nProcessing cluster: $cluster" -ForegroundColor Cyan

    try {
        if ($cluster -in $mfaClusters) {
            $mfa_code = Read-Host "Enter the code for $cluster"

            $result = & "X:\PowerShell\Scripts\Archive\rupert_scripts\usersandGroups.ps1" `
                -vip $cluster `
                -username $user_name `
                -domain `
                -mfaCode $mfa_code
        }
        else {
            $result = & "X:\PowerShell\Scripts\Archive\rupert_scripts\usersandGroups.ps1" `
                -vip $cluster `
                -username $user_name `
                -domain
        }

        if ($null -ne $result) {
            $cleanResult = $result | Where-Object {
                $_ -is [psobject] -and $_.PSObject.Properties['Type']
            }

            if ($cleanResult) {
                $allResults += $cleanResult | Select-Object `
                    @{Name='Cluster';Expression={$cluster}},
                    Type,
                    Principal,
                    Domain,
                    @{Name='Roles';Expression={
                        if ($_.Roles -is [System.Array]) { $_.Roles -join ', ' } else { $_.Roles }
                    }}
            }
            else {
                Write-Warning "No valid object output returned from $cluster"
            }
        }
        else {
            Write-Warning "No data returned from $cluster"
        }
    }
    catch {
        Write-Warning "Failed on $cluster : $($_.Exception.Message)"
    }
}

if ($allResults.Count -gt 0) {
    $allResults |
        Sort-Object Cluster, Type, Principal |
        Format-Table Cluster, Type, Principal, Domain, Roles -AutoSize

    $csvPath = "X:\PowerShell\Scripts\Archive\rupert_scripts\UsersAndGroups_Consolidated.csv"

    $allResults |
        Sort-Object Cluster, Type, Principal |
        Export-Csv $csvPath -NoTypeInformation

    Write-Host "`nCSV exported to: $csvPath" -ForegroundColor Green
}
else {
    Write-Warning "No consolidated results to display or export."
}
