$HelperPath   = "\\NAS\Cohesity\Scripts\Common\KeePassHelper.ps1"
$KeePassDb    = "\\NAS\Cohesity\Secure\CohesityVault.kdbx"
$KeePassExe   = "C:\Program Files\KeePass Password Safe 2\KeePass.exe"
$EntryTitle   = "CohesityApiKey"

Write-Host "`nValidating KeePass setup..." -ForegroundColor Cyan

$checks = @(
    @{ Name = "KeePass Helper"; Path = $HelperPath },
    @{ Name = "KeePass DB";     Path = $KeePassDb },
    @{ Name = "KeePass EXE";    Path = $KeePassExe }
)

foreach ($check in $checks) {
    if (Test-Path $check.Path) {
        Write-Host "OK      - $($check.Name): $($check.Path)" -ForegroundColor Green
    }
    else {
        throw "MISSING - $($check.Name): $($check.Path)"
    }
}

. $HelperPath

if (-not (Get-Command Get-CohesityApiKeyFromKeePass -ErrorAction SilentlyContinue)) {
    throw "Function not loaded: Get-CohesityApiKeyFromKeePass"
}

Write-Host "OK      - Helper function loaded" -ForegroundColor Green

$apiKey = Get-CohesityApiKeyFromKeePass `
    -KeePassDbPath $KeePassDb `
    -KeePassAssemblyPath $KeePassExe `
    -EntryTitle $EntryTitle

if ($apiKey -and $apiKey.Length -gt 10) {
    Write-Host "OK      - API key loaded from KeePass. Length: $($apiKey.Length)" -ForegroundColor Green
}
else {
    throw "FAILED  - API key was not loaded correctly."
}

Write-Host "`nValidation completed successfully." -ForegroundColor Cyan
