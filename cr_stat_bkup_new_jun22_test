$Report += "- SQL DB names are discovered from recent SQL run object details where DB objects are exposed."
$Report += "- SQL LastBackupTime is based on the latest successful regular run of the same SQL Protection Group."
$Report += "- This is correlated DB validation: DB list evidence and successful backup time come from the same PG, but not necessarily the same run."
$Report += "- If SQL shows DbListNotDiscovered, the PG had a successful regular backup but recent run objects did not expose DB names."
$Report += "- Oracle DB details are shown only when targeted Oracle PG configuration exposes oracleParams/dbParams/dbChannels."
$Report += "- Unknown means no matching backup object was found in the checked environments."
$Report += ""
$Report += "----------------------------------------------------------"
$Report += "Report Locations"
$Report += "----------------------------------------------------------"
$Report += "Input CSV                 : $InputCsv"
$Report += "Input TXT                 : $InputTxt"
$Report += "TXT Report                : $OutputTxt"
$Report += "Final CSV                 : $OutputCsv"
$Report += "=========================================================="

$Report | Set-Content -Path $OutputTxt -Encoding UTF8

