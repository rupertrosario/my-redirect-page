# ==========================================================
# Server Backup Module
# ==========================================================
function Get-ServerBackupRows {
    param(
        [object]$Context,
        [string]$ServerName,
        [hashtable]$ClusterMap
    )

    $rows = @()

    if ([string]::IsNullOrWhiteSpace($ServerName)) {
        return @()
    }

    # To control speed, only use original + short name for server backup search.
    $searchTerms = New-Object System.Collections.ArrayList
    Add-UniqueText -List $searchTerms -Value $ServerName
    Add-UniqueText -List $searchTerms -Value (Get-ShortName $ServerName)

    foreach ($map in $ServerBackupEnvironments) {

        $candidatesAll = @()

        foreach ($term in @($searchTerms)) {
            $candidatesAll += @(Get-SearchCandidates `
                -SearchTerm $term `
                -Environment $map.Environment `
                -ClusterMap $ClusterMap)
        }

        $candidates = @(Get-UniqueCandidates -Candidates $candidatesAll)

        foreach ($candidate in $candidates) {
            if ([string]::IsNullOrWhiteSpace($candidate.ClusterId)) {
                continue
            }

            $clusterName = Get-ClusterNameFromMap -ClusterId $candidate.ClusterId -ClusterMap $ClusterMap

            $headers = @{
                accept          = "application/json"
                apiKey          = $ApiKey
                accessClusterId = "$($candidate.ClusterId)"
            }

            foreach ($term in @($searchTerms)) {
                $script:ProtectedSearchCalls++

                $url = New-SearchUrl `
                    -Endpoint "/v2/data-protect/search/protected-objects" `
                    -SearchTerm $term `
                    -Environment $map.Environment

                $json = Invoke-HeliosGetJson -Uri $url -Headers $headers -Quiet
                $objects = @(Get-ObjectArrayFromJson $json)

                foreach ($obj in $objects) {
                    $objName = Get-ObjectNameFromProtectedObject $obj

                    if (-not (Text-MatchesName -Text $objName -Name $ServerName)) {
                        continue
                    }

                    $snap = Get-BestSnapshot -Obj $obj -BackupType $map.BackupType

                    $usecs = 0
                    $timeText = "NoBackup"

                    if ($snap) {
                        $usecs = Get-SnapshotUsecs $snap
                        $timeText = if ($usecs -gt 0) { Convert-UsecsToET $usecs } else { "NoBackupTime" }
                    }

                    $pgName = Get-PgNameFromProtectedObject -Obj $obj -Snap $snap -FallbackPgName $candidate.PgName

                    $rows += [pscustomobject]@{
                        InputCI         = $Context.InputCI
                        BackupType      = $map.BackupType
                        ObjectName      = $objName
                        ClusterName     = $clusterName
                        ProtectionGroup = $pgName
                        LastBackupTime  = $timeText
                        LastBackupUsecs = $usecs
                        HostName        = $objName
                        Source          = "$($map.BackupType)ProtectedObject"
                    }
                }
            }
        }
    }

    $script:ServerBackupRowsFound += @($rows | Where-Object { Is-ValidBackupTime $_.LastBackupTime }).Count
    return @($rows)
}

# ==========================================================
# SQL Module
# ==========================================================
function Test-SqlDbCandidate {
    param(
        [string]$ObjectType,
        [string]$ObjectName
    )

    if ([string]::IsNullOrWhiteSpace($ObjectName)) {
        return $false
    }

    # In this environment, SQL DB objects can appear as kSQL.
    if ($ObjectType -in @("kSQL", "kDatabase", "kSQLDB")) {
        return $true
    }

    if ($ObjectType -match "(?i)database|sqldb|sql.*db") {
        return $true
    }

    return $false
}

function Get-SqlObjectFields {
    param([object]$Obj)

    $objectName = Get-FirstText @(
        $Obj.object.name,
        $Obj.object.displayName,
        $Obj.name,
        $Obj.displayName,
        $Obj.databaseName,
        $Obj.dbName,
        $Obj.dbUniqueName
    )

    $objectType = Get-FirstText @(
        $Obj.object.objectType,
        $Obj.objectType,
        $Obj.type
    )

    $env = Get-FirstText @(
        $Obj.object.environment,
        $Obj.environment
    )

    $objectId = Get-FirstText @(
        $Obj.object.id,
        $Obj.object.uid,
        $Obj.id,
        $Obj.uid
    )

    $sourceId = Get-FirstText @(
        $Obj.object.sourceId,
        $Obj.sourceId,
        $Obj.parentId,
        $Obj.parentObjectId
    )

    return [pscustomobject]@{
        ObjectName  = $objectName
        ObjectType  = $objectType
        Environment = $env
        ObjectId    = $objectId
        SourceId    = $sourceId
    }
}

function Get-SqlHostMapFromRun {
    param([object]$Run)

    $hostMap = @{}
    $objects = @(AsArray $Run.objects)

    foreach ($obj in $objects) {
        $f = Get-SqlObjectFields -Obj $obj

        if ($f.Environment -ne "kSQL") {
            continue
        }

        # Host/source object is normally kSQL without sourceId.
        # DB objects can also be kSQL, so this map is best effort.
        if ($f.ObjectType -eq "kSQL" -and
            [string]::IsNullOrWhiteSpace($f.SourceId) -and
            -not [string]::IsNullOrWhiteSpace($f.ObjectId) -and
            -not [string]::IsNullOrWhiteSpace($f.ObjectName)) {
            $hostMap[$f.ObjectId] = $f.ObjectName
        }
    }

    return $hostMap
}

function Get-SqlDbRowsFromRun {
    param(
        [object]$Run,
        [string]$RunStatus,
        [string]$RunType,
        [int64]$RunEndUsecs,
        [object]$Context
    )

    $rows = @()
    $objects = @(AsArray $Run.objects)

    if ($objects.Count -eq 0) {
        return @()
    }

    $hostMap = Get-SqlHostMapFromRun -Run $Run

    foreach ($obj in $objects) {
        $f = Get-SqlObjectFields -Obj $obj

        if ($f.Environment -ne "kSQL") {
            continue
        }

        if (-not (Test-SqlDbCandidate -ObjectType $f.ObjectType -ObjectName $f.ObjectName)) {
            continue
        }

        $hostName = ""

        if (-not [string]::IsNullOrWhiteSpace($f.SourceId) -and $hostMap.ContainsKey($f.SourceId)) {
            $hostName = $hostMap[$f.SourceId]
        }

        # Avoid showing the server itself as a DB when input is server.
        if (-not $Context.IsDbAtServer) {
            if (Text-MatchesName -Text $f.ObjectName -Name $Context.InputCI) {
                # If the object name equals the server input and no SourceId exists,
                # this is probably the SQL source/server object, not a DB.
                if ([string]::IsNullOrWhiteSpace($f.SourceId)) {
                    continue
                }
            }
        }

        # For DB@SERVER, DB name must match.
        if ($Context.IsDbAtServer) {
            if (-not (Text-MatchesName -Text $f.ObjectName -Name $Context.DbName)) {
                continue
            }

            if (-not [string]::IsNullOrWhiteSpace($hostName)) {
                if (-not (Text-MatchesName -Text $hostName -Name $Context.ServerName)) {
                    continue
                }
            }
        }

        $rows += [pscustomobject]@{
            DbName               = $f.ObjectName
            HostName             = $hostName
            ObjectType           = $f.ObjectType
            ObjectId             = $f.ObjectId
            SourceId             = $f.SourceId
            DiscoveryRunStatus   = $RunStatus
            DiscoveryRunType     = $RunType
            DiscoveryRunEndUsecs = $RunEndUsecs
        }
    }

    return @($rows)
}

function Get-SqlRunEvidenceFromRecentRuns {
    param(
        [string]$PgId,
        [hashtable]$Headers,
        [object]$Context
    )

    $allDbRows = @()
    $latestSuccessUsecs = 0

    if ([string]::IsNullOrWhiteSpace($PgId)) {
        return [pscustomobject]@{
            DbRows             = @()
            LatestSuccessUsecs = 0
            LatestSuccessTime  = "NoBackup"
        }
    }

    $page = 0
    $cookie = ""

    do {
        $page++

        $uri = "$BaseUrl/v2/data-protect/protection-groups/$PgId/runs" +
               "?environments=kSQL" +
               "&isDeleted=false" +
               "&isPaused=false" +
               "&isActive=true" +
               "&numRuns=$NumRunsPerPg" +
               "&excludeNonRestorableRuns=false" +
               "&includeObjectDetails=true"

        if (-not [string]::IsNullOrWhiteSpace($cookie)) {
            $uri += "&paginationCookie=$([uri]::EscapeDataString($cookie))"
        }

        $script:PgRunCalls++

        $json = Invoke-HeliosGetJson -Uri $uri -Headers $Headers -Quiet

        if (-not $json -or -not $json.runs) {
            break
        }

        $runs = @(AsArray $json.runs | Where-Object { $_ }) |
            Sort-Object @{ Expression = { To-Int64Safe (Get-RunEndUsecsFromRun $_) }; Descending = $true }

        foreach ($run in $runs) {
            $status   = Get-RunStatusFromRun $run
            $runType  = Get-RunTypeFromRun $run
            $endUsecs = To-Int64Safe (Get-RunEndUsecsFromRun $run)

            if ($endUsecs -le 0) {
                continue
            }

            $dbRows = @(Get-SqlDbRowsFromRun `
                -Run $run `
                -RunStatus $status `
                -RunType $runType `
                -RunEndUsecs $endUsecs `
                -Context $Context)

            if ($dbRows.Count -gt 0) {
                $allDbRows += $dbRows
            }

            if ((Test-SuccessStatus $status) -and (Test-RegularRunType $runType)) {
                if ($endUsecs -gt $latestSuccessUsecs) {
                    $latestSuccessUsecs = $endUsecs
                }
            }
        }

        $cookie = Get-FirstText $json.paginationCookie

        if ($json.isResponseTruncated -ne $true) {
            break
        }

    } while (-not [string]::IsNullOrWhiteSpace($cookie) -and $page -lt $MaxRunPagesPerPg)

    $deduped = @()

    foreach ($grp in ($allDbRows | Group-Object DbName, HostName)) {
        $deduped += (
            $grp.Group |
            Sort-Object @{ Expression = { [int64]$_.DiscoveryRunEndUsecs }; Descending = $true } |
            Select-Object -First 1
        )
    }

    $successTime = "NoBackup"

    if ($latestSuccessUsecs -gt 0) {
        $successTime = Convert-UsecsToET $latestSuccessUsecs
    }

    return [pscustomobject]@{
        DbRows             = @($deduped)
        LatestSuccessUsecs = $latestSuccessUsecs
        LatestSuccessTime  = $successTime
    }
}

function Get-SqlCandidatePgs {
    param(
        [object]$Context,
        [hashtable]$ClusterMap
    )

    $all = @()
    $terms = @(Get-SqlSearchTerms -Context $Context)

    foreach ($term in $terms) {
        $all += @(Get-SearchCandidates `
            -SearchTerm $term `
            -Environment "kSQL" `
            -ClusterMap $ClusterMap)
    }

    $sqlCandidates = @(Get-UniqueCandidates -Candidates $all)

    if ($sqlCandidates.Count -eq 0 -and $EnableBroadSqlSearchIfKsqlSearchMisses) {
        foreach ($term in $terms) {
            $all += @(Get-BroadSearchCandidates `
                -SearchTerm $term `
                -ClusterMap $ClusterMap)
        }

        $sqlCandidates = @(Get-UniqueCandidates -Candidates $all)
    }

    # Prefer PGs whose name has the input/server/db term.
    $ranked = @()

    foreach ($c in $sqlCandidates) {
        $rank = 99

        foreach ($term in $terms) {
            if (Text-MatchesName -Text "$($c.PgName)" -Name "$term") {
                $rank = 1
                break
            }
        }

        if ($rank -eq 99) {
            $rank = 5
        }

        $ranked += [pscustomobject]@{
            Rank        = $rank
            ClusterId   = $c.ClusterId
            ClusterName = $c.ClusterName
            PgId        = $c.PgId
            PgName      = $c.PgName
        }
    }

    return @(
        $ranked |
        Sort-Object Rank, ClusterName, PgName |
        Select-Object -First $MaxSqlCandidatesToInspect
    )
}

function Get-SqlRows {
    param(
        [object]$Context,
        [hashtable]$ClusterMap
    )

    $rows = @()

    $candidates = @(Get-SqlCandidatePgs -Context $Context -ClusterMap $ClusterMap)
    $script:SqlCandidatesFound += $candidates.Count

    if ($candidates.Count -eq 0) {
        return @()
    }

    Write-Host "  SQL candidate PGs to inspect: $($candidates.Count)" -ForegroundColor Green

    foreach ($candidate in $candidates) {
        if ([string]::IsNullOrWhiteSpace($candidate.PgId)) {
            continue
        }

        $clusterId = "$($candidate.ClusterId)"
        $clusterName = Get-ClusterNameFromMap -ClusterId $clusterId -ClusterMap $ClusterMap

        if ($clusterName -eq $clusterId -and -not [string]::IsNullOrWhiteSpace($candidate.ClusterName)) {
            $clusterName = "$($candidate.ClusterName)"
        }

        $headers = @{
            accept          = "application/json"
            apiKey          = $ApiKey
            accessClusterId = "$clusterId"
        }

        $script:SqlCandidatesInspected++

        $evidence = Get-SqlRunEvidenceFromRecentRuns `
            -PgId "$($candidate.PgId)" `
            -Headers $headers `
            -Context $Context

        if (-not $evidence -or $evidence.LatestSuccessUsecs -le 0) {
            continue
        }

        if (-not $evidence.DbRows -or @($evidence.DbRows).Count -eq 0) {
            $script:SqlDbListNotDiscovered++
            continue
        }

        foreach ($db in @($evidence.DbRows)) {
            if ([string]::IsNullOrWhiteSpace($db.DbName)) {
                continue
            }

            $rows += [pscustomobject]@{
                InputCI         = $Context.InputCI
                BackupType      = "SQL"
                ObjectName      = $db.DbName
                ClusterName     = $clusterName
                ProtectionGroup = "$($candidate.PgName)"
                LastBackupTime  = $evidence.LatestSuccessTime
                LastBackupUsecs = $evidence.LatestSuccessUsecs
                HostName        = $db.HostName
                Source          = "SQLDbDiscoveredFromRecentRuns"
            }
        }
    }

    $script:SqlDbObjectsFound += @($rows).Count
    return @($rows)
}

# ==========================================================
# Oracle Module - Targeted PG Config + Runs
# ==========================================================
function Resolve-CohesityObjectName {
    param(
        [string]$ObjectId,
        [hashtable]$Headers
    )

    if ([string]::IsNullOrWhiteSpace($ObjectId)) {
        return ""
    }

    $script:ObjectLookupCalls++

    $uri = "$BaseUrl/v2/data-protect/objects/$ObjectId"
    $json = Invoke-HeliosGetJson -Uri $uri -Headers $Headers -Quiet

    if (-not $json) {
        return ""
    }

    return Get-FirstText @($json.name, $json.displayName)
}

function Get-ProtectionGroupDetails {
    param(
        [string]$PgId,
        [string]$Environment,
        [hashtable]$Headers
    )

    if ([string]::IsNullOrWhiteSpace($PgId)) {
        return $null
    }

    $uris = @(
        "$BaseUrl/v2/data-protect/protection-groups/$PgId",
        "$BaseUrl/v2/data-protect/protection-groups?ids=$([uri]::EscapeDataString($PgId))&environments=$([uri]::EscapeDataString($Environment))&includeLastRunInfo=true"
    )

    foreach ($uri in $uris) {
        $script:PgDetailCalls++

        $json = Invoke-HeliosGetJson -Uri $uri -Headers $Headers -Quiet

        if (-not $json) {
            continue
        }

        if ($json.protectionGroups) {
            $pg = @(AsArray $json.protectionGroups | Where-Object { $_ }) | Select-Object -First 1
            if ($pg) {
                return $pg
            }
        }

        if ($json.id -or $json.name -or $json.oracleParams) {
            return $json
        }
    }

    return $null
}

function Get-LatestPgRegularRunInfo {
    param(
        [string]$PgId,
        [string]$Environment,
        [hashtable]$Headers
    )

    if ([string]::IsNullOrWhiteSpace($PgId)) {
        return [pscustomobject]@{
            EndUsecs = 0
            EndTime  = "NoBackup"
        }
    }

    $uri = "$BaseUrl/v2/data-protect/protection-groups/$PgId/runs" +
           "?environments=$Environment" +
           "&numRuns=$NumRunsPerPg" +
           "&excludeNonRestorableRuns=false"

    $script:PgRunCalls++

    $json = Invoke-HeliosGetJson -Uri $uri -Headers $Headers -Quiet

    if (-not $json -or -not $json.runs) {
        return [pscustomobject]@{
            EndUsecs = 0
            EndTime  = "NoBackup"
        }
    }

    $bestUsecs = 0

    foreach ($run in (AsArray $json.runs)) {
        $status   = Get-RunStatusFromRun $run
        $runType  = Get-RunTypeFromRun $run
        $endUsecs = To-Int64Safe (Get-RunEndUsecsFromRun $run)

        if ($endUsecs -le 0) {
            continue
        }

        if (-not (Test-SuccessStatus $status)) {
            continue
        }

        if (-not (Test-RegularRunType $runType)) {
            continue
        }

        if ($endUsecs -gt $bestUsecs) {
            $bestUsecs = $endUsecs
        }
    }

    if ($bestUsecs -gt 0) {
        return [pscustomobject]@{
            EndUsecs = $bestUsecs
            EndTime  = Convert-UsecsToET $bestUsecs
        }
    }

    return [pscustomobject]@{
        EndUsecs = 0
        EndTime  = "NoBackup"
    }
}

function Get-OracleHostNamesFromChannel {
    param(
        [object]$Channel,
        [hashtable]$Headers
    )

    $names = New-Object System.Collections.ArrayList

    $hostIds = @()
    $hostIds += @(AsArray $Channel.databaseNodeList.hostId)
    $hostIds += @(AsArray $Channel.databaseNodeList.id)

    foreach ($hostId in ($hostIds | Where-Object { $_ -and "$_".Trim() -ne "" } | Select-Object -Unique)) {
        $hostName = Resolve-CohesityObjectName -ObjectId "$hostId" -Headers $Headers
        Add-UniqueText -List $names -Value $hostName
    }

    return @($names)
}

function Add-OracleRowIfMatched {
    param(
        [System.Collections.ArrayList]$Rows,
        [object]$Context,
        [string]$DbName,
        [object[]]$HostNames,
        [string]$ClusterName,
        [string]$PgName,
        [string]$LastBackupTime,
        [int64]$LastBackupUsecs
    )

    if ([string]::IsNullOrWhiteSpace($DbName)) {
        return
    }

    $hostText = (($HostNames | Where-Object { $_ -and "$_".Trim() -ne "" } | Select-Object -Unique) -join ";")

    if ($Context.IsDbAtServer) {
        if (-not (Text-MatchesName -Text $DbName -Name $Context.DbName)) {
            return
        }
    }
    else {
        $dbMatches = Text-MatchesName -Text $DbName -Name $Context.InputCI

        $hostMatches = $false
        foreach ($h in @($HostNames)) {
            if (Text-MatchesName -Text "$h" -Name $Context.InputCI) {
                $hostMatches = $true
                break
            }
        }

        if (-not $dbMatches -and -not $hostMatches) {
            return
        }
    }

    [void]$Rows.Add([pscustomobject]@{
        InputCI         = $Context.InputCI
        BackupType      = "Oracle"
        ObjectName      = $DbName
        ClusterName     = $ClusterName
        ProtectionGroup = $PgName
        LastBackupTime  = if ($LastBackupTime) { $LastBackupTime } else { "NoBackup" }
        LastBackupUsecs = $LastBackupUsecs
        HostName        = $hostText
        Source          = "OracleTargetedPgDetails"
    })
}

function Get-OracleRows {
    param(
        [object]$Context,
        [hashtable]$ClusterMap
    )

    $rows = New-Object System.Collections.ArrayList

    $termBase = Get-DbSearchTerm -Context $Context
    $terms = @(Get-SearchVariants -Value $termBase)

    $candidatesAll = @()

    foreach ($term in $terms) {
        $candidatesAll += @(Get-SearchCandidates `
            -SearchTerm $term `
            -Environment "kOracle" `
            -ClusterMap $ClusterMap)
    }

    $candidates = @(Get-UniqueCandidates -Candidates $candidatesAll)

    foreach ($candidate in $candidates) {
        if ([string]::IsNullOrWhiteSpace($candidate.PgId)) {
            continue
        }

        $clusterId = "$($candidate.ClusterId)"
        $clusterName = Get-ClusterNameFromMap -ClusterId $clusterId -ClusterMap $ClusterMap

        if ($clusterName -eq $clusterId -and -not [string]::IsNullOrWhiteSpace($candidate.ClusterName)) {
            $clusterName = "$($candidate.ClusterName)"
        }

        $headers = @{
            accept          = "application/json"
            apiKey          = $ApiKey
            accessClusterId = "$clusterId"
        }

        $runInfo = Get-LatestPgRegularRunInfo `
            -PgId "$($candidate.PgId)" `
            -Environment "kOracle" `
            -Headers $headers

        if ($runInfo.EndUsecs -le 0) {
            continue
        }

        $pg = Get-ProtectionGroupDetails `
            -PgId "$($candidate.PgId)" `
            -Environment "kOracle" `
            -Headers $headers

        if (-not $pg -or -not $pg.oracleParams) {
            continue
        }

        $pgName = Get-FirstText @($pg.name, $candidate.PgName)
        if ([string]::IsNullOrWhiteSpace($pgName)) {
            $pgName = "$($candidate.PgName)"
        }

        foreach ($obj in (AsArray $pg.oracleParams.objects)) {

            $baseHostNames = New-Object System.Collections.ArrayList

            Add-UniqueText -List $baseHostNames -Value (Get-FirstText @(
                $obj.sourceName,
                $obj.SourceName,
                $obj.hostName,
                $obj.HostName
            ))

            $dbParams = @(AsArray $obj.dbParams)

            if ($dbParams.Count -eq 0) {
                $dbName = Get-FirstText @(
                    $obj.databaseName,
                    $obj.databaseUniqueName,
                    $obj.dbUniqueName,
                    $obj.name
                )

                Add-OracleRowIfMatched `
                    -Rows $rows `
                    -Context $Context `
                    -DbName $dbName `
                    -HostNames @($baseHostNames) `
                    -ClusterName $clusterName `
                    -PgName $pgName `
                    -LastBackupTime "$($runInfo.EndTime)" `
                    -LastBackupUsecs ([int64]$runInfo.EndUsecs)

                continue
            }

            foreach ($dbParam in $dbParams) {

                $paramHostNames = New-Object System.Collections.ArrayList

                foreach ($h in @($baseHostNames)) {
                    Add-UniqueText -List $paramHostNames -Value $h
                }

                Add-UniqueText -List $paramHostNames -Value (Get-FirstText @(
                    $dbParam.sourceName,
                    $dbParam.SourceName,
                    $dbParam.hostName,
                    $dbParam.HostName
                ))

                $channels = @()

                if ($dbParam.dbChannels.dbChannel) {
                    $channels += @(AsArray $dbParam.dbChannels.dbChannel)
                }
                elseif ($dbParam.dbChannels) {
                    $channels += @(AsArray $dbParam.dbChannels)
                }

                if ($channels.Count -eq 0) {
                    $dbName = Get-FirstText @(
                        $dbParam.databaseName,
                        $dbParam.databaseUniqueName,
                        $obj.databaseUniqueName,
                        $obj.dbUniqueName,
                        $obj.name
                    )

                    Add-OracleRowIfMatched `
                        -Rows $rows `
                        -Context $Context `
                        -DbName $dbName `
                        -HostNames @($paramHostNames) `
                        -ClusterName $clusterName `
                        -PgName $pgName `
                        -LastBackupTime "$($runInfo.EndTime)" `
                        -LastBackupUsecs ([int64]$runInfo.EndUsecs)

                    continue
                }

                foreach ($channel in $channels) {

                    $channelHostNames = New-Object System.Collections.ArrayList

                    foreach ($h in @($paramHostNames)) {
                        Add-UniqueText -List $channelHostNames -Value $h
                    }

                    foreach ($resolvedHost in (Get-OracleHostNamesFromChannel -Channel $channel -Headers $headers)) {
                        Add-UniqueText -List $channelHostNames -Value $resolvedHost
                    }

                    $dbName = Get-FirstText @(
                        $channel.databaseUniqueName,
                        $channel.databaseName,
                        $dbParam.databaseUniqueName,
                        $dbParam.databaseName,
                        $obj.databaseUniqueName,
                        $obj.dbUniqueName,
                        $obj.name
                    )

                    Add-OracleRowIfMatched `
                        -Rows $rows `
                        -Context $Context `
                        -DbName $dbName `
                        -HostNames @($channelHostNames) `
                        -ClusterName $clusterName `
                        -PgName $pgName `
                        -LastBackupTime "$($runInfo.EndTime)" `
                        -LastBackupUsecs ([int64]$runInfo.EndUsecs)
                }
            }
        }
    }

    $script:OracleRowsFound += @($rows).Count
    return @($rows)
}

# ==========================================================
# Row Selection
# ==========================================================
function Select-BestRows {
    param([object[]]$Rows)

    $out = @()

    foreach ($grp in ($Rows | Group-Object InputCI, BackupType, ObjectName)) {
        $g = @($grp.Group)

        $valid = @($g | Where-Object { Is-ValidBackupTime $_.LastBackupTime })

        if ($valid.Count -gt 0) {
            $out += (
                $valid |
                Sort-Object `
                    @{ Expression = { [int64]$_.LastBackupUsecs }; Descending = $true },
                    ClusterName,
                    ProtectionGroup |
                Select-Object -First 1
            )
        }
        else {
            $out += (
                $g |
                Sort-Object ClusterName, ProtectionGroup |
                Select-Object -First 1
            )
        }
    }

    return @($out)
}

# ==========================================================
# Load Input CIs
# ==========================================================
$CiNames = Import-Csv -Path $InputCsv |
    ForEach-Object { "$($_.ci_item)".Trim().Trim('"').Trim("'") } |
    Where-Object { -not [string]::IsNullOrWhiteSpace($_) } |
    Sort-Object -Unique

if (-not $CiNames -or $CiNames.Count -eq 0) {
    throw "No ci_item values found in $InputCsv"
}

$CiNames | Set-Content -Path $InputTxt

$CiList = Get-Content -Path $InputTxt |
    ForEach-Object { "$_".Trim().Trim('"').Trim("'") } |
    Where-Object { -not [string]::IsNullOrWhiteSpace($_) }

# ==========================================================
# Build Cluster Map
# ==========================================================
$clusterJson = Invoke-HeliosGetJson -Uri "$BaseUrl/v2/mcm/cluster-mgmt/info" -Headers $CommonHeaders

if (-not $clusterJson -or -not $clusterJson.cohesityClusters) {
    throw "No clusters returned from Helios."
}

$Clusters = @($clusterJson.cohesityClusters)
$ClusterMap = @{}

foreach ($c in $Clusters) {
    $cname = Get-FirstText @($c.clusterName, $c.name, $c.displayName)

    if ([string]::IsNullOrWhiteSpace($cname)) {
        $cname = "Unknown-$($c.clusterId)"
    }

    Add-ClusterMapEntry -Map $ClusterMap -Id $c.clusterId -Name $cname
    Add-ClusterMapEntry -Map $ClusterMap -Id $c.id -Name $cname
    Add-ClusterMapEntry -Map $ClusterMap -Id $c.intId -Name $cname
    Add-ClusterMapEntry -Map $ClusterMap -Id $c.clusterIdentifier.clusterId -Name $cname
    Add-ClusterMapEntry -Map $ClusterMap -Id $c.clusterInfo.clusterId -Name $cname
}

# ==========================================================
# Main Processing
# ==========================================================
$Results = @()

foreach ($ci in $CiList) {
    $context = Get-CiContext $ci
    Write-Host "Processing: $($context.InputCI)" -ForegroundColor Cyan

    $ciRows = @()
    $serverTerm = Get-ServerSearchTerm -Context $context

    # -------------------------
    # 1. Server backup validation
    # -------------------------
    $serverRows = @(Get-ServerBackupRows `
        -Context $context `
        -ServerName $serverTerm `
        -ClusterMap $ClusterMap)

    $ciRows += $serverRows

    # -------------------------
    # 2. SQL application validation
    # -------------------------
    $sqlRows = @(Get-SqlRows `
        -Context $context `
        -ClusterMap $ClusterMap)

    $ciRows += $sqlRows

    # -------------------------
    # 3. Oracle application validation
    # -------------------------
    $oracleRows = @(Get-OracleRows `
        -Context $context `
        -ClusterMap $ClusterMap)

    $ciRows += $oracleRows

    # -------------------------
    # 4. If DB app backup found with host name, check host/server backup too
    # -------------------------
    $dbHostNames = New-Object System.Collections.ArrayList

    foreach ($r in @($sqlRows + $oracleRows)) {
        if (-not [string]::IsNullOrWhiteSpace($r.HostName)) {
            foreach ($h in ($r.HostName -split ";")) {
                Add-UniqueText -List $dbHostNames -Value $h
            }
        }
    }

    if ($dbHostNames.Count -gt 0) {
        $hasServerBackupAlready = @($ciRows | Where-Object {
            $_.BackupType -in @("FS", "VMware", "Hyper-V", "Nutanix", "NAS") -and
            (Is-ValidBackupTime $_.LastBackupTime)
        }).Count -gt 0

        if (-not $hasServerBackupAlready) {
            foreach ($h in @($dbHostNames)) {
                $ciRows += @(Get-ServerBackupRows `
                    -Context $context `
                    -ServerName $h `
                    -ClusterMap $ClusterMap)
            }
        }
    }

    # -------------------------
    # 5. Unknown only if nothing found anywhere
    # -------------------------
    if (-not $ciRows -or $ciRows.Count -eq 0) {
        $Results += [pscustomobject]@{
            InputCI         = $context.InputCI
            BackupType      = "Unknown"
            ObjectName      = $context.InputCI
            ClusterName     = "-"
            ProtectionGroup = "-"
            LastBackupTime  = "Unknown"
        }

        continue
    }

    $selected = @(Select-BestRows -Rows $ciRows)

    foreach ($r in $selected) {
        $Results += [pscustomobject]@{
            InputCI         = $r.InputCI
            BackupType      = $r.BackupType
            ObjectName      = $r.ObjectName
            ClusterName     = $r.ClusterName
            ProtectionGroup = $r.ProtectionGroup
            LastBackupTime  = $r.LastBackupTime
        }
    }
}

# ==========================================================
# Final Sorting / Summary
# ==========================================================
$SortedResults = $Results |
    Sort-Object `
        InputCI,
        @{ Expression = { Get-BackupTypeRank $_.BackupType } },
        ObjectName,
        ClusterName,
        ProtectionGroup

$TotalInputCIs   = $CiList.Count
$TotalBackupRows = $SortedResults.Count

$BackedUp = @($SortedResults | Where-Object {
    Is-ValidBackupTime $_.LastBackupTime
}).Count

$Unknown = @($SortedResults | Where-Object {
    $_.LastBackupTime -eq "Unknown"
}).Count

$NoBackup = @($SortedResults | Where-Object {
    $_.LastBackupTime -in @("NoBackup", "NoBackupTime", "DbListNotDiscovered")
}).Count

# ==========================================================
# Export CSV
# ==========================================================
$SortedResults |
    Select-Object InputCI, BackupType, ObjectName, ClusterName, ProtectionGroup, LastBackupTime |
    Export-Csv -Path $OutputCsv -NoTypeInformation -Encoding UTF8

