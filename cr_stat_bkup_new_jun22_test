function Test-SqlDbCandidate {
    param(
        [string]$ObjectType,
        [string]$ObjectName,
        [string]$ObjectId,
        [string]$SourceId,
        [int]$FailedAttemptsCount
    )

    if ([string]::IsNullOrWhiteSpace($ObjectName)) {
        return $false
    }

    if ($ObjectType -in @("kDatabase", "kSQLDB")) {
        return $true
    }

    if ($ObjectType -match "(?i)database|sqldb|sql.*db") {
        return $true
    }

    if ($ObjectType -eq "kSQL") {
        if (-not [string]::IsNullOrWhiteSpace($SourceId)) {
            return $true
        }

        if ($FailedAttemptsCount -gt 0) {
            return $true
        }
    }

    return $false
}

function Get-SqlObjectFields {
    param([object]$Obj)

    $objectName = Get-FirstText @(
        $Obj.object.name,
        $Obj.object.displayName,
        $Obj.name,
        $Obj.displayName,
        $Obj.databaseName,
        $Obj.dbName,
        $Obj.dbUniqueName
    )

    $objectType = Get-FirstText @(
        $Obj.object.objectType,
        $Obj.objectType,
        $Obj.type
    )

    $env = Get-FirstText @(
        $Obj.object.environment,
        $Obj.environment
    )

    $objectId = Get-FirstText @(
        $Obj.object.id,
        $Obj.object.uid,
        $Obj.id,
        $Obj.uid
    )

    $sourceId = Get-FirstText @(
        $Obj.object.sourceId,
        $Obj.sourceId,
        $Obj.parentId,
        $Obj.parentObjectId
    )

    $failedAttemptsCount = 0

    try {
        $failedAttemptsCount = @(AsArray $Obj.localSnapshotInfo.failedAttempts).Count
    }
    catch {
        $failedAttemptsCount = 0
    }

    return [pscustomobject]@{
        ObjectName          = $objectName
        ObjectType          = $objectType
        Environment         = $env
        ObjectId            = $objectId
        SourceId            = $sourceId
        FailedAttemptsCount = $failedAttemptsCount
    }
}

function Get-SqlHostMapFromRun {
    param([object]$Run)

    $hostMap = @{}
    $objects = @(AsArray $Run.objects)

    foreach ($obj in $objects) {
        $f = Get-SqlObjectFields -Obj $obj

        if ($f.Environment -ne "kSQL") {
            continue
        }

        if ($f.ObjectType -in @("kDatabase", "kSQLDB")) {
            continue
        }

        if ($f.ObjectType -eq "kSQL" -and
            (-not [string]::IsNullOrWhiteSpace($f.SourceId) -or $f.FailedAttemptsCount -gt 0)) {
            continue
        }

        if (-not [string]::IsNullOrWhiteSpace($f.ObjectId) -and
            -not [string]::IsNullOrWhiteSpace($f.ObjectName)) {
            $hostMap[$f.ObjectId] = $f.ObjectName
        }
    }

    return $hostMap
}

function Get-SqlDbRowsFromRun {
    param(
        [object]$Run,
        [string]$RunStatus,
        [string]$RunType,
        [int64]$RunEndUsecs
    )

    $rows = @()
    $objects = @(AsArray $Run.objects)

    if ($objects.Count -eq 0) {
        return @()
    }

    $hostMap = Get-SqlHostMapFromRun -Run $Run

    foreach ($obj in $objects) {
        $f = Get-SqlObjectFields -Obj $obj

        $isDb = Test-SqlDbCandidate `
            -ObjectType $f.ObjectType `
            -ObjectName $f.ObjectName `
            -ObjectId $f.ObjectId `
            -SourceId $f.SourceId `
            -FailedAttemptsCount $f.FailedAttemptsCount

        if (-not $isDb) {
            continue
        }

        $hostName = ""

        if (-not [string]::IsNullOrWhiteSpace($f.SourceId) -and $hostMap.ContainsKey($f.SourceId)) {
            $hostName = $hostMap[$f.SourceId]
        }

        $rows += [pscustomobject]@{
            DbName               = $f.ObjectName
            HostName             = $hostName
            ObjectType           = $f.ObjectType
            ObjectId             = $f.ObjectId
            SourceId             = $f.SourceId
            DiscoveryRunStatus   = $RunStatus
            DiscoveryRunType     = $RunType
            DiscoveryRunEndUsecs = $RunEndUsecs
            FailedAttemptsCount  = $f.FailedAttemptsCount
        }
    }

    return @($rows)
}

function Get-SqlRunEvidenceFromRecentRuns {
    param(
        [string]$PgId,
        [hashtable]$Headers
    )

    $allDbRows = @()
    $latestSuccessUsecs = 0
    $latestSuccessRun = $null

    if ([string]::IsNullOrWhiteSpace($PgId)) {
        return [pscustomobject]@{
            DbRows             = @()
            LatestSuccessRun   = $null
            LatestSuccessUsecs = 0
            LatestSuccessTime  = "NoBackup"
        }
    }

    $page = 0
    $cookie = ""

    do {
        $page++

        $uri = "$BaseUrl/v2/data-protect/protection-groups/$PgId/runs" +
               "?environments=kSQL" +
               "&isDeleted=false" +
               "&isPaused=false" +
               "&isActive=true" +
               "&numRuns=$NumRunsPerPg" +
               "&excludeNonRestorableRuns=false" +
               "&includeObjectDetails=true"

        if (-not [string]::IsNullOrWhiteSpace($cookie)) {
            $uri += "&paginationCookie=$([uri]::EscapeDataString($cookie))"
        }

        $script:PgRunCalls++

        $json = Invoke-HeliosGetJson -Uri $uri -Headers $Headers -Quiet

        if (-not $json -or -not $json.runs) {
            break
        }

        $runs = @(AsArray $json.runs | Where-Object { $_ })

        $runs = $runs |
            Sort-Object @{ Expression = { To-Int64Safe (Get-RunEndUsecsFromRun $_) }; Descending = $true }

        foreach ($run in $runs) {
            $status   = Get-RunStatusFromRun $run
            $runType  = Get-RunTypeFromRun $run
            $endUsecs = To-Int64Safe (Get-RunEndUsecsFromRun $run)

            if ($endUsecs -le 0) {
                continue
            }

            $dbRows = @(Get-SqlDbRowsFromRun `
                -Run $run `
                -RunStatus $status `
                -RunType $runType `
                -RunEndUsecs $endUsecs)

            if ($dbRows.Count -gt 0) {
                $allDbRows += $dbRows
            }

            if ((Test-SuccessStatus $status) -and (Test-RegularRunType $runType)) {
                $script:SqlSuccessfulRunsChecked++

                if ($endUsecs -gt $latestSuccessUsecs) {
                    $latestSuccessUsecs = $endUsecs
                    $latestSuccessRun = $run
                }
            }
        }

        $cookie = Get-FirstText $json.paginationCookie

        if ($json.isResponseTruncated -ne $true) {
            break
        }

    } while (-not [string]::IsNullOrWhiteSpace($cookie) -and $page -lt $MaxRunPagesPerPg)

    $deduped = @()

    foreach ($grp in ($allDbRows | Group-Object DbName, HostName)) {
        $deduped += (
            $grp.Group |
            Sort-Object `
                @{ Expression = { if ([string]::IsNullOrWhiteSpace($_.HostName)) { 0 } else { 1 } }; Descending = $true },
                @{ Expression = { [int64]$_.DiscoveryRunEndUsecs }; Descending = $true } |
            Select-Object -First 1
        )
    }

    $successTime = "NoBackup"

    if ($latestSuccessUsecs -gt 0) {
        $successTime = Convert-UsecsToET $latestSuccessUsecs
    }

    return [pscustomobject]@{
        DbRows             = @($deduped)
        LatestSuccessRun   = $latestSuccessRun
        LatestSuccessUsecs = $latestSuccessUsecs
        LatestSuccessTime  = $successTime
    }
}

function Get-TargetedSqlRowsFromPg {
    param(
        [object]$Context,
        [string]$SearchTerm,
        [object]$Candidate,
        [hashtable]$ClusterMap
    )

    $rows = @()

    if ([string]::IsNullOrWhiteSpace($Candidate.PgId)) {
        return @()
    }

    $clusterId = "$($Candidate.ClusterId)"
    $clusterName = Get-ClusterNameFromMap -ClusterId $clusterId -ClusterMap $ClusterMap

    if ($clusterName -eq $clusterId -and -not [string]::IsNullOrWhiteSpace($Candidate.ClusterName)) {
        $clusterName = "$($Candidate.ClusterName)"
    }

    $headers = @{
        accept          = "application/json"
        apiKey          = $ApiKey
        accessClusterId = "$clusterId"
    }

    $script:TargetedSqlInspections++

    $evidence = Get-SqlRunEvidenceFromRecentRuns `
        -PgId "$($Candidate.PgId)" `
        -Headers $headers

    if (-not $evidence -or $evidence.LatestSuccessUsecs -le 0) {
        return @(
            [pscustomobject]@{
                InputCI         = $Context.InputCI
                BackupType      = "SQL"
                ObjectName      = $SearchTerm
                ClusterName     = $clusterName
                ProtectionGroup = "$($Candidate.PgName)"
                LastBackupTime  = "NoBackup"
                LastBackupUsecs = 0
                HostName        = ""
                Source          = "SQLNoSuccessfulRegularRun"
            }
        )
    }

    if (-not $evidence.DbRows -or @($evidence.DbRows).Count -eq 0) {
        $script:SqlDbListNotDiscovered++

        return @(
            [pscustomobject]@{
                InputCI         = $Context.InputCI
                BackupType      = "SQL"
                ObjectName      = $SearchTerm
                ClusterName     = $clusterName
                ProtectionGroup = "$($Candidate.PgName)"
                LastBackupTime  = "DbListNotDiscovered"
                LastBackupUsecs = $evidence.LatestSuccessUsecs
                HostName        = $SearchTerm
                Source          = "SQLPgSuccessButNoDbList"
            }
        )
    }

    foreach ($db in @($evidence.DbRows)) {
        $dbName = $db.DbName
        $hostName = $db.HostName

        if ([string]::IsNullOrWhiteSpace($dbName)) {
            continue
        }

        if ($Context.IsDbAtServer) {
            if (-not (Text-MatchesName -Text $dbName -Name $Context.DbName)) {
                continue
            }

            if (-not [string]::IsNullOrWhiteSpace($hostName)) {
                if (-not (Text-MatchesName -Text $hostName -Name $Context.ServerName)) {
                    continue
                }
            }
        }
        else {
            $dbMatches   = Text-MatchesName -Text $dbName -Name $Context.InputCI
            $hostMatches = Text-MatchesName -Text $hostName -Name $Context.InputCI

            if (-not $dbMatches -and -not $hostMatches -and
                -not [string]::IsNullOrWhiteSpace($hostName)) {
                continue
            }
        }

        $rows += [pscustomobject]@{
            InputCI         = $Context.InputCI
            BackupType      = "SQL"
            ObjectName      = $dbName
            ClusterName     = $clusterName
            ProtectionGroup = "$($Candidate.PgName)"
            LastBackupTime  = $evidence.LatestSuccessTime
            LastBackupUsecs = $evidence.LatestSuccessUsecs
            HostName        = $hostName
            Source          = "SQLDbDiscoveredFromRecentRuns_PgSuccessTime"
        }
    }

    if ($rows.Count -gt 0) {
        $script:SqlDbObjectsFound += $rows.Count
        return @($rows)
    }

    $script:SqlDbListNotDiscovered++

    return @(
        [pscustomobject]@{
            InputCI         = $Context.InputCI
            BackupType      = "SQL"
            ObjectName      = $SearchTerm
            ClusterName     = $clusterName
            ProtectionGroup = "$($Candidate.PgName)"
            LastBackupTime  = "DbListFoundButNoInputMatch"
            LastBackupUsecs = $evidence.LatestSuccessUsecs
            HostName        = $SearchTerm
            Source          = "SQLDbListFoundButNoInputMatch"
        }
    )
}

