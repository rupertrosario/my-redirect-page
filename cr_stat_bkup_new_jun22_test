# ==========================================================
# Snapshot Helpers
# ==========================================================
function Get-SnapshotArray {
    param([object]$Obj)

    if (-not $Obj) {
        return @()
    }

    $snaps = @()
    $snaps += @(AsArray $Obj.latestSnapshotInfo)
    $snaps += @(AsArray $Obj.latestSnapshotsInfo)
    $snaps += @(AsArray $Obj.latestSnapshots)
    $snaps += @(AsArray $Obj.latestSnapshot)
    $snaps += @(AsArray $Obj.snapshotInfo)
    $snaps += @(AsArray $Obj.backupInfo)
    $snaps += @(AsArray $Obj.snapshots)

    return @($snaps | Where-Object { $_ })
}

function Get-SnapshotRunType {
    param([object]$Snap)

    return Get-FirstText @(
        $Snap.localBackupInfo.runType,
        $Snap.localBackupInfo.backupRunType,
        $Snap.originalBackupInfo.runType,
        $Snap.originalBackupInfo.backupRunType,
        $Snap.runType,
        $Snap.backupRunType,
        $Snap.snapshotRunType
    )
}

function Get-SnapshotUsecs {
    param([object]$Snap)

    if (-not $Snap) {
        return 0
    }

    foreach ($v in @(
        $Snap.protectionRunEndTimeUsecs,
        $Snap.runEndTimeUsecs,
        $Snap.endTimeUsecs,
        $Snap.snapshotCreationTimeUsecs,
        $Snap.creationTimeUsecs,
        $Snap.protectionRunStartTimeUsecs,
        $Snap.runStartTimeUsecs,
        $Snap.startTimeUsecs,
        $Snap.localBackupInfo.endTimeUsecs,
        $Snap.localBackupInfo.startTimeUsecs
    )) {
        $n = To-Int64Safe $v

        if ($n -gt 0) {
            return $n
        }
    }

    return 0
}

function Get-BestSnapshot {
    param(
        [object]$Obj,
        [string]$BackupType
    )

    $snaps = @(Get-SnapshotArray $Obj)

    if ($snaps.Count -eq 0) {
        return $null
    }

    if ($BackupType -in @("SQL", "Oracle")) {
        $regular = @($snaps | Where-Object {
            $rt = Get-SnapshotRunType $_
            Test-RegularRunType $rt
        })

        if ($regular.Count -gt 0) {
            return $regular |
                Sort-Object @{ Expression = { Get-SnapshotUsecs $_ }; Descending = $true } |
                Select-Object -First 1
        }

        return $null
    }

    $nonLog = @($snaps | Where-Object {
        $rt = Get-SnapshotRunType $_
        $rt -notmatch '(?i)log|archive'
    })

    if ($nonLog.Count -eq 0) {
        return $null
    }

    return $nonLog |
        Sort-Object @{ Expression = { Get-SnapshotUsecs $_ }; Descending = $true } |
        Select-Object -First 1
}

