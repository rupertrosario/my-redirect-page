# ==========================================================
# Cohesity Backup Validation - Full Reset Version
# GET-only | No POST / PUT / PATCH / DELETE
#
# Input:
#   X:\PowerShell\Data\Cohesity\BackupValidation\<ChangeID>.csv
#
# Required input column:
#   ci_item
#
# Output:
#   X:\PowerShell\Data\Cohesity\BackupValidation\<ChangeID>.txt
#   X:\PowerShell\Data\Cohesity\BackupValidation\<ChangeID>_BackupReport_<timestamp>.txt
#   X:\PowerShell\Data\Cohesity\BackupValidation\<ChangeID>_BackupReport_<timestamp>.csv
#
# Final columns:
#   InputCI, BackupType, ObjectName, ClusterName, ProtectionGroup, LastBackupTime
#
# BackupType:
#   SQL, Oracle, FS, VMware, Hyper-V, Nutanix, NAS, Unknown
#
# Design:
#   1. Check server backups: FS / VMware / Hyper-V / Nutanix / NAS.
#   2. Check SQL application backups.
#   3. Check Oracle application backups.
#   4. Only if nothing is found anywhere, return Unknown.
#
# SQL:
#   - Finds candidate PGs from kSQL object search.
#   - Optional broad search is used only if kSQL search finds nothing.
#   - Does NOT scan all SQL PGs.
#   - Treats kSQL, kDatabase, and kSQLDB as SQL DB candidates.
#   - Filters obvious server-name rows so server object is not shown as DB.
# ==========================================================

$ErrorActionPreference = "Stop"
$FormatEnumerationLimit = -1
[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12

# -------------------------
# Input
# -------------------------
$ChangeID   = Read-Host "Enter Change Number"
$ExecutedBy = (whoami).Trim()

# -------------------------
# Paths
# -------------------------
$BaseDir = "X:\PowerShell\Data\Cohesity\BackupValidation"

if (-not (Test-Path -Path $BaseDir -PathType Container)) {
    New-Item -Path $BaseDir -ItemType Directory | Out-Null
}

$InputCsv = Join-Path $BaseDir "$ChangeID.csv"
$InputTxt = Join-Path $BaseDir "$ChangeID.txt"

$Stamp     = Get-Date -Format "yyyyMMdd_HHmm"
$OutputTxt = Join-Path $BaseDir "${ChangeID}_BackupReport_$Stamp.txt"
$OutputCsv = Join-Path $BaseDir "${ChangeID}_BackupReport_$Stamp.csv"

if (-not (Test-Path $InputCsv)) {
    throw "Input CSV not found: $InputCsv"
}

# -------------------------
# API
# -------------------------
$BaseUrl = "https://helios.cohesity.com"
$ApiKeyPath = "X:\PowerShell\Cohesity_API_Scripts\DO_NOT_Delete\apikey.txt"

if (-not (Test-Path $ApiKeyPath)) {
    throw "API key file not found: $ApiKeyPath"
}

$ApiKey = (Get-Content -Path $ApiKeyPath -Raw).Trim()

$CommonHeaders = @{
    accept = "application/json"
    apiKey = $ApiKey
}

# -------------------------
# Settings
# -------------------------
$ReportTimeZoneId = "Eastern Standard Time"

# Keep this lower to avoid slow runs.
$GlobalSearchCount = 50
$NumRunsPerPg      = 10
$MaxRunPagesPerPg  = 1

# Avoid huge SQL inspection fan-out.
$MaxSqlCandidatesToInspect = 8

# Broad search helps when kSQL search misses, but does not scan all SQL PGs.
$EnableBroadSqlSearchIfKsqlSearchMisses = $true

# Server backup environments.
$ServerBackupEnvironments = @(
    [pscustomobject]@{ Environment = "kPhysical";   BackupType = "FS" }
    [pscustomobject]@{ Environment = "kVMware";     BackupType = "VMware" }
    [pscustomobject]@{ Environment = "kHyperV";     BackupType = "Hyper-V" }
    [pscustomobject]@{ Environment = "kAcropolis";  BackupType = "Nutanix" }
    [pscustomobject]@{ Environment = "kGenericNas"; BackupType = "NAS" }
    [pscustomobject]@{ Environment = "kIsilon";     BackupType = "NAS" }
)

# -------------------------
# Counters
# -------------------------
$script:GlobalSearchCalls        = 0
$script:ProtectedSearchCalls     = 0
$script:PgRunCalls               = 0
$script:PgDetailCalls            = 0
$script:ObjectLookupCalls        = 0
$script:FailedGets               = 0
$script:SqlCandidatesFound       = 0
$script:SqlCandidatesInspected   = 0
$script:SqlDbObjectsFound        = 0
$script:SqlDbListNotDiscovered   = 0
$script:ServerBackupRowsFound    = 0
$script:OracleRowsFound          = 0

# ==========================================================
# Common Helpers
# ==========================================================
function Invoke-HeliosGetJson {
    param(
        [Parameter(Mandatory)][string]$Uri,
        [Parameter(Mandatory)][hashtable]$Headers,
        [int]$TimeoutSec = 60,
        [switch]$Quiet
    )

    try {
        $resp = Invoke-WebRequest `
            -Uri $Uri `
            -Headers $Headers `
            -Method Get `
            -UseBasicParsing `
            -TimeoutSec $TimeoutSec `
            -ErrorAction Stop

        if (-not $resp -or [string]::IsNullOrWhiteSpace($resp.Content)) {
            return $null
        }

        return ($resp.Content | ConvertFrom-Json)
    }
    catch {
        $script:FailedGets++

        if (-not $Quiet) {
            Write-Host "GET failed:" -ForegroundColor Red
            Write-Host $Uri -ForegroundColor DarkRed
            Write-Host $_.Exception.Message -ForegroundColor DarkRed
        }

        return $null
    }
}

function AsArray {
    param([object]$Value)

    if ($null -eq $Value) {
        return @()
    }

    if ($Value -is [array]) {
        return @($Value)
    }

    return @($Value)
}

function Get-FirstText {
    param([object]$Value)

    if ($null -eq $Value) {
        return ""
    }

    if ($Value -is [array]) {
        foreach ($item in $Value) {
            $v = Get-FirstText $item
            if (-not [string]::IsNullOrWhiteSpace($v)) {
                return "$v".Trim()
            }
        }
        return ""
    }

    if ($Value -is [pscustomobject]) {
        foreach ($prop in @(
            "name",
            "displayName",
            "display_value",
            "value",
            "id",
            "uid",
            "_id",
            "clusterId",
            "clusterID",
            "intId"
        )) {
            if ($Value.PSObject.Properties.Name -contains $prop) {
                $v = Get-FirstText $Value.$prop
                if (-not [string]::IsNullOrWhiteSpace($v)) {
                    return "$v".Trim()
                }
            }
        }

        return ""
    }

    return "$Value".Trim()
}

function To-Int64Safe {
    param($Value)

    if ($null -eq $Value -or "$Value".Trim() -eq "") {
        return 0
    }

    try {
        return [int64]$Value
    }
    catch {
        return 0
    }
}

function Add-UniqueText {
    param(
        [System.Collections.ArrayList]$List,
        [string]$Value
    )

    if ([string]::IsNullOrWhiteSpace($Value)) {
        return
    }

    $v = "$Value".Trim().Trim('"').Trim("'")

    if (-not $List.Contains($v)) {
        [void]$List.Add($v)
    }
}

function Convert-UsecsToET {
    param($Usecs)

    if ($null -eq $Usecs -or "$Usecs".Trim() -eq "" -or "$Usecs" -eq "0") {
        return ""
    }

    try {
        $dto = [DateTimeOffset]::FromUnixTimeMilliseconds([int64]($Usecs / 1000))
        $tz  = [System.TimeZoneInfo]::FindSystemTimeZoneById($ReportTimeZoneId)
        return ([System.TimeZoneInfo]::ConvertTime($dto, $tz)).ToString("dd-MMM-yyyy HH:mm:ss") + " ET"
    }
    catch {
        return ""
    }
}

function Normalize-Name {
    param([string]$Value)

    if ([string]::IsNullOrWhiteSpace($Value)) {
        return ""
    }

    return "$Value".Trim().Trim('"').Trim("'").ToLower()
}

function Get-ShortName {
    param([string]$Value)

    if ([string]::IsNullOrWhiteSpace($Value)) {
        return ""
    }

    $v = "$Value".Trim()

    if ($v -match "\.") {
        return (($v -split "\.")[0]).Trim()
    }

    return $v
}

function Text-MatchesName {
    param(
        [string]$Text,
        [string]$Name
    )

    $t = Normalize-Name $Text
    $n = Normalize-Name $Name

    if ([string]::IsNullOrWhiteSpace($t) -or [string]::IsNullOrWhiteSpace($n)) {
        return $false
    }

    if ($t -eq $n) {
        return $true
    }

    $tShort = Normalize-Name (Get-ShortName $Text)
    $nShort = Normalize-Name (Get-ShortName $Name)

    if (-not [string]::IsNullOrWhiteSpace($tShort) -and $tShort -eq $n) {
        return $true
    }

    if (-not [string]::IsNullOrWhiteSpace($nShort) -and $nShort -eq $t) {
        return $true
    }

    if (-not [string]::IsNullOrWhiteSpace($tShort) -and
        -not [string]::IsNullOrWhiteSpace($nShort) -and
        $tShort -eq $nShort) {
        return $true
    }

    if ($t -like "*$n*") {
        return $true
    }

    if ($n -like "*$t*") {
        return $true
    }

    return $false
}

function Get-SearchVariants {
    param([string]$Value)

    $list = New-Object System.Collections.ArrayList

    if ([string]::IsNullOrWhiteSpace($Value)) {
        return @()
    }

    $v = "$Value".Trim()

    Add-UniqueText -List $list -Value $v

    $short = Get-ShortName $v
    if (-not [string]::IsNullOrWhiteSpace($short)) {
        Add-UniqueText -List $list -Value $short
    }

    Add-UniqueText -List $list -Value $v.ToLower()
    Add-UniqueText -List $list -Value $v.ToUpper()

    if (-not [string]::IsNullOrWhiteSpace($short)) {
        Add-UniqueText -List $list -Value $short.ToLower()
        Add-UniqueText -List $list -Value $short.ToUpper()
    }

    return @($list)
}

function Test-SuccessStatus {
    param([string]$Status)

    if ([string]::IsNullOrWhiteSpace($Status)) {
        return $false
    }

    return ($Status -match '(?i)success|succeeded|succeededwithwarning|warning')
}

function Test-RegularRunType {
    param([string]$RunType)

    if ([string]::IsNullOrWhiteSpace($RunType)) {
        # Some APIs do not expose runType consistently.
        return $true
    }

    if ($RunType -match '(?i)log|archive') {
        return $false
    }

    return ($RunType -match '(?i)regular|full|incr|incremental|kregular|snapshot')
}

function Is-ValidBackupTime {
    param([string]$Value)

    if ([string]::IsNullOrWhiteSpace($Value)) {
        return $false
    }

    return $Value -notin @(
        "Unknown",
        "NoBackup",
        "NoBackupTime",
        "DbListNotDiscovered"
    )
}

function Get-BackupTypeRank {
    param([string]$BackupType)

    switch ($BackupType) {
        "SQL"     { return 1 }
        "Oracle"  { return 2 }
        "FS"      { return 3 }
        "VMware"  { return 4 }
        "Hyper-V" { return 5 }
        "Nutanix" { return 6 }
        "NAS"     { return 7 }
        default   { return 9 }
    }
}

# ==========================================================
# CI Helpers
