# ==========================================================
# Cohesity Backup Validation – SQL + Oracle + Server Backup
# GET-only | No write operations
#
# Input CSV:
#   X:\PowerShell\Data\Cohesity\BackupValidation\<ChangeID>.csv
#
# Required input column:
#   ci_item
#
# Output:
#   <ChangeID>.txt
#   <ChangeID>_BackupReport_<timestamp>.txt
#   <ChangeID>_BackupReport_<timestamp>.csv
#
# Final CSV columns:
#   InputCI,BackupType,ObjectName,ClusterName,ProtectionGroup,LastBackupTime
#
# Backup types:
#   SQL, Oracle, FS, VMware, Hyper-V, Nutanix, NAS, Unknown
#
# Safety:
#   GET-only.
#   No POST / PUT / PATCH / DELETE.
# ==========================================================

$ErrorActionPreference = "Stop"
$FormatEnumerationLimit = -1
[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12

# -------------------------
# Input
# -------------------------
$ChangeID   = Read-Host "Enter Change Number"
$ExecutedBy = (whoami).Trim()

# -------------------------
# Paths
# -------------------------
$BaseDir = "X:\PowerShell\Data\Cohesity\BackupValidation"

if (-not (Test-Path -Path $BaseDir -PathType Container)) {
    New-Item -Path $BaseDir -ItemType Directory | Out-Null
}

$InputCsv = Join-Path $BaseDir "$ChangeID.csv"
$InputTxt = Join-Path $BaseDir "$ChangeID.txt"

$Stamp     = Get-Date -Format "yyyyMMdd_HHmm"
$OutputTxt = Join-Path $BaseDir "${ChangeID}_BackupReport_$Stamp.txt"
$OutputCsv = Join-Path $BaseDir "${ChangeID}_BackupReport_$Stamp.csv"

if (-not (Test-Path $InputCsv)) {
    throw "Input CSV not found: $InputCsv"
}

# -------------------------
# API
# -------------------------
$BaseUrl = "https://helios.cohesity.com"
$ApiKeyPath = "X:\PowerShell\Cohesity_API_Scripts\DO_NOT_Delete\apikey.txt"

if (-not (Test-Path $ApiKeyPath)) {
    throw "API key file not found: $ApiKeyPath"
}

$ApiKey = (Get-Content -Path $ApiKeyPath -Raw).Trim()

$CommonHeaders = @{
    accept = "application/json"
    apiKey = $ApiKey
}

# -------------------------
# Settings
# -------------------------
$ReportTimeZoneId = "Eastern Standard Time"

$GlobalSearchCount = 100
$NumRunsPerPg      = 20
$MaxRunPagesPerPg  = 3

$EnableTargetedSqlPgRunInspection = $true
$EnableTargetedOraclePgInspection = $true

# If runType is blank but status is success, treat it as regular.
$AllowBlankRunTypeForDb = $true

# -------------------------
# Counters
# -------------------------
$script:GlobalSearchCalls          = 0
$script:ProtectedSearchCalls       = 0
$script:PgRunCalls                 = 0
$script:PgDetailCalls              = 0
$script:ObjectLookupCalls          = 0
$script:FailedGets                 = 0
$script:TargetedSqlInspections     = 0
$script:TargetedOraInspections     = 0
$script:SqlSuccessfulRunsChecked   = 0
$script:SqlDbObjectsFound          = 0
$script:SqlDbListNotDiscovered     = 0
$script:SqlPgListFallbackCalls     = 0
$script:SqlPgListFallbackMatches   = 0

# ==========================================================
# Common Helpers
# ==========================================================
function Invoke-HeliosGetJson {
    param(
        [Parameter(Mandatory)][string]$Uri,
        [Parameter(Mandatory)][hashtable]$Headers,
        [int]$TimeoutSec = 60,
        [switch]$Quiet
    )

    try {
        $resp = Invoke-WebRequest `
            -Uri $Uri `
            -Headers $Headers `
            -Method Get `
            -UseBasicParsing `
            -TimeoutSec $TimeoutSec `
            -ErrorAction Stop

        if (-not $resp -or [string]::IsNullOrWhiteSpace($resp.Content)) {
            return $null
        }

        return ($resp.Content | ConvertFrom-Json)
    }
    catch {
        $script:FailedGets++

        if (-not $Quiet) {
            Write-Host "GET failed:" -ForegroundColor Red
            Write-Host $Uri -ForegroundColor DarkRed
            Write-Host $_.Exception.Message -ForegroundColor DarkRed
        }

        return $null
    }
}

function AsArray {
    param([object]$Value)

    if ($null -eq $Value) {
        return @()
    }

    if ($Value -is [array]) {
        return @($Value)
    }

    return @($Value)
}

function Get-FirstText {
    param([object]$Value)

    if ($null -eq $Value) {
        return ""
    }

    if ($Value -is [array]) {
        foreach ($item in $Value) {
            $v = Get-FirstText $item

            if (-not [string]::IsNullOrWhiteSpace($v)) {
                return "$v".Trim()
            }
        }

        return ""
    }

    if ($Value -is [pscustomobject]) {
        foreach ($prop in @(
            "name",
            "displayName",
            "display_value",
            "value",
            "id",
            "uid",
            "_id",
            "clusterId",
            "clusterID",
            "intId"
        )) {
            if ($Value.PSObject.Properties.Name -contains $prop) {
                $v = Get-FirstText $Value.$prop

                if (-not [string]::IsNullOrWhiteSpace($v)) {
                    return "$v".Trim()
                }
            }
        }

        return ""
    }

    return "$Value".Trim()
}

function To-Int64Safe {
    param($Value)

    if ($null -eq $Value -or "$Value".Trim() -eq "") {
        return 0
    }

    try {
        return [int64]$Value
    }
    catch {
        return 0
    }
}

function Add-UniqueText {
    param(
        [System.Collections.ArrayList]$List,
        [string]$Value
    )

    if ([string]::IsNullOrWhiteSpace($Value)) {
        return
    }

    $v = "$Value".Trim().Trim('"').Trim("'")

    if (-not $List.Contains($v)) {
        [void]$List.Add($v)
    }
}

function Convert-UsecsToET {
    param($Usecs)

    if ($null -eq $Usecs -or "$Usecs".Trim() -eq "" -or "$Usecs" -eq "0") {
        return ""
    }

    try {
        $dto = [DateTimeOffset]::FromUnixTimeMilliseconds([int64]($Usecs / 1000))
        $tz  = [System.TimeZoneInfo]::FindSystemTimeZoneById($ReportTimeZoneId)
        return ([System.TimeZoneInfo]::ConvertTime($dto, $tz)).ToString("dd-MMM-yyyy HH:mm:ss") + " ET"
    }
    catch {
        return ""
    }
}

function Text-MatchesName {
    param(
        [string]$Text,
        [string]$Name
    )

    if ([string]::IsNullOrWhiteSpace($Text) -or [string]::IsNullOrWhiteSpace($Name)) {
        return $false
    }

    $t = "$Text".Trim().ToLower()
    $n = "$Name".Trim().ToLower()

    if ($t -eq $n) {
        return $true
    }

    if ($t -like "*$n*") {
        return $true
    }

    if ($n -like "*$t*") {
        return $true
    }

    if ($t -match "\.") {
        $short = ($t -split "\.")[0]
        if ($short -eq $n) {
            return $true
        }
    }

    if ($n -match "\.") {
        $short2 = ($n -split "\.")[0]
        if ($short2 -eq $t) {
            return $true
        }
    }

    return $false
}

function Get-SearchVariants {
    param([string]$Value)

    $list = New-Object System.Collections.ArrayList

    if ([string]::IsNullOrWhiteSpace($Value)) {
        return @()
    }

    $v = "$Value".Trim()

    Add-UniqueText -List $list -Value $v
    Add-UniqueText -List $list -Value $v.ToLower()
    Add-UniqueText -List $list -Value $v.ToUpper()

    if ($v -match "\.") {
        Add-UniqueText -List $list -Value (($v -split "\.")[0])
    }

    return @($list)
}

function Test-SuccessStatus {
    param([string]$Status)

    if ([string]::IsNullOrWhiteSpace($Status)) {
        return $false
    }

    return ($Status -match '(?i)success|succeeded|succeededwithwarning|warning')
}

function Test-RegularRunType {
    param([string]$RunType)

    if ([string]::IsNullOrWhiteSpace($RunType)) {
        return $AllowBlankRunTypeForDb
    }

    if ($RunType -match '(?i)log|archive') {
        return $false
    }

    return ($RunType -match '(?i)regular|full|incr|incremental|kregular')
}

function Is-ValidBackupTime {
    param([string]$Value)

    if ([string]::IsNullOrWhiteSpace($Value)) {
        return $false
    }

    return $Value -notin @(
        "Unknown",
        "NoObject",
        "NoBackup",
        "NoBackupTime",
        "NoFSBackupFound",
        "NoDbDetailFound",
        "DbListNotDiscovered",
        "DbListFoundButNoInputMatch",
        "NoSqlPgCandidateFound"
    )
}

function Get-BackupTypeRank {
    param([string]$BackupType)

    switch ($BackupType) {
        "SQL"     { return 1 }
        "Oracle"  { return 2 }
        "FS"      { return 3 }
        "VMware"  { return 4 }
        "Hyper-V" { return 5 }
        "Nutanix" { return 6 }
        "NAS"     { return 7 }
        default   { return 9 }
    }
}

# ==========================================================
# CI Parsing
# ==========================================================
function Get-CiContext {
    param([string]$Ci)

    $clean = "$Ci".Trim().Trim('"').Trim("'")

    $isDbAtServer = $false
    $dbName = ""
    $serverName = ""

    if ($clean -match "@") {
        $parts = $clean -split "@", 2
        $dbName = "$($parts[0])".Trim()
        $serverName = "$($parts[1])".Trim()

        if (-not [string]::IsNullOrWhiteSpace($dbName) -and
            -not [string]::IsNullOrWhiteSpace($serverName)) {
            $isDbAtServer = $true
        }
    }

    return [pscustomobject]@{
        InputCI      = $clean
        IsDbAtServer = $isDbAtServer
        DbName       = $dbName
        ServerName   = $serverName
    }
}

function Get-SearchTermsForSql {
    param([object]$Context)

    $terms = New-Object System.Collections.ArrayList

    if ($Context.IsDbAtServer) {
        foreach ($v in (Get-SearchVariants -Value $Context.DbName)) {
            Add-UniqueText -List $terms -Value $v
        }

        foreach ($v in (Get-SearchVariants -Value $Context.ServerName)) {
            Add-UniqueText -List $terms -Value $v
        }
    }
    else {
        foreach ($v in (Get-SearchVariants -Value $Context.InputCI)) {
            Add-UniqueText -List $terms -Value $v
        }
    }

    return @($terms)
}

