function Add-Candidate {
    param(
        [System.Collections.ArrayList]$List,
        [hashtable]$Seen,
        [string]$ClusterId,
        [string]$ClusterName,
        [string]$PgId,
        [string]$PgName
    )

    if ([string]::IsNullOrWhiteSpace($ClusterId)) {
        return
    }

    if ([string]::IsNullOrWhiteSpace($ClusterName)) {
        $ClusterName = $ClusterId
    }

    if ([string]::IsNullOrWhiteSpace($PgId)) {
        $PgId = ""
    }

    if ([string]::IsNullOrWhiteSpace($PgName)) {
        $PgName = "-"
    }

    $key = "$ClusterId|$PgId|$PgName"

    if ($Seen.ContainsKey($key)) {
        return
    }

    $Seen[$key] = $true

    [void]$List.Add([pscustomobject]@{
        ClusterId   = $ClusterId
        ClusterName = $ClusterName
        PgId        = $PgId
        PgName      = $PgName
    })
}

function Get-CandidatesFromSearchJson {
    param(
        [object]$Json,
        [hashtable]$ClusterMap
    )

    $list = New-Object System.Collections.ArrayList
    $seen = @{}

    foreach ($obj in (Get-ObjectArrayFromJson $Json)) {

        foreach ($opi in (AsArray $obj.objectProtectionInfos)) {

            foreach ($pg in (AsArray $opi.protectionGroups)) {
                $cid    = Get-ClusterIdFromNode -Obj $obj -ProtectionInfo $opi -Pg $pg
                $cname  = Get-ClusterNameFromNode -Obj $obj -ProtectionInfo $opi -Pg $pg -ClusterId $cid -ClusterMap $ClusterMap
                $pgid   = Get-PgIdFromNode -Obj $obj -ProtectionInfo $opi -Pg $pg
                $pgname = Get-PgNameFromNode -Obj $obj -ProtectionInfo $opi -Pg $pg

                Add-Candidate -List $list -Seen $seen -ClusterId $cid -ClusterName $cname -PgId $pgid -PgName $pgname
            }

            if (-not $opi.protectionGroups) {
                $cid    = Get-ClusterIdFromNode -Obj $obj -ProtectionInfo $opi -Pg $null
                $cname  = Get-ClusterNameFromNode -Obj $obj -ProtectionInfo $opi -Pg $null -ClusterId $cid -ClusterMap $ClusterMap
                $pgid   = Get-PgIdFromNode -Obj $obj -ProtectionInfo $opi -Pg $null
                $pgname = Get-PgNameFromNode -Obj $obj -ProtectionInfo $opi -Pg $null

                Add-Candidate -List $list -Seen $seen -ClusterId $cid -ClusterName $cname -PgId $pgid -PgName $pgname
            }
        }

        foreach ($pg2 in (AsArray $obj.protectionGroups)) {
            $cid    = Get-ClusterIdFromNode -Obj $obj -ProtectionInfo $null -Pg $pg2
            $cname  = Get-ClusterNameFromNode -Obj $obj -ProtectionInfo $null -Pg $pg2 -ClusterId $cid -ClusterMap $ClusterMap
            $pgid   = Get-PgIdFromNode -Obj $obj -ProtectionInfo $null -Pg $pg2
            $pgname = Get-PgNameFromNode -Obj $obj -ProtectionInfo $null -Pg $pg2

            Add-Candidate -List $list -Seen $seen -ClusterId $cid -ClusterName $cname -PgId $pgid -PgName $pgname
        }

        $cidObj    = Get-ClusterIdFromNode -Obj $obj -ProtectionInfo $null -Pg $null
        $pgidObj   = Get-PgIdFromNode -Obj $obj -ProtectionInfo $null -Pg $null
        $pgnameObj = Get-PgNameFromNode -Obj $obj -ProtectionInfo $null -Pg $null

        if (-not [string]::IsNullOrWhiteSpace($cidObj)) {
            $cnameObj = Get-ClusterNameFromNode -Obj $obj -ProtectionInfo $null -Pg $null -ClusterId $cidObj -ClusterMap $ClusterMap
            Add-Candidate -List $list -Seen $seen -ClusterId $cidObj -ClusterName $cnameObj -PgId $pgidObj -PgName $pgnameObj
        }
    }

    return @($list)
}

function Get-SearchCandidates {
    param(
        [string]$SearchTerm,
        [string]$Environment,
        [hashtable]$ClusterMap
    )

    $script:GlobalSearchCalls++

    $globalUrl = New-SearchUrl `
        -Endpoint "/v2/data-protect/search/objects" `
        -SearchTerm $SearchTerm `
        -Environment $Environment `
        -Global

    $json = Invoke-HeliosGetJson -Uri $globalUrl -Headers $CommonHeaders -Quiet

    if (-not $json) {
        return @()
    }

    return @(
        Get-CandidatesFromSearchJson `
            -Json $json `
            -ClusterMap $ClusterMap |
        Sort-Object ClusterId, PgId, PgName -Unique
    )
}

function Get-BroadSearchCandidates {
    param(
        [string]$SearchTerm,
        [hashtable]$ClusterMap
    )

    $script:GlobalSearchCalls++

    $globalUrl = New-SearchUrl `
        -Endpoint "/v2/data-protect/search/objects" `
        -SearchTerm $SearchTerm `
        -Environment "" `
        -Global

    $json = Invoke-HeliosGetJson -Uri $globalUrl -Headers $CommonHeaders -Quiet

    if (-not $json) {
        return @()
    }

    return @(
        Get-CandidatesFromSearchJson `
            -Json $json `
            -ClusterMap $ClusterMap |
        Sort-Object ClusterId, PgId, PgName -Unique
    )
}

function Get-UniqueCandidates {
    param([object[]]$Candidates)

    $out = New-Object System.Collections.ArrayList
    $seen = @{}

    foreach ($c in @($Candidates)) {
        if (-not $c) {
            continue
        }

        $key = "$($c.ClusterId)|$($c.PgId)|$($c.PgName)"

        if ($seen.ContainsKey($key)) {
            continue
        }

        $seen[$key] = $true
        [void]$out.Add($c)
    }

    return @($out)
}

