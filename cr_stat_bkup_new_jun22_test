function Get-CiContext {
    param([string]$Ci)

    $clean = "$Ci".Trim().Trim('"').Trim("'")

    $isDbAtServer = $false
    $dbName = ""
    $serverName = ""

    if ($clean -match "@") {
        $parts = $clean -split "@", 2
        $dbName = "$($parts[0])".Trim()
        $serverName = "$($parts[1])".Trim()

        if (-not [string]::IsNullOrWhiteSpace($dbName) -and
            -not [string]::IsNullOrWhiteSpace($serverName)) {
            $isDbAtServer = $true
        }
    }

    return [pscustomobject]@{
        InputCI      = $clean
        IsDbAtServer = $isDbAtServer
        DbName       = $dbName
        ServerName   = $serverName
    }
}

function Get-SqlSearchTerms {
    param([object]$Context)

    $terms = New-Object System.Collections.ArrayList

    if ($Context.IsDbAtServer) {
        foreach ($v in (Get-SearchVariants -Value $Context.DbName)) {
            Add-UniqueText -List $terms -Value $v
        }

        foreach ($v in (Get-SearchVariants -Value $Context.ServerName)) {
            Add-UniqueText -List $terms -Value $v
        }
    }
    else {
        foreach ($v in (Get-SearchVariants -Value $Context.InputCI)) {
            Add-UniqueText -List $terms -Value $v
        }
    }

    return @($terms)
}

function Get-ServerSearchTerm {
    param([object]$Context)

    if ($Context.IsDbAtServer) {
        return $Context.ServerName
    }

    return $Context.InputCI
}

function Get-DbSearchTerm {
    param([object]$Context)

    if ($Context.IsDbAtServer) {
        return $Context.DbName
    }

    return $Context.InputCI
}

