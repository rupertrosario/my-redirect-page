export default async function (_) {

  const current =
    result('dc_iterations')[0];

  const existing =
    result('snow_search_dc')[0];

  // ------------------------------------------------
  // No Existing Incident
  // ------------------------------------------------
  if (!existing) {

    return [

      {
        shouldUpdate: false
      }
    ];
  }

  // ------------------------------------------------
  // Current Description
  // ------------------------------------------------
  const currentDesc =
    String(
      current.description || ""
    ).trim();

  // ------------------------------------------------
  // Existing Description
  // ------------------------------------------------
  const existingDesc =
    String(
      existing.description || ""
    ).trim();

  // ------------------------------------------------
  // Compare
  // ------------------------------------------------
  const shouldUpdate =
    currentDesc !== existingDesc;

  return [

    {
      shouldUpdate,
      sys_id:
        existing.sys_id
    }
  ];
}
