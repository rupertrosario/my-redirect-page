# Step 1: Get Access Token
$authBody = @{
    username = "your_username"
    password = "your_password"
    domain   = "LOCAL"   # or AD domain
} | ConvertTo-Json

$authResponse = Invoke-RestMethod `
    -Uri "https://cluster.ip.address/irisservices/api/v1/public/accessTokens" `
    -Method POST `
    -Body $authBody `
    -ContentType "application/json"

$token = $authResponse.accessToken

# Step 2: Call API with Bearer Token
$headers = @{
    "accept"        = "application/json"
    "authorization" = "Bearer $token"
}

$response = Invoke-WebRequest `
    -Uri "https://cluster.ip.address/v2/users" `
    -Method GET `
    -Headers $headers

$response.Content




# Prompt
$cred = Get-Credential

# Create session
$sessionBody = @{
    username = $cred.UserName
    password = $cred.GetNetworkCredential().Password
    domain   = "LOCAL"
} | ConvertTo-Json

$sessionResponse = Invoke-RestMethod `
    -Uri "https://cluster.ip.address/irisservices/api/v1/public/users/sessions" `
    -Method POST `
    -Body $sessionBody `
    -ContentType "application/json"

# Validate session
if (-not $sessionResponse -or -not $sessionResponse.sessionId) {
    Write-Host "Session creation failed"
    $sessionResponse | ConvertTo-Json -Depth 5
    return
}

$sessionId = $sessionResponse.sessionId

# Call API (use Invoke-RestMethod)
$headers = @{
    "accept"     = "application/json"
    "session-id" = $sessionId
}

$response = Invoke-RestMethod `
    -Uri "https://cluster.ip.address/v2/users" `
    -Method GET `
    -Headers $headers

$response
