# Prompt for credentials
$cred = Get-Credential

# Step 1: Get Access Token
$authBody = @{
    username = $cred.UserName
    password = $cred.GetNetworkCredential().Password
    domain   = "LOCAL"   # or AD domain
} | ConvertTo-Json

$authResponse = Invoke-RestMethod `
    -Uri "https://cluster.ip.address/irisservices/api/v1/public/accessTokens" `
    -Method POST `
    -Body $authBody `
    -ContentType "application/json"

# Validate token
if (-not $authResponse -or -not $authResponse.accessToken) {
    Write-Host "Token generation failed"
    $authResponse | ConvertTo-Json -Depth 5
    return
}

$token = $authResponse.accessToken

# Step 2: Call API
$headers = @{
    "accept"        = "application/json"
    "authorization" = "Bearer $token"
}

$response = Invoke-RestMethod `
    -Uri "https://cluster.ip.address/v2/users" `
    -Method GET `
    -Headers $headers

$response
