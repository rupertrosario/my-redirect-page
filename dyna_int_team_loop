export default async function (_, item) {

  return {

    query:
      "correlation_id=" +
      item.correlation_id +
      "^stateNOT IN6,7^ORDERBYDESCsys_updated_on",

    correlation_id:
      item.correlation_id,

    short_description:
      item.short_description,

    description:
      item.description
  };
}
