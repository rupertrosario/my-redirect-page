export default async function (_) {

  const item = _.item;

  return {

    query:
      "correlation_id=" +
      item.correlation_id +
      "^stateNOT IN6,7^ORDERBYDESCsys_updated_on",

    short_description:
      item.short_description,

    description:
      item.description,

    correlation_id:
      item.correlation_id
  };
}
