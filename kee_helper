# ============================================================
# KeePass 2.x API Key Reader for Cohesity PowerShell Scripts
# Works without SecretStore / SecretManagement modules
# ============================================================

$KeePassDbPath = "\\NAS\Cohesity\Secure\CohesityVault.kdbx"

# Use KeePass.exe if KeePassLib.dll is not available
$KeePassAssemblyPath = "C:\Program Files\KeePass Password Safe 2\KeePass.exe"

# Entry title inside KeePass
$KeePassEntryTitle = "CohesityApiKey"


function Convert-SecureStringToPlainText {
    param(
        [Parameter(Mandatory)]
        [SecureString]$SecureString
    )

    $ptr = [Runtime.InteropServices.Marshal]::SecureStringToBSTR($SecureString)

    try {
        return [Runtime.InteropServices.Marshal]::PtrToStringBSTR($ptr)
    }
    finally {
        [Runtime.InteropServices.Marshal]::ZeroFreeBSTR($ptr)
    }
}


function Load-KeePassAssembly {
    param(
        [Parameter(Mandatory)]
        [string]$KeePassAssemblyPath
    )

    if (-not (Test-Path $KeePassAssemblyPath)) {
        throw "KeePass assembly not found: $KeePassAssemblyPath"
    }

    $alreadyLoaded = [AppDomain]::CurrentDomain.GetAssemblies() |
        Where-Object { $_.GetName().Name -in @("KeePass", "KeePassLib") }

    if (-not $alreadyLoaded) {
        Add-Type -Path $KeePassAssemblyPath
    }

    try {
        [KeePassLib.PwDatabase] | Out-Null
    }
    catch {
        throw "KeePassLib classes could not be loaded. Try using KeePassLib.dll if available, otherwise confirm KeePass 2.x is installed correctly."
    }
}


function Find-KeePassEntryByTitle {
    param(
        [Parameter(Mandatory)]
        $Group,

        [Parameter(Mandatory)]
        [string]$Title
    )

    foreach ($entry in $Group.Entries) {
        if ($entry.Strings.ReadSafe("Title") -eq $Title) {
            return $entry
        }
    }

    foreach ($subGroup in $Group.Groups) {
        $found = Find-KeePassEntryByTitle -Group $subGroup -Title $Title

        if ($null -ne $found) {
            return $found
        }
    }

    return $null
}


function Get-CohesityApiKeyFromKeePass {
    param(
        [Parameter(Mandatory)]
        [string]$KeePassDbPath,

        [Parameter(Mandatory)]
        [string]$KeePassAssemblyPath,

        [Parameter(Mandatory)]
        [string]$EntryTitle
    )

    if (-not (Test-Path $KeePassDbPath)) {
        throw "KeePass database not found: $KeePassDbPath"
    }

    Load-KeePassAssembly -KeePassAssemblyPath $KeePassAssemblyPath

    $secureMasterPassword = Read-Host "Enter KeePass master password" -AsSecureString
    $plainMasterPassword  = Convert-SecureStringToPlainText -SecureString $secureMasterPassword

    $db  = New-Object KeePassLib.PwDatabase
    $key = New-Object KeePassLib.Keys.CompositeKey

    $passwordKey = New-Object KeePassLib.Keys.KcpPassword($plainMasterPassword)
    $key.AddUserKey($passwordKey)

    $ioc = [KeePassLib.Serialization.IOConnectionInfo]::FromPath($KeePassDbPath)

    try {
        $db.Open($ioc, $key, $null)

        $entry = Find-KeePassEntryByTitle -Group $db.RootGroup -Title $EntryTitle

        if ($null -eq $entry) {
            throw "KeePass entry not found: $EntryTitle"
        }

        $apiKey = $entry.Strings.ReadSafe("Password")

        if ([string]::IsNullOrWhiteSpace($apiKey)) {
            throw "KeePass entry password field is empty: $EntryTitle"
        }

        return $apiKey
    }
    finally {
        if ($db -and $db.IsOpen) {
            $db.Close()
        }

        $plainMasterPassword = $null
    }
}


# ============================================================
# Use this instead of plain-text apikey.txt
# ============================================================

$apiKey = Get-CohesityApiKeyFromKeePass `
    -KeePassDbPath $KeePassDbPath `
    -KeePassAssemblyPath $KeePassAssemblyPath `
    -EntryTitle $KeePassEntryTitle

$headers = @{
    apiKey = $apiKey
}
