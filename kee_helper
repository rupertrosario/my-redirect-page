function Convert-SecureStringToPlainText {
    param([Parameter(Mandatory)][SecureString]$SecureString)

    $ptr = [Runtime.InteropServices.Marshal]::SecureStringToBSTR($SecureString)
    try {
        [Runtime.InteropServices.Marshal]::PtrToStringBSTR($ptr)
    }
    finally {
        [Runtime.InteropServices.Marshal]::ZeroFreeBSTR($ptr)
    }
}

function New-AesKeyFromPassword {
    param(
        [Parameter(Mandatory)][SecureString]$Password,
        [Parameter(Mandatory)][byte[]]$Salt,
        [int]$Iterations = 300000
    )

    $plainPassword = Convert-SecureStringToPlainText $Password
    $derive = New-Object System.Security.Cryptography.Rfc2898DeriveBytes($plainPassword, $Salt, $Iterations)

    try {
        $derive.GetBytes(32)
    }
    finally {
        $derive.Dispose()
        $plainPassword = $null
    }
}

function New-CohesityEncryptedApiKey {
    param(
        [string]$EncryptedFile = "\\NAS\Cohesity\Secure\cohesity_apikey.enc"
    )

    $apiKey = Read-Host "Paste Cohesity API key" -AsSecureString
    $password1 = Read-Host "Create API key password" -AsSecureString
    $password2 = Read-Host "Confirm API key password" -AsSecureString

    if ((Convert-SecureStringToPlainText $password1) -ne (Convert-SecureStringToPlainText $password2)) {
        throw "Passwords do not match."
    }

    $salt = New-Object byte[] 32
    [System.Security.Cryptography.RandomNumberGenerator]::Create().GetBytes($salt)

    $key = New-AesKeyFromPassword -Password $password1 -Salt $salt
    $encryptedApiKey = $apiKey | ConvertFrom-SecureString -Key $key

    [pscustomobject]@{
        Version    = 1
        Iterations = 300000
        Salt       = [Convert]::ToBase64String($salt)
        ApiKey     = $encryptedApiKey
    } | ConvertTo-Json | Set-Content -Path $EncryptedFile -Encoding UTF8

    Write-Host "Encrypted API key created: $EncryptedFile" -ForegroundColor Green
}

function Get-CohesityApiKeyFromAes {
    param(
        [string]$EncryptedFile = "\\NAS\Cohesity\Secure\cohesity_apikey.enc"
    )

    if (-not (Test-Path $EncryptedFile)) {
        throw "Encrypted API key file not found: $EncryptedFile"
    }

    $vaultPassword = Read-Host "Enter Cohesity API key password" -AsSecureString

    $data = Get-Content -Path $EncryptedFile -Raw | ConvertFrom-Json
    $salt = [Convert]::FromBase64String($data.Salt)

    $key = New-AesKeyFromPassword `
        -Password $vaultPassword `
        -Salt $salt `
        -Iterations $data.Iterations

    $secureApiKey = $data.ApiKey | ConvertTo-SecureString -Key $key

    Convert-SecureStringToPlainText $secureApiKey
}
