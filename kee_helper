function Convert-SecureStringToPlainText {
    param(
        [Parameter(Mandatory)]
        [SecureString]$SecureString
    )

    $ptr = [Runtime.InteropServices.Marshal]::SecureStringToBSTR($SecureString)

    try {
        return [Runtime.InteropServices.Marshal]::PtrToStringBSTR($ptr)
    }
    finally {
        [Runtime.InteropServices.Marshal]::ZeroFreeBSTR($ptr)
    }
}

function Get-CohesityApiKeyFromKeePass {
    param(
        [string]$KeePassDbPath = "\\NAS\Cohesity\Secure\CohesityVault.kdbx",
        [string]$KPScriptPath  = "C:\Program Files (x86)\KeePass2x\KPScript.exe",
        [string]$EntryTitle    = "CohesityApiKey"
    )

    if (-not (Test-Path $KeePassDbPath)) {
        throw "KeePass database not found: $KeePassDbPath"
    }

    if (-not (Test-Path $KPScriptPath)) {
        throw "KPScript.exe not found: $KPScriptPath"
    }

    $securePassword = Read-Host "Enter KeePass master password" -AsSecureString
    $plainPassword  = Convert-SecureStringToPlainText -SecureString $securePassword

    try {
        $$output = & $KPScriptPath `
        "-c:GetEntryString" `
        "$KeePassDbPath" `
        "-pw:$plainPassword" `
        "-Field:Password" `
        "-ref-Title:$EntryTitle" `
        "-FailIfNoEntry" 2>&1

    if ($LASTEXITCODE -ne 0) {
        $safeOutput = ($output -join ' ') -replace '-pw:[^\s]+', '-pw:[REDACTED]'
        throw "KPScript failed. ExitCode=$LASTEXITCODE. Output=$safeOutput"
        }

        $apiKey = $output |
            Where-Object {
                $_ -and
                $_ -notmatch "^OK:" -and
                $_ -notmatch "^E:" -and
                $_ -notmatch "Operation completed"
            } |
            Select-Object -First 1

        if ([string]::IsNullOrWhiteSpace($apiKey)) {
            throw "API key not returned from KeePass entry: $EntryTitle"
        }

        return $apiKey.Trim()
    }
    finally {
        $plainPassword = $null
    }
}
