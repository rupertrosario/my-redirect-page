Read-Host "Enter Cohesity API Key" -AsSecureString |
ConvertFrom-SecureString |
Out-File "X:\PowerShell\Cohesity_API_Scripts\DO_NOT_Delete\apikey.txt"


$secureApiKey = Get-Content -Path $apikeypath | ConvertTo-SecureString
