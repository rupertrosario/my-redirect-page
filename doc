if (!looksDown(linkState)) continue;

const mac = norm(d.macAddr || d.mac || d.mac_address);

// prevent duplicate push for same cluster + IP
const exists = downRows.some(r =>
  r.ClusterId === String(cid) &&
  r.IP === nodeIp
);

if (exists) continue;

downRows.push({
  Location: entry.Location,
  ClusterName: entry.ClusterName,
  ClusterId: String(cid),
  IP: nodeIp,
  Serial: serial,
  MAC: mac,
  AlertCause: alertCause
});
