$report += ""
$report += "API Usage                 : GET reports + POST report preview"
$report += "Backup Impact             : None - report preview only"
$report += "API Calls                 : $script:ApiCalls"
$report += "Failed API Calls          : $script:FailedApiCalls"
$report += ""
$report += "------------------------------------------------------------"
