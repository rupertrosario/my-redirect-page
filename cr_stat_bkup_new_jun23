function Add-Candidate {
    param(
        [System.Collections.ArrayList]$List,
        [hashtable]$Seen,
        [string]$Environment,
        [string]$ClusterId,
        [string]$ClusterName,
        [string]$PgId,
        [string]$PgName
    )

    if ([string]::IsNullOrWhiteSpace($ClusterId)) {
        return
    }

    if ([string]::IsNullOrWhiteSpace($PgId)) {
        return
    }

    if ([string]::IsNullOrWhiteSpace($PgName)) {
        $PgName = "-"
    }

    $key = "$Environment|$ClusterId|$PgId|$PgName"

    if ($Seen.ContainsKey($key)) {
        return
    }

    $Seen[$key] = $true

    [void]$List.Add([pscustomobject]@{
        Environment = $Environment
        ClusterId   = "$ClusterId"
        ClusterName = "$ClusterName"
        PgId        = "$PgId"
        PgName      = "$PgName"
    })
}

function Get-CandidatesFromSearchJson {
    param(
        [object]$Json,
        [string]$Environment
    )

    $list = New-Object System.Collections.ArrayList
    $seen = @{}

    foreach ($obj in (Get-ResponseObjects $Json)) {

        foreach ($opi in (AsArray $obj.objectProtectionInfos)) {

            foreach ($pg in (AsArray $opi.protectionGroups)) {
                $cid = Get-ClusterIdFromNode -Obj $obj -ProtectionInfo $opi -Pg $pg
                $cname = Get-ClusterNameFromNode -Obj $obj -ProtectionInfo $opi -Pg $pg
                $pgid = Get-PgIdFromNode -Obj $obj -ProtectionInfo $opi -Pg $pg
                $pgname = Get-PgNameFromNode -Obj $obj -ProtectionInfo $opi -Pg $pg

                Add-Candidate `
                    -List $list `
                    -Seen $seen `
                    -Environment $Environment `
                    -ClusterId $cid `
                    -ClusterName $cname `
                    -PgId $pgid `
                    -PgName $pgname
            }

            if (-not $opi.protectionGroups) {
                $cid = Get-ClusterIdFromNode -Obj $obj -ProtectionInfo $opi -Pg $null
                $cname = Get-ClusterNameFromNode -Obj $obj -ProtectionInfo $opi -Pg $null
                $pgid = Get-PgIdFromNode -Obj $obj -ProtectionInfo $opi -Pg $null
                $pgname = Get-PgNameFromNode -Obj $obj -ProtectionInfo $opi -Pg $null

                Add-Candidate `
                    -List $list `
                    -Seen $seen `
                    -Environment $Environment `
                    -ClusterId $cid `
                    -ClusterName $cname `
                    -PgId $pgid `
                    -PgName $pgname
            }
        }

        foreach ($pg2 in (AsArray $obj.protectionGroups)) {
            $cid = Get-ClusterIdFromNode -Obj $obj -ProtectionInfo $null -Pg $pg2
            $cname = Get-ClusterNameFromNode -Obj $obj -ProtectionInfo $null -Pg $pg2
            $pgid = Get-PgIdFromNode -Obj $obj -ProtectionInfo $null -Pg $pg2
            $pgname = Get-PgNameFromNode -Obj $obj -ProtectionInfo $null -Pg $pg2

            Add-Candidate `
                -List $list `
                -Seen $seen `
                -Environment $Environment `
                -ClusterId $cid `
                -ClusterName $cname `
                -PgId $pgid `
                -PgName $pgname
        }

        $cidObj = Get-ClusterIdFromNode -Obj $obj -ProtectionInfo $null -Pg $null
        $pgidObj = Get-PgIdFromNode -Obj $obj -ProtectionInfo $null -Pg $null
        $pgnameObj = Get-PgNameFromNode -Obj $obj -ProtectionInfo $null -Pg $null
        $cnameObj = Get-ClusterNameFromNode -Obj $obj -ProtectionInfo $null -Pg $null

        Add-Candidate `
            -List $list `
            -Seen $seen `
            -Environment $Environment `
            -ClusterId $cidObj `
            -ClusterName $cnameObj `
            -PgId $pgidObj `
            -PgName $pgnameObj
    }

    return @($list)
}

function Get-SearchCandidates {
    param(
        [string]$ServerName,
        [string]$Environment
    )

    $script:GlobalSearchCalls++

    $uri = "$BaseUrl/v2/data-protect/search/objects" +
           "?searchString=$([uri]::EscapeDataString($ServerName))" +
           "&environments=$([uri]::EscapeDataString($Environment))" +
           "&includeTenants=true" +
           "&count=$GlobalSearchCount"

    $json = Invoke-HeliosGetJson -Uri $uri -Headers $CommonHeaders -Quiet

    if (-not $json) {
        return @()
    }

    return @(
        Get-CandidatesFromSearchJson `
            -Json $json `
            -Environment $Environment
    )
}

# =====================================================================
# Run parsing
# =====================================================================
function Get-RunBackupInfo {
    param([object]$Run)

    try {
        if ($Run.PSObject.Properties.Name -contains "localBackupInfo") {
            return $Run.localBackupInfo
        }

        if ($Run.PSObject.Properties.Name -contains "originalBackupInfo") {
            return $Run.originalBackupInfo
        }

        if ($Run.PSObject.Properties.Name -contains "archivalInfo") {
            return $Run.archivalInfo.archivalTargetResults[0]
        }
    }
    catch {
        return $null
    }

    return $null
}

function Get-RunStatus {
    param([object]$Run)

    $bi = Get-RunBackupInfo $Run

    return Get-FirstText @(
        $bi.status,
        $Run.status
    )
}

function Get-RunType {
    param([object]$Run)

    $bi = Get-RunBackupInfo $Run

    return Get-FirstText @(
        $bi.runType,
        $bi.backupRunType,
        $Run.runType,
        $Run.backupRunType
    )
}

function Get-RunEndUsecs {
    param([object]$Run)

    $bi = Get-RunBackupInfo $Run

    return To-Int64Safe (Get-FirstText @(
        $bi.endTimeUsecs,
        $Run.endTimeUsecs
    ))
}

function Get-ObjectNode {
