# ==========================================================
# Cohesity Backup Validation - Protected Objects First
# GET-only | FS + SQL + Oracle only
#
# Input:
#   X:\PowerShell\Data\Cohesity\BackupValidation\<ChangeID>.csv
#   Required column: ci_item
#
# Main endpoint used:
#   GET /v2/data-protect/search/protected-objects?searchString=<CI>
#
# Logic:
#   - objectType = kHost + environment = kPhysical => FS
#   - environment = kSQL                         => SQL
#   - environment = kOracle                      => Oracle
#   - latestSnapshotInfo is used for runType, PG, local snapshot, and replication snapshot details.
#   - No NAS, Nutanix, Hyper-V, VMware scan.
#
# Final columns:
#   InputCI, BackupType, ObjectName, SourceName, ClusterName, ProtectionGroup,
#   RunType, LocalSnapshotTime, ReplicationSnapshotTime, LastBackupTime, Status
# ==========================================================

$ErrorActionPreference = "Stop"
$FormatEnumerationLimit = -1
[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12

# -------------------------
# Input / paths
# -------------------------
$ChangeID   = Read-Host "Enter Change Number"
$ExecutedBy = (whoami).Trim()

$BaseDir = "X:\PowerShell\Data\Cohesity\BackupValidation"
if (-not (Test-Path -Path $BaseDir -PathType Container)) {
    New-Item -Path $BaseDir -ItemType Directory -Force | Out-Null
}

$InputCsv = Join-Path $BaseDir "$ChangeID.csv"
$InputTxt = Join-Path $BaseDir "$ChangeID.txt"

$Stamp     = Get-Date -Format "yyyyMMdd_HHmmss"
$OutputTxt = Join-Path $BaseDir "${ChangeID}_BackupReport_$Stamp.txt"
$OutputCsv = Join-Path $BaseDir "${ChangeID}_BackupReport_$Stamp.csv"
$DebugCsv  = Join-Path $BaseDir "${ChangeID}_BackupReport_Debug_$Stamp.csv"

if (-not (Test-Path $InputCsv)) {
    throw "Input CSV not found: $InputCsv"
}

# -------------------------
# API
# -------------------------
$BaseUrl = "https://helios.cohesity.com"
$ApiKeyPath = "X:\PowerShell\Cohesity_API_Scripts\DO_NOT_Delete\apikey.txt"

if (-not (Test-Path $ApiKeyPath)) {
    throw "API key file not found: $ApiKeyPath"
}

$ApiKey = (Get-Content -Path $ApiKeyPath -Raw).Trim()
if ([string]::IsNullOrWhiteSpace($ApiKey)) {
    throw "API key file is empty: $ApiKeyPath"
}

$CommonHeaders = @{
    accept = "application/json"
    apiKey = $ApiKey
}

# -------------------------
# Settings
# -------------------------
$ReportTimeZoneId = "Eastern Standard Time"
$ExportDebugCsv = $true
$IncludeMissingRows = $true

# Basic protected-objects search first, as confirmed manually.
$UseEnvironmentFallbackSearch = $true
$EnvironmentFallbacks = @("kPhysical", "kSQL", "kOracle")

# -------------------------
# Counters
# -------------------------
$script:ProtectedObjectSearchCalls = 0
$script:ClusterMapCalls            = 0
$script:FailedGets                 = 0
$script:RawObjectsSeen             = 0
$script:RowsBuilt                  = 0

# ==========================================================
# Helpers
# ==========================================================
function Invoke-HeliosGetJson {
    param(
        [Parameter(Mandatory)][string]$Uri,
        [Parameter(Mandatory)][hashtable]$Headers,
        [int]$TimeoutSec = 120,
        [switch]$Quiet
    )

    try {
        $resp = Invoke-WebRequest `
            -Uri $Uri `
            -Headers $Headers `
            -Method Get `
            -UseBasicParsing `
            -TimeoutSec $TimeoutSec `
            -ErrorAction Stop

        if (-not $resp -or [string]::IsNullOrWhiteSpace($resp.Content)) {
            return $null
        }

        return ($resp.Content | ConvertFrom-Json)
    }
    catch {
        $script:FailedGets++
        if (-not $Quiet) {
            Write-Host "GET failed:" -ForegroundColor Red
            Write-Host $Uri -ForegroundColor DarkRed
            Write-Host $_.Exception.Message -ForegroundColor DarkRed
        }
        return $null
    }
}

function AsArray {
    param([object]$Value)
    if ($null -eq $Value) { return @() }
    if ($Value -is [array]) { return @($Value) }
    return @($Value)
}

function Get-FirstText {
    param([object[]]$Values)

    foreach ($Value in $Values) {
        if ($null -eq $Value) { continue }

        if ($Value -is [array]) {
            foreach ($item in $Value) {
                $v = Get-FirstText @($item)
                if (-not [string]::IsNullOrWhiteSpace($v)) { return "$v".Trim() }
            }
            continue
        }

        if ($Value -is [pscustomobject]) {
            foreach ($prop in @("name","displayName","display_value","value","id","uid","_id","clusterId","clusterID","intId")) {
                if ($Value.PSObject.Properties.Name -contains $prop) {
                    $v = Get-FirstText @($Value.$prop)
                    if (-not [string]::IsNullOrWhiteSpace($v)) { return "$v".Trim() }
                }
            }
            continue
        }

        $text = "$Value".Trim()
        if (-not [string]::IsNullOrWhiteSpace($text)) { return $text }
    }

    return ""
}

function To-Int64Safe {
    param([object]$Value)
    if ($null -eq $Value -or "$Value".Trim() -eq "") { return 0 }
    try { return [int64]$Value } catch { return 0 }
}

function Convert-UsecsToET {
    param([object]$Usecs)

    $u = To-Int64Safe $Usecs
    if ($u -le 0) { return "" }

    try {
        $dto = [DateTimeOffset]::FromUnixTimeMilliseconds([int64]($u / 1000))
        $tz  = [System.TimeZoneInfo]::FindSystemTimeZoneById($ReportTimeZoneId)
        return ([System.TimeZoneInfo]::ConvertTime($dto, $tz)).ToString("dd-MMM-yyyy HH:mm:ss") + " ET"
    }
    catch {
        return ""
    }
}

function Get-ShortName {
    param([string]$Name)
    if ([string]::IsNullOrWhiteSpace($Name)) { return "" }
    $n = "$Name".Trim()
    if ($n -match "\.") { return (($n -split "\.")[0]).Trim() }
    return $n
}

function Text-MatchesName {
    param([string]$Text, [string]$Name)

    if ([string]::IsNullOrWhiteSpace($Text) -or [string]::IsNullOrWhiteSpace($Name)) { return $false }

    $t = "$Text".Trim().ToLower()
    $n = "$Name".Trim().ToLower()

    if ($t -eq $n) { return $true }
    if ($t -like "*$n*") { return $true }
    if ($n -like "*$t*") { return $true }

    $ts = (Get-ShortName $t).ToLower()
    $ns = (Get-ShortName $n).ToLower()

    if ($ts -and $ts -eq $n) { return $true }
    if ($ns -and $ns -eq $t) { return $true }
    if ($ts -and $ns -and $ts -eq $ns) { return $true }

    return $false
}

function Add-UniqueText {
    param([System.Collections.ArrayList]$List, [string]$Value)

    if ([string]::IsNullOrWhiteSpace($Value)) { return }
    $v = "$Value".Trim().Trim('"').Trim("'")
    if (-not $List.Contains($v)) { [void]$List.Add($v) }
}

function Is-ValidBackupTime {
    param([string]$Value)

    if ([string]::IsNullOrWhiteSpace($Value)) { return $false }
    return $Value -notin @("NoBackup", "NoBackupTime", "NoFSBackupFound", "NoDbBackupFound", "NoObject")
}

function Get-BackupTypeRank {
    param([string]$BackupType)

    switch ($BackupType) {
        "SQL"    { return 1 }
        "Oracle" { return 2 }
        "DB"     { return 3 }
        "FS"     { return 4 }
        default  { return 9 }
    }
}

# ==========================================================
# CI Parsing
# ==========================================================
function Get-CiContext {
    param([string]$Ci)

    $clean = "$Ci".Trim().Trim('"').Trim("'")
    $isDbAtServer = $false
    $dbName = ""
    $serverName = ""

    if ($clean -match "@") {
        $parts = $clean -split "@", 2
        $dbName = "$($parts[0])".Trim()
        $serverName = "$($parts[1])".Trim()
        if (-not [string]::IsNullOrWhiteSpace($dbName) -and -not [string]::IsNullOrWhiteSpace($serverName)) {
            $isDbAtServer = $true
        }
    }

    return [pscustomobject]@{
        InputCI      = $clean
        IsDbAtServer = $isDbAtServer
        DbName       = $dbName
        ServerName   = $serverName
    }
}

function Get-SearchTermsForContext {
    param([object]$Context)

    $terms = New-Object System.Collections.ArrayList

    if ($Context.IsDbAtServer) {
        Add-UniqueText -List $terms -Value $Context.DbName
        Add-UniqueText -List $terms -Value $Context.ServerName
        Add-UniqueText -List $terms -Value $Context.InputCI
    }
    else {
        Add-UniqueText -List $terms -Value $Context.InputCI
    }

    return @($terms)
}

# ==========================================================
# Cluster Map
# ==========================================================
function Add-ClusterMapEntry {
    param([hashtable]$Map, [object]$Id, [string]$Name)

    $idText = Get-FirstText @($Id)
    if (-not [string]::IsNullOrWhiteSpace($idText) -and -not [string]::IsNullOrWhiteSpace($Name)) {
        $Map["$idText"] = $Name
    }
}

function Get-ClusterNameFromMap {
    param([string]$ClusterId, [hashtable]$ClusterMap)

    if ([string]::IsNullOrWhiteSpace($ClusterId)) { return "-" }
    if ($ClusterMap.ContainsKey("$ClusterId")) { return "$($ClusterMap["$ClusterId"])" }
    return "$ClusterId"
}

function Build-ClusterMap {
    $script:ClusterMapCalls++

    $json = Invoke-HeliosGetJson -Uri "$BaseUrl/v2/mcm/cluster-mgmt/info" -Headers $CommonHeaders
    if (-not $json -or -not $json.cohesityClusters) {
        throw "No clusters returned from Helios."
    }

    $map = @{}
    foreach ($c in @(AsArray $json.cohesityClusters)) {
        $name = Get-FirstText @($c.clusterName, $c.name, $c.displayName)
        if ([string]::IsNullOrWhiteSpace($name)) { $name = "Unknown-$($c.clusterId)" }

        Add-ClusterMapEntry -Map $map -Id $c.clusterId -Name $name
        Add-ClusterMapEntry -Map $map -Id $c.id -Name $name
        Add-ClusterMapEntry -Map $map -Id $c.intId -Name $name
        Add-ClusterMapEntry -Map $map -Id $c.clusterIdentifier.clusterId -Name $name
        Add-ClusterMapEntry -Map $map -Id $c.clusterInfo.clusterId -Name $name
    }

    return $map
}

# ==========================================================
# Protected Objects Search
# ==========================================================
function Get-ObjectArrayFromJson {
    param([object]$Json)

    if ($null -eq $Json) { return @() }
    if ($Json -is [array]) { return @($Json) }

    foreach ($prop in @("objects", "protectedObjects", "protectedObjectResults", "searchResults", "results", "entities", "items", "data")) {
        if ($Json.PSObject.Properties.Name -contains $prop) {
            return @(AsArray $Json.$prop | Where-Object { $_ })
        }
    }

    return @()
}

function Search-ProtectedObjects {
    param(
        [string]$SearchTerm,
        [string]$Environment = ""
    )

    if ([string]::IsNullOrWhiteSpace($SearchTerm)) { return @() }

    $script:ProtectedObjectSearchCalls++

    $uri = "$BaseUrl/v2/data-protect/search/protected-objects" +
           "?searchString=$([uri]::EscapeDataString($SearchTerm))"

    if (-not [string]::IsNullOrWhiteSpace($Environment)) {
        $uri += "&environments=$([uri]::EscapeDataString($Environment))"
    }

    $json = Invoke-HeliosGetJson -Uri $uri -Headers $CommonHeaders -Quiet
    if (-not $json) { return @() }

    return @(Get-ObjectArrayFromJson $json)
}

function Get-ProtectedObjectsForTerms {
    param([object[]]$SearchTerms)

    $all = New-Object System.Collections.ArrayList
    $seen = @{}

    foreach ($term in @($SearchTerms)) {
        $objects = @(Search-ProtectedObjects -SearchTerm "$term")

        if ($UseEnvironmentFallbackSearch) {
            foreach ($env in $EnvironmentFallbacks) {
                $objects += @(Search-ProtectedObjects -SearchTerm "$term" -Environment $env)
            }
        }

        foreach ($obj in $objects) {
            if (-not $obj) { continue }

            $id = Get-ProtectedObjectId $obj
            $name = Get-ProtectedObjectName $obj
            $env = Get-ProtectedObjectEnvironment $obj
            $type = Get-ProtectedObjectType $obj
            $pg = Get-ProtectedObjectProtectionGroup $obj $null
            $cid = Get-ProtectedObjectClusterId $obj

            $key = "$id|$name|$env|$type|$pg|$cid"
            if ($seen.ContainsKey($key)) { continue }
            $seen[$key] = $true
            [void]$all.Add($obj)
        }
    }

    return @($all)
}

