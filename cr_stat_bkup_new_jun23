# ==========================================================
# Cohesity Backup Validation - Targeted SQL + Oracle + FS
# GET-only | No write operations | No NAS/Nutanix/Hyper-V scan
#
# Input:
#   X:\PowerShell\Data\Cohesity\BackupValidation\<ChangeID>.csv
#   Required column: ci_item
#
# Output:
#   X:\PowerShell\Data\Cohesity\BackupValidation\<ChangeID>.txt
#   X:\PowerShell\Data\Cohesity\BackupValidation\<ChangeID>_BackupReport_<timestamp>.txt
#   X:\PowerShell\Data\Cohesity\BackupValidation\<ChangeID>_BackupReport_<timestamp>.csv
#
# Final columns:
#   InputCI, BackupType, ObjectName, SourceName, ClusterName, ProtectionGroup, LastBackupTime
#
# Scope:
#   - FS only from kPhysical protected-object search
#   - SQL DBs from recent SQL PG run object details
#   - Oracle DBs from targeted Oracle PG config oracleParams/dbParams/dbChannels
#
# Notes:
#   - Uses GET only.
#   - Does not check NAS, Nutanix, Hyper-V, VMware.
#   - Does not filter DB runs too early by kFull/kIncremental.
#   - Logs/archive are excluded locally.
#   - For SQL, DB names are discovered from recent run.objects; latest successful regular PG run time is used.
# ==========================================================

$ErrorActionPreference = "Stop"
$FormatEnumerationLimit = -1
[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12

# -------------------------
# Input
# -------------------------
$ChangeID   = Read-Host "Enter Change Number"
$ExecutedBy = (whoami).Trim()

# -------------------------
# Paths
# -------------------------
$BaseDir = "X:\PowerShell\Data\Cohesity\BackupValidation"
if (-not (Test-Path -Path $BaseDir -PathType Container)) {
    New-Item -Path $BaseDir -ItemType Directory -Force | Out-Null
}

$InputCsv = Join-Path $BaseDir "$ChangeID.csv"
$InputTxt = Join-Path $BaseDir "$ChangeID.txt"
$Stamp     = Get-Date -Format "yyyyMMdd_HHmmss"
$OutputTxt = Join-Path $BaseDir "${ChangeID}_BackupReport_$Stamp.txt"
$OutputCsv = Join-Path $BaseDir "${ChangeID}_BackupReport_$Stamp.csv"
$DebugCsv  = Join-Path $BaseDir "${ChangeID}_BackupReport_Debug_$Stamp.csv"

if (-not (Test-Path $InputCsv)) {
    throw "Input CSV not found: $InputCsv"
}

# -------------------------
# API
# -------------------------
$BaseUrl = "https://helios.cohesity.com"
$ApiKeyPath = "X:\PowerShell\Cohesity_API_Scripts\DO_NOT_Delete\apikey.txt"

if (-not (Test-Path $ApiKeyPath)) {
    throw "API key file not found: $ApiKeyPath"
}

$ApiKey = (Get-Content -Path $ApiKeyPath -Raw).Trim()
if ([string]::IsNullOrWhiteSpace($ApiKey)) {
    throw "API key file is empty: $ApiKeyPath"
}

$CommonHeaders = @{
    accept = "application/json"
    apiKey = $ApiKey
}

# -------------------------
# Settings
# -------------------------
$ReportTimeZoneId = "Eastern Standard Time"
$GlobalSearchCount = 100
$NumRunsPerPg      = 20
$MaxRunPagesPerPg  = 3
$ExportDebugCsv    = $true

$EnableTargetedSqlPgRunInspection = $true
$EnableTargetedOraclePgInspection = $true
$AllowBlankRunTypeForDb = $true

# -------------------------
# Counters
# -------------------------
$script:GlobalSearchCalls          = 0
$script:ProtectedSearchCalls       = 0
$script:PgRunCalls                 = 0
$script:PgDetailCalls              = 0
$script:ObjectLookupCalls          = 0
$script:FailedGets                 = 0
$script:TargetedSqlInspections     = 0
$script:TargetedOraInspections     = 0
$script:SqlSuccessfulRunsChecked   = 0
$script:SqlDbObjectsFound          = 0
$script:SqlDbListNotDiscovered     = 0
$script:SqlPgListFallbackCalls     = 0
$script:SqlPgListFallbackMatches   = 0

# ==========================================================
# Common Helpers
# ==========================================================
function Invoke-HeliosGetJson {
    param(
        [Parameter(Mandatory)][string]$Uri,
        [Parameter(Mandatory)][hashtable]$Headers,
        [int]$TimeoutSec = 90,
        [switch]$Quiet
    )

    try {
        $resp = Invoke-WebRequest -Uri $Uri -Headers $Headers -Method Get -UseBasicParsing -TimeoutSec $TimeoutSec -ErrorAction Stop
        if (-not $resp -or [string]::IsNullOrWhiteSpace($resp.Content)) { return $null }
        return ($resp.Content | ConvertFrom-Json)
    }
    catch {
        $script:FailedGets++
        if (-not $Quiet) {
            Write-Host "GET failed:" -ForegroundColor Red
            Write-Host $Uri -ForegroundColor DarkRed
            Write-Host $_.Exception.Message -ForegroundColor DarkRed
        }
        return $null
    }
}

function AsArray {
    param([object]$Value)
    if ($null -eq $Value) { return @() }
    if ($Value -is [array]) { return @($Value) }
    return @($Value)
}

function Get-FirstText {
    param([object[]]$Values)

    foreach ($Value in $Values) {
        if ($null -eq $Value) { continue }

        if ($Value -is [array]) {
            foreach ($item in $Value) {
                $v = Get-FirstText @($item)
                if (-not [string]::IsNullOrWhiteSpace($v)) { return "$v".Trim() }
            }
            continue
        }

        if ($Value -is [pscustomobject]) {
            foreach ($prop in @("name","displayName","display_value","value","id","uid","_id","clusterId","clusterID","intId")) {
                if ($Value.PSObject.Properties.Name -contains $prop) {
                    $v = Get-FirstText @($Value.$prop)
                    if (-not [string]::IsNullOrWhiteSpace($v)) { return "$v".Trim() }
                }
            }
            continue
        }

        $text = "$Value".Trim()
        if (-not [string]::IsNullOrWhiteSpace($text)) { return $text }
    }

    return ""
}

function To-Int64Safe {
    param([object]$Value)
    if ($null -eq $Value -or "$Value".Trim() -eq "") { return 0 }
    try { return [int64]$Value } catch { return 0 }
}

function Add-UniqueText {
    param([System.Collections.ArrayList]$List, [string]$Value)
    if ([string]::IsNullOrWhiteSpace($Value)) { return }
    $v = "$Value".Trim().Trim('"').Trim("'")
    if (-not $List.Contains($v)) { [void]$List.Add($v) }
}

function Convert-UsecsToET {
    param([object]$Usecs)
    $u = To-Int64Safe $Usecs
    if ($u -le 0) { return "" }

    try {
        $dto = [DateTimeOffset]::FromUnixTimeMilliseconds([int64]($u / 1000))
        $tz  = [System.TimeZoneInfo]::FindSystemTimeZoneById($ReportTimeZoneId)
        return ([System.TimeZoneInfo]::ConvertTime($dto, $tz)).ToString("dd-MMM-yyyy HH:mm:ss") + " ET"
    }
    catch {
        return ""
    }
}

function Get-ShortName {
    param([string]$Name)
    if ([string]::IsNullOrWhiteSpace($Name)) { return "" }
    $n = "$Name".Trim()
    if ($n -match "\.") { return (($n -split "\.")[0]).Trim() }
    return $n
}

function Text-MatchesName {
    param([string]$Text, [string]$Name)

    if ([string]::IsNullOrWhiteSpace($Text) -or [string]::IsNullOrWhiteSpace($Name)) { return $false }

    $t = "$Text".Trim().ToLower()
    $n = "$Name".Trim().ToLower()

    if ($t -eq $n) { return $true }
    if ($t -like "*$n*") { return $true }
    if ($n -like "*$t*") { return $true }

    $ts = (Get-ShortName $t).ToLower()
    $ns = (Get-ShortName $n).ToLower()

    if ($ts -and $ts -eq $n) { return $true }
    if ($ns -and $ns -eq $t) { return $true }
    if ($ts -and $ns -and $ts -eq $ns) { return $true }

    return $false
}

function Test-SuccessStatus {
    param([string]$Status)
    if ([string]::IsNullOrWhiteSpace($Status)) { return $false }
    return ($Status -match '(?i)success|succeeded|succeededwithwarning|warning|ksuccess|ksuccessful')
}

function Test-RegularRunType {
    param([string]$RunType)

    if ([string]::IsNullOrWhiteSpace($RunType)) {
        return $AllowBlankRunTypeForDb
    }

    if ($RunType -match '(?i)log|archive') { return $false }
    return ($RunType -match '(?i)regular|full|incr|incremental|kregular|kfull|kincremental')
}

function Is-ValidBackupTime {
    param([string]$Value)

    if ([string]::IsNullOrWhiteSpace($Value)) { return $false }

    return $Value -notin @(
        "NoObject",
        "NoBackup",
        "NoBackupTime",
        "NoFSBackupFound",
        "NoDbBackupFound",
        "NoDbDetailFound",
        "DbListNotDiscovered",
        "DbListFoundButNoInputMatch",
        "NoSqlPgCandidateFound"
    )
}

function Get-BackupTypeRank {
    param([string]$BackupType)
    switch ($BackupType) {
        "SQL"    { return 1 }
        "Oracle" { return 2 }
        "DB"     { return 3 }
        "FS"     { return 4 }
        default  { return 9 }
    }
}

# ==========================================================
# CI Parsing
# ==========================================================
function Get-CiContext {
    param([string]$Ci)

    $clean = "$Ci".Trim().Trim('"').Trim("'")
    $isDbAtServer = $false
    $dbName = ""
    $serverName = ""

    if ($clean -match "@") {
        $parts = $clean -split "@", 2
        $dbName = "$($parts[0])".Trim()
        $serverName = "$($parts[1])".Trim()
        if (-not [string]::IsNullOrWhiteSpace($dbName) -and -not [string]::IsNullOrWhiteSpace($serverName)) {
            $isDbAtServer = $true
        }
    }

    return [pscustomobject]@{
        InputCI      = $clean
        IsDbAtServer = $isDbAtServer
        DbName       = $dbName
        ServerName   = $serverName
    }
}

function Get-SearchTermsForSql {
    param([object]$Context)

    $terms = New-Object System.Collections.ArrayList
    if ($Context.IsDbAtServer) {
        Add-UniqueText -List $terms -Value $Context.DbName
        Add-UniqueText -List $terms -Value $Context.ServerName
    }
    else {
        Add-UniqueText -List $terms -Value $Context.InputCI
    }

    return @($terms)
}

# ==========================================================
# Cluster Map
# ==========================================================
function Add-ClusterMapEntry {
    param([hashtable]$Map, [object]$Id, [string]$Name)
    $idText = Get-FirstText @($Id)
    if (-not [string]::IsNullOrWhiteSpace($idText) -and -not [string]::IsNullOrWhiteSpace($Name)) {
        $Map["$idText"] = $Name
    }
}

function Get-ClusterNameFromMap {
    param([string]$ClusterId, [hashtable]$ClusterMap)
    if ([string]::IsNullOrWhiteSpace($ClusterId)) { return "-" }
    if ($ClusterMap.ContainsKey("$ClusterId")) { return "$($ClusterMap["$ClusterId"])" }
    return "$ClusterId"
}

# ==========================================================
# Search Candidate Helpers
# ==========================================================
function Get-ObjectArrayFromJson {
    param([object]$Json)

    if ($null -eq $Json) { return @() }
    if ($Json -is [array]) { return @($Json) }

    foreach ($prop in @("objects","protectedObjects","protectedObjectResults","searchResults","results","entities","items","data","protectionGroups","protectionGroupsInfo")) {
        if ($Json.PSObject.Properties.Name -contains $prop) {
            return @(AsArray $Json.$prop | Where-Object { $_ })
        }
    }

    return @()
}

function New-SearchUrl {
    param([string]$Endpoint, [string]$SearchTerm, [string]$Environment, [switch]$Global)

    $url = "$BaseUrl$Endpoint" + "?searchString=$([uri]::EscapeDataString($SearchTerm))"
    if (-not [string]::IsNullOrWhiteSpace($Environment)) {
        $url += "&environments=$([uri]::EscapeDataString($Environment))"
    }
    if ($Global) {
        $url += "&includeTenants=true&count=$GlobalSearchCount"
    }
    return $url
}

function Get-ClusterIdFromNode {
    param([object]$Obj, [object]$ProtectionInfo, [object]$Pg)
    return Get-FirstText @(
        $Pg.clusterId,$Pg.clusterID,$Pg.cluster.id,$Pg.cluster.clusterId,$Pg.clusterInfo.clusterId,
        $ProtectionInfo.clusterId,$ProtectionInfo.clusterID,$ProtectionInfo.cluster.id,$ProtectionInfo.cluster.clusterId,$ProtectionInfo.clusterInfo.clusterId,
        $Obj.clusterId,$Obj.clusterID,$Obj.sourceClusterId,$Obj.sourceClusterID,$Obj.accessClusterId,$Obj.cluster.id,$Obj.cluster.clusterId,$Obj.clusterInfo.clusterId
    )
}

function Get-ClusterNameFromNode {
    param([object]$Obj, [object]$ProtectionInfo, [object]$Pg, [string]$ClusterId, [hashtable]$ClusterMap)
    $name = Get-FirstText @(
        $Pg.clusterName,$Pg.cluster.name,$Pg.clusterInfo.name,
        $ProtectionInfo.clusterName,$ProtectionInfo.cluster.name,$ProtectionInfo.clusterInfo.name,
        $Obj.clusterName,$Obj.cluster.name,$Obj.clusterInfo.name
    )
    if (-not [string]::IsNullOrWhiteSpace($name)) { return $name }
    return Get-ClusterNameFromMap -ClusterId $ClusterId -ClusterMap $ClusterMap
}

function Get-PgIdFromNode {
    param([object]$Obj, [object]$ProtectionInfo, [object]$Pg)
    return Get-FirstText @(
        $Pg.id,$Pg._id,$Pg.uid,$Pg.protectionGroupId,$Pg.protectionGroup.id,$Pg.protectionGroup.uid,$Pg.protectionGroupInfo.id,
        $ProtectionInfo.protectionGroupId,$ProtectionInfo.protectionGroup.id,$ProtectionInfo.protectionGroup.uid,$ProtectionInfo.protectionGroupInfo.id,
        $Obj.protectionGroupId,$Obj.protectionGroup.id,$Obj.protectionGroup.uid,$Obj.protectionGroupInfo.id
    )
}

function Get-PgNameFromNode {
    param([object]$Obj, [object]$ProtectionInfo, [object]$Pg)
    $name = Get-FirstText @(
        $Pg.name,$Pg.protectionGroupName,$Pg.displayName,$Pg.protectionGroup.name,$Pg.protectionGroup.displayName,$Pg.protectionGroupInfo.name,$Pg.protectionGroupInfo.displayName,
        $ProtectionInfo.protectionGroupName,$ProtectionInfo.protectionGroup.name,$ProtectionInfo.protectionGroup.displayName,
        $Obj.protectionGroupName,$Obj.protectionGroup.name,$Obj.protectionGroup.displayName,$Obj.protectionGroupInfo.name,$Obj.protectionGroupInfo.displayName
    )
    if ([string]::IsNullOrWhiteSpace($name)) { return "-" }
    return $name
}

function Add-Candidate {
    param([System.Collections.ArrayList]$List, [hashtable]$Seen, [string]$ClusterId, [string]$ClusterName, [string]$PgId, [string]$PgName)

    if ([string]::IsNullOrWhiteSpace($ClusterId)) { return }
    if ([string]::IsNullOrWhiteSpace($ClusterName)) { $ClusterName = $ClusterId }
    if ([string]::IsNullOrWhiteSpace($PgId)) { $PgId = "" }
    if ([string]::IsNullOrWhiteSpace($PgName)) { $PgName = "-" }

    $key = "$ClusterId|$PgId|$PgName"
    if ($Seen.ContainsKey($key)) { return }
    $Seen[$key] = $true

    [void]$List.Add([pscustomobject]@{
        ClusterId   = $ClusterId
        ClusterName = $ClusterName
        PgId        = $PgId
        PgName      = $PgName
    })
}

function Get-CandidatesFromSearchJson {
    param([object]$Json, [hashtable]$ClusterMap)

    $list = New-Object System.Collections.ArrayList
    $seen = @{}

    foreach ($obj in (Get-ObjectArrayFromJson $Json)) {
        foreach ($opi in (AsArray $obj.objectProtectionInfos)) {
            foreach ($pg in (AsArray $opi.protectionGroups)) {
                $cid = Get-ClusterIdFromNode -Obj $obj -ProtectionInfo $opi -Pg $pg
                $cname = Get-ClusterNameFromNode -Obj $obj -ProtectionInfo $opi -Pg $pg -ClusterId $cid -ClusterMap $ClusterMap
                $pgid = Get-PgIdFromNode -Obj $obj -ProtectionInfo $opi -Pg $pg
                $pgname = Get-PgNameFromNode -Obj $obj -ProtectionInfo $opi -Pg $pg
                Add-Candidate -List $list -Seen $seen -ClusterId $cid -ClusterName $cname -PgId $pgid -PgName $pgname
            }

            if (-not $opi.protectionGroups) {
                $cid = Get-ClusterIdFromNode -Obj $obj -ProtectionInfo $opi -Pg $null
                $cname = Get-ClusterNameFromNode -Obj $obj -ProtectionInfo $opi -Pg $null -ClusterId $cid -ClusterMap $ClusterMap
                $pgid = Get-PgIdFromNode -Obj $obj -ProtectionInfo $opi -Pg $null
                $pgname = Get-PgNameFromNode -Obj $obj -ProtectionInfo $opi -Pg $null
                Add-Candidate -List $list -Seen $seen -ClusterId $cid -ClusterName $cname -PgId $pgid -PgName $pgname
            }
        }

        foreach ($pg2 in (AsArray $obj.protectionGroups)) {
            $cid = Get-ClusterIdFromNode -Obj $obj -ProtectionInfo $null -Pg $pg2
            $cname = Get-ClusterNameFromNode -Obj $obj -ProtectionInfo $null -Pg $pg2 -ClusterId $cid -ClusterMap $ClusterMap
            $pgid = Get-PgIdFromNode -Obj $obj -ProtectionInfo $null -Pg $pg2
            $pgname = Get-PgNameFromNode -Obj $obj -ProtectionInfo $null -Pg $pg2
            Add-Candidate -List $list -Seen $seen -ClusterId $cid -ClusterName $cname -PgId $pgid -PgName $pgname
        }

        $cidObj = Get-ClusterIdFromNode -Obj $obj -ProtectionInfo $null -Pg $null
        $pgidObj = Get-PgIdFromNode -Obj $obj -ProtectionInfo $null -Pg $null
        $pgnameObj = Get-PgNameFromNode -Obj $obj -ProtectionInfo $null -Pg $null
        if (-not [string]::IsNullOrWhiteSpace($cidObj)) {
            $cnameObj = Get-ClusterNameFromNode -Obj $obj -ProtectionInfo $null -Pg $null -ClusterId $cidObj -ClusterMap $ClusterMap
            Add-Candidate -List $list -Seen $seen -ClusterId $cidObj -ClusterName $cnameObj -PgId $pgidObj -PgName $pgnameObj
        }
    }

    return @($list)
}

function Get-SearchCandidates {
    param([string]$SearchTerm, [string]$Environment, [hashtable]$ClusterMap)

    $script:GlobalSearchCalls++
    $globalUrl = New-SearchUrl -Endpoint "/v2/data-protect/search/objects" -SearchTerm $SearchTerm -Environment $Environment -Global
    $json = Invoke-HeliosGetJson -Uri $globalUrl -Headers $CommonHeaders -Quiet
    if (-not $json) { return @() }

    return @(Get-CandidatesFromSearchJson -Json $json -ClusterMap $ClusterMap | Sort-Object ClusterId, PgId, PgName -Unique)
}

function Get-UniqueCandidates {
    param([object[]]$Candidates)

    $out = New-Object System.Collections.ArrayList
    $seen = @{}

    foreach ($c in @($Candidates)) {
        if (-not $c) { continue }
        $key = "$($c.ClusterId)|$($c.PgId)|$($c.PgName)"
        if ($seen.ContainsKey($key)) { continue }
        $seen[$key] = $true
        [void]$out.Add($c)
    }

    return @($out)
}

# ==========================================================
# SQL Active PG List Fallback
# ==========================================================
function Get-SqlCandidatesFromActivePgList {
    param([object]$Context, [object[]]$SearchTerms, [hashtable]$ClusterMap)

    $script:SqlPgListFallbackCalls++
    $list = New-Object System.Collections.ArrayList
    $seen = @{}

    foreach ($c in $Clusters) {
        $clusterId = Get-FirstText @($c.clusterId,$c.id,$c.intId,$c.clusterIdentifier.clusterId,$c.clusterInfo.clusterId)
        if ([string]::IsNullOrWhiteSpace($clusterId)) { continue }

        $clusterName = Get-ClusterNameFromMap -ClusterId $clusterId -ClusterMap $ClusterMap
        if ([string]::IsNullOrWhiteSpace($clusterName) -or $clusterName -eq $clusterId) {
            $clusterName = Get-FirstText @($c.clusterName,$c.name,$c.displayName)
        }
        if ([string]::IsNullOrWhiteSpace($clusterName)) { $clusterName = $clusterId }

        $headers = @{ accept="application/json"; apiKey=$ApiKey; accessClusterId="$clusterId" }
        $uri = "$BaseUrl/v2/data-protect/protection-groups?environments=kSQL&isDeleted=false&isPaused=false&isActive=true&includeLastRunInfo=true"
        $json = Invoke-HeliosGetJson -Uri $uri -Headers $headers -Quiet
        if (-not $json) { continue }

        $pgs = @()
        if ($json.protectionGroups) { $pgs += @(AsArray $json.protectionGroups) }
        elseif ($json.protectionGroupsInfo) { $pgs += @(AsArray $json.protectionGroupsInfo) }
        elseif ($json.objects) { $pgs += @(AsArray $json.objects) }
        elseif ($json -is [array]) { $pgs += @(AsArray $json) }

        foreach ($pg in $pgs) {
            if (-not $pg) { continue }
            $pgId = Get-PgIdFromNode -Obj $pg -ProtectionInfo $null -Pg $pg
            $pgName = Get-PgNameFromNode -Obj $pg -ProtectionInfo $null -Pg $pg
            if ([string]::IsNullOrWhiteSpace($pgId)) { continue }

            $matched = $false
            foreach ($term in @($SearchTerms)) {
                if (Text-MatchesName -Text $pgName -Name "$term") { $matched = $true; break }
            }

            if (-not $matched) {
                try { $pgText = ($pg | ConvertTo-Json -Depth 60 -Compress) } catch { $pgText = "" }
                foreach ($term in @($SearchTerms)) {
                    if (-not [string]::IsNullOrWhiteSpace($term) -and $pgText.ToLower().Contains("$term".ToLower())) {
                        $matched = $true; break
                    }
                }
            }

            if (-not $matched) { continue }
            $script:SqlPgListFallbackMatches++
            Add-Candidate -List $list -Seen $seen -ClusterId $clusterId -ClusterName $clusterName -PgId $pgId -PgName $pgName
        }
    }

    return @($list)
}

