$Report += "------------------------------------------------------------"
$Report += "Input CSV                  : $InputCsv"
$Report += "Input TXT                  : $InputTxt"
$Report += "Final CSV                  : $OutputCsv"
$Report += "TXT Report                 : $OutputTxt"

if ($ExportDebugRows) {
    $Report += "Debug Rows CSV             : $DebugCsv"
}

$Report += "============================================================"

$Report | Set-Content -Path $OutputTxt -Encoding UTF8

# =====================================================================
# Console output
# =====================================================================
Write-Host ""
Write-Host "============================================================"
Write-Host "Cohesity Server Backup Validation" -ForegroundColor Cyan
Write-Host "============================================================"
Write-Host "Change Number              : $ChangeID"
Write-Host "Executed By                : $ExecutedBy"
Write-Host "Run Date                   : $(Get-Date -Format 'yyyy-MM-dd HH:mm:ss')"
Write-Host ""
Write-Host "Scope                      : Server -> latest FS + latest SQL/Oracle DB backups"
Write-Host "API Mode                   : GET only"
Write-Host "Run Types                  : $RunTypes"
Write-Host "Full Inventory Scan        : No"
Write-Host "Report Preview POST        : No"
Write-Host ""
Write-Host "Total Input Servers        : $($ServerList.Count)"
Write-Host "Total Output Rows          : $TotalRows"
Write-Host "Successful Backup Rows     : $SuccessfulRows"
Write-Host "No FS Backup Found         : $NoFsRows"
Write-Host "No DB Backup Found         : $NoDbRows"
Write-Host ""
Write-Host "Global Search Calls        : $script:GlobalSearchCalls"
Write-Host "Candidate PGs Inspected    : $script:CandidatePgsInspected"
Write-Host "PG Run Calls               : $script:PgRunCalls"
Write-Host "PG Detail Calls            : $script:PgDetailCalls"
Write-Host "Object Lookup Calls        : $script:ObjectLookupCalls"
Write-Host "Failed GETs                : $script:FailedGets"
Write-Host ""
Write-Host "------------------------------------------------------------"
Write-Host "Details"
Write-Host "------------------------------------------------------------"
Write-Host ""
Write-Host $DetailsText
Write-Host ""
Write-Host "------------------------------------------------------------"
Write-Host "Files"
Write-Host "------------------------------------------------------------"
Write-Host "Final CSV                  : $OutputCsv" -ForegroundColor Green
Write-Host "TXT Report                 : $OutputTxt" -ForegroundColor Green

if ($ExportDebugRows) {
    Write-Host "Debug Rows CSV             : $DebugCsv" -ForegroundColor Green
}

Write-Host "============================================================"
Write-Host ""
