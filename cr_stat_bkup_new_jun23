    param([object]$Snap)

    return Get-UsecsFromObjectPath @(
        $Snap.localSnapshotInfo.snapshotInfo.endTimeUsecs,
        $Snap.localSnapshotInfo.snapshotInfo.startTimeUsecs,
        $Snap.localSnapshotInfo.endTimeUsecs,
