function Get-SnapshotBestUsecs {
    param([object]$Snap)

    $local = Get-SnapshotLocalUsecs $Snap
    $repl  = Get-SnapshotReplicationUsecs $Snap

    if ($local -gt 0 -and $repl -gt 0) {
        if ($local -ge $repl) { return $local }
        return $repl
    }

    if ($local -gt 0) { return $local }
    if ($repl -gt 0) { return $repl }
    return 0
}

function Test-RegularSnapshot {
    param([string]$RunType)

    if ([string]::IsNullOrWhiteSpace($RunType)) { return $true }
    if ($RunType -match '(?i)log|archive') { return $false }
    return ($RunType -match '(?i)regular|full|incr|incremental|kregular|kfull|kincremental')
}

function Get-BestSnapshot {
    param([object]$Obj)

    $snaps = @(Get-SnapshotArray $Obj)
    if ($snaps.Count -eq 0) { return $null }

    $regular = @($snaps | Where-Object { Test-RegularSnapshot (Get-SnapshotRunType $_) })
    if ($regular.Count -gt 0) {
        return $regular | Sort-Object @{ Expression = { Get-SnapshotBestUsecs $_ }; Descending = $true } | Select-Object -First 1
    }

    return $snaps | Sort-Object @{ Expression = { Get-SnapshotBestUsecs $_ }; Descending = $true } | Select-Object -First 1
}

function Get-BackupTypeFromProtectedObject {
    param([object]$Obj)

    $env = Get-ProtectedObjectEnvironment $Obj
    $type = Get-ProtectedObjectType $Obj

    if ($env -eq "kPhysical" -and $type -eq "kHost") { return "FS" }
    if ($env -eq "kPhysical") { return "FS" }
    if ($env -eq "kSQL") { return "SQL" }
    if ($env -eq "kOracle") { return "Oracle" }

    return ""
}

function Test-ObjectMatchesContext {
    param([object]$Context, [object]$Obj, [string]$BackupType)

    $objName = Get-ProtectedObjectName $Obj
    $srcName = Get-ProtectedObjectSourceName $Obj

    if ($Context.IsDbAtServer) {
        if ($BackupType -eq "FS") {
            return ((Text-MatchesName -Text $objName -Name $Context.ServerName) -or (Text-MatchesName -Text $srcName -Name $Context.ServerName))
        }

        if ($BackupType -in @("SQL", "Oracle")) {
            $dbMatch = (Text-MatchesName -Text $objName -Name $Context.DbName)
            $serverMatch = $true
            if (-not [string]::IsNullOrWhiteSpace($srcName)) {
                $serverMatch = (Text-MatchesName -Text $srcName -Name $Context.ServerName)
            }
            return ($dbMatch -and $serverMatch)
        }
    }

    return ((Text-MatchesName -Text $objName -Name $Context.InputCI) -or (Text-MatchesName -Text $srcName -Name $Context.InputCI))
}

function New-RowFromProtectedObject {
    param([object]$Context, [object]$Obj, [hashtable]$ClusterMap)

    $backupType = Get-BackupTypeFromProtectedObject $Obj
    if ([string]::IsNullOrWhiteSpace($backupType)) { return $null }

    if (-not (Test-ObjectMatchesContext -Context $Context -Obj $Obj -BackupType $backupType)) { return $null }

    $snap = Get-BestSnapshot $Obj
    $objName = Get-ProtectedObjectName $Obj
    $srcName = Get-ProtectedObjectSourceName $Obj

    if ([string]::IsNullOrWhiteSpace($srcName)) {
        if ($backupType -eq "FS") { $srcName = $objName }
        elseif ($Context.IsDbAtServer) { $srcName = $Context.ServerName }
        else { $srcName = "-" }
    }

    $clusterName = Get-ProtectedObjectClusterName -Obj $Obj -ClusterMap $ClusterMap
    $pgName = Get-ProtectedObjectProtectionGroup -Obj $Obj -Snap $snap
    $runType = ""
    $status = ""
    $localUsecs = 0
    $replUsecs = 0
    $bestUsecs = 0

    if ($snap) {
        $runType = Get-SnapshotRunType $snap
        $status = Get-SnapshotStatus -Snap $snap -Obj $Obj
        $localUsecs = Get-SnapshotLocalUsecs $snap
        $replUsecs = Get-SnapshotReplicationUsecs $snap
        $bestUsecs = Get-SnapshotBestUsecs $snap
    }

    $localTime = if ($localUsecs -gt 0) { Convert-UsecsToET $localUsecs } else { "-" }
    $replTime  = if ($replUsecs -gt 0) { Convert-UsecsToET $replUsecs } else { "-" }
    $lastTime  = if ($bestUsecs -gt 0) { Convert-UsecsToET $bestUsecs } else { "NoBackup" }

    if ([string]::IsNullOrWhiteSpace($runType)) { $runType = "-" }
    if ([string]::IsNullOrWhiteSpace($status)) { $status = "-" }

    $script:RowsBuilt++

    return [pscustomobject]@{
        InputCI                 = $Context.InputCI
        BackupType              = $backupType
        ObjectName              = $objName
        SourceName              = $srcName
        ClusterName             = $clusterName
        ProtectionGroup         = $pgName
        RunType                 = $runType
        LocalSnapshotTime       = $localTime
        ReplicationSnapshotTime = $replTime
        LastBackupTime          = $lastTime
        Status                  = $status
        LastBackupUsecs         = [int64]$bestUsecs
        ObjectType              = Get-ProtectedObjectType $Obj
        Environment             = Get-ProtectedObjectEnvironment $Obj
        Source                  = "ProtectedObjectsLatestSnapshotInfo"
    }
}

function New-MissingRow {
    param([string]$InputCI, [string]$BackupType, [string]$ObjectName, [string]$SourceName, [string]$Message)

    return [pscustomobject]@{
        InputCI                 = $InputCI
        BackupType              = $BackupType
        ObjectName              = $ObjectName
        SourceName              = $SourceName
        ClusterName             = "-"
        ProtectionGroup         = "-"
        RunType                 = "-"
        LocalSnapshotTime       = "-"
        ReplicationSnapshotTime = "-"
        LastBackupTime          = $Message
        Status                  = "-"
        LastBackupUsecs         = 0
        ObjectType              = "-"
        Environment             = "-"
        Source                  = "MissingRow"
    }
}

function Select-BestRows {
    param([object[]]$Rows)

    $out = @()

    foreach ($grp in ($Rows | Group-Object InputCI, BackupType, ObjectName, SourceName, ProtectionGroup)) {
        $g = @($grp.Group)
        $valid = @($g | Where-Object { Is-ValidBackupTime $_.LastBackupTime })

        if ($valid.Count -gt 0) {
            $out += ($valid | Sort-Object @{ Expression = { [int64]$_.LastBackupUsecs }; Descending = $true }, ClusterName | Select-Object -First 1)
        }
        else {
            $out += ($g | Sort-Object ClusterName, ProtectionGroup | Select-Object -First 1)
        }
    }

    return @($out)
}

# ==========================================================
# Load input
# ==========================================================
$InputRows = Import-Csv -Path $InputCsv
if (-not $InputRows -or $InputRows.Count -eq 0) {
    throw "Input CSV is empty: $InputCsv"
}

if (-not ($InputRows[0].PSObject.Properties.Name -contains "ci_item")) {
    throw "Input CSV must contain column: ci_item"
}

$CiList = $InputRows |
    ForEach-Object { "$($_.ci_item)".Trim().Trim('"').Trim("'") } |
    Where-Object { -not [string]::IsNullOrWhiteSpace($_) } |
    Sort-Object -Unique

if (-not $CiList -or $CiList.Count -eq 0) {
    throw "No ci_item values found in $InputCsv"
}

$CiList | Set-Content -Path $InputTxt -Encoding UTF8

# ==========================================================
# Build cluster map
# ==========================================================
Write-Host "Building cluster map..." -ForegroundColor Cyan
$ClusterMap = Build-ClusterMap

# ==========================================================
# Main
# ==========================================================
$Results = @()
$DebugRows = @()

foreach ($ci in $CiList) {
    $context = Get-CiContext $ci
    Write-Host "Processing: $($context.InputCI)" -ForegroundColor Cyan

    $terms = @(Get-SearchTermsForContext -Context $context)
    $objects = @(Get-ProtectedObjectsForTerms -SearchTerms $terms)
    $script:RawObjectsSeen += $objects.Count

    $ciRows = @()

    foreach ($obj in $objects) {
        $env = Get-ProtectedObjectEnvironment $obj
        $type = Get-ProtectedObjectType $obj
        $name = Get-ProtectedObjectName $obj
        $src = Get-ProtectedObjectSourceName $obj
        $bt = Get-BackupTypeFromProtectedObject $obj

        $DebugRows += [pscustomobject]@{
            InputCI         = $context.InputCI
            SearchTerms     = ($terms -join ";")
            BackupType      = if ($bt) { $bt } else { "Ignored" }
            ObjectName      = $name
            SourceName      = $src
            ObjectType      = $type
            Environment     = $env
            ClusterId       = Get-ProtectedObjectClusterId $obj
            ClusterName     = Get-ProtectedObjectClusterName -Obj $obj -ClusterMap $ClusterMap
            ProtectionGroup = Get-ProtectedObjectProtectionGroup -Obj $obj -Snap (Get-BestSnapshot $obj)
        }

        $row = New-RowFromProtectedObject -Context $context -Obj $obj -ClusterMap $ClusterMap
        if ($row) { $ciRows += $row }
    }

    $selected = @(Select-BestRows -Rows $ciRows)

    foreach ($r in $selected) {
        $Results += $r
    }

    if ($IncludeMissingRows) {
        $hasDbBackup = @($selected | Where-Object { $_.BackupType -in @("SQL", "Oracle") -and (Is-ValidBackupTime $_.LastBackupTime) }).Count -gt 0
        $hasFsBackup = @($selected | Where-Object { $_.BackupType -eq "FS" -and (Is-ValidBackupTime $_.LastBackupTime) }).Count -gt 0

        if (-not $hasDbBackup) {
            $Results += New-MissingRow -InputCI $context.InputCI -BackupType "DB" -ObjectName "-" -SourceName $context.InputCI -Message "NoDbBackupFound"
        }

        if (-not $hasFsBackup) {
            $fsName = if ($context.IsDbAtServer) { $context.ServerName } else { $context.InputCI }
            $Results += New-MissingRow -InputCI $context.InputCI -BackupType "FS" -ObjectName $fsName -SourceName $fsName -Message "NoFSBackupFound"
        }
    }
}

# ==========================================================
# Final sorting / summary
# ==========================================================
$SortedResults = $Results |
    Sort-Object InputCI, @{ Expression = { Get-BackupTypeRank $_.BackupType } }, ObjectName, ClusterName, ProtectionGroup

$TotalInputCIs   = @($CiList).Count
$TotalBackupRows = @($SortedResults).Count
$BackedUp = @($SortedResults | Where-Object { Is-ValidBackupTime $_.LastBackupTime }).Count
$NoBackup = @($SortedResults | Where-Object { $_.LastBackupTime -in @("NoBackup", "NoBackupTime", "NoDbBackupFound", "NoFSBackupFound", "NoObject") }).Count
$NoDbBackupFound = @($SortedResults | Where-Object { $_.LastBackupTime -eq "NoDbBackupFound" }).Count
$NoFSBackupFound = @($SortedResults | Where-Object { $_.LastBackupTime -eq "NoFSBackupFound" }).Count

# ==========================================================
# Export CSV
# ==========================================================
$SortedResults |
    Select-Object InputCI, BackupType, ObjectName, SourceName, ClusterName, ProtectionGroup, RunType, LocalSnapshotTime, ReplicationSnapshotTime, LastBackupTime, Status |
    Export-Csv -Path $OutputCsv -NoTypeInformation -Encoding UTF8

if ($ExportDebugCsv) {
    $DebugRows |
        Select-Object InputCI, SearchTerms, BackupType, ObjectName, SourceName, ObjectType, Environment, ClusterId, ClusterName, ProtectionGroup |
        Export-Csv -Path $DebugCsv -NoTypeInformation -Encoding UTF8
}

# ==========================================================
# TXT Report
# ==========================================================
$DetailsText = (
    $SortedResults |
    Select-Object InputCI, BackupType, ObjectName, SourceName, ClusterName, ProtectionGroup, RunType, LocalSnapshotTime, ReplicationSnapshotTime, LastBackupTime, Status |
    Format-Table -AutoSize -Wrap |
    Out-String -Width 420
).TrimEnd()

$Report = @()
$Report += "=========================================================="
$Report += "Cohesity Backup Validation Report"
$Report += "=========================================================="
$Report += "Change Number              : $ChangeID"
$Report += "Executed By                : $ExecutedBy"
$Report += "Run Date                   : $(Get-Date -Format 'dd-MMM-yyyy HH:mm:ss')"
$Report += ""
$Report += "Scope                      : FS, SQL, Oracle only"
$Report += "Primary Endpoint           : GET /v2/data-protect/search/protected-objects?searchString=<CI>"
$Report += "Snapshot Source            : latestSnapshotInfo/localSnapshotInfo/replicationSnapshotInfo"
$Report += "Excluded                   : NAS, Nutanix, Hyper-V, VMware"
$Report += "API Mode                   : GET only"
$Report += ""
$Report += "Total Input CIs            : $TotalInputCIs"
$Report += "Total Backup Rows          : $TotalBackupRows"
$Report += "Backed Up                  : $BackedUp"
$Report += "No Backup                  : $NoBackup"
$Report += "No DB Backup Found         : $NoDbBackupFound"
$Report += "No FS Backup Found         : $NoFSBackupFound"
$Report += ""
$Report += "Protected Object Searches  : $script:ProtectedObjectSearchCalls"
$Report += "Raw Objects Seen           : $script:RawObjectsSeen"
$Report += "Rows Built                 : $script:RowsBuilt"
$Report += "Failed GETs                : $script:FailedGets"
$Report += ""
$Report += "----------------------------------------------------------"
$Report += "Details"
$Report += "----------------------------------------------------------"
$Report += ""
$Report += $DetailsText
$Report += ""
$Report += "----------------------------------------------------------"
$Report += "Validation Notes"
$Report += "----------------------------------------------------------"
$Report += "- FS is identified as environment kPhysical with objectType kHost."
$Report += "- SQL is identified from protected objects where environment is kSQL."
$Report += "- Oracle is identified from protected objects where environment is kOracle."
$Report += "- latestSnapshotInfo is preferred for LastBackupTime, RunType, PG, local snapshot, and replication snapshot details."
$Report += "- If replication snapshot time exists, it is shown separately."
$Report += "- No PG run scan is used in this version unless Cohesity already exposes the data in protected-object search."
$Report += ""
$Report += "----------------------------------------------------------"
$Report += "Report Locations"
$Report += "----------------------------------------------------------"
$Report += "Input CSV                 : $InputCsv"
$Report += "Input TXT                 : $InputTxt"
$Report += "TXT Report                : $OutputTxt"
$Report += "Final CSV                 : $OutputCsv"
if ($ExportDebugCsv) { $Report += "Debug CSV                 : $DebugCsv" }
$Report += "=========================================================="

$Report | Set-Content -Path $OutputTxt -Encoding UTF8

