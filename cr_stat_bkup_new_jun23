$Report += "No DB Backup Found         : $NoDbCount"
$Report += ""
$Report += "Clusters Queried           : $($Clusters.Count)"
$Report += "Cluster Search Calls       : $script:ClusterSearchCalls"
$Report += "Failed GETs                : $script:FailedGets"
$Report += ""
$Report += "------------------------------------------------------------"
$Report += "Backup Validation Table"
$Report += "------------------------------------------------------------"
$Report += ""
$Report += $TableText
$Report += ""
$Report += "------------------------------------------------------------"
$Report += "Files"
$Report += "------------------------------------------------------------"
$Report += "Input CSV                  : $InputCsv"
$Report += "Input TXT                  : $InputTxt"
$Report += "Output CSV                 : $OutputCsv"
$Report += "Output TXT                 : $OutputTxt"

if ($ExportDebugCsv) {
    $Report += "Debug CSV                  : $DebugCsv"
}

$Report += "============================================================"

$Report | Set-Content -Path $OutputTxt -Encoding UTF8

