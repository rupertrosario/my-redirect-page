# =====================================================================
# Cohesity Helios - Server Backup Validation
#
# Goal:
#   Input server name(s) and return BOTH:
#     1) Latest FS backup
#     2) Latest DB backup rows for SQL / Oracle databases hosted by that server
#
# Fast design:
#   - No full inventory
#   - No report-preview POST
#   - No all-cluster PG scan
#   - Search server first
#   - Inspect only candidate Protection Groups
#
# API:
#   GET only
#
# Input:
#   X:\PowerShell\Data\Cohesity\BackupValidation\<ChangeID>.csv
#
# Required CSV column:
#   ci_item
#
# Example ci_item:
#   SERVER01
#   server01.domain.com
#
# Output columns:
#   InputServer
#   BackupType
#   ObjectName
#   SourceName
#   ProtectionGroup
#   ClusterName
#   BackupLevel
#   LatestBackupET
#   Status
#
# Notes:
#   - Uses kIncremental,kFull only.
#   - Excludes logs/archive by design.
#   - Always emits FS and DB result for every server.
#   - If FS missing: NoFSBackupFound
#   - If DB missing: NoDbBackupFound
# =====================================================================

$ErrorActionPreference = "Stop"
$FormatEnumerationLimit = -1
[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12

# =====================================================================
# User input / paths
# =====================================================================
$ChangeID = Read-Host "Enter Change Number"
$ExecutedBy = (whoami).Trim()

$BaseDir = "X:\PowerShell\Data\Cohesity\BackupValidation"

if (-not (Test-Path -Path $BaseDir -PathType Container)) {
    New-Item -Path $BaseDir -ItemType Directory -Force | Out-Null
}

$InputCsv = Join-Path $BaseDir "$ChangeID.csv"
$InputTxt = Join-Path $BaseDir "$ChangeID.txt"

$Stamp = Get-Date -Format "yyyyMMdd_HHmmss"

$OutputCsv = Join-Path $BaseDir "${ChangeID}_ServerBackupValidation_$Stamp.csv"
$OutputTxt = Join-Path $BaseDir "${ChangeID}_ServerBackupValidation_$Stamp.txt"
$DebugCsv  = Join-Path $BaseDir "${ChangeID}_ServerBackupValidation_DebugRows_$Stamp.csv"

if (-not (Test-Path $InputCsv)) {
    throw "Input CSV not found: $InputCsv"
}

# =====================================================================
# API config
# =====================================================================
$BaseUrl = "https://helios.cohesity.com"
$ApiKeyPath = "X:\PowerShell\Cohesity_API_Scripts\DO_NOT_Delete\apikey.txt"

if (-not (Test-Path $ApiKeyPath)) {
    throw "API key file not found: $ApiKeyPath"
}

$ApiKey = (Get-Content -Path $ApiKeyPath -Raw).Trim()

if ([string]::IsNullOrWhiteSpace($ApiKey)) {
    throw "API key file is empty: $ApiKeyPath"
}

$CommonHeaders = @{
    accept = "application/json"
    apiKey = $ApiKey
}

# =====================================================================
# Runtime settings - keep these low for speed
# =====================================================================
$ReportTimeZoneId = "Eastern Standard Time"

# Search result count per environment.
$GlobalSearchCount = 50

# How many latest runs to check per candidate PG.
$NumRunsPerPg = 10

# Page limit per PG. Keep 1 for speed.
$MaxRunPagesPerPg = 1

# Keep false for speed.
$ExportDebugRows = $true

# Environments
$FsEnvironment     = "kPhysical"
$SqlEnvironment    = "kSQL"
$OracleEnvironment = "kOracle"

# Run types
$RunTypes = "kIncremental,kFull"

# =====================================================================
# Counters
# =====================================================================
$script:GlobalSearchCalls      = 0
$script:PgRunCalls             = 0
$script:PgDetailCalls          = 0
$script:ObjectLookupCalls      = 0
$script:FailedGets             = 0
$script:ServersProcessed       = 0
$script:FsRowsFound            = 0
$script:DbRowsFound            = 0
$script:NoFsBackupFound        = 0
$script:NoDbBackupFound        = 0
$script:CandidatePgsInspected  = 0

# =====================================================================
# Helpers
# =====================================================================
function Norm {
    param([object]$Value)

    if ($null -eq $Value) {
        return ""
    }

    return "$Value".Trim()
}

function AsArray {
    param([object]$Value)

    if ($null -eq $Value) {
        return @()
    }

    if ($Value -is [array]) {
        return @($Value)
    }

    return @($Value)
}

function Get-FirstText {
    param([object[]]$Values)

    foreach ($Value in $Values) {
        if ($null -eq $Value) {
            continue
        }

        if ($Value -is [array]) {
            foreach ($item in $Value) {
                $v = Get-FirstText @($item)

                if (-not [string]::IsNullOrWhiteSpace($v)) {
                    return "$v".Trim()
                }
            }

            continue
        }

        if ($Value -is [pscustomobject]) {
            foreach ($prop in @(
                "name",
                "displayName",
                "display_value",
                "value",
                "id",
                "uid",
                "_id",
                "clusterId",
                "clusterID",
                "intId"
            )) {
                if ($Value.PSObject.Properties.Name -contains $prop) {
                    $v = Get-FirstText @($Value.$prop)

                    if (-not [string]::IsNullOrWhiteSpace($v)) {
                        return "$v".Trim()
                    }
                }
            }

            continue
        }

        $text = "$Value".Trim()

        if (-not [string]::IsNullOrWhiteSpace($text)) {
            return $text
        }
    }

    return ""
}

function Normalize-Name {
    param([string]$Value)

    if ([string]::IsNullOrWhiteSpace($Value)) {
        return ""
    }

    return "$Value".Trim().Trim('"').Trim("'").ToLower()
}

function Get-ShortName {
    param([string]$Value)

    $v = Norm $Value

    if ([string]::IsNullOrWhiteSpace($v)) {
        return ""
    }

    if ($v -match "\.") {
        return (($v -split "\.")[0]).Trim()
    }

    return $v
}

function Text-MatchesName {
    param(
        [string]$Text,
        [string]$Name
    )

    if ([string]::IsNullOrWhiteSpace($Text) -or [string]::IsNullOrWhiteSpace($Name)) {
        return $false
    }

    $t = Normalize-Name $Text
    $n = Normalize-Name $Name

    if ($t -eq $n) {
        return $true
    }

    $ts = Normalize-Name (Get-ShortName $Text)
    $ns = Normalize-Name (Get-ShortName $Name)

    if (-not [string]::IsNullOrWhiteSpace($ts) -and $ts -eq $n) {
        return $true
    }

    if (-not [string]::IsNullOrWhiteSpace($ns) -and $ns -eq $t) {
        return $true
    }

    if (-not [string]::IsNullOrWhiteSpace($ts) -and
        -not [string]::IsNullOrWhiteSpace($ns) -and
        $ts -eq $ns) {
        return $true
    }

    return $false
}

function Any-TextMatchesName {
    param(
        [string[]]$Texts,
        [string]$Name
    )

    foreach ($t in @($Texts)) {
        if (Text-MatchesName -Text "$t" -Name $Name) {
            return $true
        }
    }

    return $false
}

function Add-UniqueText {
    param(
        [System.Collections.ArrayList]$List,
        [string]$Value
    )

    $v = Norm $Value

    if ([string]::IsNullOrWhiteSpace($v)) {
        return
    }

    if (-not $List.Contains($v)) {
        [void]$List.Add($v)
    }
}

function To-Int64Safe {
    param([object]$Value)

    if ($null -eq $Value -or "$Value".Trim() -eq "") {
        return 0
    }

    try {
        return [int64]$Value
    }
    catch {
        return 0
    }
}

function Convert-UsecsToET {
    param([object]$Usecs)

    $u = To-Int64Safe $Usecs

    if ($u -le 0) {
        return ""
    }

    try {
        $dto = [DateTimeOffset]::FromUnixTimeMilliseconds([int64]($u / 1000))
        $tz = [System.TimeZoneInfo]::FindSystemTimeZoneById($ReportTimeZoneId)
        return ([System.TimeZoneInfo]::ConvertTime($dto, $tz)).ToString("yyyy-MM-dd HH:mm:ss") + " ET"
    }
    catch {
        return ""
    }
}

function Get-HttpErrorBody {
    param([object]$ErrorRecord)

    try {
        if ($ErrorRecord.Exception.Response) {
            $stream = $ErrorRecord.Exception.Response.GetResponseStream()

            if ($stream) {
                $reader = New-Object System.IO.StreamReader($stream)
                return $reader.ReadToEnd()
            }
        }
    }
    catch {
        return ""
    }

    return ""
}

function Invoke-HeliosGetJson {
    param(
        [Parameter(Mandatory)][string]$Uri,
        [Parameter(Mandatory)][hashtable]$Headers,
        [int]$TimeoutSec = 90,
        [switch]$Quiet
    )

    try {
        $resp = Invoke-WebRequest `
            -Uri $Uri `
            -Headers $Headers `
            -Method Get `
            -UseBasicParsing `
            -TimeoutSec $TimeoutSec `
            -ErrorAction Stop

        if (-not $resp -or [string]::IsNullOrWhiteSpace($resp.Content)) {
            return $null
        }

        return ($resp.Content | ConvertFrom-Json)
    }
    catch {
        $script:FailedGets++

        if (-not $Quiet) {
            Write-Host "GET failed:" -ForegroundColor Red
            Write-Host $Uri -ForegroundColor DarkRed
            Write-Host $_.Exception.Message -ForegroundColor DarkRed

            $body = Get-HttpErrorBody $_

            if (-not [string]::IsNullOrWhiteSpace($body)) {
                Write-Host $body -ForegroundColor DarkRed
            }
        }

        return $null
    }
}

function New-ClusterHeaders {
    param([string]$ClusterId)

    return @{
        accept          = "application/json"
        apiKey          = $ApiKey
        accessClusterId = "$ClusterId"
    }
}

function Get-ResponseObjects {
    param([object]$Json)

    if ($null -eq $Json) {
        return @()
    }

    if ($Json -is [array]) {
        return @($Json)
    }

    foreach ($prop in @(
        "objects",
        "protectedObjects",
        "protectedObjectResults",
        "searchResults",
        "results",
        "entities",
        "items",
        "data",
        "rootNodes",
        "runs",
        "protectionGroups",
        "cohesityClusters"
    )) {
        if ($Json.PSObject.Properties.Name -contains $prop) {
            return @(AsArray $Json.$prop | Where-Object { $_ })
        }
    }

    return @()
}

function Get-BackupLevelFromRunType {
    param([string]$RunType)

    switch -Regex ($RunType) {
        "kFull|full" { return "Full" }
        "kIncremental|incremental|incr" { return "Incremental" }
        default { return $RunType }
    }
}

function Test-SuccessStatus {
    param([string]$Status)

    if ([string]::IsNullOrWhiteSpace($Status)) {
        return $false
    }

    return ($Status -match '(?i)success|succeeded|succeededwithwarning|warning|ksuccess|ksuccessful')
}

function Test-RegularRunType {
    param([string]$RunType)

    if ([string]::IsNullOrWhiteSpace($RunType)) {
        return $false
    }

    if ($RunType -match '(?i)log|archive') {
        return $false
    }

    return ($RunType -match '(?i)full|incr|incremental|regular|kfull|kincremental|kregular')
}

function Is-ValidBackupTime {
    param([string]$Value)

    if ([string]::IsNullOrWhiteSpace($Value)) {
        return $false
    }

    return $Value -notin @(
        "NoFSBackupFound",
        "NoDbBackupFound",
        "NoBackup",
        "NoBackupTime",
        "NoDbDetailFound",
        "NoObject",
        "Unknown"
    )
}

# =====================================================================
# Cluster map
# =====================================================================
function Add-ClusterMapEntry {
    param(
        [hashtable]$Map,
        [object]$Id,
        [string]$Name
    )

    $idText = Get-FirstText @($Id)

    if (-not [string]::IsNullOrWhiteSpace($idText) -and
        -not [string]::IsNullOrWhiteSpace($Name)) {
        $Map["$idText"] = $Name
    }
}

function Get-ClusterNameFromMap {
    param(
        [string]$ClusterId,
        [hashtable]$ClusterMap,
        [string]$FallbackName = ""
    )

    if (-not [string]::IsNullOrWhiteSpace($FallbackName)) {
        return $FallbackName
    }

    if ([string]::IsNullOrWhiteSpace($ClusterId)) {
        return "-"
    }

    if ($ClusterMap.ContainsKey("$ClusterId")) {
        return "$($ClusterMap["$ClusterId"])"
    }

    return "$ClusterId"
}

