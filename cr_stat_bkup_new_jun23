function Get-BackupTypeRank {
    param([string]$BackupType)

    switch ($BackupType) {
        "FS"      { return 1 }
        "SQL"     { return 2 }
        "Oracle"  { return 3 }
        "DB"      { return 4 }
        default   { return 9 }
    }
}

function Test-HasValidFs {
    param($Rows)

    return (@($Rows | Where-Object { $_.BackupType -eq "FS" -and (Is-ValidBackupTime -TimeText $_.LastBackupTime) }).Count -gt 0)
}

function Test-HasValidDb {
    param($Rows)

    return (@($Rows | Where-Object { $_.BackupType -in @("SQL", "Oracle", "DB") -and (Is-ValidBackupTime -TimeText $_.LastBackupTime) }).Count -gt 0)
}

# ==========================================================
# Read CI List
# ==========================================================
$CsvRows = Import-Csv -Path $InputCsv

if ($null -eq $CsvRows -or $CsvRows.Count -eq 0) {
    throw "Input CSV is empty: $InputCsv"
}

if (-not ($CsvRows[0].PSObject.Properties.Name -contains "ci_item")) {
    throw "Input CSV must contain column: ci_item"
}

$CiNames = $CsvRows |
ForEach-Object { "$($_.ci_item)".Trim().Trim('"').Trim("'") } |
Where-Object { -not [string]::IsNullOrWhiteSpace($_) } |
Sort-Object -Unique

if (-not $CiNames -or $CiNames.Count -eq 0) {
    throw "No CI names found in CSV: $InputCsv"
}

$CiNames | Set-Content -Path $InputTxt -Encoding UTF8

$CiList = Get-Content -Path $InputTxt |
ForEach-Object { $_.Trim().Trim('"').Trim("'") } |
Where-Object { -not [string]::IsNullOrWhiteSpace($_) }

if (-not $CiList -or $CiList.Count -eq 0) {
    throw "No CI names found in TXT: $InputTxt"
}

# ==========================================================
# Get Trusted Cluster Names
# ==========================================================
Write-Host ""
Write-Host "Building cluster map..." -ForegroundColor Cyan

$ClusterJson = Invoke-HeliosJson -Uri "$BaseUrl/v2/mcm/cluster-mgmt/info" -Headers @{
    accept = "application/json"
    apiKey = $ApiKey
}

if (-not $ClusterJson -or -not $ClusterJson.cohesityClusters) {
    throw "No clusters returned from Helios."
}

$ClusterMap = @{}
$Clusters = @()

foreach ($c in @($ClusterJson.cohesityClusters)) {
    $cid = First-NonBlank -Values @($c.clusterId, $c.id, $c.intId, $c.clusterIdentifier.clusterId, $c.clusterInfo.clusterId)
    $cn  = First-NonBlank -Values @($c.clusterName, $c.name, $c.displayName)

    if ([string]::IsNullOrWhiteSpace($cid)) { continue }
    if ([string]::IsNullOrWhiteSpace($cn)) { $cn = "Unknown-$cid" }

    $Clusters += [pscustomobject]@{
        clusterId   = "$cid"
        clusterName = "$cn"
    }

    Add-ClusterMapEntry -Map $ClusterMap -Id $c.clusterId -ClusterName $cn
    Add-ClusterMapEntry -Map $ClusterMap -Id $c.id -ClusterName $cn
    Add-ClusterMapEntry -Map $ClusterMap -Id $c.intId -ClusterName $cn
    Add-ClusterMapEntry -Map $ClusterMap -Id $c.clusterIdentifier.clusterId -ClusterName $cn
    Add-ClusterMapEntry -Map $ClusterMap -Id $c.clusterInfo.clusterId -ClusterName $cn
}

if (-not $Clusters -or $Clusters.Count -eq 0) {
    throw "No usable cluster IDs found."
}

Write-Host "Clusters loaded      : $($Clusters.Count)" -ForegroundColor Green
Write-Host "Cluster map entries  : $($ClusterMap.Count)" -ForegroundColor Green

# ==========================================================
# Main Processing
# ==========================================================
$Results = @()
$DebugRows = New-Object System.Collections.ArrayList

foreach ($Ci in $CiList) {
    if ($ShowProgress) {
        Write-Host ""
        Write-Host "Processing: [$Ci]" -ForegroundColor Cyan
    }

    $CiRows = @()
    $SearchedClusterTermKeys = New-Object System.Collections.ArrayList
    $SearchTerms = @(Get-SearchTermsForCi -Ci $Ci)

    # ------------------------------------------------------
    # FAST STEP 1:
    # Global search to identify candidate clusterId only.
    # This is only a hint; failure here does not stop protected-object search.
    # ------------------------------------------------------
    $GlobalSearchCalls++

    $GlobalSearchUrl = "$BaseUrl/v2/data-protect/search/objects?searchString=$([uri]::EscapeDataString($Ci))&includeTenants=true&count=$GlobalSearchCount"

    $GlobalJson = Invoke-HeliosJson -Uri $GlobalSearchUrl -Headers @{
        accept = "application/json"
        apiKey = $ApiKey
    }

    $CandidateClusterIds = @(Get-CandidateClusterIdsFromGlobalSearch -Json $GlobalJson -ClusterMap $ClusterMap)

    $CandidateClusters = New-Object System.Collections.ArrayList
    $CandidateSeen = @{}

    foreach ($ClusterId in $CandidateClusterIds) {
        Add-CandidateCluster -List $CandidateClusters -Seen $CandidateSeen -ClusterId "$ClusterId" -ClusterName (Get-ClusterNameFromMap -ClusterId "$ClusterId" -ClusterMap $ClusterMap) -SearchMode "Fast"
    }

    if (-not $CandidateClusters -or $CandidateClusters.Count -eq 0) {
        $FallbackCiCount++

        foreach ($Clu in $Clusters) {
            Add-CandidateCluster -List $CandidateClusters -Seen $CandidateSeen -ClusterId "$($Clu.clusterId)" -ClusterName "$($Clu.clusterName)" -SearchMode "FallbackNoGlobalObject"
        }
    }

    # ------------------------------------------------------
    # FAST STEP 2:
    # Protected-object search on candidate clusters.
    # ------------------------------------------------------
    $CiRows += Search-ProtectedObjectsOnClusters -Ci $Ci -SearchTerms $SearchTerms -CandidateClusters @($CandidateClusters) -ClusterMap $ClusterMap -SearchedClusterTermKeys $SearchedClusterTermKeys -DebugRows $DebugRows

    # ------------------------------------------------------
    # FAST STEP 3:
    # If snapshot reports replicationSnapshotInfo.clusterId,
    # search that replicated cluster too.
    # ------------------------------------------------------
    if ($SearchReplicatedClusterToo) {
        $ReplicatedClusterIds = @(
            $CiRows |
            Where-Object {
                $_.BackupLocation -eq "Replicated" -and
                -not [string]::IsNullOrWhiteSpace($_.BackupClusterId) -and
                $_.BackupClusterId -ne "-" -and
                $ClusterMap.ContainsKey("$($_.BackupClusterId)")
            } |
            Select-Object -ExpandProperty BackupClusterId -Unique
        )

        $ReplicatedClustersToSearch = New-Object System.Collections.ArrayList
        $RepSeen = @{}

        foreach ($Rid in $ReplicatedClusterIds) {
            Add-CandidateCluster -List $ReplicatedClustersToSearch -Seen $RepSeen -ClusterId "$Rid" -ClusterName (Get-ClusterNameFromMap -ClusterId "$Rid" -ClusterMap $ClusterMap) -SearchMode "ReplicatedProbe"
        }

        if ($ReplicatedClustersToSearch.Count -gt 0) {
            $ReplicatedProbeCiCount++

            if ($ShowProgress) {
                Write-Host "  Replicated cluster probe: $($ReplicatedClustersToSearch.Count)" -ForegroundColor DarkGray
            }

            $CiRows += Search-ProtectedObjectsOnClusters -Ci $Ci -SearchTerms $SearchTerms -CandidateClusters @($ReplicatedClustersToSearch) -ClusterMap $ClusterMap -SearchedClusterTermKeys $SearchedClusterTermKeys -DebugRows $DebugRows
        }
    }

    # ------------------------------------------------------
    # FALLBACK STEP:
    # If FS or DB is still missing, search all clusters not already searched.
    # ------------------------------------------------------
    $NeedFallbackForMissingType = $FallbackWhenMissingFsOrDb -and (-not (Test-HasValidFs -Rows $CiRows) -or -not (Test-HasValidDb -Rows $CiRows))

    if ($NeedFallbackForMissingType) {
        $AllClusterFallback = New-Object System.Collections.ArrayList
        $FallbackSeen = @{}

        foreach ($Clu in $Clusters) {
            Add-CandidateCluster -List $AllClusterFallback -Seen $FallbackSeen -ClusterId "$($Clu.clusterId)" -ClusterName "$($Clu.clusterName)" -SearchMode "FallbackMissingFsOrDb"
        }

        if ($AllClusterFallback.Count -gt 0) {
            $FallbackCiCount++

            if ($ShowProgress) {
                Write-Host "  Fallback all-cluster protected search: $($AllClusterFallback.Count)" -ForegroundColor DarkGray
            }

            $CiRows += Search-ProtectedObjectsOnClusters -Ci $Ci -SearchTerms $SearchTerms -CandidateClusters @($AllClusterFallback) -ClusterMap $ClusterMap -SearchedClusterTermKeys $SearchedClusterTermKeys -DebugRows $DebugRows
        }
    }

    if (-not $CiRows -or $CiRows.Count -eq 0) {
        $Results += [pscustomobject]@{
            ServerName      = $Ci
            BackupType      = "Unknown"
            ObjectName      = "-"
            SourceName      = $Ci
            BackupLocation  = "-"
            BackupClusterId = "-"
            ClusterName     = "-"
            ProtectionGroup = "-"
            LastBackupTime  = "NoObject"
            LastBackupUsecs = 0
        }
        continue
    }

    # Keep latest row per CI + BackupType + ObjectName + SourceName + Cluster + PG + Location.
    $DedupedRows = $CiRows |
        Group-Object ServerName, BackupType, ObjectName, SourceName, BackupLocation, ClusterName, ProtectionGroup |
        ForEach-Object { $_.Group | Sort-Object LastBackupUsecs -Descending | Select-Object -First 1 }

    foreach ($Row in $DedupedRows) {
        $Results += [pscustomobject]@{
            ServerName      = $Row.ServerName
            BackupType      = $Row.BackupType
            ObjectName      = $Row.ObjectName
            SourceName      = $Row.SourceName
            BackupLocation  = $Row.BackupLocation
            BackupClusterId = $Row.BackupClusterId
            ClusterName     = $Row.ClusterName
            ProtectionGroup = $Row.ProtectionGroup
            LastBackupTime  = $Row.LastBackupTime
            LastBackupUsecs = $Row.LastBackupUsecs
        }
    }

    $HasDbBackup = Test-HasValidDb -Rows $DedupedRows
    $HasFS       = Test-HasValidFs -Rows $DedupedRows

    if ($HasDbBackup -and -not $HasFS) {
        $Results += [pscustomobject]@{
            ServerName      = $Ci
            BackupType      = "FS"
            ObjectName      = $Ci
            SourceName      = $Ci
            BackupLocation  = "-"
            BackupClusterId = "-"
            ClusterName     = "-"
            ProtectionGroup = "-"
            LastBackupTime  = "NoFSBackupFound"
            LastBackupUsecs = 0
        }
    }
}

# -------------------------
# Summary
# -------------------------
$TotalInputCIs = $CiList.Count
$TotalBackupRows = $Results.Count

$BackedUp = ($Results | Where-Object {
    $_.LastBackupTime -notin @("NoBackup", "NoBackupTime", "NoObject", "NoFSBackupFound", "NoDbBackupFound", "")
}).Count

$NoBackup = ($Results | Where-Object { $_.LastBackupTime -in @("NoBackup", "NoBackupTime") }).Count
$NoFSBackupFound = ($Results | Where-Object { $_.LastBackupTime -eq "NoFSBackupFound" }).Count
$NoObject = ($Results | Where-Object { $_.LastBackupTime -eq "NoObject" }).Count

$SortedResults = $Results |
    Sort-Object ServerName, @{ Expression = { Get-BackupTypeRank $_.BackupType } }, ObjectName, ClusterName, ProtectionGroup

$DetailsText = (
    $SortedResults |
    Format-Table ServerName, BackupType, ObjectName, SourceName, BackupLocation, ClusterName, ProtectionGroup, LastBackupTime -AutoSize |
    Out-String -Width 360
).TrimEnd()

# -------------------------
# Write CSV Outputs
# -------------------------
$SortedResults |
    Select-Object ServerName, BackupType, ObjectName, SourceName, BackupLocation, BackupClusterId, ClusterName, ProtectionGroup, LastBackupTime |
    Export-Csv -Path $OutputCsv -NoTypeInformation -Encoding UTF8

$DebugRows |
    Export-Csv -Path $DebugCsv -NoTypeInformation -Encoding UTF8

# -------------------------
# Build Report
# -------------------------
$Report = @()
$Report += "=========================================================="
$Report += "Cohesity Backup Validation Report"
$Report += "=========================================================="
$Report += "Change Number          : $ChangeID"
$Report += "Executed By            : $ExecutedBy"
$Report += "Run Date               : $(Get-Date -Format 'dd-MMM-yyyy HH:mm:ss')"
$Report += ""
$Report += "Total Input CIs        : $TotalInputCIs"
$Report += "Total Backup Rows      : $TotalBackupRows"
$Report += "Backed Up              : $BackedUp"
$Report += "No Backup              : $NoBackup"
$Report += "No FS Backup Found     : $NoFSBackupFound"
$Report += "No Object              : $NoObject"
$Report += ""
$Report += "Global Search Calls    : $GlobalSearchCalls"
$Report += "Protected Search Calls : $ProtectedSearchCalls"
$Report += "Replicated Probe CIs   : $ReplicatedProbeCiCount"
$Report += "Fallback CI Count      : $FallbackCiCount"
$Report += "Failed GETs            : $FailedGets"
$Report += ""
$Report += "----------------------------------------------------------"
$Report += "Details"
$Report += "----------------------------------------------------------"
$Report += ""
$Report += $DetailsText
$Report += ""
$Report += "----------------------------------------------------------"
$Report += "Summary Notes"
$Report += "----------------------------------------------------------"
$Report += "- FS backup          : Parent/root protected object latestSnapshotsInfo."
$Report += "- DB backup          : Protected object name SERVER/DB and/or childObjects latestSnapshotsInfo."
$Report += "- ObjectName         : Displays DB name for SQL/Oracle rows and server name for FS rows."
$Report += "- Search terms       : The protected search tries both ci_item and shortname(ci_item)."
$Report += "- Backed Up          : CI found with valid snapshot and backup time."
$Report += "- No Backup          : CI found in Cohesity but no usable snapshot time returned."
$Report += "- No Object          : CI not found in Cohesity protected-object search."
$Report += "- NoFSBackupFound    : SQL/Oracle backup found, but no matching FS backup found for the CI."
$Report += "- BackupLocation     : Replicated when latestSnapshotsInfo.replicationSnapshotInfo.clusterId exists; otherwise Local."
$Report += "- Replicated Probe   : If snapshot points to replicationSnapshotInfo.clusterId, that cluster is searched too."
$Report += "- Fallback           : If global search has no cluster, or FS/DB is missing, protected-object search scans all clusters."
$Report += ""
$Report += "----------------------------------------------------------"
$Report += "Report Location"
$Report += "----------------------------------------------------------"
$Report += "TXT : $OutputTxt"
$Report += "CSV : $OutputCsv"
$Report += "Debug CSV : $DebugCsv"
$Report += "=========================================================="

# -------------------------
# Write Report
# -------------------------
$Report | Set-Content -Path $OutputTxt -Encoding UTF8

