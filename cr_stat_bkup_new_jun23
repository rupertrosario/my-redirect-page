$report += "------------------------------------------------------------"
$report += $summaryText
$report += ""
$report += "------------------------------------------------------------"
$report += "Details"
$report += "------------------------------------------------------------"
$report += $detailsText
$report += ""
$report += "------------------------------------------------------------"
$report += "Files"
$report += "------------------------------------------------------------"
$report += "Input CSV                 : $InputCsv"
$report += "Input TXT                 : $InputTxt"
$report += "Final CSV                 : $CsvOutput"
$report += "Text Report               : $TxtOutput"

if ($ExportNormalizedRows) {
