# ==========================================================
# Snapshot Helpers for FS / Oracle fallback
# ==========================================================
function Get-SnapshotArray {
    param([object]$Obj)
    if (-not $Obj) { return @() }
    $snaps = @()
    $snaps += @(AsArray $Obj.latestSnapshotInfo)
    $snaps += @(AsArray $Obj.latestSnapshotsInfo)
    $snaps += @(AsArray $Obj.latestSnapshots)
    $snaps += @(AsArray $Obj.latestSnapshot)
    $snaps += @(AsArray $Obj.snapshotInfo)
    $snaps += @(AsArray $Obj.backupInfo)
    $snaps += @(AsArray $Obj.snapshots)
    return @($snaps | Where-Object { $_ })
}

function Get-SnapshotRunType {
    param([object]$Snap)
    return Get-FirstText @($Snap.localBackupInfo.runType,$Snap.localBackupInfo.backupRunType,$Snap.originalBackupInfo.runType,$Snap.originalBackupInfo.backupRunType,$Snap.runType,$Snap.backupRunType,$Snap.snapshotRunType)
}

function Get-SnapshotUsecs {
    param([object]$Snap)
    if (-not $Snap) { return 0 }
    foreach ($v in @($Snap.protectionRunEndTimeUsecs,$Snap.runEndTimeUsecs,$Snap.endTimeUsecs,$Snap.snapshotCreationTimeUsecs,$Snap.creationTimeUsecs,$Snap.protectionRunStartTimeUsecs,$Snap.runStartTimeUsecs,$Snap.startTimeUsecs,$Snap.localBackupInfo.endTimeUsecs,$Snap.localBackupInfo.startTimeUsecs)) {
        $n = To-Int64Safe $v
        if ($n -gt 0) { return $n }
    }
    return 0
}

function Get-BestSnapshot {
    param([object]$Obj, [string]$BackupType)

    $snaps = @(Get-SnapshotArray $Obj)
    if ($snaps.Count -eq 0) { return $null }

    if ($BackupType -in @("SQL","Oracle")) {
        $regular = @($snaps | Where-Object { Test-RegularRunType (Get-SnapshotRunType $_) })
        if ($regular.Count -gt 0) {
            return $regular | Sort-Object @{Expression={Get-SnapshotUsecs $_};Descending=$true} | Select-Object -First 1
        }
        return $null
    }

    $nonLog = @($snaps | Where-Object { (Get-SnapshotRunType $_) -notmatch '(?i)log|archive' })
    if ($nonLog.Count -eq 0) { return $null }
    return $nonLog | Sort-Object @{Expression={Get-SnapshotUsecs $_};Descending=$true} | Select-Object -First 1
}

function Get-ObjectNameFromProtectedObject {
    param([object]$Obj)
    $name = Get-FirstText @($Obj.name,$Obj.object.name,$Obj.objectName,$Obj.displayName,$Obj.hostName,$Obj.sourceName,$Obj.databaseName,$Obj.dbName,$Obj.dbUniqueName,$Obj.entity.name,$Obj.entity.displayName,$Obj.sourceInfo.name,$Obj.sourceInfo.displayName,$Obj.protectionSource.name,$Obj.protectionSource.displayName)
    if ([string]::IsNullOrWhiteSpace($name)) { return "-" }
    return $name
}

function Get-PgNameFromProtectedObject {
    param([object]$Obj, [object]$Snap, [string]$FallbackPgName)
    $name = Get-FirstText @($Snap.protectionGroupName,$Snap.protectionGroup.name,$Snap.protectionGroup.displayName,$Snap.protectionGroupInfo.name,$Obj.protectionGroupName,$Obj.protectionGroup.name,$Obj.protectionGroup.displayName,$Obj.protectionGroupInfo.name,$FallbackPgName)
    if ([string]::IsNullOrWhiteSpace($name)) { return "-" }
    return $name
}

# ==========================================================
# FS Module
# ==========================================================
function Get-FsRows {
    param([object]$Context, [string]$ServerName, [hashtable]$ClusterMap)

    $rows = @()
    if ([string]::IsNullOrWhiteSpace($ServerName)) { return @() }

    $candidates = Get-SearchCandidates -SearchTerm $ServerName -Environment "kPhysical" -ClusterMap $ClusterMap

    foreach ($candidate in $candidates) {
        if ([string]::IsNullOrWhiteSpace($candidate.ClusterId)) { continue }
        $clusterName = Get-ClusterNameFromMap -ClusterId $candidate.ClusterId -ClusterMap $ClusterMap
        $headers = @{ accept="application/json"; apiKey=$ApiKey; accessClusterId="$($candidate.ClusterId)" }

        $script:ProtectedSearchCalls++
        $url = New-SearchUrl -Endpoint "/v2/data-protect/search/protected-objects" -SearchTerm $ServerName -Environment "kPhysical"
        $json = Invoke-HeliosGetJson -Uri $url -Headers $headers -Quiet
        $objects = @(Get-ObjectArrayFromJson $json)

        foreach ($obj in $objects) {
            $objName = Get-ObjectNameFromProtectedObject $obj
            if (-not (Text-MatchesName -Text $objName -Name $ServerName)) { continue }

            $snap = Get-BestSnapshot -Obj $obj -BackupType "FS"
            $usecs = 0
            $timeText = "NoBackup"
            if ($snap) {
                $usecs = Get-SnapshotUsecs $snap
                $timeText = if ($usecs -gt 0) { Convert-UsecsToET $usecs } else { "NoBackupTime" }
            }

            $pgName = Get-PgNameFromProtectedObject -Obj $obj -Snap $snap -FallbackPgName $candidate.PgName

            $rows += [pscustomobject]@{
                InputCI         = $Context.InputCI
                BackupType      = "FS"
                ObjectName      = $ServerName
                SourceName      = $ServerName
                ClusterName     = $clusterName
                ProtectionGroup = $pgName
                LastBackupTime  = $timeText
                LastBackupUsecs = $usecs
                Source          = "FSProtectedObject"
            }
        }
    }

    return @($rows)
}

# ==========================================================
# SQL Module - DB Discovery from Any Recent Run + PG Success Time
# ==========================================================
function Test-SqlDbCandidate {
    param([string]$ObjectType, [string]$ObjectName, [string]$ObjectId, [string]$SourceId, [int]$FailedAttemptsCount)

    if ([string]::IsNullOrWhiteSpace($ObjectName)) { return $false }
    if ($ObjectType -in @("kDatabase","kSQLDB")) { return $true }
    if ($ObjectType -match "(?i)database|sqldb|sql.*db") { return $true }
    if ($ObjectType -eq "kSQL") {
        if (-not [string]::IsNullOrWhiteSpace($SourceId)) { return $true }
        if ($FailedAttemptsCount -gt 0) { return $true }
    }
    return $false
}

function Get-SqlObjectFields {
    param([object]$Obj)

    $objectName = Get-FirstText @($Obj.object.name,$Obj.object.displayName,$Obj.name,$Obj.displayName,$Obj.databaseName,$Obj.dbName,$Obj.dbUniqueName)
    $objectType = Get-FirstText @($Obj.object.objectType,$Obj.objectType,$Obj.type)
    $env = Get-FirstText @($Obj.object.environment,$Obj.environment)
    $objectId = Get-FirstText @($Obj.object.id,$Obj.object.uid,$Obj.id,$Obj.uid)
    $sourceId = Get-FirstText @($Obj.object.sourceId,$Obj.sourceId,$Obj.parentId,$Obj.parentObjectId)

    $failedAttemptsCount = 0
    try { $failedAttemptsCount = @(AsArray $Obj.localSnapshotInfo.failedAttempts).Count } catch { $failedAttemptsCount = 0 }

    return [pscustomobject]@{
        ObjectName          = $objectName
        ObjectType          = $objectType
        Environment         = $env
        ObjectId            = $objectId
        SourceId            = $sourceId
        FailedAttemptsCount = $failedAttemptsCount
    }
}

function Get-SqlHostMapFromRun {
    param([object]$Run)

    $hostMap = @{}
    foreach ($obj in @(AsArray $Run.objects)) {
        $f = Get-SqlObjectFields -Obj $obj

        if ($f.Environment -ne "kSQL") { continue }
        if ($f.ObjectType -in @("kDatabase","kSQLDB")) { continue }
        if ($f.ObjectType -eq "kSQL" -and (-not [string]::IsNullOrWhiteSpace($f.SourceId) -or $f.FailedAttemptsCount -gt 0)) { continue }

        if (-not [string]::IsNullOrWhiteSpace($f.ObjectId) -and -not [string]::IsNullOrWhiteSpace($f.ObjectName)) {
            $hostMap[$f.ObjectId] = $f.ObjectName
        }
    }

    return $hostMap
}

function Get-SqlDbRowsFromRun {
    param([object]$Run, [string]$RunStatus, [string]$RunType, [int64]$RunEndUsecs)

    $rows = @()
    $objects = @(AsArray $Run.objects)
    if ($objects.Count -eq 0) { return @() }

    $hostMap = Get-SqlHostMapFromRun -Run $Run

    foreach ($obj in $objects) {
        $f = Get-SqlObjectFields -Obj $obj
        $isDb = Test-SqlDbCandidate -ObjectType $f.ObjectType -ObjectName $f.ObjectName -ObjectId $f.ObjectId -SourceId $f.SourceId -FailedAttemptsCount $f.FailedAttemptsCount
        if (-not $isDb) { continue }

        $hostName = ""
        if (-not [string]::IsNullOrWhiteSpace($f.SourceId) -and $hostMap.ContainsKey($f.SourceId)) {
            $hostName = $hostMap[$f.SourceId]
        }

        $rows += [pscustomobject]@{
            DbName               = $f.ObjectName
            HostName             = $hostName
            ObjectType           = $f.ObjectType
            ObjectId             = $f.ObjectId
            SourceId             = $f.SourceId
            DiscoveryRunStatus   = $RunStatus
            DiscoveryRunType     = $RunType
            DiscoveryRunEndUsecs = $RunEndUsecs
            FailedAttemptsCount  = $f.FailedAttemptsCount
        }
    }

    return @($rows)
}

function Get-SqlRunEvidenceFromRecentRuns {
    param([string]$PgId, [hashtable]$Headers)

    $allDbRows = @()
    $latestSuccessUsecs = 0
    $latestSuccessRun = $null

    if ([string]::IsNullOrWhiteSpace($PgId)) {
        return [pscustomobject]@{ DbRows=@(); LatestSuccessRun=$null; LatestSuccessUsecs=0; LatestSuccessTime="NoBackup" }
    }

    $page = 0
    $cookie = ""

    do {
        $page++
        $uri = "$BaseUrl/v2/data-protect/protection-groups/$PgId/runs" +
               "?environments=kSQL" +
               "&numRuns=$NumRunsPerPg" +
               "&excludeNonRestorableRuns=false" +
               "&includeObjectDetails=true"

        if (-not [string]::IsNullOrWhiteSpace($cookie)) {
            $uri += "&paginationCookie=$([uri]::EscapeDataString($cookie))"
        }

        $script:PgRunCalls++
        $json = Invoke-HeliosGetJson -Uri $uri -Headers $Headers -Quiet
        if (-not $json -or -not $json.runs) { break }

        $runs = @(AsArray $json.runs | Where-Object { $_ }) | Sort-Object @{Expression={ To-Int64Safe (Get-RunEndUsecsFromRun $_) };Descending=$true}

        foreach ($run in $runs) {
            $status = Get-RunStatusFromRun $run
            $runType = Get-RunTypeFromRun $run
            $endUsecs = To-Int64Safe (Get-RunEndUsecsFromRun $run)
            if ($endUsecs -le 0) { continue }

            $dbRows = @(Get-SqlDbRowsFromRun -Run $run -RunStatus $status -RunType $runType -RunEndUsecs $endUsecs)
            if ($dbRows.Count -gt 0) { $allDbRows += $dbRows }

            if ((Test-SuccessStatus $status) -and (Test-RegularRunType $runType)) {
                $script:SqlSuccessfulRunsChecked++
                if ($endUsecs -gt $latestSuccessUsecs) {
                    $latestSuccessUsecs = $endUsecs
                    $latestSuccessRun = $run
                }
            }
        }

        $cookie = Get-FirstText @($json.paginationCookie)
        if ($json.isResponseTruncated -ne $true) { break }
    } while (-not [string]::IsNullOrWhiteSpace($cookie) -and $page -lt $MaxRunPagesPerPg)

    $deduped = @()
    foreach ($grp in ($allDbRows | Group-Object DbName, HostName)) {
        $deduped += ($grp.Group | Sort-Object @{Expression={ if ([string]::IsNullOrWhiteSpace($_.HostName)) { 0 } else { 1 } };Descending=$true}, @{Expression={[int64]$_.DiscoveryRunEndUsecs};Descending=$true} | Select-Object -First 1)
    }

    $successTime = "NoBackup"
    if ($latestSuccessUsecs -gt 0) { $successTime = Convert-UsecsToET $latestSuccessUsecs }

    return [pscustomobject]@{
        DbRows             = @($deduped)
        LatestSuccessRun   = $latestSuccessRun
        LatestSuccessUsecs = $latestSuccessUsecs
        LatestSuccessTime  = $successTime
    }
}

function Get-TargetedSqlRowsFromPg {
    param([object]$Context, [string]$SearchTerm, [object]$Candidate, [hashtable]$ClusterMap)

    $rows = @()
    if ([string]::IsNullOrWhiteSpace($Candidate.PgId)) { return @() }

    $clusterId = "$($Candidate.ClusterId)"
    $clusterName = Get-ClusterNameFromMap -ClusterId $clusterId -ClusterMap $ClusterMap
    if ($clusterName -eq $clusterId -and -not [string]::IsNullOrWhiteSpace($Candidate.ClusterName)) { $clusterName = "$($Candidate.ClusterName)" }

    $headers = @{ accept="application/json"; apiKey=$ApiKey; accessClusterId="$clusterId" }
    $script:TargetedSqlInspections++

    $evidence = Get-SqlRunEvidenceFromRecentRuns -PgId "$($Candidate.PgId)" -Headers $headers

    if (-not $evidence -or $evidence.LatestSuccessUsecs -le 0) {
        return @()
    }

    if (-not $evidence.DbRows -or @($evidence.DbRows).Count -eq 0) {
        $script:SqlDbListNotDiscovered++
        return @()
    }

    foreach ($db in @($evidence.DbRows)) {
        $dbName = $db.DbName
        $hostName = $db.HostName
        if ([string]::IsNullOrWhiteSpace($dbName)) { continue }

        if ($Context.IsDbAtServer) {
            if (-not (Text-MatchesName -Text $dbName -Name $Context.DbName)) { continue }
            if (-not [string]::IsNullOrWhiteSpace($hostName) -and -not (Text-MatchesName -Text $hostName -Name $Context.ServerName)) { continue }
        }
        else {
            $dbMatches = Text-MatchesName -Text $dbName -Name $Context.InputCI
            $hostMatches = Text-MatchesName -Text $hostName -Name $Context.InputCI
            # Server input: if host is blank, still include DBs from candidate PG.
            if (-not $dbMatches -and -not $hostMatches -and -not [string]::IsNullOrWhiteSpace($hostName)) { continue }
        }

        $rows += [pscustomobject]@{
            InputCI         = $Context.InputCI
            BackupType      = "SQL"
            ObjectName      = $dbName
            SourceName      = if ($hostName) { $hostName } else { $SearchTerm }
            ClusterName     = $clusterName
            ProtectionGroup = "$($Candidate.PgName)"
            LastBackupTime  = $evidence.LatestSuccessTime
            LastBackupUsecs = $evidence.LatestSuccessUsecs
            Source          = "SQLDbDiscoveredFromRecentRuns_PgSuccessTime"
        }
    }

    if ($rows.Count -gt 0) { $script:SqlDbObjectsFound += $rows.Count }
    return @($rows)
}

# ==========================================================
# Oracle Module
# ==========================================================
function Resolve-CohesityObjectName {
    param([string]$ObjectId, [hashtable]$Headers)
    if ([string]::IsNullOrWhiteSpace($ObjectId)) { return "" }
    $script:ObjectLookupCalls++
    $uri = "$BaseUrl/v2/data-protect/objects/$ObjectId"
    $json = Invoke-HeliosGetJson -Uri $uri -Headers $Headers -Quiet
    if (-not $json) { return "" }
    return Get-FirstText @($json.name,$json.displayName)
}

function Get-ProtectionGroupDetails {
    param([string]$PgId, [string]$Environment, [hashtable]$Headers)
    if ([string]::IsNullOrWhiteSpace($PgId)) { return $null }

    $uris = @(
        "$BaseUrl/v2/data-protect/protection-groups/$PgId",
        "$BaseUrl/v2/data-protect/protection-groups?ids=$([uri]::EscapeDataString($PgId))&environments=$([uri]::EscapeDataString($Environment))&includeLastRunInfo=true"
    )

    foreach ($uri in $uris) {
        $script:PgDetailCalls++
        $json = Invoke-HeliosGetJson -Uri $uri -Headers $Headers -Quiet
        if (-not $json) { continue }
        if ($json.protectionGroups) {
            $pg = @(AsArray $json.protectionGroups | Where-Object { $_ }) | Select-Object -First 1
            if ($pg) { return $pg }
        }
        if ($json.id -or $json.name -or $json.oracleParams) { return $json }
    }

    return $null
}

function Get-LatestOracleRegularRunInfo {
    param([string]$PgId, [hashtable]$Headers)

    if ([string]::IsNullOrWhiteSpace($PgId)) { return [pscustomobject]@{ EndUsecs=0; EndTime="NoBackup" } }

    $page = 0
    $cookie = ""
    $bestUsecs = 0

    do {
        $page++
        $uri = "$BaseUrl/v2/data-protect/protection-groups/$PgId/runs?numRuns=$NumRunsPerPg&excludeNonRestorableRuns=false"
        if (-not [string]::IsNullOrWhiteSpace($cookie)) { $uri += "&paginationCookie=$([uri]::EscapeDataString($cookie))" }

        $script:PgRunCalls++
        $json = Invoke-HeliosGetJson -Uri $uri -Headers $Headers -Quiet
        if (-not $json -or -not $json.runs) { break }

        foreach ($run in (AsArray $json.runs)) {
            $status = Get-RunStatusFromRun $run
            $runType = Get-RunTypeFromRun $run
            $endUsecs = To-Int64Safe (Get-RunEndUsecsFromRun $run)
            if ($endUsecs -le 0) { continue }
            if (-not (Test-SuccessStatus $status)) { continue }
            if (-not (Test-RegularRunType $runType)) { continue }
            if ($endUsecs -gt $bestUsecs) { $bestUsecs = $endUsecs }
        }

        $cookie = Get-FirstText @($json.paginationCookie)
        if ($json.isResponseTruncated -ne $true) { break }
    } while (-not [string]::IsNullOrWhiteSpace($cookie) -and $page -lt $MaxRunPagesPerPg)

    if ($bestUsecs -gt 0) { return [pscustomobject]@{ EndUsecs=$bestUsecs; EndTime=(Convert-UsecsToET $bestUsecs) } }
    return [pscustomobject]@{ EndUsecs=0; EndTime="NoBackup" }
}

function Get-OracleHostNamesFromChannel {
    param([object]$Channel, [hashtable]$Headers)

    $names = New-Object System.Collections.ArrayList
    $hostIds = @()
    $hostIds += @(AsArray $Channel.databaseNodeList.hostId)
    $hostIds += @(AsArray $Channel.databaseNodeList.id)

    foreach ($hostId in ($hostIds | Where-Object { $_ -and "$($_)".Trim() -ne "" } | Select-Object -Unique)) {
        $hostName = Resolve-CohesityObjectName -ObjectId "$hostId" -Headers $Headers
        Add-UniqueText -List $names -Value $hostName
    }

    return @($names)
}

function Add-OracleRowIfMatched {
    param(
        [System.Collections.ArrayList]$Rows,
        [object]$Context,
        [string]$DbName,
        [object[]]$HostNames,
        [string]$ClusterName,
        [string]$PgName,
        [string]$LastBackupTime,
        [int64]$LastBackupUsecs
    )

    if ([string]::IsNullOrWhiteSpace($DbName)) { return }

    $hostText = (($HostNames | Where-Object { $_ -and "$($_)".Trim() -ne "" } | Select-Object -Unique) -join ";")

    if ($Context.IsDbAtServer) {
        if (-not (Text-MatchesName -Text $DbName -Name $Context.DbName)) { return }
        if (-not [string]::IsNullOrWhiteSpace($hostText) -and -not (Text-MatchesName -Text $hostText -Name $Context.ServerName)) { return }
    }
    else {
        $dbMatches = Text-MatchesName -Text $DbName -Name $Context.InputCI
        $hostMatches = $false
        foreach ($h in @($HostNames)) {
            if (Text-MatchesName -Text "$h" -Name $Context.InputCI) { $hostMatches = $true; break }
        }
        if (-not $dbMatches -and -not $hostMatches) { return }
    }

    [void]$Rows.Add([pscustomobject]@{
        InputCI         = $Context.InputCI
        BackupType      = "Oracle"
        ObjectName      = $DbName
        SourceName      = $hostText
        ClusterName     = $ClusterName
        ProtectionGroup = $PgName
        LastBackupTime  = if ($LastBackupTime) { $LastBackupTime } else { "NoBackup" }
        LastBackupUsecs = $LastBackupUsecs
        Source          = "OracleTargetedPgDetails"
    })
}

function Get-TargetedOracleRowsFromPg {
    param([object]$Context, [string]$SearchTerm, [object]$Candidate, [hashtable]$ClusterMap)

    $rows = New-Object System.Collections.ArrayList
    if ([string]::IsNullOrWhiteSpace($Candidate.PgId)) { return @() }

    $clusterId = "$($Candidate.ClusterId)"
    $clusterName = Get-ClusterNameFromMap -ClusterId $clusterId -ClusterMap $ClusterMap
    if ($clusterName -eq $clusterId -and -not [string]::IsNullOrWhiteSpace($Candidate.ClusterName)) { $clusterName = "$($Candidate.ClusterName)" }

    $headers = @{ accept="application/json"; apiKey=$ApiKey; accessClusterId="$clusterId" }
    $script:TargetedOraInspections++

    $runInfo = Get-LatestOracleRegularRunInfo -PgId "$($Candidate.PgId)" -Headers $headers
    $pg = Get-ProtectionGroupDetails -PgId "$($Candidate.PgId)" -Environment "kOracle" -Headers $headers
    if (-not $pg -or -not $pg.oracleParams) { return @() }

    $pgName = Get-FirstText @($pg.name,$Candidate.PgName)
    if ([string]::IsNullOrWhiteSpace($pgName)) { $pgName = "$($Candidate.PgName)" }

    foreach ($obj in (AsArray $pg.oracleParams.objects)) {
        $baseHostNames = New-Object System.Collections.ArrayList
        Add-UniqueText -List $baseHostNames -Value (Get-FirstText @($obj.sourceName,$obj.SourceName,$obj.hostName,$obj.HostName))

        $dbParams = @(AsArray $obj.dbParams)
        if ($dbParams.Count -eq 0) {
            $dbName = Get-FirstText @($obj.databaseName,$obj.databaseUniqueName,$obj.dbUniqueName,$obj.name)
            Add-OracleRowIfMatched -Rows $rows -Context $Context -DbName $dbName -HostNames @($baseHostNames) -ClusterName $clusterName -PgName $pgName -LastBackupTime "$($runInfo.EndTime)" -LastBackupUsecs ([int64]$runInfo.EndUsecs)
            continue
        }

        foreach ($dbParam in $dbParams) {
            $paramHostNames = New-Object System.Collections.ArrayList
            foreach ($h in @($baseHostNames)) { Add-UniqueText -List $paramHostNames -Value $h }
            Add-UniqueText -List $paramHostNames -Value (Get-FirstText @($dbParam.sourceName,$dbParam.SourceName,$dbParam.hostName,$dbParam.HostName))

            $channels = @()
            if ($dbParam.dbChannels.dbChannel) { $channels += @(AsArray $dbParam.dbChannels.dbChannel) }
            elseif ($dbParam.dbChannels) { $channels += @(AsArray $dbParam.dbChannels) }

            if ($channels.Count -eq 0) {
                $dbName = Get-FirstText @($dbParam.databaseName,$dbParam.databaseUniqueName,$obj.databaseUniqueName,$obj.dbUniqueName,$obj.name)
                Add-OracleRowIfMatched -Rows $rows -Context $Context -DbName $dbName -HostNames @($paramHostNames) -ClusterName $clusterName -PgName $pgName -LastBackupTime "$($runInfo.EndTime)" -LastBackupUsecs ([int64]$runInfo.EndUsecs)
                continue
            }

            foreach ($channel in $channels) {
                $channelHostNames = New-Object System.Collections.ArrayList
                foreach ($h in @($paramHostNames)) { Add-UniqueText -List $channelHostNames -Value $h }
                foreach ($resolvedHost in (Get-OracleHostNamesFromChannel -Channel $channel -Headers $headers)) { Add-UniqueText -List $channelHostNames -Value $resolvedHost }

                $dbName = Get-FirstText @($channel.databaseUniqueName,$channel.databaseName,$dbParam.databaseUniqueName,$dbParam.databaseName,$obj.databaseUniqueName,$obj.dbUniqueName,$obj.name)
                Add-OracleRowIfMatched -Rows $rows -Context $Context -DbName $dbName -HostNames @($channelHostNames) -ClusterName $clusterName -PgName $pgName -LastBackupTime "$($runInfo.EndTime)" -LastBackupUsecs ([int64]$runInfo.EndUsecs)
            }
        }
    }

    return @($rows)
}

# ==========================================================
# Row Selection
# ==========================================================
function Select-BestRows {
    param([object[]]$Rows)

    $out = @()
    foreach ($grp in ($Rows | Group-Object InputCI, BackupType, ObjectName, SourceName)) {
        $g = @($grp.Group)
        $valid = @($g | Where-Object { Is-ValidBackupTime $_.LastBackupTime })
        if ($valid.Count -gt 0) {
            $out += ($valid | Sort-Object @{Expression={[int64]$_.LastBackupUsecs};Descending=$true}, ClusterName, ProtectionGroup | Select-Object -First 1)
        }
        else {
            $out += ($g | Sort-Object ClusterName, ProtectionGroup | Select-Object -First 1)
        }
    }
    return @($out)
}

function New-MissingRow {
    param([string]$InputCI, [string]$BackupType, [string]$ObjectName, [string]$SourceName, [string]$Message)
    return [pscustomobject]@{
        InputCI         = $InputCI
        BackupType      = $BackupType
        ObjectName      = $ObjectName
        SourceName      = $SourceName
        ClusterName     = "-"
        ProtectionGroup = "-"
        LastBackupTime  = $Message
        LastBackupUsecs = 0
        Source          = "MissingRow"
    }
}

# ==========================================================
# Load Input CIs
# ==========================================================
$CiNames = Import-Csv -Path $InputCsv |
    ForEach-Object { "$($_.ci_item)".Trim().Trim('"').Trim("'") } |
    Where-Object { -not [string]::IsNullOrWhiteSpace($_) } |
    Sort-Object -Unique

if (-not $CiNames -or $CiNames.Count -eq 0) {
    throw "No ci_item values found in $InputCsv"
}

$CiNames | Set-Content -Path $InputTxt -Encoding UTF8
$CiList = Get-Content -Path $InputTxt | ForEach-Object { "$($_)".Trim().Trim('"').Trim("'") } | Where-Object { -not [string]::IsNullOrWhiteSpace($_) }

# ==========================================================
# Build Cluster Map
# ==========================================================
Write-Host "Building cluster map..." -ForegroundColor Cyan
$clusterJson = Invoke-HeliosGetJson -Uri "$BaseUrl/v2/mcm/cluster-mgmt/info" -Headers $CommonHeaders
if (-not $clusterJson -or -not $clusterJson.cohesityClusters) { throw "No clusters returned from Helios." }

$Clusters = @($clusterJson.cohesityClusters)
$ClusterMap = @{}
foreach ($c in $Clusters) {
    $cname = Get-FirstText @($c.clusterName,$c.name,$c.displayName)
    if ([string]::IsNullOrWhiteSpace($cname)) { $cname = "Unknown-$($c.clusterId)" }
    Add-ClusterMapEntry -Map $ClusterMap -Id $c.clusterId -Name $cname
    Add-ClusterMapEntry -Map $ClusterMap -Id $c.id -Name $cname
    Add-ClusterMapEntry -Map $ClusterMap -Id $c.intId -Name $cname
    Add-ClusterMapEntry -Map $ClusterMap -Id $c.clusterIdentifier.clusterId -Name $cname
    Add-ClusterMapEntry -Map $ClusterMap -Id $c.clusterInfo.clusterId -Name $cname
}

# ==========================================================
# Main Processing
# ==========================================================
$Results = @()
$DebugRows = @()

foreach ($ci in $CiList) {
    $context = Get-CiContext $ci
    Write-Host "Processing: $($context.InputCI)" -ForegroundColor Cyan

    $ciRows = @()
    $dbHostNames = New-Object System.Collections.ArrayList

    if ($context.IsDbAtServer) {
        $fsSearchTerm = $context.ServerName
        $oraSearchTerm = $context.DbName
    }
    else {
        $fsSearchTerm = $context.InputCI
        $oraSearchTerm = $context.InputCI
    }

    # FS validation
    $fsRows = @(Get-FsRows -Context $context -ServerName $fsSearchTerm -ClusterMap $ClusterMap)
    $ciRows += $fsRows
    $DebugRows += $fsRows

    # SQL targeted validation
    $sqlCandidatesAll = @()
    $sqlTerms = @(Get-SearchTermsForSql -Context $context)

    foreach ($sqlTerm in $sqlTerms) {
        $sqlCandidatesAll += @(Get-SearchCandidates -SearchTerm $sqlTerm -Environment "kSQL" -ClusterMap $ClusterMap)
    }

    $sqlCandidates = @(Get-UniqueCandidates -Candidates $sqlCandidatesAll)

    if ($sqlCandidates.Count -eq 0) {
        Write-Host "  SQL object search found no PG. Trying active SQL PG list fallback..." -ForegroundColor Yellow
        $sqlCandidates = @(Get-SqlCandidatesFromActivePgList -Context $context -SearchTerms $sqlTerms -ClusterMap $ClusterMap)
    }

    if ($sqlCandidates.Count -gt 0) {
        Write-Host "  SQL PG candidates found: $($sqlCandidates.Count)" -ForegroundColor Green
    }
    else {
        Write-Host "  No SQL PG candidate found for $($context.InputCI)" -ForegroundColor DarkYellow
    }

    foreach ($candidate in $sqlCandidates) {
        if ($EnableTargetedSqlPgRunInspection -and -not [string]::IsNullOrWhiteSpace($candidate.PgId)) {
            $sqlRows = @(Get-TargetedSqlRowsFromPg -Context $context -SearchTerm $context.InputCI -Candidate $candidate -ClusterMap $ClusterMap)
            foreach ($r in $sqlRows) {
                $ciRows += $r
                $DebugRows += $r
                if (-not [string]::IsNullOrWhiteSpace($r.SourceName) -and (Is-ValidBackupTime $r.LastBackupTime)) {
                    foreach ($h in ($r.SourceName -split ";")) { Add-UniqueText -List $dbHostNames -Value $h }
                }
            }
        }
    }

    # Oracle targeted validation
    $oraCandidates = @(Get-SearchCandidates -SearchTerm $oraSearchTerm -Environment "kOracle" -ClusterMap $ClusterMap)

    foreach ($candidate in $oraCandidates) {
        if ($EnableTargetedOraclePgInspection -and -not [string]::IsNullOrWhiteSpace($candidate.PgId)) {
            $oraRows = @(Get-TargetedOracleRowsFromPg -Context $context -SearchTerm $oraSearchTerm -Candidate $candidate -ClusterMap $ClusterMap)
            foreach ($r in $oraRows) {
                $ciRows += $r
                $DebugRows += $r
                if (-not [string]::IsNullOrWhiteSpace($r.SourceName)) {
                    foreach ($h in ($r.SourceName -split ";")) { Add-UniqueText -List $dbHostNames -Value $h }
                }
            }
        }
    }

    # DB-name-only host -> FS check
    if (-not $context.IsDbAtServer -and $dbHostNames.Count -gt 0) {
        $hasFsAlready = @($ciRows | Where-Object { $_.BackupType -eq "FS" -and (Is-ValidBackupTime $_.LastBackupTime) }).Count -gt 0
        if (-not $hasFsAlready) {
            foreach ($hostName in @($dbHostNames)) {
                $hostFsRows = @(Get-FsRows -Context $context -ServerName $hostName -ClusterMap $ClusterMap)
                $ciRows += $hostFsRows
                $DebugRows += $hostFsRows
            }
        }
    }

    if (-not $ciRows -or $ciRows.Count -eq 0) {
        $Results += New-MissingRow -InputCI $context.InputCI -BackupType "DB" -ObjectName "-" -SourceName $context.InputCI -Message "NoDbBackupFound"
        $Results += New-MissingRow -InputCI $context.InputCI -BackupType "FS" -ObjectName $fsSearchTerm -SourceName $fsSearchTerm -Message "NoFSBackupFound"
        continue
    }

    $selected = @(Select-BestRows -Rows $ciRows)

    foreach ($r in $selected) {
        $Results += [pscustomobject]@{
            InputCI         = $r.InputCI
            BackupType      = $r.BackupType
            ObjectName      = $r.ObjectName
            SourceName      = $r.SourceName
            ClusterName     = $r.ClusterName
            ProtectionGroup = $r.ProtectionGroup
            LastBackupTime  = $r.LastBackupTime
            LastBackupUsecs = $r.LastBackupUsecs
            Source          = $r.Source
        }
    }

    # Add consolidated NoDbBackupFound if neither SQL nor Oracle valid backup was found.
    $hasDbBackup = @($selected | Where-Object { $_.BackupType -in @("SQL","Oracle") -and (Is-ValidBackupTime $_.LastBackupTime) }).Count -gt 0
    if (-not $hasDbBackup) {
        $Results += New-MissingRow -InputCI $context.InputCI -BackupType "DB" -ObjectName "-" -SourceName $context.InputCI -Message "NoDbBackupFound"
    }

    # Add NoFSBackupFound when DB found but FS not found.
    $hasFsBackup = @($selected | Where-Object { $_.BackupType -eq "FS" -and (Is-ValidBackupTime $_.LastBackupTime) }).Count -gt 0
    if ($hasDbBackup -and -not $hasFsBackup) {
        $fsObject = if ($context.IsDbAtServer) { $context.ServerName } elseif ($dbHostNames.Count -gt 0) { (@($dbHostNames) -join ";") } else { $fsSearchTerm }
        $Results += New-MissingRow -InputCI $context.InputCI -BackupType "FS" -ObjectName $fsObject -SourceName $fsObject -Message "NoFSBackupFound"
    }
}

# ==========================================================
# Final Sorting / Summary
# ==========================================================
$SortedResults = $Results |
    Sort-Object InputCI, @{Expression={ Get-BackupTypeRank $_.BackupType }}, ObjectName, ClusterName, ProtectionGroup

$TotalInputCIs   = $CiList.Count
$TotalBackupRows = @($SortedResults).Count
$BackedUp = @($SortedResults | Where-Object { Is-ValidBackupTime $_.LastBackupTime }).Count
$NoObject = @($SortedResults | Where-Object { $_.LastBackupTime -eq "NoObject" }).Count
$NoBackup = @($SortedResults | Where-Object { $_.LastBackupTime -in @("NoBackup","NoBackupTime","NoDbDetailFound","DbListNotDiscovered","DbListFoundButNoInputMatch","NoSqlPgCandidateFound","NoDbBackupFound") }).Count
$NoFSBackupFound = @($SortedResults | Where-Object { $_.LastBackupTime -eq "NoFSBackupFound" }).Count
$NoDbBackupFound = @($SortedResults | Where-Object { $_.LastBackupTime -eq "NoDbBackupFound" }).Count

# ==========================================================
# Export CSV
# ==========================================================
$SortedResults |
    Select-Object InputCI, BackupType, ObjectName, SourceName, ClusterName, ProtectionGroup, LastBackupTime |
    Export-Csv -Path $OutputCsv -NoTypeInformation -Encoding UTF8

if ($ExportDebugCsv) {
    $DebugRows |
        Select-Object InputCI, BackupType, ObjectName, SourceName, ClusterName, ProtectionGroup, LastBackupTime, LastBackupUsecs, Source |
        Export-Csv -Path $DebugCsv -NoTypeInformation -Encoding UTF8
}

