export default async function ({ execution_id }, iterationInput) {

  const item = iterationInput;

  return {

    query:
      `correlation_id=${encodeURIComponent(item.correlation_id)}`,

    short_description:
      item.short_description,

    fingerprint:
      item.fingerprint,

    comparison_key:
      String(item.fingerprint || "")
        .trim()
        .toLowerCase(),

    description:
      item.description,

    correlation_id:
      item.correlation_id

  };

}
