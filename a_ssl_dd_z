# Prompt for credentials
$cred = Get-Credential

# Convert secure password to plain text for API
$plainPassword = [Runtime.InteropServices.Marshal]::PtrToStringAuto(
    [Runtime.InteropServices.Marshal]::SecureStringToBSTR($cred.Password)
)

# Build body
$body = @{
    username = $cred.UserName
    password = $plainPassword
} | ConvertTo-Json

# SSL bypass (PS 5.1)
[System.Net.ServicePointManager]::ServerCertificateValidationCallback = { $true }

$dd = "https://<dd-ip>:3009"

# Auth call
$login = Invoke-WebRequest -Uri "$dd/rest/v1.0/auth" -Method POST -Body $body -ContentType "application/json"

# Extract token
$token = $login.Headers["X-DD-AUTH-TOKEN"]

# GET system info
Invoke-RestMethod -Uri "$dd/rest/v1.0/system" -Headers @{ "X-DD-AUTH-TOKEN" = $token }
