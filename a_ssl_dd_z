# ------------------------------------------------------------
# Data Domain - Login with service account and get users
# PowerShell 5.1
# ------------------------------------------------------------

# DD URL
$dd = "https://<dd-ip>:3009"

# Prompt for service account credentials
$cred = Get-Credential

# TEMP ONLY:
# If DD cert is self-signed and not trusted yet, uncomment next line.
# Remove it later after importing the DD cert properly.
#[System.Net.ServicePointManager]::ServerCertificateValidationCallback = { $true }

try {
    # Convert secure password to plain text only for auth body
    $bstr = [Runtime.InteropServices.Marshal]::SecureStringToBSTR($cred.Password)
    $plainPassword = [Runtime.InteropServices.Marshal]::PtrToStringAuto($bstr)

    # Build login body
    $body = @{
        username = $cred.UserName
        password = $plainPassword
    } | ConvertTo-Json

    # Step 1 - Login and get token
    $login = Invoke-WebRequest -Uri "$dd/rest/v1.0/auth" `
                               -Method POST `
                               -Body $body `
                               -ContentType "application/json"

    $token = $login.Headers["X-DD-AUTH-TOKEN"]

    if (-not $token) {
        throw "Authentication token was not returned."
    }

    # Clear plaintext password immediately
    $plainPassword = $null
    $body = $null
    [Runtime.InteropServices.Marshal]::ZeroFreeBSTR($bstr)

    # Common headers for next calls
    $headers = @{
        "X-DD-AUTH-TOKEN" = $token
        "Accept"          = "application/json"
    }

    # Step 2 - Get system info
    $sys = Invoke-RestMethod -Uri "$dd/rest/v1.0/system" `
                             -Method GET `
                             -Headers $headers

    $systemId = $sys.id
    if (-not $systemId) {
        throw "System ID not found in /system response."
    }

    # Encode system ID because it may contain :
    $encodedSystemId = [System.Uri]::EscapeDataString($systemId)

    # Step 3 - Get users
    $resp = Invoke-RestMethod -Uri "$dd/rest/v1.0/dd-systems/$encodedSystemId/users" `
                              -Method GET `
                              -Headers $headers

    # Step 4 - Show only required fields
    $users = $resp.users | Select-Object `
        @{n='Id';   e={$_.id}},
        @{n='Name'; e={$_.name}},
        @{n='Role'; e={$_.role}}

    $users | Format-Table -AutoSize
}
catch {
    Write-Host "Request failed: $($_.Exception.Message)" -ForegroundColor Red

    if ($_.Exception.Response) {
        try {
            $reader = New-Object System.IO.StreamReader($_.Exception.Response.GetResponseStream())
            $respBody = $reader.ReadToEnd()
            if ($respBody) {
                Write-Host "Response Body:`n$respBody" -ForegroundColor Yellow
            }
        } catch {}
    }
}
finally {
    $plainPassword = $null
    $body = $null
}
