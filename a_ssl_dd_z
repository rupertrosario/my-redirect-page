# ------------------------------------------------------------
# Data Domain - Get Users (Id, Name, Role only)
# PowerShell 5.1
# ------------------------------------------------------------

# Prompt for credentials
$cred = Get-Credential

# Ignore self-signed cert
[System.Net.ServicePointManager]::ServerCertificateValidationCallback = { $true }

# DD base URL
$dd = "https://<dd-ip>:3009"

try {
    # Convert secure password to plain text only for auth
    $bstr = [Runtime.InteropServices.Marshal]::SecureStringToBSTR($cred.Password)
    $plainPassword = [Runtime.InteropServices.Marshal]::PtrToStringAuto($bstr)

    # Build auth body
    $body = @{
        username = $cred.UserName
        password = $plainPassword
    } | ConvertTo-Json

    # Login and get token
    $login = Invoke-WebRequest -Uri "$dd/rest/v1.0/auth" `
                               -Method POST `
                               -Body $body `
                               -ContentType "application/json"

    $token = $login.Headers["X-DD-AUTH-TOKEN"]

    if (-not $token) {
        throw "Authentication token not returned."
    }

    # Clear plaintext password after login
    $plainPassword = $null
    $body = $null
    [Runtime.InteropServices.Marshal]::ZeroFreeBSTR($bstr)

    $headers = @{
        "X-DD-AUTH-TOKEN" = $token
        "Accept"          = "application/json"
    }

    # Get system info
    $sys = Invoke-RestMethod -Uri "$dd/rest/v1.0/system" `
                             -Method GET `
                             -Headers $headers

    $systemId = $sys.id
    if (-not $systemId) {
        throw "System ID was not found in /system response."
    }

    # Encode systemId because it contains special chars like :
    $encodedSystemId = [System.Uri]::EscapeDataString($systemId)

    # Get users response
    $resp = Invoke-RestMethod -Uri "$dd/rest/v1.0/dd-systems/$encodedSystemId/users" `
                              -Method GET `
                              -Headers $headers

    # Keep only users array, and only id / name / role
    $users = $resp.users | Select-Object `
        @{n='Id';   e={$_.id}},
        @{n='Name'; e={$_.name}},
        @{n='Role'; e={$_.role}}

    # Display
    $users | Format-Table -AutoSize

}
catch {
    Write-Host "Request failed: $($_.Exception.Message)" -ForegroundColor Red

    if ($_.Exception.Response) {
        try {
            $reader = New-Object System.IO.StreamReader($_.Exception.Response.GetResponseStream())
            $respBody = $reader.ReadToEnd()
            if ($respBody) {
                Write-Host "Response Body:`n$respBody" -ForegroundColor Yellow
            }
        } catch {}
    }
}
finally {
    $plainPassword = $null
    $body = $null
}
