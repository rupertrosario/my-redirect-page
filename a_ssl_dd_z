[System.Net.ServicePointManager]::ServerCertificateValidationCallback = { $true }
$dd   = "https://<dd-ip>:3009"
$body = @{ username = "sysadmin"; password = "<password>" } | ConvertTo-Json

$login = Invoke-WebRequest -Uri "$dd/rest/v1.0/auth" -Method POST -Body $body -ContentType "application/json"
$token = $login.Headers["X-DD-AUTH-TOKEN"]

Invoke-RestMethod -Uri "$dd/rest/v1.0/system" -Method GET -Headers @{ "X-DD-AUTH-TOKEN" = $token }
