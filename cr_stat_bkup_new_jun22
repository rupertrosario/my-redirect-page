# ==========================================================
# FS Module
# ==========================================================
function Get-FsRows {
    param(
        [object]$Context,
        [string]$ServerName,
        [hashtable]$ClusterMap
    )

    $rows = @()

    if ([string]::IsNullOrWhiteSpace($ServerName)) {
        return @()
    }

    $candidates = Get-SearchCandidates `
        -SearchTerm $ServerName `
        -Environment "kPhysical" `
        -ClusterMap $ClusterMap

    foreach ($candidate in $candidates) {
        if ([string]::IsNullOrWhiteSpace($candidate.ClusterId)) {
            continue
        }

        $clusterName = Get-ClusterNameFromMap -ClusterId $candidate.ClusterId -ClusterMap $ClusterMap

        $headers = @{
            accept          = "application/json"
            apiKey          = $ApiKey
            accessClusterId = "$($candidate.ClusterId)"
        }

        $script:ProtectedSearchCalls++

        $url = New-SearchUrl `
            -Endpoint "/v2/data-protect/search/protected-objects" `
            -SearchTerm $ServerName `
            -Environment "kPhysical"

        $json = Invoke-HeliosGetJson -Uri $url -Headers $headers -Quiet
        $objects = @(Get-ObjectArrayFromJson $json)

        foreach ($obj in $objects) {
            $objName = Get-ObjectNameFromProtectedObject $obj

            if (-not (Text-MatchesName -Text $objName -Name $ServerName)) {
                continue
            }

            $snap = Get-BestSnapshot -Obj $obj -BackupType "FS"

            $usecs = 0
            $timeText = "NoBackup"

            if ($snap) {
                $usecs = Get-SnapshotUsecs $snap
                $timeText = if ($usecs -gt 0) { Convert-UsecsToET $usecs } else { "NoBackupTime" }
            }

            $pgName = Get-PgNameFromProtectedObject -Obj $obj -Snap $snap -FallbackPgName $candidate.PgName

            $rows += [pscustomobject]@{
                InputCI         = $Context.InputCI
                BackupType      = "FS"
                ObjectName      = $ServerName
                ClusterName     = $clusterName
                ProtectionGroup = $pgName
                LastBackupTime  = $timeText
                LastBackupUsecs = $usecs
                HostName        = $ServerName
                Source          = "FSProtectedObject"
            }
        }
    }

    return @($rows)
}

# ==========================================================
# SQL Module
# Uses:
# - Direct run.objects host/db/sourceId mapping from your SQL failure script.
# - Deep recursive scan if direct objects do not expose DBs.
# - Returns NoDbDetailFound instead of host-level SQL fallback.
# ==========================================================
function Find-SqlObjectsDeep {
    param(
        [object]$Node,
        [int]$Depth = 0
    )

    $found = @()

    if ($null -eq $Node) {
        return @()
    }

    if ($Depth -gt 8) {
        return @()
    }

    foreach ($item in (AsArray $Node)) {

        if ($null -eq $item) {
            continue
        }

        if ($item -isnot [pscustomobject]) {
            continue
        }

        $objType = Get-FirstText @(
            $item.object.objectType,
            $item.objectType,
            $item.type
        )

        $env = Get-FirstText @(
            $item.object.environment,
            $item.environment
        )

        $objName = Get-FirstText @(
            $item.object.name,
            $item.object.displayName,
            $item.name,
            $item.displayName,
            $item.databaseName,
            $item.dbName,
            $item.dbUniqueName
        )

        $objId = Get-FirstText @(
            $item.object.id,
            $item.object.uid,
            $item.id,
            $item.uid
        )

        $sourceId = Get-FirstText @(
            $item.object.sourceId,
            $item.sourceId,
            $item.parentId,
            $item.parentObjectId
        )

        if (-not [string]::IsNullOrWhiteSpace($objType) -or
            -not [string]::IsNullOrWhiteSpace($env) -or
            -not [string]::IsNullOrWhiteSpace($objName)) {

            $found += [pscustomobject]@{
                RawObject    = $item
                ObjectName   = $objName
                ObjectType   = $objType
                Environment  = $env
                ObjectId     = $objId
                SourceId     = $sourceId
            }
        }

        foreach ($prop in $item.PSObject.Properties) {
            if ($prop.Value -is [pscustomobject] -or $prop.Value -is [array]) {
                $found += @(Find-SqlObjectsDeep -Node $prop.Value -Depth ($Depth + 1))
            }
        }
    }

    return @($found)
}

function Test-SqlDbObject {
    param(
        [string]$ObjectType,
        [string]$ObjectName
    )

    if ([string]::IsNullOrWhiteSpace($ObjectType) -and [string]::IsNullOrWhiteSpace($ObjectName)) {
        return $false
    }

    if ($ObjectType -in @("kDatabase", "kSQLDB")) {
        return $true
    }

    if ($ObjectType -match "(?i)database|sqldb|sql.*db") {
        return $true
    }

    # kSQL can be a host/server object in some responses.
    # Do not treat kSQL alone as DB unless name looks DB-like.
    if ($ObjectType -eq "kSQL" -and $ObjectName -match "(?i)db|database") {
        return $true
    }

    return $false
}

function Get-TargetedSqlRowsFromPg {
    param(
        [object]$Context,
        [string]$SearchTerm,
        [object]$Candidate,
        [hashtable]$ClusterMap
    )

    $rows = @()

    if ([string]::IsNullOrWhiteSpace($Candidate.PgId)) {
        return @()
    }

    $clusterId = "$($Candidate.ClusterId)"
    $clusterName = Get-ClusterNameFromMap -ClusterId $clusterId -ClusterMap $ClusterMap

    if ($clusterName -eq $clusterId -and -not [string]::IsNullOrWhiteSpace($Candidate.ClusterName)) {
        $clusterName = "$($Candidate.ClusterName)"
    }

    $headers = @{
        accept          = "application/json"
        apiKey          = $ApiKey
        accessClusterId = "$clusterId"
    }

    $script:TargetedSqlInspections++

    $latestRun = Get-LatestRegularRun `
        -PgId "$($Candidate.PgId)" `
        -Headers $headers `
        -IncludeObjectDetails

    if (-not $latestRun) {
        return @(
            [pscustomobject]@{
                InputCI         = $Context.InputCI
                BackupType      = "SQL"
                ObjectName      = $SearchTerm
                ClusterName     = $clusterName
                ProtectionGroup = "$($Candidate.PgName)"
                LastBackupTime  = "NoBackup"
                LastBackupUsecs = 0
                HostName        = ""
                Source          = "SQLNoRegularRun"
            }
        )
    }

    $runEndUsecs = To-Int64Safe (Get-RunEndUsecsFromRun $latestRun)
    $runEndTime  = if ($runEndUsecs -gt 0) { Convert-UsecsToET $runEndUsecs } else { "NoBackupTime" }

    # -------------------------
    # Method 1: direct run.objects, same base mapping as your SQL failure script.
    # -------------------------
    $objects = @(AsArray $latestRun.objects)

    $hosts = @($objects | Where-Object {
        $_.object.environment -eq "kSQL" -and
        $_.object.objectType -notin @("kDatabase", "kSQLDB")
    })

    $dbs = @($objects | Where-Object {
        $otype = Get-FirstText @($_.object.objectType, $_.objectType)
        $oname = Get-FirstText @($_.object.name, $_.object.displayName, $_.name)
        Test-SqlDbObject -ObjectType $otype -ObjectName $oname
    })

    foreach ($db in $dbs) {

        $dbName = Get-FirstText @(
            $db.object.name,
            $db.object.displayName,
            $db.object.databaseName,
            $db.object.dbName,
            $db.object.dbUniqueName,
            $db.name
        )

        $sourceId = Get-FirstText @(
            $db.object.sourceId,
            $db.sourceId
        )

        if ([string]::IsNullOrWhiteSpace($dbName)) {
            continue
        }

        $parentHost = $hosts | Where-Object {
            "$($_.object.id)" -eq "$sourceId"
        } | Select-Object -First 1

        $hostName = ""

        if ($parentHost) {
            $hostName = Get-FirstText @(
                $parentHost.object.name,
                $parentHost.object.displayName,
                $parentHost.name
            )
        }

        if ($Context.IsDbAtServer) {
            if (-not (Text-MatchesName -Text $dbName -Name $Context.DbName)) {
                continue
            }
        }
        else {
            $dbMatches   = Text-MatchesName -Text $dbName -Name $Context.InputCI
            $hostMatches = Text-MatchesName -Text $hostName -Name $Context.InputCI

            if (-not $dbMatches -and -not $hostMatches) {
                continue
            }
        }

        $rows += [pscustomobject]@{
            InputCI         = $Context.InputCI
            BackupType      = "SQL"
            ObjectName      = $dbName
            ClusterName     = $clusterName
            ProtectionGroup = "$($Candidate.PgName)"
            LastBackupTime  = $runEndTime
            LastBackupUsecs = $runEndUsecs
            HostName        = $hostName
            Source          = "SQLDirectRunObject"
        }
    }

    if ($rows.Count -gt 0) {
        $script:SqlDbObjectsFound += $rows.Count
        return @($rows)
    }

    # -------------------------
    # Method 2: deep recursive scan.
    # -------------------------
    $deepObjects = @(Find-SqlObjectsDeep -Node $latestRun)

    $deepHosts = @($deepObjects | Where-Object {
        $_.Environment -eq "kSQL" -and
        -not (Test-SqlDbObject -ObjectType $_.ObjectType -ObjectName $_.ObjectName)
    })

    $deepDbs = @($deepObjects | Where-Object {
        Test-SqlDbObject -ObjectType $_.ObjectType -ObjectName $_.ObjectName
    })

    foreach ($db in $deepDbs) {

        $dbName = $db.ObjectName

        if ([string]::IsNullOrWhiteSpace($dbName)) {
            continue
        }

        $parentHost = $deepHosts | Where-Object {
            -not [string]::IsNullOrWhiteSpace($_.ObjectId) -and
            "$($_.ObjectId)" -eq "$($db.SourceId)"
        } | Select-Object -First 1

        $hostName = ""

        if ($parentHost) {
            $hostName = $parentHost.ObjectName
        }

        if ($Context.IsDbAtServer) {
            if (-not (Text-MatchesName -Text $dbName -Name $Context.DbName)) {
                continue
            }
        }
        else {
            $dbMatches   = Text-MatchesName -Text $dbName -Name $Context.InputCI
            $hostMatches = Text-MatchesName -Text $hostName -Name $Context.InputCI

            if (-not $dbMatches -and -not $hostMatches) {
                continue
            }
        }

        $rows += [pscustomobject]@{
            InputCI         = $Context.InputCI
            BackupType      = "SQL"
            ObjectName      = $dbName
            ClusterName     = $clusterName
            ProtectionGroup = "$($Candidate.PgName)"
            LastBackupTime  = $runEndTime
            LastBackupUsecs = $runEndUsecs
            HostName        = $hostName
            Source          = "SQLDeepRunObject"
        }
    }

    if ($rows.Count -gt 0) {
        $script:SqlDbObjectsFound += $rows.Count
        return @($rows)
    }

    # -------------------------
    # Important correction:
    # Do NOT pretend server-level SQL object is DB-level backup.
    # -------------------------
    $script:SqlNoDbDetailFound++

    return @(
        [pscustomobject]@{
            InputCI         = $Context.InputCI
            BackupType      = "SQL"
            ObjectName      = $SearchTerm
            ClusterName     = $clusterName
            ProtectionGroup = "$($Candidate.PgName)"
            LastBackupTime  = "NoDbDetailFound"
            LastBackupUsecs = $runEndUsecs
            HostName        = $SearchTerm
            Source          = "SQLHostOnlyNoDbExpansion"
        }
    )
}

# ==========================================================
# Oracle Module
# Uses targeted oracleParams/dbParams/dbChannels logic.
# ==========================================================
function Resolve-CohesityObjectName {
    param(
        [string]$ObjectId,
        [hashtable]$Headers
    )

    if ([string]::IsNullOrWhiteSpace($ObjectId)) {
        return ""
    }

    $script:ObjectLookupCalls++

    $uri = "$BaseUrl/v2/data-protect/objects/$ObjectId"
    $json = Invoke-HeliosGetJson -Uri $uri -Headers $Headers -Quiet

    if (-not $json) {
        return ""
    }

    return Get-FirstText @($json.name, $json.displayName)
}

function Get-ProtectionGroupDetails {
    param(
        [string]$PgId,
        [string]$Environment,
        [hashtable]$Headers
    )

    if ([string]::IsNullOrWhiteSpace($PgId)) {
        return $null
    }

    $uris = @(
        "$BaseUrl/v2/data-protect/protection-groups/$PgId",
        "$BaseUrl/v2/data-protect/protection-groups?ids=$([uri]::EscapeDataString($PgId))&environments=$([uri]::EscapeDataString($Environment))&includeLastRunInfo=true"
    )

    foreach ($uri in $uris) {
        $script:PgDetailCalls++

        $json = Invoke-HeliosGetJson -Uri $uri -Headers $Headers -Quiet

        if (-not $json) {
            continue
        }

        if ($json.protectionGroups) {
            $pg = @(AsArray $json.protectionGroups | Where-Object { $_ }) | Select-Object -First 1

            if ($pg) {
                return $pg
            }
        }

        if ($json.id -or $json.name -or $json.oracleParams) {
            return $json
        }
    }

    return $null
}

function Get-OracleHostNamesFromChannel {
    param(
        [object]$Channel,
        [hashtable]$Headers
    )

    $names = New-Object System.Collections.ArrayList

    $hostIds = @()
    $hostIds += @(AsArray $Channel.databaseNodeList.hostId)
    $hostIds += @(AsArray $Channel.databaseNodeList.id)

    foreach ($hostId in ($hostIds | Where-Object { $_ -and "$_".Trim() -ne "" } | Select-Object -Unique)) {
        $hostName = Resolve-CohesityObjectName -ObjectId "$hostId" -Headers $Headers
        Add-UniqueText -List $names -Value $hostName
    }

    return @($names)
}

function Add-OracleRowIfMatched {
    param(
        [System.Collections.ArrayList]$Rows,
        [object]$Context,
        [string]$DbName,
        [object[]]$HostNames,
        [string]$ClusterName,
        [string]$PgName,
        [string]$LastBackupTime,
        [int64]$LastBackupUsecs
    )

    if ([string]::IsNullOrWhiteSpace($DbName)) {
        return
    }

    $hostText = (($HostNames | Where-Object { $_ -and "$_".Trim() -ne "" } | Select-Object -Unique) -join ";")

    if ($Context.IsDbAtServer) {
        if (-not (Text-MatchesName -Text $DbName -Name $Context.DbName)) {
            return
        }
    }
    else {
        $dbMatches = Text-MatchesName -Text $DbName -Name $Context.InputCI

        $hostMatches = $false

        foreach ($h in @($HostNames)) {
            if (Text-MatchesName -Text "$h" -Name $Context.InputCI) {
                $hostMatches = $true
                break
            }
        }

        if (-not $dbMatches -and -not $hostMatches) {
            return
        }
    }

    [void]$Rows.Add([pscustomobject]@{
        InputCI         = $Context.InputCI
        BackupType      = "Oracle"
        ObjectName      = $DbName
        ClusterName     = $ClusterName
        ProtectionGroup = $PgName
        LastBackupTime  = if ($LastBackupTime) { $LastBackupTime } else { "NoBackup" }
        LastBackupUsecs = $LastBackupUsecs
        HostName        = $hostText
        Source          = "OracleTargetedPgDetails"
    })
}

function Get-TargetedOracleRowsFromPg {
    param(
        [object]$Context,
        [string]$SearchTerm,
        [object]$Candidate,
        [hashtable]$ClusterMap
    )

    $rows = New-Object System.Collections.ArrayList

    if ([string]::IsNullOrWhiteSpace($Candidate.PgId)) {
        return @()
    }

    $clusterId = "$($Candidate.ClusterId)"
    $clusterName = Get-ClusterNameFromMap -ClusterId $clusterId -ClusterMap $ClusterMap

    if ($clusterName -eq $clusterId -and -not [string]::IsNullOrWhiteSpace($Candidate.ClusterName)) {
        $clusterName = "$($Candidate.ClusterName)"
    }

    $headers = @{
        accept          = "application/json"
        apiKey          = $ApiKey
        accessClusterId = "$clusterId"
    }

    $script:TargetedOraInspections++

    $latestRun = Get-LatestRegularRun `
        -PgId "$($Candidate.PgId)" `
        -Headers $headers

    $lastUsecs = 0
    $lastTime = "NoBackup"

    if ($latestRun) {
        $lastUsecs = To-Int64Safe (Get-RunEndUsecsFromRun $latestRun)

        if ($lastUsecs -gt 0) {
            $lastTime = Convert-UsecsToET $lastUsecs
        }
    }

    $pg = Get-ProtectionGroupDetails `
        -PgId "$($Candidate.PgId)" `
        -Environment "kOracle" `
        -Headers $headers

    if (-not $pg -or -not $pg.oracleParams) {
        return @()
    }

    $pgName = Get-FirstText @($pg.name, $Candidate.PgName)

    if ([string]::IsNullOrWhiteSpace($pgName)) {
        $pgName = "$($Candidate.PgName)"
    }

    foreach ($obj in (AsArray $pg.oracleParams.objects)) {

        $baseHostNames = New-Object System.Collections.ArrayList

        Add-UniqueText -List $baseHostNames -Value (Get-FirstText @(
            $obj.sourceName,
            $obj.SourceName,
            $obj.hostName,
            $obj.HostName
        ))

        $dbParams = @(AsArray $obj.dbParams)

        if ($dbParams.Count -eq 0) {
            $dbName = Get-FirstText @(
                $obj.databaseName,
                $obj.databaseUniqueName,
                $obj.dbUniqueName,
                $obj.name
            )

            Add-OracleRowIfMatched `
                -Rows $rows `
                -Context $Context `
                -DbName $dbName `
                -HostNames @($baseHostNames) `
                -ClusterName $clusterName `
                -PgName $pgName `
                -LastBackupTime $lastTime `
                -LastBackupUsecs $lastUsecs

            continue
        }

        foreach ($dbParam in $dbParams) {

            $paramHostNames = New-Object System.Collections.ArrayList

            foreach ($h in @($baseHostNames)) {
                Add-UniqueText -List $paramHostNames -Value $h
            }

            Add-UniqueText -List $paramHostNames -Value (Get-FirstText @(
                $dbParam.sourceName,
                $dbParam.SourceName,
                $dbParam.hostName,
                $dbParam.HostName
            ))

            $channels = @()

            if ($dbParam.dbChannels.dbChannel) {
                $channels += @(AsArray $dbParam.dbChannels.dbChannel)
            }
            elseif ($dbParam.dbChannels) {
                $channels += @(AsArray $dbParam.dbChannels)
            }

            if ($channels.Count -eq 0) {
                $dbName = Get-FirstText @(
                    $dbParam.databaseName,
                    $dbParam.databaseUniqueName,
                    $obj.databaseUniqueName,
                    $obj.dbUniqueName,
                    $obj.name
                )

                Add-OracleRowIfMatched `
                    -Rows $rows `
                    -Context $Context `
                    -DbName $dbName `
                    -HostNames @($paramHostNames) `
                    -ClusterName $clusterName `
                    -PgName $pgName `
                    -LastBackupTime $lastTime `
                    -LastBackupUsecs $lastUsecs

                continue
            }

            foreach ($channel in $channels) {

                $channelHostNames = New-Object System.Collections.ArrayList

                foreach ($h in @($paramHostNames)) {
                    Add-UniqueText -List $channelHostNames -Value $h
                }

                foreach ($resolvedHost in (Get-OracleHostNamesFromChannel -Channel $channel -Headers $headers)) {
                    Add-UniqueText -List $channelHostNames -Value $resolvedHost
                }

                $dbName = Get-FirstText @(
                    $channel.databaseUniqueName,
                    $channel.databaseName,
                    $dbParam.databaseUniqueName,
                    $dbParam.databaseName,
                    $obj.databaseUniqueName,
                    $obj.dbUniqueName,
                    $obj.name
                )

                Add-OracleRowIfMatched `
                    -Rows $rows `
                    -Context $Context `
                    -DbName $dbName `
                    -HostNames @($channelHostNames) `
                    -ClusterName $clusterName `
                    -PgName $pgName `
                    -LastBackupTime $lastTime `
                    -LastBackupUsecs $lastUsecs
            }
        }
    }

    return @($rows)
}

# ==========================================================
# DB Fallback for Oracle only
# SQL fallback is intentionally disabled after targeted inspection
# because it can produce misleading server-name rows.
# ==========================================================
function Get-OracleFallbackRowsFromProtectedObjects {
    param(
        [object]$Context,
        [string]$SearchTerm,
        [object[]]$Candidates,
        [hashtable]$ClusterMap
    )

    $rows = @()

    foreach ($candidate in ($Candidates | Where-Object { -not [string]::IsNullOrWhiteSpace($_.ClusterId) })) {
        $clusterId = "$($candidate.ClusterId)"
        $clusterName = Get-ClusterNameFromMap -ClusterId $clusterId -ClusterMap $ClusterMap

        $headers = @{
            accept          = "application/json"
            apiKey          = $ApiKey
            accessClusterId = "$clusterId"
        }

        $script:ProtectedSearchCalls++

        $url = New-SearchUrl `
            -Endpoint "/v2/data-protect/search/protected-objects" `
            -SearchTerm $SearchTerm `
            -Environment "kOracle"

        $json = Invoke-HeliosGetJson -Uri $url -Headers $headers -Quiet
        $objects = @(Get-ObjectArrayFromJson $json)

        foreach ($obj in $objects) {
            $objName = Get-ObjectNameFromProtectedObject $obj

            if ($Context.IsDbAtServer) {
                if (-not (Text-MatchesName -Text $objName -Name $Context.DbName)) {
                    continue
                }

                $objName = $Context.DbName
            }
            else {
                $objMatches = Text-MatchesName -Text $objName -Name $Context.InputCI
                $pgMatches = Text-MatchesName -Text "$($candidate.PgName)" -Name $Context.InputCI

                if (-not $objMatches -and -not $pgMatches) {
                    continue
                }
            }

            $snap = Get-BestSnapshot -Obj $obj -BackupType "Oracle"

            $usecs = 0
            $timeText = "NoBackup"

            if ($snap) {
                $usecs = Get-SnapshotUsecs $snap
                $timeText = if ($usecs -gt 0) { Convert-UsecsToET $usecs } else { "NoBackupTime" }
            }

            $pgName = Get-PgNameFromProtectedObject -Obj $obj -Snap $snap -FallbackPgName "$($candidate.PgName)"

            $rows += [pscustomobject]@{
                InputCI         = $Context.InputCI
                BackupType      = "Oracle"
                ObjectName      = $objName
                ClusterName     = $clusterName
                ProtectionGroup = $pgName
                LastBackupTime  = $timeText
                LastBackupUsecs = $usecs
                HostName        = ""
                Source          = "OracleProtectedObjectFallback"
            }
        }
    }

    return @($rows)
}

# ==========================================================
# Row Selection
# ==========================================================
function Select-BestRows {
    param([object[]]$Rows)

    $out = @()

    foreach ($grp in ($Rows | Group-Object InputCI, BackupType, ObjectName)) {
        $g = @($grp.Group)

        $valid = @($g | Where-Object { Is-ValidBackupTime $_.LastBackupTime })

        if ($valid.Count -gt 0) {
            $out += (
                $valid |
                Sort-Object `
                    @{ Expression = { [int64]$_.LastBackupUsecs }; Descending = $true },
                    ClusterName,
                    ProtectionGroup |
                Select-Object -First 1
            )
        }
        else {
            $out += (
                $g |
                Sort-Object ClusterName, ProtectionGroup |
                Select-Object -First 1
            )
        }
    }

    return @($out)
}

