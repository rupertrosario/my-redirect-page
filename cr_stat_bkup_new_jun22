$clusterJson = Invoke-HeliosGetJson -Uri "$BaseUrl/v2/mcm/cluster-mgmt/info" -Headers $CommonHeaders

if (-not $clusterJson -or -not $clusterJson.cohesityClusters) {
    throw "No clusters returned from Helios."
}

$Clusters = @($clusterJson.cohesityClusters)
$ClusterMap = @{}

foreach ($c in $Clusters) {
    $cname = Get-FirstText @($c.clusterName, $c.name, $c.displayName)

    if ([string]::IsNullOrWhiteSpace($cname)) {
        $cname = "Unknown-$($c.clusterId)"
    }

    Add-ClusterMapEntry -Map $ClusterMap -Id $c.clusterId -Name $cname
    Add-ClusterMapEntry -Map $ClusterMap -Id $c.id -Name $cname
    Add-ClusterMapEntry -Map $ClusterMap -Id $c.intId -Name $cname
    Add-ClusterMapEntry -Map $ClusterMap -Id $c.clusterIdentifier.clusterId -Name $cname
    Add-ClusterMapEntry -Map $ClusterMap -Id $c.clusterInfo.clusterId -Name $cname
}

# ==========================================================
# Main Processing
# ==========================================================
$Results = @()

foreach ($ci in $CiList) {
    $context = Get-CiContext $ci
    Write-Host "Processing: $($context.InputCI)" -ForegroundColor Cyan

    $ciRows = @()
    $dbHostNames = New-Object System.Collections.ArrayList

    if ($context.IsDbAtServer) {
        $dbSearchTerm = $context.DbName
        $fsSearchTerm = $context.ServerName
    }
    else {
        $dbSearchTerm = $context.InputCI
        $fsSearchTerm = $context.InputCI
    }

    # -------------------------
    # FS validation
    # -------------------------
    $fsRows = @(Get-FsRows -Context $context -ServerName $fsSearchTerm -ClusterMap $ClusterMap)
    $ciRows += $fsRows

    # -------------------------
    # SQL targeted validation
    # -------------------------
    $sqlCandidates = @(Get-SearchCandidates -SearchTerm $dbSearchTerm -Environment "kSQL" -ClusterMap $ClusterMap)

    foreach ($candidate in $sqlCandidates) {
        if ($EnableTargetedSqlPgRunInspection -and -not [string]::IsNullOrWhiteSpace($candidate.PgId)) {
            $sqlRows = @(Get-TargetedSqlRowsFromPg `
                -Context $context `
                -SearchTerm $dbSearchTerm `
                -Candidate $candidate `
                -ClusterMap $ClusterMap)

            foreach ($r in $sqlRows) {
                $ciRows += $r

                if (-not [string]::IsNullOrWhiteSpace($r.HostName) -and
                    $r.LastBackupTime -ne "NoDbDetailFound") {
                    foreach ($h in ($r.HostName -split ";")) {
                        Add-UniqueText -List $dbHostNames -Value $h
                    }
                }
            }
        }
    }

    # Important:
    # SQL protected-object fallback is intentionally NOT used here.
    # It was causing SQL host/server rows to look like DB-level validation.

    # -------------------------
    # Oracle targeted validation
    # -------------------------
    $oraCandidates = @(Get-SearchCandidates -SearchTerm $dbSearchTerm -Environment "kOracle" -ClusterMap $ClusterMap)

    foreach ($candidate in $oraCandidates) {
        if ($EnableTargetedOraclePgInspection -and -not [string]::IsNullOrWhiteSpace($candidate.PgId)) {
            $oraRows = @(Get-TargetedOracleRowsFromPg `
                -Context $context `
                -SearchTerm $dbSearchTerm `
                -Candidate $candidate `
                -ClusterMap $ClusterMap)

            foreach ($r in $oraRows) {
                $ciRows += $r

                if (-not [string]::IsNullOrWhiteSpace($r.HostName)) {
                    foreach ($h in ($r.HostName -split ";")) {
                        Add-UniqueText -List $dbHostNames -Value $h
                    }
                }
            }
        }
    }

    # Oracle fallback is still allowed because oracle protected object may be actual DB.
    $hasOraRows = @($ciRows | Where-Object { $_.BackupType -eq "Oracle" }).Count -gt 0

    if (-not $hasOraRows -and $oraCandidates.Count -gt 0) {
        $ciRows += @(Get-OracleFallbackRowsFromProtectedObjects `
            -Context $context `
            -SearchTerm $dbSearchTerm `
            -Candidates $oraCandidates `
            -ClusterMap $ClusterMap)
    }

    # -------------------------
    # DB-name-only host -> FS check
    # If DB was found and host was extracted, try FS for host once.
    # -------------------------
    if (-not $context.IsDbAtServer -and $dbHostNames.Count -gt 0) {
        $hasFsAlready = @($ciRows | Where-Object {
            $_.BackupType -eq "FS" -and
            (Is-ValidBackupTime $_.LastBackupTime)
        }).Count -gt 0

        if (-not $hasFsAlready) {
            foreach ($hostName in @($dbHostNames)) {
                $hostFsRows = @(Get-FsRows -Context $context -ServerName $hostName -ClusterMap $ClusterMap)
                $ciRows += $hostFsRows
            }
        }
    }

    # -------------------------
    # No result
    # -------------------------
    if (-not $ciRows -or $ciRows.Count -eq 0) {
        $Results += [pscustomobject]@{
            InputCI         = $context.InputCI
            BackupType      = "Unknown"
            ObjectName      = "-"
            ClusterName     = "-"
            ProtectionGroup = "-"
            LastBackupTime  = "NoObject"
        }

        continue
    }

    # -------------------------
    # Select best rows
    # -------------------------
    $selected = @(Select-BestRows -Rows $ciRows)

    foreach ($r in $selected) {
        $Results += [pscustomobject]@{
            InputCI         = $r.InputCI
            BackupType      = $r.BackupType
            ObjectName      = $r.ObjectName
            ClusterName     = $r.ClusterName
            ProtectionGroup = $r.ProtectionGroup
            LastBackupTime  = $r.LastBackupTime
        }
    }

    # -------------------------
    # Add NoFSBackupFound when DB found but FS not found
    # -------------------------
    $hasDbBackup = @($selected | Where-Object {
        $_.BackupType -in @("SQL", "Oracle") -and
        (Is-ValidBackupTime $_.LastBackupTime)
    }).Count -gt 0

    $hasFsBackup = @($selected | Where-Object {
        $_.BackupType -eq "FS" -and
        (Is-ValidBackupTime $_.LastBackupTime)
    }).Count -gt 0

    if ($hasDbBackup -and -not $hasFsBackup) {
        $fsObject = "-"

        if ($context.IsDbAtServer) {
            $fsObject = $context.ServerName
        }
        elseif ($dbHostNames.Count -gt 0) {
            $fsObject = (@($dbHostNames) -join ";")
        }

        $Results += [pscustomobject]@{
            InputCI         = $context.InputCI
            BackupType      = "FS"
            ObjectName      = $fsObject
            ClusterName     = "-"
            ProtectionGroup = "-"
            LastBackupTime  = "NoFSBackupFound"
        }
    }
}

# ==========================================================
# Final Sorting / Summary
# ==========================================================
$SortedResults = $Results |
    Sort-Object `
        InputCI,
        @{ Expression = { Get-BackupTypeRank $_.BackupType } },
        ObjectName,
        ClusterName,
        ProtectionGroup

$TotalInputCIs = $CiList.Count
$TotalBackupRows = $SortedResults.Count

$BackedUp = @($SortedResults | Where-Object {
    Is-ValidBackupTime $_.LastBackupTime
}).Count

$NoObject = @($SortedResults | Where-Object {
    $_.LastBackupTime -eq "NoObject"
}).Count

$NoBackup = @($SortedResults | Where-Object {
    $_.LastBackupTime -in @("NoBackup", "NoBackupTime", "NoDbDetailFound")
}).Count

$NoFSBackupFound = @($SortedResults | Where-Object {
    $_.LastBackupTime -eq "NoFSBackupFound"
}).Count

# ==========================================================
# Export CSV
# ==========================================================
$SortedResults |
    Select-Object InputCI, BackupType, ObjectName, ClusterName, ProtectionGroup, LastBackupTime |
    Export-Csv -Path $OutputCsv -NoTypeInformation -Encoding UTF8

# ==========================================================
# TXT Report
# ==========================================================
$DetailsText = (
    $SortedResults |
    Select-Object InputCI, BackupType, ObjectName, ClusterName, ProtectionGroup, LastBackupTime |
    Format-Table -AutoSize -Wrap |
    Out-String -Width 300
).TrimEnd()

$Report = @()
$Report += "=========================================================="
$Report += "Cohesity Backup Validation Report"
$Report += "=========================================================="
$Report += "Change Number              : $ChangeID"
$Report += "Executed By                : $ExecutedBy"
