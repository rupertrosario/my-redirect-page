$Report += "Total Backup Rows          : $TotalBackupRows"
$Report += "Backed Up                  : $BackedUp"
$Report += "No Backup                  : $NoBackup"
$Report += "No FS Backup Found         : $NoFSBackupFound"
$Report += "No Object                  : $NoObject"
$Report += ""
$Report += "Global Search Calls        : $script:GlobalSearchCalls"
$Report += "Protected Search Calls     : $script:ProtectedSearchCalls"
$Report += "Targeted SQL Inspections   : $script:TargetedSqlInspections"
$Report += "Targeted Oracle Inspections: $script:TargetedOraInspections"
$Report += "SQL DB Objects Found       : $script:SqlDbObjectsFound"
$Report += "SQL No DB Detail Found     : $script:SqlNoDbDetailFound"
$Report += "PG Run Calls               : $script:PgRunCalls"
$Report += "PG Detail Calls            : $script:PgDetailCalls"
$Report += "Object Lookup Calls        : $script:ObjectLookupCalls"
$Report += "Failed GETs                : $script:FailedGets"
$Report += ""
$Report += "----------------------------------------------------------"
$Report += "Details"
$Report += "----------------------------------------------------------"
$Report += ""
$Report += $DetailsText
$Report += ""
$Report += "----------------------------------------------------------"
$Report += "Validation Scope / Limitations"
$Report += "----------------------------------------------------------"
$Report += "- This is a best-effort Cohesity backup validation report."
$Report += "- The script performs targeted searches based on the CI values provided."
$Report += "- It does not perform a full SQL or Oracle database inventory across all clusters."
$Report += "- It does not enumerate every database inside every SQL or Oracle Protection Group."
$Report += "- SQL DB details are shown only when the targeted SQL PG successful run exposes DB objects."
$Report += "- If the latest successful SQL run exposes only the SQL server/source object, the report shows NoDbDetailFound."
$Report += "- The script intentionally does not treat SQL server/source object as DB-level evidence."
$Report += "- Oracle DB details are shown only when targeted Oracle PG configuration exposes oracleParams/dbParams/dbChannels."
$Report += "- For DBNAME@SERVERNAME input, the script checks the specified DB name and the specified server name only."
$Report += "- For server-only input, DB rows are shown only if targeted search exposes DB-to-host details."
$Report += "- VIPs, cluster names, listeners, aliases, and floating names may not resolve unless they are directly searchable in Cohesity."
$Report += "- No all-cluster fallback is enabled in this version to avoid long execution time."
$Report += "- If expected DBs or server backups are missing, search manually in Cohesity using DB name, server name, PG name, VIP, and cluster node names."
$Report += ""
$Report += "----------------------------------------------------------"
$Report += "Report Locations"
$Report += "----------------------------------------------------------"
$Report += "Input CSV                 : $InputCsv"
$Report += "Input TXT                 : $InputTxt"
$Report += "TXT Report                : $OutputTxt"
$Report += "Final CSV                 : $OutputCsv"
$Report += "=========================================================="

$Report | Set-Content -Path $OutputTxt -Encoding UTF8

