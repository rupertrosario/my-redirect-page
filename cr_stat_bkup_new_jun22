$InputCsv  = Join-Path $BaseDir "$ChangeID.csv"
$InputTxt  = Join-Path $BaseDir "$ChangeID.txt"
$TimeStamp = Get-Date -Format "yyyyMMdd_HHmm"

$OutputTxt = Join-Path $BaseDir "${ChangeID}_BackupReport_$TimeStamp.txt"
$OutputCsv = Join-Path $BaseDir "${ChangeID}_BackupReport_$TimeStamp.csv"

# Future use only. Do not generate now.
# $ValidationCsv = Join-Path $BaseDir "${ChangeID}_BackupValidation_Details_$TimeStamp.csv"

if (-not (Test-Path $InputCsv)) {
    throw "CSV not found: $InputCsv"
}

# -------------------------
# API Key
# -------------------------
$ApiKeyPath = "X:\PowerShell\Cohesity_API_Scripts\DO_NOT_Delete\apikey.txt"

if (-not (Test-Path $ApiKeyPath)) {
    throw "API key file not found: $ApiKeyPath"
}

$ApiKey = (Get-Content -Path $ApiKeyPath -Raw).Trim()

# -------------------------
# API / Search Settings
# -------------------------
$BaseUrl = "https://helios.cohesity.com"

$GlobalSearchCount = 100

# If global search finds an object but cannot return clusterId, fallback to all clusters.
$EnableAllClusterFallback = $true

# Keep false for speed.
# Set true only if you want all-cluster scan even when global search returns no object.
$FallbackWhenNoGlobalObject = $false

# SQL/Oracle:
# true  = if runType is blank, allow timestamp because some responses do not expose runType.
# false = only kRegular/Regular is accepted.
$AllowBlankRunTypeForDb = $true

# Report time zone
$ReportTimeZoneId = "Eastern Standard Time"

# -------------------------
# Counters
# -------------------------
