$ProtectedSearchCalls   = 0
$FallbackCiCount        = 0
$FailedProtectedGets    = 0
$ReplicationSourceAdds  = 0

# ==========================================================
# Basic Functions
# ==========================================================
function Invoke-HeliosJson {
    param(
        [Parameter(Mandatory = $true)][string]$Uri,
        [Parameter(Mandatory = $true)][hashtable]$Headers,
        [int]$TimeoutSec = 45,
        [switch]$Quiet
    )

    try {
        $r = Invoke-WebRequest `
            -UseBasicParsing `
            -Method Get `
            -Uri $Uri `
            -Headers $Headers `
            -TimeoutSec $TimeoutSec `
            -ErrorAction Stop

        if ([string]::IsNullOrWhiteSpace($r.Content)) {
            return $null
        }

        return ($r.Content | ConvertFrom-Json)
    }
    catch {
        if (-not $Quiet) {
            Write-Host "GET failed:" -ForegroundColor DarkRed
            Write-Host $Uri -ForegroundColor DarkRed
            Write-Host $_.Exception.Message -ForegroundColor DarkRed
        }

        return $null
    }
}

function AsArray {
    param($Value)

    if ($null -eq $Value) {
        return @()
    }

    if ($Value -is [array]) {
        return @($Value)
    }

    return @($Value)
}

function Get-FirstText {
    param($Value)

    if ($null -eq $Value) {
        return ""
    }

    if ($Value -is [array]) {
        foreach ($Item in $Value) {
            $Text = Get-FirstText $Item

            if (-not [string]::IsNullOrWhiteSpace($Text)) {
                return $Text
            }
        }

        return ""
    }

    if ($Value -is [pscustomobject]) {
        foreach ($Prop in @(
            "display_value",
            "displayName",
            "name",
            "value",
            "id",
            "uid",
            "clusterId",
            "clusterID",
            "sourceClusterId",
            "sourceClusterID",
            "accessClusterId",
            "intId"
        )) {
            if ($Value.PSObject.Properties.Name -contains $Prop) {
                $Text = Get-FirstText $Value.$Prop

                if (-not [string]::IsNullOrWhiteSpace($Text)) {
                    return $Text
                }
            }
        }

        return ""
    }

    return "$Value".Trim()
}

function Add-UniqueString {
    param(
        [System.Collections.ArrayList]$List,
        [string]$Value
    )

    $v = "$Value".Trim().Trim('"').Trim("'")

    if (-not [string]::IsNullOrWhiteSpace($v)) {
        if (-not $List.Contains($v)) {
            [void]$List.Add($v)
        }
    }
}

function Text-MatchesName {
    param(
        [string]$Text,
        [string]$Name
    )

    $t = "$Text".ToLower().Trim()
    $n = "$Name".ToLower().Trim()

    if ([string]::IsNullOrWhiteSpace($t) -or [string]::IsNullOrWhiteSpace($n)) {
        return $false
    }

    if ($t -eq $n) { return $true }
    if ($t -like "*$n*") { return $true }
    if ($n -like "*$t*") { return $true }

    return $false
}

function Get-UsecsValue {
    param($Value)

    if ($null -eq $Value) {
        return $null
    }

    $Values = @()

    foreach ($Item in (AsArray $Value)) {
        if ($null -ne $Item -and "$Item".Trim() -ne "") {
            try {
                $Values += [int64]$Item
            }
            catch {}
        }
    }

    if ($Values.Count -eq 0) {
        return $null
    }

    return ($Values | Sort-Object -Descending | Select-Object -First 1)
}

function ToDate {
    param($Usecs)

    if (-not $Usecs) {
        return ""
    }

    try {
        $dto = [DateTimeOffset]::FromUnixTimeMilliseconds([int64]($Usecs / 1000))

        try {
            $tz = [System.TimeZoneInfo]::FindSystemTimeZoneById($ReportTimeZoneId)
            return ([System.TimeZoneInfo]::ConvertTime($dto, $tz)).ToString("dd-MMM-yyyy HH:mm:ss") + " ET"
        }
        catch {
            return $dto.LocalDateTime.ToString("dd-MMM-yyyy HH:mm:ss")
        }
    }
    catch {
        return ""
    }
}

function Is-ValidBackupTime {
    param([string]$LastBackupTime)

    return $LastBackupTime -notin @(
        "",
        $null,
        "NoBackup",
        "NoBackupTime",
        "NoObject",
        "NoFSBackupFound"
    )
}

# ==========================================================
# CI Context / Search Plan
# ==========================================================
function Get-CiSearchContext {
    param([string]$Ci)

    $CleanCi = "$Ci".Trim().Trim('"').Trim("'")

    $IsDbAtServer = $false
    $DbName = ""
    $ServerName = ""

    if ($CleanCi -match "@") {
        $Parts = $CleanCi -split "@", 2

        $DbName = "$($Parts[0])".Trim()
        $ServerName = "$($Parts[1])".Trim()

        if (-not [string]::IsNullOrWhiteSpace($DbName) -and -not [string]::IsNullOrWhiteSpace($ServerName)) {
            $IsDbAtServer = $true
        }
    }

    return [pscustomobject]@{
        InputCI      = $CleanCi
        IsDbAtServer = $IsDbAtServer
        DbName       = $DbName
        ServerName   = $ServerName
    }
}

function Get-SearchPlans {
    param($Context)

    $Plans = @()

    if ($Context.IsDbAtServer) {

        # Targeted DBNAME@SERVERNAME mode.
        # DB search uses DBNAME only.
        # FS search uses SERVERNAME only.
        $Plans += [pscustomobject]@{
            SearchTerm     = $Context.DbName
            Environment    = "kOracle"
            BackupTypeHint = "Oracle"
            Role           = "DB"
            TargetName     = $Context.DbName
        }

        $Plans += [pscustomobject]@{
            SearchTerm     = $Context.DbName
            Environment    = "kSQL"
            BackupTypeHint = "SQL"
            Role           = "DB"
            TargetName     = $Context.DbName
        }

        $Plans += [pscustomobject]@{
            SearchTerm     = $Context.ServerName
            Environment    = "kPhysical"
            BackupTypeHint = "FS"
            Role           = "Server"
            TargetName     = $Context.ServerName
        }

        return @($Plans)
    }

    # Normal CI mode.
    # This supports server-only input where multiple DBs may exist on the same server.
    foreach ($Plan in @(
        @{ Environment = "kOracle";    BackupTypeHint = "Oracle";  Role = "DB"     },
        @{ Environment = "kSQL";       BackupTypeHint = "SQL";     Role = "DB"     },
        @{ Environment = "kPhysical";  BackupTypeHint = "FS";      Role = "Server" },
        @{ Environment = "kGenericNas";BackupTypeHint = "NAS";     Role = "Server" },
        @{ Environment = "kIsilon";    BackupTypeHint = "NAS";     Role = "Server" },
        @{ Environment = "kHyperV";    BackupTypeHint = "Hyper-V"; Role = "Server" },
        @{ Environment = "kAcropolis"; BackupTypeHint = "Nutanix"; Role = "Server" },
        @{ Environment = "kVMware";    BackupTypeHint = "VMware";  Role = "Server" }
    )) {
        $Plans += [pscustomobject]@{
            SearchTerm     = $Context.InputCI
            Environment    = $Plan.Environment
            BackupTypeHint = $Plan.BackupTypeHint
            Role           = $Plan.Role
            TargetName     = $Context.InputCI
        }
    }

    return @($Plans)
}

function New-SearchUrl {
    param(
        [string]$Endpoint,
        [string]$SearchTerm,
        [string]$Environment,
        [switch]$Global
    )

    $Url =
        "$BaseUrl$Endpoint" +
        "?searchString=$([uri]::EscapeDataString($SearchTerm))"

    if (-not [string]::IsNullOrWhiteSpace($Environment)) {
        $Url += "&environments=$([uri]::EscapeDataString($Environment))"
    }

    if ($Global) {
        $Url += "&includeTenants=true"
        $Url += "&count=$GlobalSearchCount"
    }

    return $Url
}

