function Add-CandidateDetail {
    param(
        [System.Collections.ArrayList]$List,
        [hashtable]$Seen,
        [string]$ClusterId,
        [string]$ClusterName,
        [string]$ProtectionGroup,
        [string]$SearchMode
    )

    if ([string]::IsNullOrWhiteSpace($ClusterId)) {
        return
    }

    if ([string]::IsNullOrWhiteSpace($ClusterName)) {
        $ClusterName = $ClusterId
    }

    if ([string]::IsNullOrWhiteSpace($ProtectionGroup)) {
        $ProtectionGroup = "-"
    }

    if ([string]::IsNullOrWhiteSpace($SearchMode)) {
        $SearchMode = "Fast"
    }

    $Key = "$ClusterId|$ProtectionGroup"

    if ($Seen.ContainsKey($Key)) {
        return
    }

    $Seen[$Key] = $true

    [void]$List.Add([pscustomobject]@{
        clusterId               = "$ClusterId"
        clusterName             = "$ClusterName"
        fallbackProtectionGroup = "$ProtectionGroup"
        searchMode              = "$SearchMode"
    })
}

function Get-CandidateDetailsFromGlobalSearch {
    param(
        $Json,
        [hashtable]$ClusterMap
    )

    $List = New-Object System.Collections.ArrayList
    $Seen = @{}

    $Objects = Get-GlobalObjects -Json $Json

    foreach ($Obj in $Objects) {

        foreach ($ProtectionInfo in (AsArray $Obj.objectProtectionInfos)) {

            $HasPg = $false

            foreach ($Pg in (AsArray $ProtectionInfo.protectionGroups)) {
                $HasPg = $true

                $ClusterId = Get-ClusterIdFromSearchNode `
                    -Object $Obj `
                    -ProtectionInfo $ProtectionInfo `
                    -ProtectionGroup $Pg

                $ClusterName = Get-ClusterNameFromSearchNode `
                    -Object $Obj `
                    -ProtectionInfo $ProtectionInfo `
                    -ProtectionGroup $Pg `
                    -ClusterId $ClusterId `
                    -ClusterMap $ClusterMap

                $PgName = Get-ProtectionGroupNameFromSearchNode -ProtectionGroup $Pg

                Add-CandidateDetail `
                    -List $List `
                    -Seen $Seen `
                    -ClusterId $ClusterId `
                    -ClusterName $ClusterName `
                    -ProtectionGroup $PgName `
                    -SearchMode "Fast"
            }

            if (-not $HasPg) {
                $ClusterId = Get-ClusterIdFromSearchNode `
                    -Object $Obj `
                    -ProtectionInfo $ProtectionInfo `
                    -ProtectionGroup $null

                $ClusterName = Get-ClusterNameFromSearchNode `
                    -Object $Obj `
                    -ProtectionInfo $ProtectionInfo `
                    -ProtectionGroup $null `
                    -ClusterId $ClusterId `
                    -ClusterMap $ClusterMap

                Add-CandidateDetail `
                    -List $List `
                    -Seen $Seen `
                    -ClusterId $ClusterId `
                    -ClusterName $ClusterName `
                    -ProtectionGroup "-" `
                    -SearchMode "Fast"
            }
        }

        foreach ($Pg2 in (AsArray $Obj.protectionGroups)) {
            $ClusterId = Get-ClusterIdFromSearchNode `
                -Object $Obj `
                -ProtectionInfo $null `
                -ProtectionGroup $Pg2

            $ClusterName = Get-ClusterNameFromSearchNode `
                -Object $Obj `
                -ProtectionInfo $null `
                -ProtectionGroup $Pg2 `
                -ClusterId $ClusterId `
                -ClusterMap $ClusterMap

            $PgName = Get-ProtectionGroupNameFromSearchNode -ProtectionGroup $Pg2

            Add-CandidateDetail `
                -List $List `
                -Seen $Seen `
                -ClusterId $ClusterId `
                -ClusterName $ClusterName `
                -ProtectionGroup $PgName `
                -SearchMode "Fast"
        }

        $ObjectClusterId = Get-ClusterIdFromSearchNode `
            -Object $Obj `
            -ProtectionInfo $null `
            -ProtectionGroup $null

        if (-not [string]::IsNullOrWhiteSpace($ObjectClusterId)) {
            $ObjectClusterName = Get-ClusterNameFromSearchNode `
                -Object $Obj `
                -ProtectionInfo $null `
                -ProtectionGroup $null `
                -ClusterId $ObjectClusterId `
                -ClusterMap $ClusterMap

            Add-CandidateDetail `
                -List $List `
                -Seen $Seen `
                -ClusterId $ObjectClusterId `
                -ClusterName $ObjectClusterName `
                -ProtectionGroup "-" `
                -SearchMode "Fast"
        }
    }

    return @($List)
}

