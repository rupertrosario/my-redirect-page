# ==========================================================
# Replication
# ==========================================================
function Get-ReplicationInfo {
    param(
        $Node,
        [int]$Depth = 0
    )

    $result = [pscustomobject]@{
        Present         = $false
        SourceClusterId = ""
    }

    if ($null -eq $Node) {
        return $result
    }

    if ($Depth -gt 6) {
        return $result
    }

    foreach ($item in (AsArray $Node)) {
        if ($null -eq $item -or $item -isnot [pscustomobject]) {
            continue
        }

        foreach ($prop in $item.PSObject.Properties) {
            $pn = "$($prop.Name)"
            $pv = $prop.Value

            if ($pn -eq "replicationSnapshotInfo") {
                $result.Present = $true

                foreach ($rep in (AsArray $pv)) {
                    $src = Get-FirstText @(
                        $rep.clusterId,
                        $rep.clusterID,
                        $rep.sourceClusterId,
                        $rep.sourceClusterID,
                        $rep.cluster.id,
                        $rep.cluster.clusterId,
                        $rep.clusterInfo.clusterId
                    )

                    if (-not [string]::IsNullOrWhiteSpace($src)) {
                        $result.SourceClusterId = "$src"
                        return $result
                    }
                }
            }

            if ($pv -is [array] -or $pv -is [pscustomobject]) {
                $child = Get-ReplicationInfo -Node $pv -Depth ($Depth + 1)

                if ($child.Present) {
                    $result.Present = $true

                    if (-not [string]::IsNullOrWhiteSpace($child.SourceClusterId)) {
                        $result.SourceClusterId = "$($child.SourceClusterId)"
                        return $result
                    }
                }
            }
        }
    }

    return $result
}

