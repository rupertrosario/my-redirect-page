function Get-BackupTypeRank {
    param([string]$BackupType)

    switch ($BackupType) {
        "SQL"    { return 1 }
        "Oracle" { return 2 }
        "FS"     { return 3 }
        default  { return 9 }
    }
}

function Select-BestRows {
    param($Rows)

    $selected = @()

    foreach ($grp in ($Rows | Group-Object InputCI, BackupType, ObjectName)) {

        $groupRows = @($grp.Group)

        $validSource = @($groupRows | Where-Object {
            (Is-ValidBackupTime $_.LastBackupTime) -and (-not $_.IsReplicatedCopy)
        })

        if ($validSource.Count -gt 0) {
            $selected += (
                $validSource |
                Sort-Object `
                    @{ Expression = { [int64]$_.LastBackupUsecs }; Descending = $true },
                    ClusterName,
                    ProtectionGroup |
                Select-Object -First 1
            )
            continue
        }

        $validReplica = @($groupRows | Where-Object {
            (Is-ValidBackupTime $_.LastBackupTime) -and ($_.IsReplicatedCopy)
        })

        if ($validReplica.Count -gt 0) {
            $selected += (
                $validReplica |
                Sort-Object `
                    @{ Expression = { [int64]$_.LastBackupUsecs }; Descending = $true },
                    ClusterName,
                    ProtectionGroup |
                Select-Object -First 1
            )
            continue
        }

        $selected += (
            $groupRows |
            Sort-Object ClusterName, ProtectionGroup |
            Select-Object -First 1
        )
    }

    return @($selected)
}

# ==========================================================
# Load CIs
# ==========================================================
$CiNames = Import-Csv -Path $InputCsv |
ForEach-Object {
    "$($_.ci_item)".Trim().Trim('"').Trim("'")
} |
Where-Object {
    -not [string]::IsNullOrWhiteSpace($_)
} |
Sort-Object -Unique

if (-not $CiNames -or $CiNames.Count -eq 0) {
    throw "No CI names found in CSV: $InputCsv"
}

$CiNames | Set-Content -Path $InputTxt

$CiList = Get-Content -Path $InputTxt |
ForEach-Object {
    $_.Trim().Trim('"').Trim("'")
} |
Where-Object {
    -not [string]::IsNullOrWhiteSpace($_)
}

if (-not $CiList -or $CiList.Count -eq 0) {
    throw "No CI names found in TXT: $InputTxt"
}

# ==========================================================
# Get Clusters
# ==========================================================
$ClusterJson = Invoke-HeliosJson -Uri "$BaseUrl/v2/mcm/cluster-mgmt/info" -Headers @{
    accept = "application/json"
    apiKey = $ApiKey
}

if (-not $ClusterJson -or -not $ClusterJson.cohesityClusters) {
    throw "No clusters returned from Helios."
}

$Clusters = $ClusterJson.cohesityClusters | Sort-Object -Property clusterName
$ClusterMap = @{}

foreach ($clu in $Clusters) {
    $cname = Get-FirstText @($clu.clusterName, $clu.name, $clu.displayName)

    if ([string]::IsNullOrWhiteSpace($cname)) {
        $cname = "Unknown-$($clu.clusterId)"
    }

    Add-ClusterMapEntry -Map $ClusterMap -Id $clu.clusterId -Name $cname
    Add-ClusterMapEntry -Map $ClusterMap -Id $clu.id -Name $cname
    Add-ClusterMapEntry -Map $ClusterMap -Id $clu.intId -Name $cname
    Add-ClusterMapEntry -Map $ClusterMap -Id $clu.clusterIdentifier.clusterId -Name $cname
    Add-ClusterMapEntry -Map $ClusterMap -Id $clu.clusterInfo.clusterId -Name $cname
}

# ==========================================================
# Process
# ==========================================================
$Results = @()

foreach ($Ci in $CiList) {

    $Context = Get-CiContext -Ci $Ci
    Write-Host "Processing: [$($Context.InputCI)]"

    $Plans = @(Get-SearchPlans -Context $Context)
    $CiRows = @()
    $DiscoveredHostsForDb = New-Object System.Collections.ArrayList

    foreach ($Plan in $Plans) {

        $GlobalSearchCalls++

        $GlobalUrl = New-SearchUrl `
            -Endpoint "/v2/data-protect/search/objects" `
            -SearchTerm "$($Plan.SearchTerm)" `
            -Environment "$($Plan.Environment)" `
            -Global

        $GlobalJson = Invoke-HeliosJson -Uri $GlobalUrl -Headers @{
            accept = "application/json"
            apiKey = $ApiKey
        } -Quiet

        $GlobalObjects = Get-ObjectArrayFromJson -Json $GlobalJson

        $Candidates = @(
            Get-CandidatesFromGlobalSearch `
                -Json $GlobalJson `
                -ClusterMap $ClusterMap
        )

        if (($Candidates.Count -eq 0) -and $EnableAllClusterFallback) {
            foreach ($clu in $Clusters) {
                Add-Candidate `
                    -List ([System.Collections.ArrayList]$Candidates) `
                    -Seen @{} `
                    -ClusterId "$($clu.clusterId)" `
                    -ClusterName "$(Get-ClusterNameFromMap -ClusterId "$($clu.clusterId)" -ClusterMap $ClusterMap)" `
                    -PgId "" `
                    -PgName "-" `
                    -SearchMode "Fallback"
            }
        }

        if (-not $Candidates -or $Candidates.Count -eq 0) {
            continue
        }

        foreach ($Candidate in $Candidates) {

            $ClusterId = "$($Candidate.ClusterId)"
            $ClusterName = Get-ClusterNameFromMap -ClusterId $ClusterId -ClusterMap $ClusterMap

            if ([string]::IsNullOrWhiteSpace($ClusterName) -or $ClusterName -eq $ClusterId) {
                $ClusterName = "$($Candidate.ClusterName)"
            }

            $headers = @{
                accept          = "application/json"
                apiKey          = $ApiKey
                accessClusterId = "$ClusterId"
            }

            # --------------------------------------------------
            # Targeted PG inspection for SQL / Oracle
            # --------------------------------------------------
            if (
                $EnableTargetedPgRunInspection -and
                $Plan.BackupTypeHint -in @("SQL", "Oracle") -and
                -not [string]::IsNullOrWhiteSpace($Candidate.PgId)
            ) {
                $TargetedPgInspectCount++

                if ($Plan.BackupTypeHint -eq "SQL") {
                    $latestRun = Get-LatestRegularRunWithObjects `
                        -PgId "$($Candidate.PgId)" `
                        -ClusterId "$ClusterId" `
                        -Headers $headers

                    $sqlRows = @(Get-SqlRowsFromRun `
                        -Context $Context `
                        -Plan $Plan `
                        -Run $latestRun `
                        -ClusterName $ClusterName `
                        -ClusterId $ClusterId `
                        -PgName "$($Candidate.PgName)")

                    foreach ($r in $sqlRows) {
                        $CiRows += $r

                        if (-not [string]::IsNullOrWhiteSpace($r.HostName)) {
                            Add-UniqueText -List $DiscoveredHostsForDb -Value $r.HostName
                        }
                    }

                    if ($sqlRows.Count -gt 0) {
                        continue
                    }
                }

                if ($Plan.BackupTypeHint -eq "Oracle") {

                    $runInfo = Get-LatestRegularRunInfo -PgId "$($Candidate.PgId)" -Headers $headers

                    $pgDetails = Get-ProtectionGroupDetails `
                        -PgId "$($Candidate.PgId)" `
                        -Environment "kOracle" `
                        -Headers $headers

                    $oraRows = @(Get-OracleDbRowsFromPgDetails `
                        -Context $Context `
                        -Plan $Plan `
                        -Pg $pgDetails `
                        -ClusterName $ClusterName `
                        -ClusterId $ClusterId `
                        -PgName "$($Candidate.PgName)" `
                        -LastRegularBackupTime "$($runInfo.EndTimeET)" `
                        -LastRegularUsecs ([int64]$runInfo.EndUsecs))

                    foreach ($r in $oraRows) {
                        $CiRows += $r

                        if (-not [string]::IsNullOrWhiteSpace($r.HostName)) {
                            Add-UniqueText -List $DiscoveredHostsForDb -Value $r.HostName
                        }
                    }

                    if ($oraRows.Count -gt 0) {
                        continue
                    }
                }
            }

            # --------------------------------------------------
            # Protected-object fallback row
            # --------------------------------------------------
            $ProtectedSearchCalls++

            $ProtectedUrl = New-SearchUrl `
                -Endpoint "/v2/data-protect/search/protected-objects" `
                -SearchTerm "$($Plan.SearchTerm)" `
                -Environment "$($Plan.Environment)"

            $ProtectedJson = Invoke-HeliosJson -Uri $ProtectedUrl -Headers $headers -Quiet
            $ProtectedObjects = Get-ObjectArrayFromJson -Json $ProtectedJson

            if (-not $ProtectedObjects -or $ProtectedObjects.Count -eq 0) {
                continue
            }

            foreach ($Obj in $ProtectedObjects) {

                $PreType = Get-BackupType -Obj $Obj -Snapshot $null -BackupTypeHint "$($Plan.BackupTypeHint)"
                $Snap = Get-BestSnapshot -Obj $Obj -BackupType $PreType
                $BackupType = Get-BackupType -Obj $Obj -Snapshot $Snap -BackupTypeHint "$($Plan.BackupTypeHint)"

                if ([string]::IsNullOrWhiteSpace($BackupType)) {
                    $BackupType = "$($Plan.BackupTypeHint)"
                }

                $ObjName = Get-ObjectNameFromProtectedObject -Obj $Obj

                # DBNAME@SERVERNAME targeted filtering.
                if ($Context.IsDbAtServer) {
                    if ($BackupType -in @("SQL", "Oracle")) {
                        if (-not (Text-MatchesName -Text $ObjName -Name $Context.DbName)) {
                            continue
                        }

                        $ObjName = $Context.DbName
                    }

                    if ($BackupType -eq "FS") {
                        if (-not (Text-MatchesName -Text $ObjName -Name $Context.ServerName)) {
                            continue
                        }

                        $ObjName = $Context.ServerName
                    }
                }

                $ObjRep = Get-ReplicationInfo -Node $Obj
                $SnapRep = Get-ReplicationInfo -Node $Snap

                $IsReplica = [bool]($ObjRep.Present -or $SnapRep.Present)
                $RepSource = Get-FirstText @($ObjRep.SourceClusterId, $SnapRep.SourceClusterId)

                $Usecs = $null
                $TimeText = "NoBackup"

                if ($Snap) {
                    $Usecs = Get-SnapshotUsecs -Snapshot $Snap
                    if ($Usecs) {
                        $TimeText = ToDate $Usecs
                    }
                    else {
                        $TimeText = "NoBackupTime"
                    }
                }

                $PgName = Get-ProtectionGroupName `
                    -Obj $Obj `
                    -Snapshot $Snap `
                    -FallbackPgName "$($Candidate.PgName)"

                $CiRows += [pscustomobject]@{
                    InputCI                    = $Context.InputCI
                    BackupType                 = $BackupType
                    ObjectName                 = $ObjName
                    ClusterName                = $ClusterName
                    ClusterId                  = $ClusterId
                    ProtectionGroup            = $PgName
                    LastBackupTime             = $TimeText
                    LastBackupUsecs            = if ($Usecs) { [int64]$Usecs } else { 0 }
                    IsReplicatedCopy           = $IsReplica
                    ReplicationSourceClusterId = $RepSource
                    HostName                   = ""
                    DetailSource               = "ProtectedObjectSearch"
                }
            }
        }
    }

    # Optional DB-name-only FS lookup if host was discovered.
    if (-not $Context.IsDbAtServer -and $DiscoveredHostsForDb.Count -gt 0) {

        foreach ($hostName in @($DiscoveredHostsForDb)) {

            $fsContext = [pscustomobject]@{
                InputCI      = $Context.InputCI
                IsDbAtServer = $true
                DbName       = $Context.InputCI
                ServerName   = $hostName
            }

            $fsPlan = [pscustomobject]@{
                SearchTerm     = $hostName
                Environment    = "kPhysical"
                BackupTypeHint = "FS"
                Role           = "Server"
                TargetName     = $hostName
            }

            $GlobalSearchCalls++

            $fsGlobalUrl = New-SearchUrl `
                -Endpoint "/v2/data-protect/search/objects" `
                -SearchTerm "$hostName" `
                -Environment "kPhysical" `
                -Global

            $fsGlobalJson = Invoke-HeliosJson -Uri $fsGlobalUrl -Headers @{
                accept = "application/json"
                apiKey = $ApiKey
            } -Quiet

            $fsCandidates = @(
                Get-CandidatesFromGlobalSearch `
                    -Json $fsGlobalJson `
                    -ClusterMap $ClusterMap
            )

            foreach ($fc in $fsCandidates) {

                $ClusterId = "$($fc.ClusterId)"
                $ClusterName = Get-ClusterNameFromMap -ClusterId $ClusterId -ClusterMap $ClusterMap

                $headers = @{
                    accept          = "application/json"
                    apiKey          = $ApiKey
                    accessClusterId = "$ClusterId"
                }

                $ProtectedSearchCalls++

                $fsProtectedUrl = New-SearchUrl `
                    -Endpoint "/v2/data-protect/search/protected-objects" `
                    -SearchTerm "$hostName" `
                    -Environment "kPhysical"

                $fsProtectedJson = Invoke-HeliosJson -Uri $fsProtectedUrl -Headers $headers -Quiet
                $fsObjects = Get-ObjectArrayFromJson -Json $fsProtectedJson

                foreach ($Obj in $fsObjects) {

                    $ObjName = Get-ObjectNameFromProtectedObject -Obj $Obj

                    if (-not (Text-MatchesName -Text $ObjName -Name $hostName)) {
                        continue
                    }

                    $Snap = Get-BestSnapshot -Obj $Obj -BackupType "FS"
                    $Usecs = $null
                    $TimeText = "NoBackup"

                    if ($Snap) {
                        $Usecs = Get-SnapshotUsecs -Snapshot $Snap
                        $TimeText = if ($Usecs) { ToDate $Usecs } else { "NoBackupTime" }
                    }

                    $PgName = Get-ProtectionGroupName `
                        -Obj $Obj `
                        -Snapshot $Snap `
                        -FallbackPgName "$($fc.PgName)"

                    $CiRows += [pscustomobject]@{
                        InputCI                    = $Context.InputCI
                        BackupType                 = "FS"
                        ObjectName                 = $hostName
                        ClusterName                = $ClusterName
                        ClusterId                  = $ClusterId
                        ProtectionGroup            = $PgName
                        LastBackupTime             = $TimeText
                        LastBackupUsecs            = if ($Usecs) { [int64]$Usecs } else { 0 }
                        IsReplicatedCopy           = $false
                        ReplicationSourceClusterId = ""
                        HostName                   = $hostName
                        DetailSource               = "DbHostFsLookup"
                    }
                }
            }
        }
    }

    if (-not $CiRows -or $CiRows.Count -eq 0) {
        $Results += [pscustomobject]@{
            InputCI         = $Context.InputCI
            BackupType      = "Unknown"
            ObjectName      = "-"
            ClusterName     = "-"
            ProtectionGroup = "-"
            LastBackupTime  = "NoObject"
        }

        continue
    }

    $KnownRows = @($CiRows | Where-Object { $_.BackupType -ne "Unknown" })

    if ($KnownRows.Count -gt 0) {
        $CiRows = $KnownRows
    }

    $SelectedRows = @(Select-BestRows -Rows $CiRows)

    foreach ($row in $SelectedRows) {
        $Results += [pscustomobject]@{
            InputCI         = $row.InputCI
            BackupType      = $row.BackupType
            ObjectName      = $row.ObjectName
            ClusterName     = $row.ClusterName
            ProtectionGroup = $row.ProtectionGroup
            LastBackupTime  = $row.LastBackupTime
        }
    }

    # If DB backup found but no FS found, show clear FS missing row.
    $HasDb = @($SelectedRows | Where-Object {
        $_.BackupType -in @("SQL", "Oracle") -and (Is-ValidBackupTime $_.LastBackupTime)
    }).Count -gt 0

    $HasFs = @($SelectedRows | Where-Object {
        $_.BackupType -eq "FS" -and (Is-ValidBackupTime $_.LastBackupTime)
    }).Count -gt 0

    if ($HasDb -and -not $HasFs) {

        $fsName = "-"

        if ($Context.IsDbAtServer) {
            $fsName = $Context.ServerName
        }
        elseif ($DiscoveredHostsForDb.Count -gt 0) {
            $fsName = (@($DiscoveredHostsForDb) -join ";")
        }

        $Results += [pscustomobject]@{
            InputCI         = $Context.InputCI
            BackupType      = "FS"
            ObjectName      = $fsName
            ClusterName     = "-"
            ProtectionGroup = "-"
            LastBackupTime  = "NoFSBackupFound"
        }
    }
}

# ==========================================================
# Summary
# ==========================================================
$TotalInputCIs = $CiList.Count
$TotalBackupRows = $Results.Count

$BackedUp = @($Results | Where-Object {
    $_.LastBackupTime -notin @("NoBackup", "NoBackupTime", "NoObject", "NoFSBackupFound", "NoDbDetailFound", "")
}).Count

$NoBackup = @($Results | Where-Object {
    $_.LastBackupTime -in @("NoBackup", "NoBackupTime", "NoDbDetailFound")
}).Count

$NoFSBackupFound = @($Results | Where-Object {
    $_.LastBackupTime -eq "NoFSBackupFound"
}).Count

$NoObject = @($Results | Where-Object {
    $_.LastBackupTime -eq "NoObject"
}).Count

$SortedResults = $Results |
    Sort-Object `
        InputCI,
        @{ Expression = { Get-BackupTypeRank $_.BackupType } },
        ObjectName,
        ClusterName,
        ProtectionGroup

$DetailsText = (
    $SortedResults |
    Format-Table InputCI, BackupType, ObjectName, ClusterName, ProtectionGroup, LastBackupTime -AutoSize |
    Out-String -Width 350
).TrimEnd()

# ==========================================================
# Export CSV
# ==========================================================
$SortedResults |
    Select-Object InputCI, BackupType, ObjectName, ClusterName, ProtectionGroup, LastBackupTime |
    Export-Csv -Path $OutputCsv -NoTypeInformation

# ==========================================================
