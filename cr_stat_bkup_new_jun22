$Report += "- It does not perform a full SQL or Oracle database inventory across all clusters."
$Report += "- It does not enumerate every database inside every SQL/Oracle Protection Group."
$Report += "- DB-level details are shown only when targeted PG run details or PG configuration expose DB objects clearly."
$Report += "- For DBNAME@SERVERNAME input, the script checks only the specified DB name and the specified server name."
$Report += "- For server-only input, DB rows are shown only if the targeted search exposes DB-to-host details."
$Report += "- VIPs, cluster names, listeners, aliases, and floating names may not resolve unless directly searchable in Cohesity."
$Report += "- If expected DBs or server backups are missing, search manually in Cohesity using DB name, server name, PG name, VIP, and cluster node names."
$Report += "- No all-cluster fallback is enabled in this version to avoid long execution times."
$Report += ""
$Report += "----------------------------------------------------------"
$Report += "Report Locations"
$Report += "----------------------------------------------------------"
$Report += "TXT Report            : $OutputTxt"
$Report += "Final CSV             : $OutputCsv"
$Report += "=========================================================="

$Report | Set-Content -Path $OutputTxt

