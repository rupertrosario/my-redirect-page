function Get-ObjectNames {
    param($Object)

    $Names = @(
        $Object.name,
        $Object.objectName,
        $Object.hostName,
        $Object.displayName,
        $Object.sourceName,
        $Object.entity.displayName,
        $Object.entity.name,
        $Object.object.name,
        $Object.object.displayName,
        $Object.sourceInfo.name,
        $Object.sourceInfo.displayName,
        $Object.protectionSource.name,
        $Object.protectionSource.displayName
    )

    return @(
        $Names |
        ForEach-Object {
            $Text = Get-FirstText $_
            if ($Text) { $Text.ToLower() }
        } |
        Where-Object { $_ }
    )
}

function Object-MatchesCi {
    param(
        $Object,
        [string]$CiName
    )

    $CiLower = "$CiName".ToLower().Trim()

    if ([string]::IsNullOrWhiteSpace($CiLower)) {
        return $false
    }

    $Names = Get-ObjectNames -Object $Object

    if (-not $Names -or $Names.Count -eq 0) {
        return $false
    }

    foreach ($Name in $Names) {
        if ($Name -eq $CiLower) { return $true }
        if ($Name -like "*$CiLower*") { return $true }
        if ($CiLower -like "*$Name*") { return $true }
    }

    return $false
}

function Get-EnvironmentText {
    param(
        $Object,
        $Snapshot
    )

    $Candidates = @()

    if ($Object) {
        $Candidates += $Object.environment
        $Candidates += $Object.object.environment
        $Candidates += $Object.objectType
        $Candidates += $Object.type
        $Candidates += $Object.protectionType
        $Candidates += $Object.sourceInfo.environment
        $Candidates += $Object.sourceInfo.type
        $Candidates += $Object.protectionSource.environment
        $Candidates += $Object.protectionSource.type
        $Candidates += $Object.entity.environment
        $Candidates += $Object.entity.type
        $Candidates += $Object.latestSnapshotInfo.environment
        $Candidates += $Object.latestSnapshotInfo.objectType
        $Candidates += $Object.latestSnapshotsInfo.environment
        $Candidates += $Object.latestSnapshotsInfo.objectType
    }

    if ($Snapshot) {
        $Candidates += $Snapshot.environment
        $Candidates += $Snapshot.objectType
        $Candidates += $Snapshot.type
        $Candidates += $Snapshot.sourceInfo.environment
        $Candidates += $Snapshot.sourceInfo.type
        $Candidates += $Snapshot.entity.environment
        $Candidates += $Snapshot.entity.type
    }

    $Texts = @()

    foreach ($Candidate in $Candidates) {
        $Text = Get-FirstText $Candidate

        if (-not [string]::IsNullOrWhiteSpace($Text)) {
            $Texts += $Text.ToLower()
        }
    }

    return ($Texts -join " ")
}

function Get-BackupType {
    param(
        $Object,
        $Snapshot
    )

    # Do NOT use object name, display name, PG name, or policy name here.
    # BackupType must be from Cohesity environment/type fields only.

    $AllText = Get-EnvironmentText -Object $Object -Snapshot $Snapshot

    if ($AllText -match "ksql|mssql|sqlserver|sql server|\bsql\b") {
        return "SQL"
    }

    if ($AllText -match "koracle|\boracle\b") {
        return "Oracle"
    }

    if ($AllText -match "kphysical|physical|filesystem|file_system|file system|volume|windows|linux") {
        return "FS"
    }

    if ($AllText -match "kgenericnas|kisilon|nas|isilon|smb|cifs|nfs") {
        return "NAS"
    }

    if ($AllText -match "khyperv|hyperv|hyper-v") {
        return "Hyper-V"
    }

    if ($AllText -match "kacropolis|nutanix|ahv|acropolis") {
        return "Nutanix"
    }

    if ($AllText -match "kvmware|vmware") {
        return "VMware"
    }

    return "Unknown"
}

function Get-SnapshotCandidates {
    param($Object)

    if (-not $Object) {
        return @()
    }

    $Snaps = @()

    $Snaps += @(AsArray $Object.latestSnapshotInfo)
    $Snaps += @(AsArray $Object.latestSnapshotsInfo)
    $Snaps += @(AsArray $Object.latestSnapshots)
    $Snaps += @(AsArray $Object.latestSnapshot)
    $Snaps += @(AsArray $Object.snapshotInfo)
    $Snaps += @(AsArray $Object.backupInfo)
    $Snaps += @(AsArray $Object.snapshots)

    return @($Snaps | Where-Object { $_ })
}

function Get-SnapshotUsecs {
    param($Snapshot)

    if (-not $Snapshot) {
        return $null
    }

    foreach ($Field in @(
        $Snapshot.protectionRunEndTimeUsecs,
        $Snapshot.runEndTimeUsecs,
        $Snapshot.endTimeUsecs,
        $Snapshot.snapshotCreationTimeUsecs,
        $Snapshot.creationTimeUsecs,
        $Snapshot.protectionRunStartTimeUsecs,
        $Snapshot.runStartTimeUsecs,
        $Snapshot.startTimeUsecs
    )) {
        $Usecs = Get-UsecsValue -Value $Field

        if ($Usecs) {
            return $Usecs
        }
    }

    foreach ($LocalBackupInfo in (AsArray $Snapshot.localBackupInfo)) {
        foreach ($Field in @(
            $LocalBackupInfo.endTimeUsecs,
            $LocalBackupInfo.startTimeUsecs
        )) {
            $Usecs = Get-UsecsValue -Value $Field

            if ($Usecs) {
                return $Usecs
            }
        }
    }

    return $null
}

function Get-SnapshotRunType {
    param($Snapshot)

    if (-not $Snapshot) {
        return ""
    }

    $RunType = Get-FirstText @(
        $Snapshot.localBackupInfo.runType,
        $Snapshot.localBackupInfo.backupRunType,
        $Snapshot.originalBackupInfo.runType,
        $Snapshot.originalBackupInfo.backupRunType,
        $Snapshot.runType,
        $Snapshot.backupRunType,
        $Snapshot.snapshotRunType
    )

    if (-not [string]::IsNullOrWhiteSpace($RunType)) {
        return $RunType
    }

    foreach ($LocalBackupInfo in (AsArray $Snapshot.localBackupInfo)) {
        $RunType = Get-FirstText @(
            $LocalBackupInfo.runType,
            $LocalBackupInfo.backupRunType
        )

        if (-not [string]::IsNullOrWhiteSpace($RunType)) {
            return $RunType
        }
    }

    return ""
}

function Get-BestSnapshot {
    param(
        $Object,
        [string]$BackupType
    )

    $Snapshots = Get-SnapshotCandidates -Object $Object

    if (-not $Snapshots -or $Snapshots.Count -eq 0) {
        return $null
    }

    if ($BackupType -in @("SQL", "Oracle")) {

        $RegularSnaps = @($Snapshots | Where-Object {
            $rt = (Get-SnapshotRunType -Snapshot $_).ToLower()
            $rt -match "kregular|regular"
        })

        if ($RegularSnaps.Count -gt 0) {
            return $RegularSnaps |
                Sort-Object @{ Expression = { [int64](Get-SnapshotUsecs -Snapshot $_) } } -Descending |
                Select-Object -First 1
        }

        $NonLogSnaps = @($Snapshots | Where-Object {
            $rt = (Get-SnapshotRunType -Snapshot $_).ToLower()

            if ($rt -match "klog|\blog\b") {
                return $false
            }

            if ([string]::IsNullOrWhiteSpace($rt) -and $AllowBlankRunTypeForDb) {
                return $true
            }

            return $false
        })

        if ($NonLogSnaps.Count -gt 0) {
            return $NonLogSnaps |
                Sort-Object @{ Expression = { [int64](Get-SnapshotUsecs -Snapshot $_) } } -Descending |
                Select-Object -First 1
        }

        return $null
    }

    $AllowedSnaps = @($Snapshots | Where-Object {
        $rt = (Get-SnapshotRunType -Snapshot $_).ToLower()
        $rt -notmatch "klog|\blog\b"
    })

    if ($AllowedSnaps.Count -eq 0) {
        return $null
    }

    return $AllowedSnaps |
        Sort-Object @{ Expression = { [int64](Get-SnapshotUsecs -Snapshot $_) } } -Descending |
        Select-Object -First 1
}

function Get-ProtectionGroupName {
    param(
        $Object,
        $Snapshot,
        [string]$FallbackProtectionGroup
    )

    $Candidates = @(
        $Snapshot.protectionGroupName,
        $Snapshot.protectionGroup.name,
        $Snapshot.protectionGroup.displayName,
        $Snapshot.protectionGroupInfo.name,
        $Snapshot.protectionGroupInfo.displayName,

        $Object.protectionGroupName,
        $Object.protectionGroup.name,
        $Object.protectionGroup.displayName,
        $Object.protectionGroupInfo.name,
        $Object.protectionGroupInfo.displayName,

        $FallbackProtectionGroup
    )

    foreach ($Candidate in $Candidates) {
        $Text = Get-FirstText $Candidate

        if (-not [string]::IsNullOrWhiteSpace($Text) -and $Text -ne "-") {
            return $Text
        }
    }

    return "-"
}

# ==========================================================
# Replication Functions
# ==========================================================
function Get-ReplicationInfo {
    param(
        $Node,
        [int]$Depth = 0
    )

    $Result = [pscustomobject]@{
        Present         = $false
        SourceClusterId = ""
    }

    if ($null -eq $Node) {
        return $Result
    }

    if ($Depth -gt 6) {
        return $Result
    }

    foreach ($Item in (AsArray $Node)) {

        if ($null -eq $Item) {
            continue
        }

        if ($Item -isnot [pscustomobject]) {
            continue
        }

        foreach ($Prop in $Item.PSObject.Properties) {

            $PropName  = "$($Prop.Name)"
            $PropValue = $Prop.Value

            if ($PropName -eq "replicationSnapshotInfo") {
                $Result.Present = $true

                foreach ($Rep in (AsArray $PropValue)) {
                    $SourceClusterId = Get-FirstText @(
                        $Rep.clusterId,
                        $Rep.clusterID,
                        $Rep.sourceClusterId,
                        $Rep.sourceClusterID,
                        $Rep.cluster.id,
                        $Rep.cluster.clusterId,
                        $Rep.clusterInfo.clusterId
                    )

                    if (-not [string]::IsNullOrWhiteSpace($SourceClusterId)) {
                        $Result.SourceClusterId = "$SourceClusterId"
                        return $Result
                    }
                }
            }

            if ($PropValue -is [array] -or $PropValue -is [pscustomobject]) {
                $Child = Get-ReplicationInfo -Node $PropValue -Depth ($Depth + 1)

                if ($Child.Present) {
                    $Result.Present = $true

                    if (-not [string]::IsNullOrWhiteSpace($Child.SourceClusterId)) {
                        $Result.SourceClusterId = "$($Child.SourceClusterId)"
                        return $Result
                    }
                }
            }
        }
    }

    return $Result
}

function SearchQueueHasCluster {
    param(
        [System.Collections.ArrayList]$Queue,
        [string]$ClusterId
    )

    foreach ($Item in $Queue) {
        if ("$($Item.clusterId)" -eq "$ClusterId") {
            return $true
        }
    }

    return $false
}

# ==========================================================
# Row Selection Functions
# ==========================================================
function Get-BackupTypeRank {
    param([string]$BackupType)

    switch ($BackupType) {
        "SQL"      { return 1 }
        "Oracle"   { return 2 }
        "FS"       { return 3 }
        "NAS"      { return 4 }
        "Hyper-V"  { return 5 }
        "Nutanix"  { return 6 }
        "VMware"   { return 7 }
        default    { return 9 }
    }
}

function Select-BestRowsForCi {
    param($Rows)

    $Selected = @()

    foreach ($Group in ($Rows | Group-Object ServerName, BackupType)) {

        $GroupRows = @($Group.Group)

        $ValidSourceRows = @($GroupRows | Where-Object {
            (Is-ValidBackupTime $_.LastBackupTime) -and (-not $_.IsReplicatedCopy)
        })

        if ($ValidSourceRows.Count -gt 0) {
            $Selected += (
                $ValidSourceRows |
                Sort-Object `
                    @{ Expression = { [int64]$_.LastBackupUsecs }; Descending = $true },
                    ClusterName,
                    ProtectionGroup |
                Select-Object -First 1
            )

            continue
        }

        $ValidReplicaRows = @($GroupRows | Where-Object {
            (Is-ValidBackupTime $_.LastBackupTime) -and ($_.IsReplicatedCopy)
        })

        if ($ValidReplicaRows.Count -gt 0) {
            $Selected += (
                $ValidReplicaRows |
                Sort-Object `
                    @{ Expression = { [int64]$_.LastBackupUsecs }; Descending = $true },
                    ClusterName,
                    ProtectionGroup |
                Select-Object -First 1
            )

            continue
        }

        $InvalidSourceRows = @($GroupRows | Where-Object {
            -not $_.IsReplicatedCopy
        })

        if ($InvalidSourceRows.Count -gt 0) {
            $Selected += (
                $InvalidSourceRows |
                Sort-Object ClusterName, ProtectionGroup |
                Select-Object -First 1
            )

            continue
        }

        $Selected += (
            $GroupRows |
            Sort-Object ClusterName, ProtectionGroup |
            Select-Object -First 1
        )
    }

    return @($Selected)
}

# ==========================================================
# CSV -> TXT
# ==========================================================
$CiNames = Import-Csv -Path $InputCsv |
ForEach-Object {
    "$($_.ci_item)".Trim().Trim('"').Trim("'")
} |
Where-Object {
    -not [string]::IsNullOrWhiteSpace($_)
} |
Sort-Object -Unique

if (-not $CiNames -or $CiNames.Count -eq 0) {
    throw "No CI names found in CSV: $InputCsv"
}

$CiNames | Set-Content -Path $InputTxt

$CiList = Get-Content -Path $InputTxt |
ForEach-Object {
    $_.Trim().Trim('"').Trim("'")
} |
Where-Object {
    -not [string]::IsNullOrWhiteSpace($_)
}

if (-not $CiList -or $CiList.Count -eq 0) {
    throw "No CI names found in TXT: $InputTxt"
}

# ==========================================================
# Get Clusters
# ==========================================================
$ClusterUrl = "$BaseUrl/v2/mcm/cluster-mgmt/info"

$ClusterJson = Invoke-HeliosJson -Uri $ClusterUrl -Headers @{
    accept = "application/json"
    apiKey = $ApiKey
}

if (-not $ClusterJson -or -not $ClusterJson.cohesityClusters -or $ClusterJson.cohesityClusters.Count -eq 0) {
    throw "No clusters returned from Helios."
}

$Clusters = $ClusterJson.cohesityClusters | Sort-Object -Property clusterName

$ClusterMap = @{}

foreach ($Clu in $Clusters) {
    $ClusterName = Get-FirstText @($Clu.clusterName, $Clu.name, $Clu.displayName)

    if ([string]::IsNullOrWhiteSpace($ClusterName)) {
        $ClusterName = "Unknown"
    }

    Add-ClusterMapEntry -Map $ClusterMap -Id $Clu.clusterId -Name $ClusterName
    Add-ClusterMapEntry -Map $ClusterMap -Id $Clu.id -Name $ClusterName
    Add-ClusterMapEntry -Map $ClusterMap -Id $Clu.intId -Name $ClusterName
    Add-ClusterMapEntry -Map $ClusterMap -Id $Clu.clusterIdentifier.clusterId -Name $ClusterName
    Add-ClusterMapEntry -Map $ClusterMap -Id $Clu.clusterInfo.clusterId -Name $ClusterName
}

# ==========================================================
# Process
# ==========================================================
$Results = @()
$ValidationResults = @()

foreach ($Ci in $CiList) {

    $Ci = $Ci.Trim().Trim('"').Trim("'")
    Write-Host "Processing: [$Ci]"

    if ([string]::IsNullOrWhiteSpace($Ci)) {
        continue
    }

    $CiRows = @()

    # ------------------------------------------------------
    # STEP 1:
    # Global search to identify candidate clusterId + PG fallback
    # ------------------------------------------------------
    $GlobalSearchCalls++

    $GlobalSearchUrl =
        "$BaseUrl/v2/data-protect/search/objects" +
        "?searchString=$([uri]::EscapeDataString($Ci))" +
        "&includeTenants=true" +
        "&count=$GlobalSearchCount"

    $GlobalJson = Invoke-HeliosJson -Uri $GlobalSearchUrl -Headers @{
        accept = "application/json"
        apiKey = $ApiKey
    } -Quiet

    $GlobalObjects = Get-GlobalObjects -Json $GlobalJson

    $CandidateClusters = @(
        Get-CandidateDetailsFromGlobalSearch `
            -Json $GlobalJson `
            -ClusterMap $ClusterMap
    )

    if (-not $CandidateClusters -or $CandidateClusters.Count -eq 0) {

        $ShouldFallback =
            $EnableAllClusterFallback -and
            (
                ($GlobalObjects -and $GlobalObjects.Count -gt 0) -or
                $FallbackWhenNoGlobalObject
            )

        if ($ShouldFallback) {
            $FallbackCiCount++
            $CandidateClusters = @()

            foreach ($Clu in $Clusters) {
                $ClusterName = Get-FirstText @($Clu.clusterName, $Clu.name, $Clu.displayName)

                if ([string]::IsNullOrWhiteSpace($ClusterName)) {
                    $ClusterName = "$($Clu.clusterId)"
                }

                $CandidateClusters += [pscustomobject]@{
                    clusterId               = "$($Clu.clusterId)"
                    clusterName             = "$ClusterName"
                    fallbackProtectionGroup = "-"
                    searchMode              = "Fallback"
                }
            }
        }
    }

    if (-not $CandidateClusters -or $CandidateClusters.Count -eq 0) {

        $Results += [pscustomobject]@{
            ServerName      = $Ci
            BackupType      = "Unknown"
            ClusterName     = "-"
            ProtectionGroup = "-"
            LastBackupTime  = "NoObject"
        }

        $ValidationResults += [pscustomobject]@{
            ServerName                 = $Ci
            BackupType                 = "Unknown"
            ClusterName                = "-"
            ClusterId                  = ""
            ProtectionGroup            = "-"
            LastBackupTime             = "NoObject"
            LastBackupUsecs            = 0
            RunType                    = ""
            IsReplicatedCopy           = $false
            ReplicationSourceClusterId = ""
            SearchMode                 = ""
            SelectionNote              = "No candidate cluster found from global search"
        }

        continue
    }

    # ------------------------------------------------------
    # STEP 2:
    # Search protected-objects on candidate clusters.
    # Add source cluster if replicated row points to source.
    # ------------------------------------------------------
    $SearchQueue = New-Object System.Collections.ArrayList
    $SearchedClusters = @{}

    foreach ($Candidate in $CandidateClusters) {
        if (-not (SearchQueueHasCluster -Queue $SearchQueue -ClusterId "$($Candidate.clusterId)")) {
            [void]$SearchQueue.Add($Candidate)
        }
    }

    for ($i = 0; $i -lt $SearchQueue.Count; $i++) {

        $Clu = $SearchQueue[$i]
        $ClusterId = "$($Clu.clusterId)"

        if ([string]::IsNullOrWhiteSpace($ClusterId)) {
            continue
        }

        if ($SearchedClusters.ContainsKey($ClusterId)) {
            continue
        }

        $SearchedClusters[$ClusterId] = $true

        $ClusterName = Get-ClusterNameFromMap `
            -ClusterId $ClusterId `
            -ClusterMap $ClusterMap

        if ([string]::IsNullOrWhiteSpace($ClusterName) -or $ClusterName -eq $ClusterId) {
            $ClusterName = "$($Clu.clusterName)"
        }

        $FallbackProtectionGroup = "$($Clu.fallbackProtectionGroup)"

        $ProtectedSearchCalls++

        $ProtectedSearchUrl =
            "$BaseUrl/v2/data-protect/search/protected-objects" +
            "?searchString=$([uri]::EscapeDataString($Ci))"

        $ProtectedJson = Invoke-HeliosJson -Uri $ProtectedSearchUrl -Headers @{
            accept          = "application/json"
            apiKey          = $ApiKey
            accessClusterId = "$ClusterId"
        } -Quiet

        if ($null -eq $ProtectedJson) {
            $FailedProtectedGets++
            continue
        }

        $ProtectedObjects = Get-ProtectedObjects -Json $ProtectedJson

        if (-not $ProtectedObjects -or $ProtectedObjects.Count -eq 0) {
            continue
        }

        $MatchingObjects = @($ProtectedObjects | Where-Object {
            Object-MatchesCi -Object $_ -CiName $Ci
        })

        if ($MatchingObjects -and $MatchingObjects.Count -gt 0) {
            $ObjectsToCheck = $MatchingObjects
        }
        else {
            $ObjectsToCheck = $ProtectedObjects
        }

        foreach ($Obj in $ObjectsToCheck) {

            $ObjRepInfo = Get-ReplicationInfo -Node $Obj

            if (
                $ObjRepInfo.Present -and
                -not [string]::IsNullOrWhiteSpace($ObjRepInfo.SourceClusterId) -and
                $ClusterMap.ContainsKey("$($ObjRepInfo.SourceClusterId)") -and
                -not $SearchedClusters.ContainsKey("$($ObjRepInfo.SourceClusterId)") -and
                -not (SearchQueueHasCluster -Queue $SearchQueue -ClusterId "$($ObjRepInfo.SourceClusterId)")
            ) {
                $SourceClusterName = Get-ClusterNameFromMap `
                    -ClusterId "$($ObjRepInfo.SourceClusterId)" `
                    -ClusterMap $ClusterMap

                [void]$SearchQueue.Add([pscustomobject]@{
                    clusterId               = "$($ObjRepInfo.SourceClusterId)"
                    clusterName             = "$SourceClusterName"
                    fallbackProtectionGroup = "$FallbackProtectionGroup"
                    searchMode              = "ReplicationSource"
                })

                $ReplicationSourceAdds++
            }

            $PreBackupType = Get-BackupType -Object $Obj -Snapshot $null
            $Snap = Get-BestSnapshot -Object $Obj -BackupType $PreBackupType

            $BackupType = Get-BackupType -Object $Obj -Snapshot $Snap

            if ([string]::IsNullOrWhiteSpace($BackupType)) {
                $BackupType = $PreBackupType
            }

            if ([string]::IsNullOrWhiteSpace($BackupType)) {
                $BackupType = "Unknown"
            }

            if ($BackupType -ne $PreBackupType) {
                $Snap = Get-BestSnapshot -Object $Obj -BackupType $BackupType
            }

            $SnapRepInfo = Get-ReplicationInfo -Node $Snap

            $IsReplicatedCopy = [bool]($ObjRepInfo.Present -or $SnapRepInfo.Present)

            $ReplicationSourceClusterId = Get-FirstText @(
                $ObjRepInfo.SourceClusterId,
                $SnapRepInfo.SourceClusterId
            )

            if (
                $IsReplicatedCopy -and
                -not [string]::IsNullOrWhiteSpace($ReplicationSourceClusterId) -and
                $ClusterMap.ContainsKey("$ReplicationSourceClusterId") -and
                -not $SearchedClusters.ContainsKey("$ReplicationSourceClusterId") -and
                -not (SearchQueueHasCluster -Queue $SearchQueue -ClusterId "$ReplicationSourceClusterId")
            ) {
                $SourceClusterName = Get-ClusterNameFromMap `
                    -ClusterId "$ReplicationSourceClusterId" `
                    -ClusterMap $ClusterMap

                [void]$SearchQueue.Add([pscustomobject]@{
                    clusterId               = "$ReplicationSourceClusterId"
                    clusterName             = "$SourceClusterName"
                    fallbackProtectionGroup = "$FallbackProtectionGroup"
                    searchMode              = "ReplicationSource"
                })

                $ReplicationSourceAdds++
            }

            $RunType = Get-SnapshotRunType -Snapshot $Snap

            if ($Snap) {
                $Usecs = Get-SnapshotUsecs -Snapshot $Snap

                if ($Usecs) {
                    $LastBackupTime = ToDate $Usecs
                }
                else {
                    $LastBackupTime = "NoBackupTime"
                }

                $ProtectionGroup = Get-ProtectionGroupName `
                    -Object $Obj `
                    -Snapshot $Snap `
                    -FallbackProtectionGroup $FallbackProtectionGroup

                $CiRows += [pscustomobject]@{
                    ServerName                 = $Ci
                    BackupType                 = $BackupType
                    ClusterName                = $ClusterName
                    ClusterId                  = $ClusterId
                    ProtectionGroup            = $ProtectionGroup
                    LastBackupTime             = $LastBackupTime
                    LastBackupUsecs            = if ($Usecs) { [int64]$Usecs } else { 0 }
                    RunType                    = $RunType
                    IsReplicatedCopy           = $IsReplicatedCopy
                    ReplicationSourceClusterId = $ReplicationSourceClusterId
                    SearchMode                 = "$($Clu.searchMode)"
                }
            }
            else {
                $ProtectionGroup = Get-ProtectionGroupName `
                    -Object $Obj `
                    -Snapshot $null `
                    -FallbackProtectionGroup $FallbackProtectionGroup

                $CiRows += [pscustomobject]@{
                    ServerName                 = $Ci
                    BackupType                 = $BackupType
                    ClusterName                = $ClusterName
                    ClusterId                  = $ClusterId
                    ProtectionGroup            = $ProtectionGroup
                    LastBackupTime             = "NoBackup"
                    LastBackupUsecs            = 0
                    RunType                    = ""
                    IsReplicatedCopy           = $IsReplicatedCopy
                    ReplicationSourceClusterId = $ReplicationSourceClusterId
                    SearchMode                 = "$($Clu.searchMode)"
                }
            }
        }
    }

    if (-not $CiRows -or $CiRows.Count -eq 0) {

        $Results += [pscustomobject]@{
            ServerName      = $Ci
            BackupType      = "Unknown"
            ClusterName     = "-"
            ProtectionGroup = "-"
            LastBackupTime  = "NoObject"
        }

        $ValidationResults += [pscustomobject]@{
            ServerName                 = $Ci
            BackupType                 = "Unknown"
            ClusterName                = "-"
            ClusterId                  = ""
            ProtectionGroup            = "-"
            LastBackupTime             = "NoObject"
            LastBackupUsecs            = 0
            RunType                    = ""
            IsReplicatedCopy           = $false
            ReplicationSourceClusterId = ""
            SearchMode                 = ""
            SelectionNote              = "Candidate clusters searched but no protected-object rows returned"
        }

        continue
    }

    $KnownRows = @($CiRows | Where-Object {
        $_.BackupType -ne "Unknown"
    })

    if ($KnownRows.Count -gt 0) {
        $CiRows = $KnownRows
    }

    $SelectedRows = @(Select-BestRowsForCi -Rows $CiRows)

    foreach ($Row in $SelectedRows) {

        $Results += [pscustomobject]@{
            ServerName      = $Row.ServerName
            BackupType      = $Row.BackupType
            ClusterName     = $Row.ClusterName
            ProtectionGroup = $Row.ProtectionGroup
            LastBackupTime  = $Row.LastBackupTime
        }

        $ValidationResults += [pscustomobject]@{
            ServerName                 = $Row.ServerName
            BackupType                 = $Row.BackupType
            ClusterName                = $Row.ClusterName
            ClusterId                  = $Row.ClusterId
            ProtectionGroup            = $Row.ProtectionGroup
            LastBackupTime             = $Row.LastBackupTime
            LastBackupUsecs            = $Row.LastBackupUsecs
            RunType                    = $Row.RunType
            IsReplicatedCopy           = $Row.IsReplicatedCopy
            ReplicationSourceClusterId = $Row.ReplicationSourceClusterId
            SearchMode                 = $Row.SearchMode
            SelectionNote              = if ($Row.IsReplicatedCopy) { "Replicated row selected - source/original row not found" } else { "Source/original row selected" }
        }
    }

    $HasSQL = @($SelectedRows | Where-Object {
        $_.BackupType -eq "SQL" -and (Is-ValidBackupTime $_.LastBackupTime)
    }).Count -gt 0

    $HasOracle = @($SelectedRows | Where-Object {
        $_.BackupType -eq "Oracle" -and (Is-ValidBackupTime $_.LastBackupTime)
    }).Count -gt 0

    $HasFS = @($SelectedRows | Where-Object {
        $_.BackupType -eq "FS" -and (Is-ValidBackupTime $_.LastBackupTime)
    }).Count -gt 0

    $HasDBBackup = $HasSQL -or $HasOracle

    if ($HasDBBackup -and -not $HasFS) {

        $Results += [pscustomobject]@{
            ServerName      = $Ci
            BackupType      = "FS"
            ClusterName     = "-"
            ProtectionGroup = "-"
            LastBackupTime  = "NoFSBackupFound"
        }

        $ValidationResults += [pscustomobject]@{
            ServerName                 = $Ci
            BackupType                 = "FS"
            ClusterName                = "-"
            ClusterId                  = ""
            ProtectionGroup            = "-"
            LastBackupTime             = "NoFSBackupFound"
            LastBackupUsecs            = 0
            RunType                    = ""
            IsReplicatedCopy           = $false
            ReplicationSourceClusterId = ""
            SearchMode                 = ""
            SelectionNote              = "SQL/Oracle found but FS backup not found"
        }
    }
}

# ==========================================================
# Summary
# ==========================================================
$TotalInputCIs = $CiList.Count
$TotalBackupRows = $Results.Count

$BackedUp = @($Results | Where-Object {
    $_.LastBackupTime -notin @("NoBackup", "NoBackupTime", "NoObject", "NoFSBackupFound", "")
}).Count

$NoBackup = @($Results | Where-Object {
    $_.LastBackupTime -in @("NoBackup", "NoBackupTime")
}).Count

$NoFSBackupFound = @($Results | Where-Object {
    $_.LastBackupTime -eq "NoFSBackupFound"
}).Count

$NoObject = @($Results | Where-Object {
    $_.LastBackupTime -eq "NoObject"
}).Count

$SortedResults = $Results |
    Sort-Object `
        ServerName,
        @{ Expression = { Get-BackupTypeRank $_.BackupType } },
        ClusterName,
        ProtectionGroup

$SortedValidationResults = $ValidationResults |
    Sort-Object `
        ServerName,
        @{ Expression = { Get-BackupTypeRank $_.BackupType } },
        ClusterName,
        ProtectionGroup

$DetailsText = (
    $SortedResults |
    Format-Table ServerName, BackupType, ClusterName, ProtectionGroup, LastBackupTime -AutoSize |
    Out-String -Width 300
).TrimEnd()

# ==========================================================
# Export CSVs
# ==========================================================
$SortedResults |
    Select-Object ServerName, BackupType, ClusterName, ProtectionGroup, LastBackupTime |
    Export-Csv -Path $OutputCsv -NoTypeInformation

$SortedValidationResults |
    Select-Object `
        ServerName,
        BackupType,
        ClusterName,
        ClusterId,
        ProtectionGroup,
        LastBackupTime,
        LastBackupUsecs,
        RunType,
        IsReplicatedCopy,
        ReplicationSourceClusterId,
        SearchMode,
        SelectionNote |
    Export-Csv -Path $ValidationCsv -NoTypeInformation

# ==========================================================
# Build Report
# ==========================================================
$Report = @()
$Report += "=========================================================="
$Report += "Cohesity Backup Validation Report"
$Report += "=========================================================="
$Report += "Change Number          : $ChangeID"
$Report += "Executed By            : $ExecutedBy"
$Report += "Run Date               : $(Get-Date -Format 'dd-MMM-yyyy HH:mm:ss')"
$Report += ""
$Report += "Total Input CIs        : $TotalInputCIs"
$Report += "Total Backup Rows      : $TotalBackupRows"
$Report += "Backed Up              : $BackedUp"
$Report += "No Backup              : $NoBackup"
$Report += "No FS Backup Found     : $NoFSBackupFound"
$Report += "No Object              : $NoObject"
$Report += ""
$Report += "Global Search Calls    : $GlobalSearchCalls"
$Report += "Protected Search Calls : $ProtectedSearchCalls"
$Report += "Failed Protected GETs  : $FailedProtectedGets"
$Report += "Fallback CI Count      : $FallbackCiCount"
$Report += "Replication Source Adds: $ReplicationSourceAdds"
$Report += ""
$Report += "----------------------------------------------------------"
$Report += "Details"
$Report += "----------------------------------------------------------"
$Report += ""
$Report += $DetailsText
$Report += ""
$Report += "----------------------------------------------------------"
$Report += "Summary Notes"
$Report += "----------------------------------------------------------"
$Report += "- Backed Up          : CI found with valid snapshot and backup time"
$Report += "- No Backup          : CI found in Cohesity but no usable snapshot time returned"
$Report += "- No Object          : CI not found in Cohesity search"
$Report += "- NoFSBackupFound    : SQL/Oracle backup found, but no matching FS backup found for the CI"
$Report += "- BackupType         : Derived from Cohesity environment/type metadata only"
$Report += "- BackupType         : PG name, object name, and display name are not used for BackupType"
$Report += "- SQL/Oracle         : kRegular/Regular is preferred; kLog/Log is ignored"
$Report += "- Cluster Selection  : Source/original row is preferred over replicated row"
$Report += "- Replication        : replicationSnapshotInfo marks a replicated/target row"
$Report += "- Fast Logic         : Global search identifies candidate clusterId first, then protected-object search runs only on candidate clusters"
$Report += "- Fallback           : All-cluster scan is used only when global search finds an object but does not return clusterId"
$Report += ""
$Report += "----------------------------------------------------------"
$Report += "Report Locations"
$Report += "----------------------------------------------------------"
$Report += "TXT Report            : $OutputTxt"
$Report += "Final CSV             : $OutputCsv"
$Report += "Validation CSV        : $ValidationCsv"
$Report += "=========================================================="

# ==========================================================
# Write TXT Report
# ==========================================================
$Report | Set-Content -Path $OutputTxt

# ==========================================================
# Display
# ==========================================================
Write-Host ""
Write-Host "=========================================================="
Write-Host "Cohesity Backup Validation Report"
Write-Host "=========================================================="
Write-Host "Change Number          : $ChangeID"
Write-Host "Executed By            : $ExecutedBy"
Write-Host "Run Date               : $(Get-Date -Format 'dd-MMM-yyyy HH:mm:ss')"
Write-Host ""
Write-Host "Total Input CIs        : $TotalInputCIs"
Write-Host "Total Backup Rows      : $TotalBackupRows"
Write-Host "Backed Up              : $BackedUp"
Write-Host "No Backup              : $NoBackup"
Write-Host "No FS Backup Found     : $NoFSBackupFound"
Write-Host "No Object              : $NoObject"
Write-Host ""
Write-Host "Global Search Calls    : $GlobalSearchCalls"
Write-Host "Protected Search Calls : $ProtectedSearchCalls"
Write-Host "Failed Protected GETs  : $FailedProtectedGets"
Write-Host "Fallback CI Count      : $FallbackCiCount"
Write-Host "Replication Source Adds: $ReplicationSourceAdds"
Write-Host ""
Write-Host "----------------------------------------------------------"
Write-Host "Details"
Write-Host "----------------------------------------------------------"
Write-Host ""
Write-Host $DetailsText
Write-Host ""
