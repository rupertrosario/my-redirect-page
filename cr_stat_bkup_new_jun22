    param($Json)

    if (-not $Json) {
        return @()
    }

    if ($Json -is [array]) {
        return @($Json)
    }

    foreach ($Prop in @("objects", "searchResults", "results", "entities", "data", "items")) {
        if ($Json.PSObject.Properties.Name -contains $Prop) {
            return @(AsArray $Json.$Prop | Where-Object { $_ })
        }
    }

    return @()
}

