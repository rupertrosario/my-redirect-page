function Test-SuccessStatus {
    param([string]$Status)

    if ([string]::IsNullOrWhiteSpace($Status)) {
        return $false
    }

    return ($Status -match '(?i)success|succeed|succeededwithwarning|warning')
}

function Test-RegularRunType {
    param([string]$RunType)

    if ([string]::IsNullOrWhiteSpace($RunType)) {
        return $AllowBlankRunTypeForDb
    }

    return ($RunType -match '(?i)regular|full|incr|incremental' -and $RunType -notmatch '(?i)log|archive')
}

function Get-RunTypeFromRun {
    param($Run)

    return Get-FirstText @(
        $Run.localBackupInfo.runType,
        $Run.originalBackupInfo.runType,
        $Run.runType
