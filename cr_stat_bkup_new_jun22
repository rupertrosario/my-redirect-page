$Report += "Protected Search Calls : $ProtectedSearchCalls"
$Report += "Failed Protected GETs  : $FailedProtectedGets"
$Report += "Fallback CI Count      : $FallbackCiCount"
$Report += "Replication Source Adds: $ReplicationSourceAdds"
$Report += ""
$Report += "----------------------------------------------------------"
$Report += "Details"
$Report += "----------------------------------------------------------"
$Report += ""
$Report += $DetailsText
$Report += ""
$Report += "----------------------------------------------------------"
$Report += "Summary Notes"
$Report += "----------------------------------------------------------"
$Report += "- Backed Up          : CI found with valid snapshot and backup time"
$Report += "- No Backup          : CI found in Cohesity but no usable snapshot time returned"
$Report += "- No Object          : CI not found in Cohesity search"
$Report += "- NoFSBackupFound    : SQL/Oracle backup found, but no matching FS/server backup found for the CI"
$Report += "- ObjectName         : For DBNAME@SERVERNAME, DB rows show DBNAME and FS rows show SERVERNAME"
$Report += "- BackupType         : Derived from Cohesity environment/type metadata only"
$Report += "- SQL/Oracle         : kRegular/Regular is preferred; kLog/Log is ignored"
$Report += "- Cluster Selection  : Source/original row is preferred over replicated row"
$Report += "- Replication        : replicationSnapshotInfo marks a replicated/target row"
$Report += "- DBNAME@SERVERNAME  : Other DBs on SERVERNAME are suppressed"
$Report += "- Fast Logic         : Global search identifies candidate clusterId first, then protected-object search runs only on candidate clusters"
$Report += "- Fallback           : All-cluster scan is used only when global search finds an object but does not return clusterId"
$Report += ""
$Report += "----------------------------------------------------------"
$Report += "Report Locations"
$Report += "----------------------------------------------------------"
$Report += "TXT Report            : $OutputTxt"
$Report += "Final CSV             : $OutputCsv"
$Report += "=========================================================="

# ==========================================================
# Write TXT Report
# ==========================================================
$Report | Set-Content -Path $OutputTxt

# ==========================================================
# Display
# ==========================================================
Write-Host ""
Write-Host "=========================================================="
