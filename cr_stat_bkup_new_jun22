# ==========================================================
# Cohesity Backup Validation – DISPLAY + TXT + CSV OUTPUT
# GET ONLY | SEARCH ONLY | FAST CLUSTER DISCOVERY
#
# - Reads CIs from CSV
# - Writes unique cleaned CIs to TXT in same location
# - Uses global search first to identify candidate clusterId + PG fallback
# - Searches protected-objects only on candidate clusters
# - Falls back to all clusters only if global search returns object but no clusterId
# - Displays full report on screen
# - Writes same report to TXT
# - Writes clean final CSV
# - Writes validation CSV with source/replica selection details
#
# BackupType:
# SQL / Oracle / FS / NAS / Hyper-V / Nutanix / VMware / Unknown
#
# Important logic:
# - BackupType is derived only from Cohesity environment/type metadata
# - PG name / object name / display name are NOT used for BackupType
# - SQL/Oracle prefer kRegular and ignore kLog
# - Source/original row is preferred over replicated row
# - Replicated row is detected by replicationSnapshotInfo
# - If SQL or Oracle backup exists, FS backup is also validated
# ==========================================================

$ErrorActionPreference = "Stop"
$FormatEnumerationLimit = -1
[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12

# -------------------------
# Input
# -------------------------
$ChangeID   = Read-Host "Enter Change Number"
$ExecutedBy = (whoami).Trim()

# -------------------------
# Paths
# -------------------------
$BaseDir   = "X:\PowerShell\Data\Cohesity\BackupValidation"
$InputCsv  = Join-Path $BaseDir "$ChangeID.csv"
$InputTxt  = Join-Path $BaseDir "$ChangeID.txt"
$TimeStamp = Get-Date -Format "yyyyMMdd_HHmm"

$OutputTxt     = Join-Path $BaseDir "${ChangeID}_BackupReport_$TimeStamp.txt"
$OutputCsv     = Join-Path $BaseDir "${ChangeID}_BackupReport_$TimeStamp.csv"
$ValidationCsv = Join-Path $BaseDir "${ChangeID}_BackupValidation_Details_$TimeStamp.csv"

if (-not (Test-Path $InputCsv)) {
    throw "CSV not found: $InputCsv"
}

# -------------------------
# API Key
# -------------------------
$ApiKeyPath = "X:\PowerShell\Cohesity_API_Scripts\DO_NOT_Delete\apikey.txt"

if (-not (Test-Path $ApiKeyPath)) {
    throw "API key file not found: $ApiKeyPath"
}

$ApiKey = (Get-Content -Path $ApiKeyPath -Raw).Trim()

# -------------------------
# API / Search Settings
# -------------------------
$BaseUrl = "https://helios.cohesity.com"

$GlobalSearchCount = 100

# Fast mode.
# If global search finds an object but cannot return clusterId, fallback to all clusters.
$EnableAllClusterFallback = $true

# Keep false for speed.
# Set true only if you want all-cluster scan even when global search returns no object.
$FallbackWhenNoGlobalObject = $false

# SQL/Oracle:
# true  = if runType is blank, allow timestamp because some responses do not expose runType
# false = only kRegular/Regular is accepted
$AllowBlankRunTypeForDb = $true

# Report time zone
$ReportTimeZoneId = "Eastern Standard Time"

# -------------------------
# Counters
# -------------------------
$GlobalSearchCalls      = 0
$ProtectedSearchCalls   = 0
$FallbackCiCount        = 0
$FailedProtectedGets    = 0
$ReplicationSourceAdds  = 0

# ==========================================================
# Basic Functions
# ==========================================================
function Invoke-HeliosJson {
    param(
        [Parameter(Mandatory = $true)][string]$Uri,
        [Parameter(Mandatory = $true)][hashtable]$Headers,
        [int]$TimeoutSec = 45,
        [switch]$Quiet
    )

    try {
        $r = Invoke-WebRequest `
            -UseBasicParsing `
            -Method Get `
            -Uri $Uri `
            -Headers $Headers `
            -TimeoutSec $TimeoutSec `
            -ErrorAction Stop

        if ([string]::IsNullOrWhiteSpace($r.Content)) {
            return $null
        }

        return ($r.Content | ConvertFrom-Json)
    }
    catch {
        if (-not $Quiet) {
            Write-Host "GET failed:" -ForegroundColor DarkRed
            Write-Host $Uri -ForegroundColor DarkRed
            Write-Host $_.Exception.Message -ForegroundColor DarkRed
        }

        return $null
    }
}

function AsArray {
    param($Value)

    if ($null -eq $Value) {
        return @()
    }

    if ($Value -is [array]) {
        return @($Value)
    }

    return @($Value)
}

function Get-FirstText {
    param($Value)

    if ($null -eq $Value) {
        return ""
    }

    if ($Value -is [array]) {
        foreach ($Item in $Value) {
            $Text = Get-FirstText $Item

            if (-not [string]::IsNullOrWhiteSpace($Text)) {
                return $Text
            }
        }

        return ""
    }

    if ($Value -is [pscustomobject]) {
        foreach ($Prop in @(
            "display_value",
            "displayName",
            "name",
            "value",
            "id",
            "uid",
            "clusterId",
            "clusterID",
            "sourceClusterId",
            "sourceClusterID",
            "accessClusterId",
            "intId"
        )) {
            if ($Value.PSObject.Properties.Name -contains $Prop) {
                $Text = Get-FirstText $Value.$Prop

                if (-not [string]::IsNullOrWhiteSpace($Text)) {
                    return $Text
                }
            }
        }

        return ""
    }

    return "$Value".Trim()
}

function Get-UsecsValue {
    param($Value)

    if ($null -eq $Value) {
        return $null
    }

    $Values = @()

    foreach ($Item in (AsArray $Value)) {
        if ($null -ne $Item -and "$Item".Trim() -ne "") {
            try {
                $Values += [int64]$Item
            }
            catch {}
        }
    }

    if ($Values.Count -eq 0) {
        return $null
    }

    return ($Values | Sort-Object -Descending | Select-Object -First 1)
}

function ToDate {
    param($Usecs)

    if (-not $Usecs) {
        return ""
    }

    try {
        $dto = [DateTimeOffset]::FromUnixTimeMilliseconds([int64]($Usecs / 1000))

        try {
            $tz = [System.TimeZoneInfo]::FindSystemTimeZoneById($ReportTimeZoneId)
            return ([System.TimeZoneInfo]::ConvertTime($dto, $tz)).ToString("dd-MMM-yyyy HH:mm:ss") + " ET"
        }
        catch {
            return $dto.LocalDateTime.ToString("dd-MMM-yyyy HH:mm:ss")
        }
    }
    catch {
        return ""
    }
}

function Is-ValidBackupTime {
    param([string]$LastBackupTime)

    return $LastBackupTime -notin @(
        "",
        $null,
        "NoBackup",
        "NoBackupTime",
        "NoObject",
        "NoFSBackupFound"
    )
}

