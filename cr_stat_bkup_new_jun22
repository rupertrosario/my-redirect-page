function Get-LatestRegularRun {
    param(
        [string]$PgId,
        [hashtable]$Headers,
        [switch]$IncludeObjectDetails
    )

    if ([string]::IsNullOrWhiteSpace($PgId)) {
        return $null
    }

    $page = 0
    $cookie = ""

    do {
        $page++

        $uri = "$BaseUrl/v2/data-protect/protection-groups/$PgId/runs" +
               "?numRuns=$NumRunsPerPg" +
               "&excludeNonRestorableRuns=false"

        if ($IncludeObjectDetails) {
            $uri += "&includeObjectDetails=true"
        }

        if (-not [string]::IsNullOrWhiteSpace($cookie)) {
            $uri += "&paginationCookie=$([uri]::EscapeDataString($cookie))"
        }

        $script:PgRunCalls++

        $json = Invoke-HeliosGetJson -Uri $uri -Headers $Headers -Quiet

        if (-not $json -or -not $json.runs) {
            return $null
        }

        $good = @()

        foreach ($run in (AsArray $json.runs)) {
            $status = Get-RunStatusFromRun $run
            $runType = Get-RunTypeFromRun $run
            $endUsecs = To-Int64Safe (Get-RunEndUsecsFromRun $run)

            if ($endUsecs -le 0) {
                continue
            }

            if (-not (Test-SuccessStatus $status)) {
                continue
            }

            if (-not (Test-RegularRunType $runType)) {
                continue
            }

            $good += [pscustomobject]@{
                Run      = $run
                EndUsecs = $endUsecs
            }
        }

        if ($good.Count -gt 0) {
            return ($good | Sort-Object EndUsecs -Descending | Select-Object -First 1).Run
        }

        $cookie = Get-FirstText $json.paginationCookie

        if ($json.isResponseTruncated -ne $true) {
            break
        }

    } while (-not [string]::IsNullOrWhiteSpace($cookie) -and $page -lt $MaxRunPagesPerPg)

    return $null
}

# ==========================================================
# Protected Object / Snapshot Helpers
# ==========================================================
function Get-SnapshotArray {
    param([object]$Obj)

    if (-not $Obj) {
        return @()
    }

    $snaps = @()
    $snaps += @(AsArray $Obj.latestSnapshotInfo)
    $snaps += @(AsArray $Obj.latestSnapshotsInfo)
    $snaps += @(AsArray $Obj.latestSnapshots)
    $snaps += @(AsArray $Obj.latestSnapshot)
    $snaps += @(AsArray $Obj.snapshotInfo)
    $snaps += @(AsArray $Obj.backupInfo)
    $snaps += @(AsArray $Obj.snapshots)

    return @($snaps | Where-Object { $_ })
}

function Get-SnapshotRunType {
    param([object]$Snap)

    return Get-FirstText @(
        $Snap.localBackupInfo.runType,
        $Snap.localBackupInfo.backupRunType,
        $Snap.originalBackupInfo.runType,
        $Snap.originalBackupInfo.backupRunType,
        $Snap.runType,
        $Snap.backupRunType,
        $Snap.snapshotRunType
    )
}

function Get-SnapshotUsecs {
    param([object]$Snap)

    if (-not $Snap) {
        return 0
    }

    foreach ($v in @(
        $Snap.protectionRunEndTimeUsecs,
        $Snap.runEndTimeUsecs,
        $Snap.endTimeUsecs,
        $Snap.snapshotCreationTimeUsecs,
        $Snap.creationTimeUsecs,
        $Snap.protectionRunStartTimeUsecs,
        $Snap.runStartTimeUsecs,
        $Snap.startTimeUsecs,
        $Snap.localBackupInfo.endTimeUsecs,
        $Snap.localBackupInfo.startTimeUsecs
    )) {
        $n = To-Int64Safe $v

        if ($n -gt 0) {
            return $n
        }
    }

    return 0
}

function Get-BestSnapshot {
    param(
        [object]$Obj,
        [string]$BackupType
    )

    $snaps = @(Get-SnapshotArray $Obj)

    if ($snaps.Count -eq 0) {
        return $null
    }

    if ($BackupType -in @("SQL", "Oracle")) {
        $regular = @($snaps | Where-Object {
            $rt = Get-SnapshotRunType $_
            Test-RegularRunType $rt
        })

        if ($regular.Count -gt 0) {
            return $regular |
                Sort-Object @{ Expression = { Get-SnapshotUsecs $_ }; Descending = $true } |
                Select-Object -First 1
        }

        return $null
    }

    $nonLog = @($snaps | Where-Object {
        $rt = Get-SnapshotRunType $_
        $rt -notmatch '(?i)log|archive'
    })

    if ($nonLog.Count -eq 0) {
        return $null
    }

    return $nonLog |
        Sort-Object @{ Expression = { Get-SnapshotUsecs $_ }; Descending = $true } |
        Select-Object -First 1
}

function Get-ObjectNameFromProtectedObject {
    param([object]$Obj)

    $name = Get-FirstText @(
        $Obj.name,
        $Obj.object.name,
        $Obj.objectName,
        $Obj.displayName,
        $Obj.hostName,
        $Obj.sourceName,
        $Obj.databaseName,
        $Obj.dbName,
        $Obj.dbUniqueName,
        $Obj.entity.name,
        $Obj.entity.displayName,
        $Obj.sourceInfo.name,
        $Obj.sourceInfo.displayName,
        $Obj.protectionSource.name,
        $Obj.protectionSource.displayName
    )

