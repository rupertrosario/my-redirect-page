function Get-LatestRegularRunWithObjects {
    param(
        [string]$PgId,
        [string]$ClusterId,
        [hashtable]$Headers
    )

    if ([string]::IsNullOrWhiteSpace($PgId)) {
        return $null
    }

    $cookie = ""
    $page = 0

    do {
        $page++

        $uri = "$BaseUrl/v2/data-protect/protection-groups/$PgId/runs" +
               "?includeObjectDetails=true" +
               "&excludeNonRestorableRuns=false" +
               "&numRuns=10"

        if (-not [string]::IsNullOrWhiteSpace($cookie)) {
            $uri += "&paginationCookie=$([uri]::EscapeDataString($cookie))"
        }

        $script:PgRunCalls++

        $json = Invoke-HeliosJson -Uri $uri -Headers $Headers -Quiet

        if (-not $json -or -not $json.runs) {
            return $null
        }

        $runs = @($json.runs | Where-Object { $_ })

        $candidateRuns = @()

        foreach ($run in $runs) {
            $rt = Get-RunTypeFromRun -Run $run
            $st = Get-RunStatusFromRun -Run $run
            $end = Get-RunEndUsecsFromRun -Run $run

            if (-not (Test-SuccessStatus -Status $st)) {
                continue
            }

            if (-not (Test-RegularRunType -RunType $rt)) {
                continue
            }

            $endNum = 0

            try {
                $endNum = [double]$end
            }
            catch {
                $endNum = 0
            }

            if ($endNum -le 0) {
                continue
            }

            $candidateRuns += [pscustomobject]@{
                Run     = $run
                EndUsecs = $endNum
            }
        }

        if ($candidateRuns.Count -gt 0) {
            return ($candidateRuns | Sort-Object EndUsecs -Descending | Select-Object -First 1).Run
        }

        $cookie = Get-FirstText $json.paginationCookie

        if ($json.isResponseTruncated -ne $true) {
            break
        }

    } while (-not [string]::IsNullOrWhiteSpace($cookie) -and $page -lt $RunPagesPerPg)

    return $null
}

function Get-SqlRowsFromRun {
    param(
        $Context,
        $Plan,
        $Run,
        [string]$ClusterName,
        [string]$ClusterId,
        [string]$PgName
    )

    $rows = @()

    if (-not $Run -or -not $Run.objects) {
        return @()
    }

    $runEndUsecs = Get-RunEndUsecsFromRun -Run $Run
    $runEndEt = ToDate $runEndUsecs

    $objs = @(AsArray $Run.objects)

    $hosts = @($objs | Where-Object {
        $_.object.environment -eq "kSQL" -and $_.object.objectType -ne "kDatabase"
    })

    $dbs = @($objs | Where-Object {
        $_.object.objectType -in @("kDatabase", "kSQL", "kSQLDB")
    })

    foreach ($db in $dbs) {

        $dbName = Get-FirstText @(
            $db.object.name,
            $db.object.displayName,
            $db.object.databaseName,
            $db.object.dbName,
            $db.object.dbUniqueName,
            $db.name
        )

        if ([string]::IsNullOrWhiteSpace($dbName)) {
            continue
        }

        $parentHost = $hosts | Where-Object {
            "$($_.object.id)" -eq "$($db.object.sourceId)"
        } | Select-Object -First 1

        $hostName = ""
        if ($parentHost) {
            $hostName = Get-FirstText @(
                $parentHost.object.name,
                $parentHost.object.displayName,
                $parentHost.name
            )
        }

        # DBNAME@SERVERNAME: keep only DBNAME.
        if ($Context.IsDbAtServer) {
            if (-not (Text-MatchesName -Text $dbName -Name $Context.DbName)) {
                continue
            }
        }
        else {
            # Normal CI:
            # keep if DB matches input OR host matches input OR PG search matched.
            $dbMatches = Text-MatchesName -Text $dbName -Name $Context.InputCI
            $hostMatches = Text-MatchesName -Text $hostName -Name $Context.InputCI

            if (-not $dbMatches -and -not $hostMatches) {
                # still allow if this came from a targeted search and object detail exists
                # but avoid too much noise by requiring at least plan target match in host/db if available
                continue
            }
        }

        $rows += [pscustomobject]@{
            InputCI                    = $Context.InputCI
            BackupType                 = "SQL"
            ObjectName                 = $dbName
            ClusterName                = $ClusterName
            ClusterId                  = $ClusterId
            ProtectionGroup            = $PgName
            LastBackupTime             = if ($runEndEt) { $runEndEt } else { "NoBackupTime" }
            LastBackupUsecs            = if ($runEndUsecs) { [int64]$runEndUsecs } else { 0 }
            IsReplicatedCopy           = $false
            ReplicationSourceClusterId = ""
            HostName                   = $hostName
            DetailSource               = "TargetedPgRun"
        }
    }

    return @($rows)
}

function Get-OracleDbRowsFromPgDetails {
    param(
        $Context,
        $Plan,
        $Pg,
        [string]$ClusterName,
        [string]$ClusterId,
        [string]$PgName,
        [string]$LastRegularBackupTime,
        [int64]$LastRegularUsecs
    )

    $rows = @()

    if (-not $Pg) {
        return @()
    }

    $persistMountPoints = Get-FirstText @(
        $Pg.oracleParams.persistMountPoints,
        $Pg.oracleParams.persistMountpoints
    )

    foreach ($obj in (AsArray $Pg.oracleParams.objects)) {

        $dbParams = @(AsArray $obj.dbParams)

        if ($dbParams.Count -eq 0) {

            $dbName = Get-FirstText @(
                $obj.databaseName,
                $obj.databaseUniqueName,
                $obj.dbUniqueName,
                $obj.name
            )

            if ([string]::IsNullOrWhiteSpace($dbName)) {
                continue
            }

            if ($Context.IsDbAtServer -and -not (Text-MatchesName -Text $dbName -Name $Context.DbName)) {
                continue
            }

            if (-not $Context.IsDbAtServer) {
                if (-not (Text-MatchesName -Text $dbName -Name $Context.InputCI)) {
                    continue
                }
            }

            $rows += [pscustomobject]@{
                InputCI                    = $Context.InputCI
                BackupType                 = "Oracle"
                ObjectName                 = $dbName
                ClusterName                = $ClusterName
                ClusterId                  = $ClusterId
                ProtectionGroup            = $PgName
                LastBackupTime             = if ($LastRegularBackupTime) { $LastRegularBackupTime } else { "NoBackup" }
                LastBackupUsecs            = $LastRegularUsecs
                IsReplicatedCopy           = $false
                ReplicationSourceClusterId = ""
                HostName                   = Get-FirstText @($obj.sourceName, $obj.SourceName)
                DetailSource               = "TargetedPgDetails"
            }

            continue
        }

        foreach ($dbParam in $dbParams) {

            $dbChannels = @()

            if ($dbParam.dbChannels.dbChannel) {
                $dbChannels += @(AsArray $dbParam.dbChannels.dbChannel)
            }
            elseif ($dbParam.dbChannels) {
                $dbChannels += @(AsArray $dbParam.dbChannels)
            }

            if ($dbChannels.Count -eq 0) {

                $dbName = Get-FirstText @(
                    $dbParam.databaseName,
                    $dbParam.databaseUniqueName,
                    $obj.databaseUniqueName,
                    $obj.dbUniqueName,
                    $obj.name
                )

                if ([string]::IsNullOrWhiteSpace($dbName)) {
                    continue
                }

                if ($Context.IsDbAtServer -and -not (Text-MatchesName -Text $dbName -Name $Context.DbName)) {
                    continue
                }

                if (-not $Context.IsDbAtServer) {
                    if (-not (Text-MatchesName -Text $dbName -Name $Context.InputCI)) {
                        continue
                    }
                }

                $rows += [pscustomobject]@{
                    InputCI                    = $Context.InputCI
                    BackupType                 = "Oracle"
                    ObjectName                 = $dbName
                    ClusterName                = $ClusterName
                    ClusterId                  = $ClusterId
                    ProtectionGroup            = $PgName
                    LastBackupTime             = if ($LastRegularBackupTime) { $LastRegularBackupTime } else { "NoBackup" }
                    LastBackupUsecs            = $LastRegularUsecs
                    IsReplicatedCopy           = $false
                    ReplicationSourceClusterId = ""
                    HostName                   = Get-FirstText @($obj.sourceName, $obj.SourceName, $dbParam.sourceName, $dbParam.SourceName)
                    DetailSource               = "TargetedPgDetails"
                }

                continue
            }

            foreach ($channel in $dbChannels) {

                $dbName = Get-FirstText @(
                    $channel.databaseUniqueName,
                    $channel.databaseName,
                    $dbParam.databaseUniqueName,
                    $dbParam.databaseName,
                    $obj.databaseUniqueName,
                    $obj.dbUniqueName,
                    $obj.name
                )

                if ([string]::IsNullOrWhiteSpace($dbName)) {
                    continue
                }

                if ($Context.IsDbAtServer -and -not (Text-MatchesName -Text $dbName -Name $Context.DbName)) {
                    continue
                }

                if (-not $Context.IsDbAtServer) {
                    if (-not (Text-MatchesName -Text $dbName -Name $Context.InputCI)) {
                        continue
                    }
                }

                $rows += [pscustomobject]@{
                    InputCI                    = $Context.InputCI
                    BackupType                 = "Oracle"
                    ObjectName                 = $dbName
                    ClusterName                = $ClusterName
                    ClusterId                  = $ClusterId
                    ProtectionGroup            = $PgName
                    LastBackupTime             = if ($LastRegularBackupTime) { $LastRegularBackupTime } else { "NoBackup" }
                    LastBackupUsecs            = $LastRegularUsecs
                    IsReplicatedCopy           = $false
                    ReplicationSourceClusterId = ""
                    HostName                   = Get-FirstText @($obj.sourceName, $obj.SourceName, $dbParam.sourceName, $dbParam.SourceName)
                    DetailSource               = "TargetedPgDetails"
                }
            }
        }
    }

    return @($rows)
}

function Get-ProtectionGroupDetails {
    param(
        [string]$PgId,
        [string]$Environment,
        [hashtable]$Headers
    )

    if ([string]::IsNullOrWhiteSpace($PgId)) {
        return $null
    }

    $uris = @(
        "$BaseUrl/v2/data-protect/protection-groups/$PgId",
        "$BaseUrl/v2/data-protect/protection-groups?ids=$([uri]::EscapeDataString($PgId))&environments=$([uri]::EscapeDataString($Environment))&includeLastRunInfo=true"
    )

    foreach ($uri in $uris) {
        $script:PgDetailCalls++

        $json = Invoke-HeliosJson -Uri $uri -Headers $Headers -Quiet

        if (-not $json) {
            continue
        }

        if ($json.protectionGroups) {
            $pg = @($json.protectionGroups | Where-Object { $_ }) | Select-Object -First 1
            if ($pg) { return $pg }
        }

        if ($json.id -or $json.name -or $json.oracleParams) {
            return $json
        }
    }

    return $null
}

function Get-LatestRegularRunInfo {
    param(
        [string]$PgId,
        [hashtable]$Headers
    )

    $run = Get-LatestRegularRunWithObjects -PgId $PgId -ClusterId "" -Headers $Headers

    if (-not $run) {
        return [pscustomobject]@{
            Run       = $null
            EndUsecs  = 0
            EndTimeET = ""
        }
    }

    $end = Get-RunEndUsecsFromRun -Run $run
    $endNum = 0

    try {
        $endNum = [int64]$end
    }
    catch {
        $endNum = 0
    }

    return [pscustomobject]@{
        Run       = $run
        EndUsecs  = $endNum
        EndTimeET = ToDate $end
    }
}

