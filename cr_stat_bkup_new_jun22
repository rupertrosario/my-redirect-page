# ==========================================================
# Basic Helpers
# ==========================================================
function Invoke-HeliosJson {
    param(
        [Parameter(Mandatory = $true)][string]$Uri,
        [Parameter(Mandatory = $true)][hashtable]$Headers,
        [int]$TimeoutSec = 45,
        [switch]$Quiet
    )

    try {
        $resp = Invoke-WebRequest `
            -UseBasicParsing `
            -Method Get `
            -Uri $Uri `
            -Headers $Headers `
            -TimeoutSec $TimeoutSec `
            -ErrorAction Stop

        if (-not $resp -or [string]::IsNullOrWhiteSpace($resp.Content)) {
            return $null
        }

        return ($resp.Content | ConvertFrom-Json)
    }
    catch {
        $script:FailedGets++

        if (-not $Quiet) {
            Write-Host "GET failed:" -ForegroundColor DarkRed
            Write-Host $Uri -ForegroundColor DarkRed
            Write-Host $_.Exception.Message -ForegroundColor DarkRed
        }

        return $null
    }
}

function AsArray {
    param($Value)

    if ($null -eq $Value) {
        return @()
    }

    if ($Value -is [array]) {
        return @($Value)
    }

    return @($Value)
}

function Get-FirstText {
    param($Value)

    if ($null -eq $Value) {
        return ""
    }

    if ($Value -is [array]) {
        foreach ($Item in $Value) {
            $Text = Get-FirstText $Item

            if (-not [string]::IsNullOrWhiteSpace($Text)) {
                return "$Text".Trim()
            }
        }

        return ""
    }

    if ($Value -is [pscustomobject]) {
        foreach ($Prop in @(
            "display_value",
            "displayName",
            "name",
            "value",
            "id",
            "uid",
            "clusterId",
            "clusterID",
            "sourceClusterId",
            "sourceClusterID",
            "accessClusterId",
            "intId"
        )) {
            if ($Value.PSObject.Properties.Name -contains $Prop) {
                $Text = Get-FirstText $Value.$Prop

                if (-not [string]::IsNullOrWhiteSpace($Text)) {
                    return "$Text".Trim()
                }
            }
        }

        return ""
    }

    return "$Value".Trim()
}

function Add-UniqueText {
    param(
        [System.Collections.ArrayList]$List,
        [string]$Value
    )

    $v = "$Value".Trim().Trim('"').Trim("'")

    if (-not [string]::IsNullOrWhiteSpace($v)) {
        if (-not $List.Contains($v)) {
            [void]$List.Add($v)
        }
    }
}

function Normalize-Key {
    param([string]$Value)

    if ([string]::IsNullOrWhiteSpace($Value)) {
        return ""
    }

    return "$Value".Trim().ToUpper()
}

function Text-MatchesName {
    param(
        [string]$Text,
        [string]$Name
    )

    $t = "$Text".ToLower().Trim()
    $n = "$Name".ToLower().Trim()

    if ([string]::IsNullOrWhiteSpace($t) -or [string]::IsNullOrWhiteSpace($n)) {
        return $false
    }

    if ($t -eq $n) { return $true }
    if ($t -like "*$n*") { return $true }
    if ($n -like "*$t*") { return $true }

    # Compare FQDN short name.
    if ($t -match "\.") {
        $short = ($t -split "\.")[0]
        if ($short -eq $n) { return $true }
    }

    if ($n -match "\.") {
        $short2 = ($n -split "\.")[0]
        if ($short2 -eq $t) { return $true }
    }

    return $false
}

function Get-UsecsValue {
    param($Value)

    if ($null -eq $Value) {
        return $null
    }

    $values = @()

    foreach ($item in (AsArray $Value)) {
        if ($null -ne $item -and "$item".Trim() -ne "") {
            try {
                $values += [int64]$item
            }
            catch {}
        }
    }

    if ($values.Count -eq 0) {
        return $null
    }

    return ($values | Sort-Object -Descending | Select-Object -First 1)
}

function ToDate {
    param($Usecs)

    if ($null -eq $Usecs -or "$Usecs".Trim() -eq "" -or "$Usecs" -eq "0") {
        return ""
    }

    try {
        $dto = [DateTimeOffset]::FromUnixTimeMilliseconds([int64]($Usecs / 1000))

        try {
            $tz = [System.TimeZoneInfo]::FindSystemTimeZoneById($ReportTimeZoneId)
            return ([System.TimeZoneInfo]::ConvertTime($dto, $tz)).ToString("dd-MMM-yyyy HH:mm:ss") + " ET"
        }
        catch {
            return $dto.LocalDateTime.ToString("dd-MMM-yyyy HH:mm:ss")
        }
    }
    catch {
        return ""
    }
}

function Is-ValidBackupTime {
    param([string]$LastBackupTime)

    return $LastBackupTime -notin @(
        "",
        $null,
        "NoBackup",
        "NoBackupTime",
        "NoObject",
        "NoFSBackupFound",
        "NoDbDetailFound"
    )
}

# ==========================================================
# CI Context / Search Plans
# ==========================================================
function Get-CiContext {
    param([string]$Ci)

    $CleanCi = "$Ci".Trim().Trim('"').Trim("'")

    $IsDbAtServer = $false
    $DbName = ""
    $ServerName = ""

    if ($CleanCi -match "@") {
        $Parts = $CleanCi -split "@", 2

        $DbName = "$($Parts[0])".Trim()
        $ServerName = "$($Parts[1])".Trim()

        if (-not [string]::IsNullOrWhiteSpace($DbName) -and -not [string]::IsNullOrWhiteSpace($ServerName)) {
            $IsDbAtServer = $true
        }
    }

    return [pscustomobject]@{
        InputCI      = $CleanCi
        IsDbAtServer = $IsDbAtServer
        DbName       = $DbName
        ServerName   = $ServerName
    }
}

function Get-SearchPlans {
    param($Context)

    $plans = @()

    if ($Context.IsDbAtServer) {

        $plans += [pscustomobject]@{
            SearchTerm     = $Context.DbName
            Environment    = "kSQL"
            BackupTypeHint = "SQL"
            Role           = "DB"
            TargetName     = $Context.DbName
        }

        $plans += [pscustomobject]@{
            SearchTerm     = $Context.DbName
            Environment    = "kOracle"
            BackupTypeHint = "Oracle"
            Role           = "DB"
            TargetName     = $Context.DbName
        }

        $plans += [pscustomobject]@{
            SearchTerm     = $Context.ServerName
            Environment    = "kPhysical"
            BackupTypeHint = "FS"
            Role           = "Server"
            TargetName     = $Context.ServerName
        }

        return @($plans)
    }

    # Normal CI:
    # Best-effort. Search FS + SQL + Oracle only.
    # This avoids NAS/VM/Hyper-V/Nutanix expansion for now.
    $plans += [pscustomobject]@{
        SearchTerm     = $Context.InputCI
        Environment    = "kPhysical"
        BackupTypeHint = "FS"
        Role           = "Server"
        TargetName     = $Context.InputCI
    }

    $plans += [pscustomobject]@{
        SearchTerm     = $Context.InputCI
        Environment    = "kSQL"
        BackupTypeHint = "SQL"
        Role           = "DBOrServer"
        TargetName     = $Context.InputCI
    }

    $plans += [pscustomobject]@{
        SearchTerm     = $Context.InputCI
        Environment    = "kOracle"
        BackupTypeHint = "Oracle"
        Role           = "DBOrServer"
        TargetName     = $Context.InputCI
    }

    return @($plans)
}

function New-SearchUrl {
    param(
        [string]$Endpoint,
        [string]$SearchTerm,
        [string]$Environment,
        [switch]$Global
    )

    $url = "$BaseUrl$Endpoint" +
           "?searchString=$([uri]::EscapeDataString($SearchTerm))"

    if (-not [string]::IsNullOrWhiteSpace($Environment)) {
        $url += "&environments=$([uri]::EscapeDataString($Environment))"
    }

    if ($Global) {
        $url += "&includeTenants=true"
        $url += "&count=$GlobalSearchCount"
    }

    return $url
}

