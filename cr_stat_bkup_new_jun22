function Add-Candidate {
    param(
        [System.Collections.ArrayList]$List,
        [hashtable]$Seen,
        [string]$ClusterId,
        [string]$ClusterName,
        [string]$PgId,
        [string]$PgName,
        [string]$SearchMode
    )

    if ([string]::IsNullOrWhiteSpace($ClusterId)) {
        return
    }

    if ([string]::IsNullOrWhiteSpace($ClusterName)) {
        $ClusterName = $ClusterId
    }

    if ([string]::IsNullOrWhiteSpace($PgId)) {
        $PgId = ""
    }

    if ([string]::IsNullOrWhiteSpace($PgName)) {
        $PgName = "-"
    }

    $key = "$ClusterId|$PgId|$PgName"

    if ($Seen.ContainsKey($key)) {
        return
    }

    $Seen[$key] = $true

    [void]$List.Add([pscustomobject]@{
        ClusterId   = "$ClusterId"
        ClusterName = "$ClusterName"
        PgId        = "$PgId"
        PgName      = "$PgName"
        SearchMode  = "$SearchMode"
    })
}

function Get-CandidatesFromGlobalSearch {
    param(
        $Json,
        [hashtable]$ClusterMap
    )

    $list = New-Object System.Collections.ArrayList
    $seen = @{}

    foreach ($obj in (Get-ObjectArrayFromJson -Json $Json)) {

        foreach ($opi in (AsArray $obj.objectProtectionInfos)) {

            $hasPg = $false

            foreach ($pg in (AsArray $opi.protectionGroups)) {
                $hasPg = $true

                $cid = Get-ClusterIdFromNode -Obj $obj -ProtectionInfo $opi -Pg $pg
                $cname = Get-ClusterNameFromNode -Obj $obj -ProtectionInfo $opi -Pg $pg -ClusterId $cid -ClusterMap $ClusterMap
                $pgid = Get-PgIdFromNode -Obj $obj -ProtectionInfo $opi -Pg $pg
                $pgname = Get-PgNameFromNode -Obj $obj -ProtectionInfo $opi -Pg $pg

                Add-Candidate -List $list -Seen $seen -ClusterId $cid -ClusterName $cname -PgId $pgid -PgName $pgname -SearchMode "Global"
            }

            if (-not $hasPg) {
                $cid = Get-ClusterIdFromNode -Obj $obj -ProtectionInfo $opi -Pg $null
                $cname = Get-ClusterNameFromNode -Obj $obj -ProtectionInfo $opi -Pg $null -ClusterId $cid -ClusterMap $ClusterMap
                $pgid = Get-PgIdFromNode -Obj $obj -ProtectionInfo $opi -Pg $null
                $pgname = Get-PgNameFromNode -Obj $obj -ProtectionInfo $opi -Pg $null

                Add-Candidate -List $list -Seen $seen -ClusterId $cid -ClusterName $cname -PgId $pgid -PgName $pgname -SearchMode "Global"
            }
        }

        foreach ($pg2 in (AsArray $obj.protectionGroups)) {
            $cid = Get-ClusterIdFromNode -Obj $obj -ProtectionInfo $null -Pg $pg2
            $cname = Get-ClusterNameFromNode -Obj $obj -ProtectionInfo $null -Pg $pg2 -ClusterId $cid -ClusterMap $ClusterMap
            $pgid = Get-PgIdFromNode -Obj $obj -ProtectionInfo $null -Pg $pg2
            $pgname = Get-PgNameFromNode -Obj $obj -ProtectionInfo $null -Pg $pg2

            Add-Candidate -List $list -Seen $seen -ClusterId $cid -ClusterName $cname -PgId $pgid -PgName $pgname -SearchMode "Global"
        }

        $cidObj = Get-ClusterIdFromNode -Obj $obj -ProtectionInfo $null -Pg $null
        if (-not [string]::IsNullOrWhiteSpace($cidObj)) {
            $cnameObj = Get-ClusterNameFromNode -Obj $obj -ProtectionInfo $null -Pg $null -ClusterId $cidObj -ClusterMap $ClusterMap
            $pgidObj = Get-PgIdFromNode -Obj $obj -ProtectionInfo $null -Pg $null
            $pgnameObj = Get-PgNameFromNode -Obj $obj -ProtectionInfo $null -Pg $null

            Add-Candidate -List $list -Seen $seen -ClusterId $cidObj -ClusterName $cnameObj -PgId $pgidObj -PgName $pgnameObj -SearchMode "Global"
        }
    }

    return @($list)
}

# ==========================================================
# Backup Type / Snapshot Helpers
# ==========================================================
function Get-EnvironmentText {
    param($Obj, $Snapshot)

    $candidates = @()

    if ($Obj) {
        $candidates += $Obj.environment
        $candidates += $Obj.object.environment
        $candidates += $Obj.object.objectType
        $candidates += $Obj.objectType
        $candidates += $Obj.type
        $candidates += $Obj.protectionType
        $candidates += $Obj.sourceInfo.environment
        $candidates += $Obj.sourceInfo.type
        $candidates += $Obj.protectionSource.environment
        $candidates += $Obj.protectionSource.type
        $candidates += $Obj.entity.environment
        $candidates += $Obj.entity.type
        $candidates += $Obj.latestSnapshotInfo.environment
        $candidates += $Obj.latestSnapshotInfo.objectType
    }

    if ($Snapshot) {
        $candidates += $Snapshot.environment
        $candidates += $Snapshot.objectType
        $candidates += $Snapshot.type
        $candidates += $Snapshot.sourceInfo.environment
        $candidates += $Snapshot.sourceInfo.type
    }

    $text = @()

    foreach ($c in $candidates) {
        $t = Get-FirstText $c
        if (-not [string]::IsNullOrWhiteSpace($t)) {
            $text += $t.ToLower()
        }
    }

    return ($text -join " ")
}

function Get-BackupType {
    param(
        $Obj,
        $Snapshot,
        [string]$BackupTypeHint
    )

    $all = Get-EnvironmentText -Obj $Obj -Snapshot $Snapshot

    if ($all -match "ksql|mssql|sqlserver|sql server|\bsql\b") {
        return "SQL"
    }

    if ($all -match "koracle|\boracle\b") {
        return "Oracle"
    }

    if ($all -match "kphysical|physical|filesystem|file_system|file system|volume|windows|linux") {
        return "FS"
    }

    if (-not [string]::IsNullOrWhiteSpace($BackupTypeHint)) {
        return $BackupTypeHint
    }

    return "Unknown"
}

function Get-SnapshotCandidates {
    param($Obj)

    if (-not $Obj) {
        return @()
    }

    $snaps = @()
    $snaps += @(AsArray $Obj.latestSnapshotInfo)
    $snaps += @(AsArray $Obj.latestSnapshotsInfo)
    $snaps += @(AsArray $Obj.latestSnapshots)
    $snaps += @(AsArray $Obj.latestSnapshot)
    $snaps += @(AsArray $Obj.snapshotInfo)
    $snaps += @(AsArray $Obj.backupInfo)
    $snaps += @(AsArray $Obj.snapshots)

    return @($snaps | Where-Object { $_ })
}

function Get-SnapshotUsecs {
    param($Snapshot)

    if (-not $Snapshot) {
        return $null
    }

    foreach ($field in @(
        $Snapshot.protectionRunEndTimeUsecs,
        $Snapshot.runEndTimeUsecs,
        $Snapshot.endTimeUsecs,
        $Snapshot.snapshotCreationTimeUsecs,
        $Snapshot.creationTimeUsecs,
        $Snapshot.protectionRunStartTimeUsecs,
        $Snapshot.runStartTimeUsecs,
        $Snapshot.startTimeUsecs
    )) {
        $u = Get-UsecsValue $field
        if ($u) { return $u }
    }

    foreach ($lbi in (AsArray $Snapshot.localBackupInfo)) {
        foreach ($field in @($lbi.endTimeUsecs, $lbi.startTimeUsecs)) {
            $u = Get-UsecsValue $field
            if ($u) { return $u }
        }
    }

    return $null
}

function Get-SnapshotRunType {
    param($Snapshot)

    if (-not $Snapshot) {
        return ""
    }

    $rt = Get-FirstText @(
        $Snapshot.localBackupInfo.runType,
        $Snapshot.localBackupInfo.backupRunType,
        $Snapshot.originalBackupInfo.runType,
        $Snapshot.originalBackupInfo.backupRunType,
        $Snapshot.runType,
        $Snapshot.backupRunType,
        $Snapshot.snapshotRunType
    )

    if (-not [string]::IsNullOrWhiteSpace($rt)) {
        return $rt
    }

    foreach ($lbi in (AsArray $Snapshot.localBackupInfo)) {
        $rt2 = Get-FirstText @($lbi.runType, $lbi.backupRunType)
        if (-not [string]::IsNullOrWhiteSpace($rt2)) {
            return $rt2
        }
    }

    return ""
}

function Get-BestSnapshot {
    param(
        $Obj,
        [string]$BackupType
    )

    $snaps = @(Get-SnapshotCandidates -Obj $Obj)

    if (-not $snaps -or $snaps.Count -eq 0) {
        return $null
    }

    if ($BackupType -in @("SQL", "Oracle")) {

        $regular = @($snaps | Where-Object {
            ((Get-SnapshotRunType $_).ToLower() -match "kregular|regular")
        })

        if ($regular.Count -gt 0) {
            return $regular |
                Sort-Object @{ Expression = { [int64](Get-SnapshotUsecs $_) }; Descending = $true } |
                Select-Object -First 1
        }

        $nonLog = @($snaps | Where-Object {
            $rt = (Get-SnapshotRunType $_).ToLower()

            if ($rt -match "klog|\blog\b") {
                $false
            }
            elseif ([string]::IsNullOrWhiteSpace($rt) -and $AllowBlankRunTypeForDb) {
                $true
            }
            else {
                $false
            }
        })

        if ($nonLog.Count -gt 0) {
            return $nonLog |
                Sort-Object @{ Expression = { [int64](Get-SnapshotUsecs $_) }; Descending = $true } |
                Select-Object -First 1
        }

        return $null
    }

    $allowed = @($snaps | Where-Object {
        ((Get-SnapshotRunType $_).ToLower() -notmatch "klog|\blog\b")
    })

    if ($allowed.Count -eq 0) {
        return $null
    }

    return $allowed |
        Sort-Object @{ Expression = { [int64](Get-SnapshotUsecs $_) }; Descending = $true } |
        Select-Object -First 1
}

function Get-ObjectNameFromProtectedObject {
    param($Obj)

