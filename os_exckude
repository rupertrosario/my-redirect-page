# =========================
# Cohesity Helios - Users + Groups
# Uses:
#   /irisservices/api/v1/public/users?includeTenantInfo=true&allUnderHierarchy=true
#   /irisservices/api/v1/public/groups?includeTenantInfo=true&allUnderHierarchy=true
# =========================

# --- API key path ---
$apiKeyPath = "X:\Powershell\Cohesity\API Scripts\DO NOT Delete\apikey.txt"
if (-not (Test-Path $apiKeyPath)) {
    throw "API key file not found: $apiKeyPath"
}
$apiKey = (Get-Content -Path $apiKeyPath -Raw).Trim()

# --- Headers ---
$headers = @{
    accept = "application/json"
    apiKey = $apiKey
}

# --- URLs ---
$usersUrl  = "https://helios.cohesity.com/irisservices/api/v1/public/users?includeTenantInfo=true&allUnderHierarchy=true"
$groupsUrl = "https://helios.cohesity.com/irisservices/api/v1/public/groups?includeTenantInfo=true&allUnderHierarchy=true"

function Invoke-HeliosGet {
    param(
        [Parameter(Mandatory)][string]$Uri,
        [Parameter(Mandatory)][hashtable]$Headers
    )

    try {
        $resp = Invoke-RestMethod -Method Get -Uri $Uri -Headers $Headers -TimeoutSec 60 -ErrorAction Stop
        return $resp
    }
    catch {
        Write-Host "Failed: $Uri" -ForegroundColor Red
        Write-Host $_.Exception.Message -ForegroundColor Yellow
        return @()
    }
}

# --- Get data ---
$usersRaw  = Invoke-HeliosGet -Uri $usersUrl  -Headers $headers
$groupsRaw = Invoke-HeliosGet -Uri $groupsUrl -Headers $headers

# Normalize in case single object comes back
if ($null -eq $usersRaw)  { $usersRaw  = @() }
if ($null -eq $groupsRaw) { $groupsRaw = @() }
if ($usersRaw  -isnot [System.Collections.IEnumerable] -or $usersRaw  -is [string]) { $usersRaw  = @($usersRaw) }
if ($groupsRaw -isnot [System.Collections.IEnumerable] -or $groupsRaw -is [string]) { $groupsRaw = @($groupsRaw) }

# --- Flatten USERS ---
$userResults = foreach ($u in $usersRaw) {
    [PSCustomObject]@{
        RecordType = "User"
        Name       = $u.username          # username for user
        Domain     = $u.domain
        Roles      = if ($u.roles) { ($u.roles -join ", ") } else { "" }
        Tenant     = if ($u.tenantInfo) { $u.tenantInfo.name } else { "" }
        Members    = ""
    }
}

# --- Flatten GROUPS ---
$groupResults = foreach ($g in $groupsRaw) {

    $groupUsers =
        if ($g.users) {
            if ($g.users -is [System.Array]) {
                ($g.users | ForEach-Object {
                    if ($_ -is [string]) { $_ }
                    elseif ($_.username) { $_.username }
                    elseif ($_.name) { $_.name }
                    else { $_ | Out-String }
                }) -join ", "
            }
            else {
                if ($g.users -is [string]) { $g.users }
                elseif ($g.users.username) { $g.users.username }
                elseif ($g.users.name) { $g.users.name }
                else { $g.users | Out-String }
            }
        }
        else { "" }

    [PSCustomObject]@{
        RecordType = "Group"
        Name       = $g.name
        Domain     = $g.domain
        Roles      = if ($g.roles) { ($g.roles -join ", ") } else { "" }
        Tenant     = if ($g.tenantInfo) { $g.tenantInfo.name } else { "" }
        Members    = $groupUsers         # users for group
    }
}

# --- Combined output ---
$results = @($userResults) + @($groupResults)

$results |
    Sort-Object RecordType, Name |
    Format-Table RecordType, Name, Domain, Roles, Tenant, Members -AutoSize
