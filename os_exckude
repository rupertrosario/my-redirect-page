# ============================================
# Cohesity Users and Groups Inventory
# GET-only | All clusters | CSV output
# ============================================

# ---------- API KEY ----------
$apikeypath = "X:\PowerShell\Cohesity_API_Scripts\DO_NOT_Delete\apikey.txt"
$ApiKey = (Get-Content $apikeypath -Raw).Trim()

$commonHeaders = @{
    accept = "application/json"
    apiKey = $ApiKey
}

# ---------- OUTPUT ----------
$reportDate = Get-Date -Format "yyyy-MM-dd_HHmm"

$userDetailCsv  = "X:\PowerShell\Data\Cohesity\Alerts\Cluster_User_Details_$reportDate.csv"
$userUniqueCsv  = "X:\PowerShell\Data\Cohesity\Alerts\Unique_User_Consolidated_$reportDate.csv"
$groupDetailCsv = "X:\PowerShell\Data\Cohesity\Alerts\Cluster_Group_Details_$reportDate.csv"
$groupUniqueCsv = "X:\PowerShell\Data\Cohesity\Alerts\Unique_Group_Consolidated_$reportDate.csv"

$userResults = @()
$groupResults = @()
$nonWorkingClusters = @()

# ---------- GET CLUSTERS ----------
$url = "https://helios.cohesity.com/v2/mcm/cluster-mgmt/info"
$clusters = (Invoke-RestMethod -Method Get -Uri $url -Headers $commonHeaders).cohesityClusters

foreach ($clus in $clusters) {

    $clusterName = $clus.clusterName
    $clusterId   = $clus.clusterId

    $headers = @{
        accept = "application/json"
        apiKey = $ApiKey
        accessClusterId = $clusterId
    }

    $clusterErrors = @()

    # ---------- USERS ----------
    try {
        $usersUrl  = "https://helios.cohesity.com/irisservices/api/v1/public/users"
        $usersResp = Invoke-RestMethod -Method Get -Uri $usersUrl -Headers $headers -ErrorAction Stop
        $users     = if ($usersResp.users) { $usersResp.users } else { $usersResp }

        foreach ($u in $users) {
            $name   = $u.user
            $domain = $u.domain
            $roles  = if ($u.roles -is [System.Array]) { $u.roles -join ", " } else { "$($u.roles)" }

            if ($name) {
                $userResults += [PSCustomObject]@{
                    Cluster = $clusterName
                    User    = $name
                    Domain  = $domain
                    Roles   = $roles
                }
            }
        }
    }
    catch {
        $clusterErrors += "Users API failed: $($_.Exception.Message)"
    }

    # ---------- GROUPS ----------
    try {
        $groupsUrl  = "https://helios.cohesity.com/irisservices/api/v1/public/groups"
        $groupsResp = Invoke-RestMethod -Method Get -Uri $groupsUrl -Headers $headers -ErrorAction Stop
        $groups     = if ($groupsResp.groups) { $groupsResp.groups } elseif ($groupsResp.groupVec) { $groupsResp.groupVec } else { $groupsResp }

        foreach ($g in $groups) {
            $name   = $g.username
            $domain = $g.domain
            $roles  = if ($g.roles -is [System.Array]) { $g.roles -join ", " } else { "$($g.roles)" }

            if ($name) {
                $groupResults += [PSCustomObject]@{
                    Cluster = $clusterName
                    Group   = $name
                    Domain  = $domain
                    Roles   = $roles
                }
            }
        }
    }
    catch {
        $clusterErrors += "Groups API failed: $($_.Exception.Message)"
    }

    # ---------- NON-WORKING CLUSTERS ----------
    if ($clusterErrors.Count -gt 0) {
        $nonWorkingClusters += [PSCustomObject]@{
            Cluster = $clusterName
            Reason  = ($clusterErrors -join " | ")
        }
    }
}

# ---------- REMOVE EXACT DUPLICATES ----------
$userResults  = $userResults  | Sort-Object Cluster,User,Domain,Roles -Unique
$groupResults = $groupResults | Sort-Object Cluster,Group,Domain,Roles -Unique

# ---------- UNIQUE CONSOLIDATED ----------
$userUniqueResults = $userResults |
Group-Object User,Domain,Roles |
ForEach-Object {
    $first = $_.Group | Select-Object -First 1
    [PSCustomObject]@{
        User     = $first.User
        Domain   = $first.Domain
        Roles    = $first.Roles
        Clusters = (($_.Group.Cluster | Sort-Object -Unique) -join ", ")
    }
} | Sort-Object User,Domain

$groupUniqueResults = $groupResults |
Group-Object Group,Domain,Roles |
ForEach-Object {
    $first = $_.Group | Select-Object -First 1
    [PSCustomObject]@{
        Group    = $first.Group
        Domain   = $first.Domain
        Roles    = $first.Roles
        Clusters = (($_.Group.Cluster | Sort-Object -Unique) -join ", ")
    }
} | Sort-Object Group,Domain

# ---------- CONSOLE OUTPUT ----------
Write-Host ""
Write-Host "=== Users - Cluster-by-Cluster ===" -ForegroundColor Cyan
$userResults | Format-Table Cluster,User,Domain,Roles -Wrap -AutoSize

Write-Host ""
Write-Host "=== Users - Unique Consolidated ===" -ForegroundColor Cyan
$userUniqueResults | Format-Table User,Domain,Roles,Clusters -Wrap -AutoSize

Write-Host ""
Write-Host "=== Groups - Cluster-by-Cluster ===" -ForegroundColor Cyan
$groupResults | Format-Table Cluster,Group,Domain,Roles -Wrap -AutoSize

Write-Host ""
Write-Host "=== Groups - Unique Consolidated ===" -ForegroundColor Cyan
$groupUniqueResults | Format-Table Group,Domain,Roles,Clusters -Wrap -AutoSize

Write-Host ""
Write-Host "=== Non-Working Clusters ===" -ForegroundColor Cyan
if ($nonWorkingClusters.Count -gt 0) {
    $nonWorkingClusters | Sort-Object Cluster -Unique | Format-Table Cluster,Reason -Wrap -AutoSize
}
else {
    Write-Host "No non-working clusters found." -ForegroundColor Green
}

# ---------- EXPORT CSV ----------
$userResults |
Sort-Object Cluster,User |
Export-Csv -Path $userDetailCsv -NoTypeInformation

$userUniqueResults |
Sort-Object User,Domain |
Export-Csv -Path $userUniqueCsv -NoTypeInformation

$groupResults |
Sort-Object Cluster,Group |
Export-Csv -Path $groupDetailCsv -NoTypeInformation

$groupUniqueResults |
Sort-Object Group,Domain |
Export-Csv -Path $groupUniqueCsv -NoTypeInformation

Write-Host ""
Write-Host "Saved user detail CSV  : $userDetailCsv" -ForegroundColor Green
Write-Host "Saved user unique CSV  : $userUniqueCsv" -ForegroundColor Green
Write-Host "Saved group detail CSV : $groupDetailCsv" -ForegroundColor Green
Write-Host "Saved group unique CSV : $groupUniqueCsv" -ForegroundColor Green
