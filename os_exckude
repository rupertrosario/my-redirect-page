$apikeypath = "X:\PowerShell\Cohesity_API_Scripts\DO_NOT_Delete\apikey.txt"
$ApiKey = (Get-Content $apikeypath -Raw).Trim()

$commonHeaders = @{
    accept = "application/json"
    apiKey = $ApiKey
}

# Get clusters
$url = "https://helios.cohesity.com/v2/mcm/cluster-mgmt/info"
$clusters = ((Invoke-WebRequest -Method GET -Uri $url -Headers $commonHeaders).Content | ConvertFrom-Json).cohesityClusters

$objectRows = @()

foreach ($clus in $clusters) {

    $clusterName = $clus.name
    $clusterId   = $clus.clusterId

    $headers = @{
        accept = "application/json"
        apiKey = $ApiKey
        accessClusterId = $clusterId
    }

    $url = "https://helios.cohesity.com/v2/data-protect/protection-groups"
    $pgs = ((Invoke-WebRequest -Method GET -Uri $url -Headers $headers).Content | ConvertFrom-Json).protectionGroups

    $pgRows = @()

    foreach ($pg in $pgs) {

        $pgName = $pg.name
        $global = $pg.physicalParams.fileProtectionTypeParams.globalExcludePaths
        if (!$global) { $global = "None" } else { $global = ($global -join ", ") }

        $pgRows += [PSCustomObject]@{
            Cluster = $clusterName
            GlobalExclude = $global
            ProtectionGroup = $pgName
        }

        $objects = $pg.physicalParams.fileProtectionTypeParams.objects
        foreach ($obj in $objects) {

            if ($obj.filePaths) {
                $objectRows += [PSCustomObject]@{
                    Cluster = $clusterName
                    ProtectionGroup = $pgName
                    Object = $obj.name
                    ExcludedPaths = ($obj.filePaths -join ", ")
                }
            }
        }
    }

    Write-Host ""
    Write-Host "GLOBAL EXCLUDES (Consolidated) - $clusterName"
    Write-Host "---------------------------------------------"

    $pgRows |
    Group-Object GlobalExclude |
    ForEach-Object {
        [PSCustomObject]@{
            Cluster = $clusterName
            ProtectionGroups = ($_.Group.ProtectionGroup -join ", ")
            GlobalExcludePaths = $_.Name
        }
    } |
    Format-Table -AutoSize
}

Write-Host ""
Write-Host "OBJECT LEVEL EXCLUDES"
Write-Host "---------------------"

$objectRows | Format-Table -AutoSize
