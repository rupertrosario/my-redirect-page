# ============================================
# Cohesity Users and Groups Inventory
# GET-only | Invoke-WebRequest | CSV output
# ============================================

# ---------- API KEY ----------
$apikeypath = "X:\PowerShell\Cohesity_API_Scripts\DO_NOT_Delete\apikeyDO_NOT_Delete\apikey.txt"
$ApiKey = (Get-Content $apikeypath -Raw).Trim()

$commonHeaders = @{
    accept = "application/json"
    apiKey = $ApiKey
}

# ---------- OUTPUT ----------
$reportDate = Get-Date -Format "yyyy-MM-dd_HHmm"

$userDetailCsv  = "X:\PowerShell\Data\Cohesity\Alerts\Cluster_User_Details_$reportDate.csv"
$userUniqueCsv  = "X:\PowerShell\Data\Cohesity\Alerts\Unique_User_Consolidated_$reportDate.csv"
$groupDetailCsv = "X:\PowerShell\Data\Cohesity\Alerts\Cluster_Group_Details_$reportDate.csv"
$groupUniqueCsv = "X:\PowerShell\Data\Cohesity\Alerts\Unique_Group_Consolidated_$reportDate.csv"

$userResults = [System.Collections.Generic.List[object]]::new()
$groupResults = [System.Collections.Generic.List[object]]::new()
$nonWorkingClusters = [System.Collections.Generic.List[object]]::new()

# ---------- GET CLUSTERS ----------
$clusterUrl = "https://helios.cohesity.com/v2/mcm/cluster-mgmt/info"
$clusterResp = Invoke-WebRequest -Method Get -Uri $clusterUrl -Headers $commonHeaders -UseBasicParsing
$clusters = @((($clusterResp.Content | ConvertFrom-Json).cohesityClusters))

foreach ($clus in $clusters) {

    $clusterName = $clus.clusterName
    $clusterId   = $clus.clusterId

    $headers = @{
        accept = "application/json"
        apiKey = $ApiKey
        accessClusterId = $clusterId
    }

    $clusterErrors = @()

    # ---------- USERS ----------
    try {
        $usersUrl  = "https://helios.cohesity.com/irisservices/api/v1/public/users"
        $usersResp = Invoke-WebRequest -Method Get -Uri $usersUrl -Headers $headers -UseBasicParsing -ErrorAction Stop
        $usersJson = $usersResp.Content | ConvertFrom-Json
        $users = if ($usersJson.users) { @($usersJson.users) } else { @($usersJson) }

        foreach ($u in $users) {
            if ($u.user) {
                $roles = if ($u.roles -is [System.Array]) { $u.roles -join ", " } else { "$($u.roles)" }

                $userResults.Add([PSCustomObject]@{
                    Cluster = $clusterName
                    User    = $u.user
                    Domain  = $u.domain
                    Roles   = $roles
                })
            }
        }
    }
    catch {
        $clusterErrors += "Users API failed: $($_.Exception.Message)"
    }

    # ---------- GROUPS ----------
    try {
        $groupsUrl  = "https://helios.cohesity.com/irisservices/api/v1/public/groups"
        $groupsResp = Invoke-WebRequest -Method Get -Uri $groupsUrl -Headers $headers -UseBasicParsing -ErrorAction Stop
        $groupsJson = $groupsResp.Content | ConvertFrom-Json
        $groups = if ($groupsJson.groups) { @($groupsJson.groups) } elseif ($groupsJson.groupVec) { @($groupsJson.groupVec) } else { @($groupsJson) }

        foreach ($g in $groups) {
            if ($g.username) {
                $roles = if ($g.roles -is [System.Array]) { $g.roles -join ", " } else { "$($g.roles)" }

                $groupResults.Add([PSCustomObject]@{
                    Cluster = $clusterName
                    Group   = $g.username
                    Domain  = $g.domain
                    Roles   = $roles
                })
            }
        }
    }
    catch {
        $clusterErrors += "Groups API failed: $($_.Exception.Message)"
    }

    if ($clusterErrors.Count -gt 0) {
        $nonWorkingClusters.Add([PSCustomObject]@{
            Cluster = $clusterName
            Reason  = $clusterErrors -join " | "
        })
    }
}

# ---------- REMOVE EXACT DUPLICATES ----------
$userResults  = $userResults  | Sort-Object Cluster,User,Domain,Roles -Unique
$groupResults = $groupResults | Sort-Object Cluster,Group,Domain,Roles -Unique

# ---------- UNIQUE CONSOLIDATED ----------
$userUniqueResults = $userResults |
Group-Object User,Domain,Roles |
ForEach-Object {
    $first = $_.Group | Select-Object -First 1
    [PSCustomObject]@{
        User     = $first.User
        Domain   = $first.Domain
        Roles    = $first.Roles
        Clusters = (($_.Group.Cluster | Sort-Object -Unique) -join ", ")
    }
}

$groupUniqueResults = $groupResults |
Group-Object Group,Domain,Roles |
ForEach-Object {
    $first = $_.Group | Select-Object -First 1
    [PSCustomObject]@{
        Group    = $first.Group
        Domain   = $first.Domain
        Roles    = $first.Roles
        Clusters = (($_.Group.Cluster | Sort-Object -Unique) -join ", ")
    }
}

# ---------- CONSOLE OUTPUT ----------
Write-Host ""
Write-Host "=== Users - Cluster-by-Cluster ===" -ForegroundColor Cyan
$userResults | Format-Table Cluster,User,Domain,Roles -AutoSize

Write-Host ""
Write-Host "=== Users - Unique Consolidated ===" -ForegroundColor Cyan
$userUniqueResults | Format-Table User,Domain,Roles,Clusters -AutoSize

Write-Host ""
Write-Host "=== Groups - Cluster-by-Cluster ===" -ForegroundColor Cyan
$groupResults | Format-Table Cluster,Group,Domain,Roles -AutoSize

Write-Host ""
Write-Host "=== Groups - Unique Consolidated ===" -ForegroundColor Cyan
$groupUniqueResults | Format-Table Group,Domain,Roles,Clusters -AutoSize

Write-Host ""
Write-Host "=== Non-Working Clusters ===" -ForegroundColor Cyan
if ($nonWorkingClusters.Count -gt 0) {
    $nonWorkingClusters | Sort-Object Cluster -Unique | Format-Table Cluster,Reason -AutoSize
}
else {
    Write-Host "No non-working clusters found." -ForegroundColor Green
}

# ---------- EXPORT CSV ----------
$userResults | Sort-Object Cluster,User | Export-Csv -Path $userDetailCsv -NoTypeInformation
$userUniqueResults | Sort-Object User,Domain | Export-Csv -Path $userUniqueCsv -NoTypeInformation
$groupResults | Sort-Object Cluster,Group | Export-Csv -Path $groupDetailCsv -NoTypeInformation
$groupUniqueResults | Sort-Object Group,Domain | Export-Csv -Path $groupUniqueCsv -NoTypeInformation

Write-Host ""
Write-Host "Saved user detail CSV  : $userDetailCsv" -ForegroundColor Green
Write-Host "Saved user unique CSV  : $userUniqueCsv" -ForegroundColor Green
Write-Host "Saved group detail CSV : $groupDetailCsv" -ForegroundColor Green
Write-Host "Saved group unique CSV : $groupUniqueCsv" -ForegroundColor Green
