# ============================================================
# Cohesity Helios - All Clusters - Users + Groups + Review Summary
# Plus separate HELIOS PRINCIPALS section and CSV
# - Cluster summary/counts remain cluster-only
# - Helios principals are displayed separately
# - Helios principals do NOT affect cluster review counts
# ============================================================

# ---------- CONFIG ----------
$apiKeyPath          = "X:\PowerShell\Cohesity_API_Scripts\DO_NOT_Delete\apikey.txt"
$clusterInfoUrl      = "https://helios.cohesity.com/v2/mcm/cluster-mgmt/info"
$clusterUsersUrl     = "https://helios.cohesity.com/irisservices/api/v1/public/users"
$clusterGroupsUrl    = "https://helios.cohesity.com/irisservices/api/v1/public/groups"
$heliosPrincipalsUrl = "https://helios.cohesity.com/irisservices/api/v1/public/mcm/users"
$exportPath          = "X:\PowerShell\Data\Cohesity\UsersAndGroups"

# ---------- FUNCTIONS ----------
function Get-ApiKey {
    param([string]$Path)

    if (-not (Test-Path $Path)) {
        throw "API key file not found: $Path"
    }

    return (Get-Content -Path $Path -Raw).Trim()
}

function Convert-ToArray {
    param($InputObject)

    if ($null -eq $InputObject) { return @() }
    if ($InputObject -is [System.Array]) { return $InputObject }
    if ($InputObject -is [System.Collections.IEnumerable] -and $InputObject -isnot [string]) { return @($InputObject) }
    return @($InputObject)
}

function Get-RoleText {
    param($Roles)

    if ($null -eq $Roles) { return "" }

    $roleArray = Convert-ToArray $Roles
    if (-not $roleArray -or $roleArray.Count -eq 0) { return "" }

    $names = foreach ($r in $roleArray) {
        if ($null -eq $r) { continue }
        elseif ($r -is [string]) { $r }
        elseif ($r.name) { $r.name }
        elseif ($r.roleName) { $r.roleName }
        else { [string]$r }
    }

    (($names |
        Where-Object { $_ -and $_.Trim() -ne "" } |
        ForEach-Object { $_.Trim() } |
        Sort-Object -Unique) -join ", ")
}

function Invoke-HeliosGet {
    param(
        [Parameter(Mandatory)][string]$Uri,
        [Parameter(Mandatory)][hashtable]$Headers
    )

    try {
        return Invoke-RestMethod -Method Get -Uri $Uri -Headers $Headers -TimeoutSec 60 -ErrorAction Stop
    }
    catch {
        return $null
    }
}

function Get-Clusters {
    param([hashtable]$Headers)

    $resp = Invoke-HeliosGet -Uri $clusterInfoUrl -Headers $Headers
    if ($null -eq $resp) { return @() }

    if ($resp.cohesityClusters) {
        return @(Convert-ToArray $resp.cohesityClusters)
    }
    elseif ($resp.data) {
        return @(Convert-ToArray $resp.data)
    }
    else {
        return @(Convert-ToArray $resp)
    }
}

function Get-PrincipalName {
    param($Object)

    if ($null -eq $Object) { return "" }

    if ($Object.username)    { return [string]$Object.username }
    if ($Object.userName)    { return [string]$Object.userName }
    if ($Object.name)        { return [string]$Object.name }
    if ($Object.displayName) { return [string]$Object.displayName }
    if ($Object.email)       { return [string]$Object.email }

    return ""
}

function Get-PrincipalDomain {
    param($Object)

    if ($null -eq $Object) { return "" }

    if ($Object.domain)           { return [string]$Object.domain }
    if ($Object.domainName)       { return [string]$Object.domainName }
    if ($Object.identityProvider) { return [string]$Object.identityProvider }

    return ""
}

# ---------- API KEY ----------
$apiKey = Get-ApiKey -Path $apiKeyPath

$commonHeaders = @{
    accept = "application/json"
    apiKey = $apiKey
}

# ---------- GET CLUSTERS ----------
$clusters = Get-Clusters -Headers $commonHeaders

if (-not $clusters -or $clusters.Count -eq 0) {
    throw "No clusters returned from Helios cluster-mgmt/info"
}

# ---------- COLLECT CLUSTER RESULTS ----------
$allResults = @()
$failedClusters = @()

foreach ($clus in $clusters) {

    $clusterName = $null
    $clusterId   = $null

    if ($clus.clusterName)      { $clusterName = $clus.clusterName }
    elseif ($clus.name)         { $clusterName = $clus.name }
    else                        { $clusterName = "UnknownCluster" }

    if ($clus.clusterId)        { $clusterId = $clus.clusterId }
    elseif ($clus.id)           { $clusterId = $clus.id }
    else                        { $clusterId = $null }

    if (-not $clusterId) {
        $failedClusters += [PSCustomObject]@{
            Cluster = $clusterName
            Reason  = "Missing ClusterId"
        }
        continue
    }

    $clusterHeaders = @{
        accept          = "application/json"
        apiKey          = $apiKey
        accessClusterId = "$clusterId"
    }

    $usersRaw  = Invoke-HeliosGet -Uri $clusterUsersUrl  -Headers $clusterHeaders
    $groupsRaw = Invoke-HeliosGet -Uri $clusterGroupsUrl -Headers $clusterHeaders

    if ($null -eq $usersRaw -and $null -eq $groupsRaw) {
        $failedClusters += [PSCustomObject]@{
            Cluster = $clusterName
            Reason  = "Users/Groups API returned nothing"
        }
        continue
    }

    $users  = Convert-ToArray $usersRaw
    $groups = Convert-ToArray $groupsRaw

    foreach ($u in $users) {
        $name   = Get-PrincipalName   -Object $u
        $domain = Get-PrincipalDomain -Object $u
        $roles  = Get-RoleText        -Roles  $u.roles

        if ($name -and $name.Trim() -ne "") {
            $allResults += [PSCustomObject]@{
                Cluster = $clusterName
                Type    = "User"
                Name    = $name
                Domain  = $domain
                Roles   = $roles
            }
        }
    }

    foreach ($g in $groups) {
        $name   = Get-PrincipalName   -Object $g
        $domain = Get-PrincipalDomain -Object $g
        $roles  = Get-RoleText        -Roles  $g.roles

        if ($name -and $name.Trim() -ne "") {
            $allResults += [PSCustomObject]@{
                Cluster = $clusterName
                Type    = "Group"
                Name    = $name
                Domain  = $domain
                Roles   = $roles
            }
        }
    }
}

# ---------- HELIOS PRINCIPALS (SEPARATE / NOT IN SUMMARY) ----------
$heliosPrincipals = @()

$heliosRaw = Invoke-HeliosGet -Uri $heliosPrincipalsUrl -Headers $commonHeaders
$heliosItems = Convert-ToArray $heliosRaw

foreach ($p in $heliosItems) {
    $name =
        if ($p.username)      { [string]$p.username }
        elseif ($p.userName)  { [string]$p.userName }
        elseif ($p.name)      { [string]$p.name }
        else                  { "" }

    $domain =
        if ($p.domain)        { [string]$p.domain }
        elseif ($p.domainName){ [string]$p.domainName }
        else                  { "" }

    $roles = Get-RoleText -Roles $p.roles

    if ($name -and $name.Trim() -ne "") {
        $heliosPrincipals += [PSCustomObject]@{
            Name   = $name
            Domain = $domain
            Roles  = $roles
        }
    }
}

$heliosPrincipals = $heliosPrincipals | Sort-Object Name

# ---------- SORTED CLUSTER-WISE ----------
$clusterWiseResults = $allResults | Sort-Object Cluster, Type, Name

# ---------- CONSOLIDATED USERS ----------
$usersConsolidated = $allResults |
    Where-Object { $_.Type -eq "User" } |
    Group-Object Name, Domain, Roles |
    ForEach-Object {
        $first = $_.Group | Select-Object -First 1
        [PSCustomObject]@{
            Name     = $first.Name
            Domain   = $first.Domain
            Roles    = $first.Roles
            Clusters = ($_.Group.Cluster | Sort-Object -Unique) -join ", "
        }
    } |
    Sort-Object Name, Domain

# ---------- CONSOLIDATED GROUPS ----------
$groupsConsolidated = $allResults |
    Where-Object { $_.Type -eq "Group" } |
    Group-Object Name, Domain, Roles |
    ForEach-Object {
        $first = $_.Group | Select-Object -First 1
        [PSCustomObject]@{
            Name     = $first.Name
            Domain   = $first.Domain
            Roles    = $first.Roles
            Clusters = ($_.Group.Cluster | Sort-Object -Unique) -join ", "
        }
    } |
    Sort-Object Name, Domain

# ---------- SUMMARY (CLUSTERS ONLY) ----------
$successfulClusters = ($allResults.Cluster | Sort-Object -Unique).Count
$failedClusterCount = $failedClusters.Count

$clusterWiseUserCount  = ($allResults | Where-Object { $_.Type -eq "User"  }).Count
$clusterWiseGroupCount = ($allResults | Where-Object { $_.Type -eq "Group" }).Count

$uniqueUserCount  = $usersConsolidated.Count
$uniqueGroupCount = $groupsConsolidated.Count
$totalUniquePrincipals = $uniqueUserCount + $uniqueGroupCount

$uniqueRoles = $allResults |
    Where-Object { $_.Roles -and $_.Roles.Trim() -ne "" } |
    ForEach-Object { $_.Roles -split "," } |
    ForEach-Object { $_.Trim() } |
    Where-Object { $_ -ne "" } |
    Sort-Object -Unique

$uniqueRoleCount = $uniqueRoles.Count

$summary = [PSCustomObject]@{
    SuccessfulClustersReviewed = $successfulClusters
    FailedOrSkippedClusters    = $failedClusterCount
    ClusterWiseUsersReviewed   = $clusterWiseUserCount
    ClusterWiseGroupsReviewed  = $clusterWiseGroupCount
    UniqueUsersReviewed        = $uniqueUserCount
    UniqueGroupsReviewed       = $uniqueGroupCount
    TotalUniquePrincipals      = $totalUniquePrincipals
    UniqueRolesReviewed        = $uniqueRoleCount
    RoleList                   = ($uniqueRoles -join ", ")
}

$reviewStatement = "Reviewed $uniqueUserCount unique users, $uniqueGroupCount unique groups, and $uniqueRoleCount unique roles across $successfulClusters successfully queried clusters."

# ---------- CONSOLE OUTPUT ----------
Write-Host ""
Write-Host "================ REVIEW SUMMARY ================" -ForegroundColor White
$summary | Format-List

Write-Host ""
Write-Host "Review Statement:" -ForegroundColor White
Write-Host $reviewStatement -ForegroundColor Cyan

Write-Host ""
Write-Host "================ CLUSTER-WISE USERS + GROUPS ================" -ForegroundColor Cyan
$clusterWiseResults | Format-Table Cluster, Type, Name, Domain, Roles -AutoSize

Write-Host ""
Write-Host "================ CONSOLIDATED USERS ================" -ForegroundColor Green
$usersConsolidated | Format-Table Name, Domain, Roles, Clusters -AutoSize

Write-Host ""
Write-Host "================ CONSOLIDATED GROUPS ================" -ForegroundColor Yellow
$groupsConsolidated | Format-Table Name, Domain, Roles, Clusters -AutoSize

Write-Host ""
Write-Host "================ HELIOS PRINCIPALS ================" -ForegroundColor DarkCyan
$heliosPrincipals | Format-Table Name, Domain, Roles -AutoSize

if ($failedClusters.Count -gt 0) {
    Write-Host ""
    Write-Host "================ FAILED / SKIPPED CLUSTERS ================" -ForegroundColor Red
    $failedClusters | Sort-Object Cluster | Format-Table Cluster, Reason -AutoSize
}

# ---------- EXPORT CSV ----------
if (-not (Test-Path $exportPath)) {
    New-Item -ItemType Directory -Path $exportPath -Force | Out-Null
}

$timeStamp = Get-Date -Format "yyyyMMdd_HHmmss"

$summaryCsv      = Join-Path $exportPath "Cohesity_Review_Summary_$timeStamp.csv"
$clusterWiseCsv  = Join-Path $exportPath "Cohesity_ClusterWise_Users_Groups_$timeStamp.csv"
$usersCsv        = Join-Path $exportPath "Cohesity_Consolidated_Users_$timeStamp.csv"
$groupsCsv       = Join-Path $exportPath "Cohesity_Consolidated_Groups_$timeStamp.csv"
$heliosCsv       = Join-Path $exportPath "Cohesity_Helios_Principals_$timeStamp.csv"
$failedCsv       = Join-Path $exportPath "Cohesity_Failed_Clusters_$timeStamp.csv"
$reviewTxt       = Join-Path $exportPath "Cohesity_Review_Statement_$timeStamp.txt"

$summary |
    Export-Csv -Path $summaryCsv -NoTypeInformation -Encoding UTF8

$clusterWiseResults |
    Export-Csv -Path $clusterWiseCsv -NoTypeInformation -Encoding UTF8

$usersConsolidated |
    Export-Csv -Path $usersCsv -NoTypeInformation -Encoding UTF8

$groupsConsolidated |
    Export-Csv -Path $groupsCsv -NoTypeInformation -Encoding UTF8

$heliosPrincipals |
    Export-Csv -Path $heliosCsv -NoTypeInformation -Encoding UTF8

if ($failedClusters.Count -gt 0) {
    $failedClusters |
        Sort-Object Cluster |
        Export-Csv -Path $failedCsv -NoTypeInformation -Encoding UTF8
}

$reviewStatement | Out-File -FilePath $reviewTxt -Encoding UTF8

# ---------- FILES CREATED ----------
Write-Host ""
Write-Host "================ FILES CREATED ================" -ForegroundColor Magenta
Write-Host $summaryCsv
Write-Host $clusterWiseCsv
Write-Host $usersCsv
Write-Host $groupsCsv
Write-Host $heliosCsv
if ($failedClusters.Count -gt 0) {
    Write-Host $failedCsv
}
Write-Host $reviewTxt
