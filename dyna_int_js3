// ------------------------------------------------
// Compare Existing Incident vs Current Fingerprint
// ------------------------------------------------

import { result as wfResult } from "@dynatrace-sdk/automation-utils";

export default async function () {

  // ------------------------------------------------
  // Previous Steps
  // ------------------------------------------------
  const js2 =
    await wfResult("validate_interfaces");

  const snowSearch =
    await wfResult("snow_search_team");

  // ------------------------------------------------
  // Current Team Incidents From JS2
  // ------------------------------------------------
  const incidents =
    js2?.teamIncidents || [];

  // ------------------------------------------------
  // Existing SNOW Results
  // ------------------------------------------------
  const existing =
    snowSearch?.result ||
    snowSearch?.results ||
    [];

  // ------------------------------------------------
  // Output
  // ------------------------------------------------
  const updateList = [];

  for (const inc of incidents) {

    const correlationId =
      inc.correlation_id;

    const currentFingerprint =
      inc.fingerprint || "";

    // ------------------------------------------------
    // Match Existing Incident
    // ------------------------------------------------
    const match =
      existing.find(r =>
        String(r.correlation_id || "").trim() ===
        String(correlationId).trim()
      );

    // ------------------------------------------------
    // No Existing Incident
    // ------------------------------------------------
    if (!match) {

      updateList.push({

        action: "create",

        correlation_id:
          correlationId,

        payload:
          inc
      });

      continue;
    }

    // ------------------------------------------------
    // Existing Fingerprint
    // ------------------------------------------------
    const existingDesc =
      String(
        match.description || ""
      );

    const oldFingerprintMatch =
      existingDesc.match(
        /Fingerprint:\s*(.*)/i
      );

    const oldFingerprint =
      oldFingerprintMatch
        ? oldFingerprintMatch[1].trim()
        : "";

    // ------------------------------------------------
    // Same Fingerprint
    // ------------------------------------------------
    if (
      oldFingerprint ===
      currentFingerprint
    ) {

      console.log(
        "No change detected for: " +
        correlationId
      );

      continue;
    }

    // ------------------------------------------------
    // Different Fingerprint
    // ------------------------------------------------
    updateList.push({

      action: "update",

      sys_id:
        match.sys_id,

      correlation_id:
        correlationId,

      payload:
        inc
    });
  }

  // ------------------------------------------------
  // Return
  // ------------------------------------------------
  return {

    ok: true,

    updateList
  };
}
