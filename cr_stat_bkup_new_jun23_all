# ==========================================================
function Test-ValidDbName {
    param(
        [string]$Name,
        [string]$ServerName
    )

    if ([string]::IsNullOrWhiteSpace($Name)) {
        return $false
    }

    $n = "$Name".Trim()

    if ([string]::IsNullOrWhiteSpace($n)) {
        return $false
    }

    if (Test-OracleContainerName -Name $n) {
        return $false
    }

    $bad = @(
        "database",
        "databases",
        "db",
        "name",
        "mssql",
        "sql",
        "oracle",
        "source",
        "server",
        "object",
        "objects",
        "Oracle Servers",
        "kRACDatabase",
        "kNonRACDatabase",
        "kOracleDatabase"
    )

    if ((Normalize-Name $n) -in ($bad | ForEach-Object { Normalize-Name $_ })) {
        return $false
    }

    if (Text-MatchesName -Text $n -Name $ServerName) {
        return $false
    }

    return $true
}

function Find-DatabaseNames {
    param(
        $Value,
        [string]$ServerName,
        [string]$Path = "",
        [int]$Depth = 0
    )

    $out = @()

    if ($Depth -gt 10) {
        return @()
    }

    foreach ($item in (As-Array -Value $Value)) {
        if ($null -eq $item) {
            continue
        }

        if ($item -is [string]) {
            if ($Path -match '(?i)mssql|sql|oracle|database|databases|db' -and
                (Test-ValidDbName -Name $item -ServerName $ServerName)) {
                $out += "$item".Trim()
            }

            continue
        }

        if ($item -isnot [pscustomobject]) {
            continue
        }

        $objType = First-NonBlank -Values @(
            $item.objectType,
            $item.type,
            $item.entityType
        )

        $dbName = First-NonBlank -Values @(
            $item.databaseName,
            $item.dbName,
            $item.dbUniqueName,
            $item.database,
            $item.db
        )

        if ([string]::IsNullOrWhiteSpace($dbName)) {
            if (($Path -match '(?i)mssql|sql|oracle|database|databases|db') -or
                ($objType -match '(?i)database|db|sql|oracle')) {
                $dbName = First-NonBlank -Values @(
                    $item.name,
                    $item.displayName
                )
            }
        }

        if (Test-ValidDbName -Name $dbName -ServerName $ServerName) {
            $out += "$dbName".Trim()
        }

        foreach ($prop in @($item.PSObject.Properties)) {
            if ($prop.Name -match '(?i)mssql|sql|oracle|database|databases|db|params|objects|children|instances|list|info') {
                $nextPath = if ([string]::IsNullOrWhiteSpace($Path)) {
                    $prop.Name
                }
                else {
                    "$Path/$($prop.Name)"
                }

                $out += Find-DatabaseNames -Value $prop.Value -ServerName $ServerName -Path $nextPath -Depth ($Depth + 1)
            }
        }
    }

    return @($out | Where-Object { -not [string]::IsNullOrWhiteSpace($_) } | Sort-Object -Unique)
}

function Get-ParamDbRows {
    param(
        $Object,
        [string]$SourceName,
        [string]$ParentName,
        [string]$Environment,
        [int]$Depth
    )

    $rows = @()

    if ([string]::IsNullOrWhiteSpace($SourceName) -or
        (Test-OracleContainerName -Name $SourceName)) {
        return @()
    }

    $containers = @(
        $Object.mssqlParams,
        $Object.sqlParams,
        $Object.mssql,
        $Object.oracleParams,
        $Object.databaseParams,
        $Object.dbParams,
        $Object.databaseInfo,
        $Object.databases,
        $Object.databaseList,
        $Object.protectedDatabases,
        $Object.selectedDatabases,
        $Object.includedDatabases
    )

    $dbNames = @()

    foreach ($container in $containers) {
        $dbNames += Find-DatabaseNames -Value $container -ServerName $SourceName
    }

    $dbNames = @(
        $dbNames |
        Where-Object { Test-ValidDbName -Name $_ -ServerName $SourceName } |
        Sort-Object -Unique
    )

    foreach ($db in $dbNames) {
        $fullName = "$db"

        if ($fullName -notlike "*/*") {
            $fullName = "$SourceName/$db"
        }

        if (Test-OracleContainerName -Name $fullName) {
            continue
        }

        $rows += [pscustomobject]@{
            Object            = $Object
            ObjectName        = $fullName
            ParentName        = $ParentName
            ParentEnvironment = $Environment
            Environment       = $Environment
            ObjectType        = "kDatabase"
            SqlHostName       = Get-SqlHostNameFromNode -Object $Object
            OracleHostName    = Get-OracleHostNameFromNode -Object $Object
            GenericSourceName = Get-GenericSourceNameFromNode -Object $Object
            SourceName        = $SourceName
            SourceInfoName    = $SourceName
            Depth             = $Depth + 1
        }
    }

    return @($rows)
}

