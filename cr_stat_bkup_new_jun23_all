function Get-VmBackupTypeFromText {
    param(
        [string]$Environment,
        [string]$ObjectType,
        [string]$ObjectName,
        [string]$SourceName,
        [string]$SourceInfoName
    )

    $text = "$Environment $ObjectType $ObjectName $SourceName $SourceInfoName"

    if ($text -match '(?i)kAcropolis|Acropolis|Nutanix|AHV') {
        return "Nutanix"
    }

    if ($text -match '(?i)kHyperV|HyperV|Hyper-V') {
        return "HyperV"
    }

    if ($text -match '(?i)kVMware|VMware|kVirtualMachine|VirtualMachine') {
        return "VM"
    }

    return ""
}

function Resolve-SourceName {
    param(
        [string]$BackupType,
        [string]$ObjectName,
        [string]$ParentName,
        [string]$SqlHostName,
        [string]$OracleHostName,
        [string]$GenericSourceName,
        [string]$ParentSourceName
    )

    if ($BackupType -eq "Oracle") {
        if (-not [string]::IsNullOrWhiteSpace($OracleHostName)) {
            return $OracleHostName
        }

        return ""
    }

    if ($BackupType -eq "SQL") {
        if (-not [string]::IsNullOrWhiteSpace($SqlHostName)) {
            return $SqlHostName
        }
    }

    if (-not [string]::IsNullOrWhiteSpace($GenericSourceName) -and
        -not (Test-OracleContainerName -Name $GenericSourceName)) {
        return $GenericSourceName
    }

    if (-not [string]::IsNullOrWhiteSpace($ParentSourceName) -and
        -not (Test-OracleContainerName -Name $ParentSourceName)) {
        return $ParentSourceName
    }

    if (-not [string]::IsNullOrWhiteSpace($ObjectName) -and $ObjectName -like "*/*") {
        $prefix = (($ObjectName -split "/", 2)[0]).Trim()

        if (-not (Test-OracleContainerName -Name $prefix)) {
            return $prefix
        }
    }

    if (-not [string]::IsNullOrWhiteSpace($ParentName) -and
        -not (Test-OracleContainerName -Name $ParentName)) {
        return $ParentName
    }

    return $ObjectName
}

function Get-DisplayObjectName {
    param(
        [string]$ObjectName,
        [string]$BackupType
    )

    if ([string]::IsNullOrWhiteSpace($ObjectName)) {
        return "-"
    }

    return $ObjectName
}

function Object-MatchesCiFlat {
    param(
        $FlatObject,
        [string]$CiName
    )

    foreach ($v in @(
        $FlatObject.SourceName,
        $FlatObject.SourceInfoName,
        $FlatObject.ObjectName,
        $FlatObject.ParentName
    )) {
        if (-not [string]::IsNullOrWhiteSpace("$v") -and
            -not (Test-OracleContainerName -Name "$v") -and
            (Text-MatchesName -Text "$v" -Name $CiName)) {
            return $true
        }
    }

    if (-not [string]::IsNullOrWhiteSpace($FlatObject.ObjectName) -and
        $FlatObject.ObjectName -like "*/*") {
        $prefix = (($FlatObject.ObjectName -split "/", 2)[0]).Trim()

        if (-not (Test-OracleContainerName -Name $prefix) -and
            (Text-MatchesName -Text $prefix -Name $CiName)) {
            return $true
        }
    }

    return $false
}

function Object-MatchesCiAliasesFlat {
    param(
        $FlatObject,
        [string[]]$CiAliases
    )

    foreach ($alias in @($CiAliases)) {
        if ([string]::IsNullOrWhiteSpace($alias)) {
            continue
        }

        if (Object-MatchesCiFlat -FlatObject $FlatObject -CiName $alias) {
            return $true
        }
    }

    return $false
}

function Test-NonDisplayObject {
    param($FlatObject)

    if (Test-OracleContainerName -Name "$($FlatObject.ObjectName)") {
        return $true
    }

    if (Test-OracleContainerName -Name "$($FlatObject.SourceName)") {
        return $true
    }

    return $false
}

function Get-BackupType {
    param($FlatObject)

    if (Test-NonDisplayObject -FlatObject $FlatObject) {
        return "Container"
    }

    if (-not [string]::IsNullOrWhiteSpace($FlatObject.SqlHostName)) {
        return "SQL"
    }

    if (-not [string]::IsNullOrWhiteSpace($FlatObject.OracleHostName)) {
        return "Oracle"
    }

    $vmType = Get-VmBackupTypeFromText `
        -Environment $FlatObject.Environment `
        -ObjectType $FlatObject.ObjectType `
        -ObjectName $FlatObject.ObjectName `
        -SourceName $FlatObject.SourceName `
        -SourceInfoName $FlatObject.SourceInfoName

    if (-not [string]::IsNullOrWhiteSpace($vmType)) {
        return $vmType
    }

    $text = "$($FlatObject.Environment) $($FlatObject.ObjectType) $($FlatObject.ObjectName) $($FlatObject.SourceName) $($FlatObject.SourceInfoName)"

    if ($text -match '(?i)kOracle|oracle|kRAC|kNonRAC') {
        return "Oracle"
    }

    if ($text -match '(?i)kSQL|mssql|sql server|sql') {
        return "SQL"
    }

    if ($text -match '(?i)kDatabase|database|db') {
        return "DB"
    }

    return "FS"
}

function Test-DbLikeFlat {
    param($FlatObject)

    if (Test-NonDisplayObject -FlatObject $FlatObject) {
        return $false
    }

    $bt = Get-BackupType -FlatObject $FlatObject

    return ($bt -in @("SQL", "Oracle", "DB"))
}

function Test-VmLikeFlat {
    param($FlatObject)

    $bt = Get-BackupType -FlatObject $FlatObject

    return ($bt -in @("HyperV", "Nutanix", "VM"))
}

# ==========================================================
# Snapshot Helpers
# ==========================================================
function Get-SnapshotRunType {
    param($Snapshot)

    return First-NonBlank -Values @(
        $Snapshot.runType,
        $Snapshot.backupRunType
    )
}

function Is-RegularSnapshot {
    param($Snapshot)

    $rt = Get-SnapshotRunType -Snapshot $Snapshot

    if ([string]::IsNullOrWhiteSpace($rt)) {
        return $true
    }

    if ($rt -match '(?i)log|archive') {
        return $false
    }

    return $true
}

function Get-SnapshotUsecs {
    param($Snapshot)

    $localInfo   = @(As-Array -Value $Snapshot.localSnapshotInfo)
    $archiveInfo = @(As-Array -Value $Snapshot.archivalSnapshotsInfo)

    return Get-MaxUsecs -Values @(
        $Snapshot.protectionRunStartTimeUsecs,
        $Snapshot.runStartTimeUsecs,
        $Snapshot.startTimeUsecs,
        $Snapshot.snapshotTimestampUsecs,
        $Snapshot.endTimeUsecs,
        $localInfo.snapshotInfo.endTimeUsecs,
        $localInfo.snapshotInfo.snapshotTimestampUsecs,
        $localInfo.snapshotInfo.startTimeUsecs,
        $archiveInfo.snapshotInfo.endTimeUsecs,
        $archiveInfo.snapshotInfo.snapshotTimestampUsecs
    )
}

function Get-BestSnapshot {
    param($Object)

    $snapshots = @(As-Array -Value $Object.latestSnapshotsInfo | Where-Object { $_ })

    if (-not $snapshots -or $snapshots.Count -eq 0) {
        return $null
    }

    $regular = @($snapshots | Where-Object { Is-RegularSnapshot -Snapshot $_ })

    if ($regular.Count -gt 0) {
        return @(
            $regular |
            Sort-Object @{ Expression = { [int64](Get-SnapshotUsecs -Snapshot $_) }; Descending = $true } |
            Select-Object -First 1
        )[0]
    }

    return @(
        $snapshots |
        Sort-Object @{ Expression = { [int64](Get-SnapshotUsecs -Snapshot $_) }; Descending = $true } |
        Select-Object -First 1
    )[0]
}

function Get-ProtectionGroupName {
    param(
        $Object,
        $Snapshot
    )

    $pg = First-NonBlank -Values @(
        $Snapshot.protectionGroupName,
        $Snapshot.protectionGroup.name,
        $Snapshot.protectionGroupInfo.name,
        $Object.protectionGroupName,
        $Object.protectionGroup.name,
        $Object.protectionGroupInfo.name
    )

    if ([string]::IsNullOrWhiteSpace($pg)) {
        return "-"
    }

    return $pg
}

# ==========================================================
