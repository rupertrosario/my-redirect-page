function Get-FlatProtectedObjects {
    param(
        $Object,
        [string]$ParentName = "",
        [string]$ParentEnvironment = "",
        [string]$ParentSourceName = "",
        [int]$Depth = 0
    )

    $rows = @()

    if ($null -eq $Object) {
        return @()
    }

    $objectName = Get-ObjectNameFromNode -Object $Object
    $env = Get-EnvironmentFromNode -Object $Object -ParentEnvironment $ParentEnvironment
    $objectType = Get-ObjectTypeFromNode -Object $Object

    $sqlHostName = Get-SqlHostNameFromNode -Object $Object
    $oracleHostName = Get-OracleHostNameFromNode -Object $Object
    $genericSourceName = Get-GenericSourceNameFromNode -Object $Object

    $preVmType = Get-VmBackupTypeFromText `
        -Environment $env `
        -ObjectType $objectType `
        -ObjectName $objectName `
        -SourceName $genericSourceName `
        -SourceInfoName ""

    $preType = ""

    if (-not [string]::IsNullOrWhiteSpace($sqlHostName)) {
        $preType = "SQL"
    }
    elseif (-not [string]::IsNullOrWhiteSpace($oracleHostName)) {
        $preType = "Oracle"
    }
    elseif (-not [string]::IsNullOrWhiteSpace($preVmType)) {
        $preType = $preVmType
    }
    elseif ("$env $objectType $objectName $genericSourceName" -match '(?i)kOracle|oracle|kRAC|kNonRAC') {
        $preType = "Oracle"
    }
    elseif ("$env $objectType $objectName $genericSourceName" -match '(?i)kSQL|mssql|sql server|sql') {
        $preType = "SQL"
    }
    else {
        $preType = "FS"
    }

    $sourceName = Resolve-SourceName `
        -BackupType $preType `
        -ObjectName $objectName `
        -ParentName $ParentName `
        -SqlHostName $sqlHostName `
        -OracleHostName $oracleHostName `
        -GenericSourceName $genericSourceName `
        -ParentSourceName $ParentSourceName

    $rows += [pscustomobject]@{
        Object            = $Object
        ObjectName        = $objectName
        ParentName        = $ParentName
        ParentEnvironment = $ParentEnvironment
        Environment       = $env
        ObjectType        = $objectType
        SqlHostName       = $sqlHostName
        OracleHostName    = $oracleHostName
        GenericSourceName = $genericSourceName
        SourceName        = $sourceName
        SourceInfoName    = $sourceName
        Depth             = $Depth
    }

    $rows += Get-ParamDbRows `
        -Object $Object `
        -SourceName $sourceName `
        -ParentName $objectName `
        -Environment $env `
        -Depth $Depth

    foreach ($child in (As-Array -Value $Object.childObjects)) {
        $rows += Get-FlatProtectedObjects `
            -Object $child `
            -ParentName $objectName `
            -ParentEnvironment $env `
            -ParentSourceName $sourceName `
            -Depth ($Depth + 1)
    }

    return @($rows)
}

function Convert-FlatObjectToBackupRow {
    param(
        $FlatObject,
        [string]$Ci,
        $CandidateCluster
    )

    $obj = $FlatObject.Object
    $snap = Get-BestSnapshot -Object $obj
    $backupType = Get-BackupType -FlatObject $FlatObject

    if ($backupType -eq "Container") {
        return $null
    }

    if ($backupType -eq "Oracle" -and
        [string]::IsNullOrWhiteSpace($FlatObject.OracleHostName)) {
        return $null
    }

    $objectNameOut = Get-DisplayObjectName `
        -ObjectName $FlatObject.ObjectName `
        -BackupType $backupType

    $sourceNameOut = Resolve-SourceName `
        -BackupType $backupType `
        -ObjectName $FlatObject.ObjectName `
        -ParentName $FlatObject.ParentName `
        -SqlHostName $FlatObject.SqlHostName `
        -OracleHostName $FlatObject.OracleHostName `
        -GenericSourceName $FlatObject.GenericSourceName `
        -ParentSourceName $FlatObject.SourceName

    if ($backupType -eq "Oracle" -and [string]::IsNullOrWhiteSpace($sourceNameOut)) {
        return $null
    }

    if ($snap) {
        $usecs = Get-SnapshotUsecs -Snapshot $snap
        $lastBackupTime = if ($usecs -gt 0) { ToDate -Usecs $usecs } else { "NoBackupTime" }
        $pg = Get-ProtectionGroupName -Object $obj -Snapshot $snap
    }
    else {
        $usecs = 0
        $lastBackupTime = "NoBackup"
        $pg = Get-ProtectionGroupName -Object $obj -Snapshot $null
    }

    return [pscustomobject]@{
        ServerName      = $Ci
        BackupType      = $backupType
        ObjectName      = $objectNameOut
        SourceName      = $sourceNameOut
        ClusterName     = "$($CandidateCluster.clusterName)"
        ProtectionGroup = $pg
        LastBackupTime  = $lastBackupTime
        LastBackupUsecs = if ($usecs) { [int64]$usecs } else { 0 }
    }
}

function Search-ProtectedObjectsOnClusters {
    param(
        [string]$Ci,
        [string[]]$CiAliases,
        [string[]]$SearchTerms,
        [object[]]$CandidateClusters,
        [System.Collections.ArrayList]$SearchedClusterTermKeys
    )

    $Rows = @()

    foreach ($Clu in @($CandidateClusters)) {
        if ([string]::IsNullOrWhiteSpace("$($Clu.clusterId)")) {
            continue
        }

        foreach ($Term in @($SearchTerms)) {
            if ([string]::IsNullOrWhiteSpace($Term)) {
                continue
            }

            $searchKey = "$($Clu.clusterId)|$Term"

            if ($SearchedClusterTermKeys.Contains($searchKey)) {
                continue
            }

            [void]$SearchedClusterTermKeys.Add($searchKey)

            $ProtectedSearchUrl = "$BaseUrl/v2/data-protect/search/protected-objects?searchString=$([uri]::EscapeDataString($Term))"

            $ProtectedJson = Invoke-HeliosJson -Uri $ProtectedSearchUrl -Headers @{
                accept          = "application/json"
                apiKey          = $ApiKey
                accessClusterId = "$($Clu.clusterId)"
            } -Quiet

            $ProtectedObjects = @(Get-ProtectedObjects -Json $ProtectedJson)

            if (-not $ProtectedObjects -or $ProtectedObjects.Count -eq 0) {
                continue
            }

            $FlatObjects = @()

            foreach ($Obj in $ProtectedObjects) {
                $FlatObjects += Get-FlatProtectedObjects -Object $Obj
            }

            $FlatObjects = @($FlatObjects | Where-Object {
                -not (Test-NonDisplayObject -FlatObject $_)
            })

            if (-not $FlatObjects -or $FlatObjects.Count -eq 0) {
                continue
            }

            $MatchingFlatObjects = @($FlatObjects | Where-Object {
                Object-MatchesCiAliasesFlat -FlatObject $_ -CiAliases $CiAliases
            })

            $DbFlatObjects = @($FlatObjects | Where-Object {
                Test-DbLikeFlat -FlatObject $_
            })

            $VmFlatObjects = @($FlatObjects | Where-Object {
                Test-VmLikeFlat -FlatObject $_
            })

            $ObjectsToCheck = @(
                $MatchingFlatObjects
                $DbFlatObjects
                $VmFlatObjects
            ) | Where-Object { $_ } |
                Sort-Object ObjectName, SourceName, ObjectType -Unique

            if (-not $ObjectsToCheck -or $ObjectsToCheck.Count -eq 0) {
                $ObjectsToCheck = $FlatObjects
            }

            foreach ($Flat in $ObjectsToCheck) {
                if (Test-NonDisplayObject -FlatObject $Flat) {
                    continue
                }

                $row = Convert-FlatObjectToBackupRow -FlatObject $Flat -Ci $Ci -CandidateCluster $Clu

                if ($null -eq $row) {
                    continue
                }

                $Rows += $row
            }
        }
    }

    return @($Rows)
}

