function Test-OracleContainerName {
    param([string]$Name)

    if ([string]::IsNullOrWhiteSpace($Name)) {
        return $false
    }

    $n = "$Name".Trim()

    if ($n -match '(?i)^Oracle\s+Servers($|/)') {
        return $true
    }

    if ($n -match '(?i)(^|/)(kRACDatabase|kNonRACDatabase|kOracleDatabase)$') {
        return $true
    }

    return $false
}

