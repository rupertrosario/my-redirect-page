function Get-BackupTypeRank {
    param([string]$BackupType)

    switch ($BackupType) {
        "FS"      { return 1 }
        "HyperV"  { return 2 }
        "Nutanix" { return 3 }
        "VM"      { return 4 }
        "SQL"     { return 5 }
        "Oracle"  { return 6 }
        "DB"      { return 7 }
        default   { return 9 }
    }
}

function Test-HasValidFs {
    param($Rows)

    return (@($Rows | Where-Object {
        $_.BackupType -eq "FS" -and
        (Is-ValidBackupTime -TimeText $_.LastBackupTime)
    }).Count -gt 0)
}

function Test-HasValidDb {
    param($Rows)

    return (@($Rows | Where-Object {
        $_.BackupType -in @("SQL", "Oracle", "DB") -and
        (Is-ValidBackupTime -TimeText $_.LastBackupTime)
    }).Count -gt 0)
}

function Test-HasValidSqlOrOracle {
    param($Rows)

    return (@($Rows | Where-Object {
        $_.BackupType -in @("SQL", "Oracle") -and
        (Is-ValidBackupTime -TimeText $_.LastBackupTime)
    }).Count -gt 0)
}

